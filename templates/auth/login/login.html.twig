{% extends 'auth.html.twig' %}

{% block title %}Sign In | Conscious Craftsmanship | Mifania{% endblock %}

{% block main_content %}
    <div class="text-left mb-10 mt-10">
        <h1 class="text-2xl font-bold text-brand-dark tracking-tight mb-2">Sign In</h1>
        <p class="text-sm text-gray-500 font-medium tracking-widest">Fill in your credentials to access your account.</p>
    </div>

    <form method="post" class="space-y-6" novalidate>
        {% if error %}
            <div class="bg-red-50 text-red-600 p-4 rounded-sm text-xs font-bold tracking-widest border border-red-100 flex items-center gap-3">
                {{ ux_icon('si:error-line', {class: 'w-4 h-4 shrink-0'}) }}
                <div class="flex-1">
                    {{ error.messageKey|trans(error.messageData, 'security')|raw }}
                </div>
            </div>
        {% endif %}

        <div>
            <label for="inputEmail" class="block text-xs font-bold text-gray-400 tracking-[0.2em] mb-2">Email Address</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors"
                    autocomplete="email" required autofocus>
        </div>

        <div>
            <div class="flex justify-between items-end mb-2">
                    <label for="inputPassword" class="block text-xs font-bold text-gray-400 tracking-[0.2em]">Password</label>
            </div>
            <input type="password" name="password" id="inputPassword"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors"
                    autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="w-full bg-brand text-white h-14 rounded-sm text-sm font-bold tracking-[0.2em] hover:bg-brand-dark transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 mt-4 cursor-pointer">
            Sign In
        </button>
    </form>

    <div class="relative flex items-center py-2 mt-6">
        <div class="flex-grow border-t border-gray-200"></div>
        <span class="flex-shrink mx-4 text-gray-400 text-xs font-bold tracking-widest uppercase">Social Gateways</span>
        <div class="flex-grow border-t border-gray-200"></div>
    </div>

    <a href="{{ path('connect_google') }}"
        class="w-full flex items-center justify-center gap-3 py-3.5 mt-6 rounded-sm bg-white border border-gray-200 text-gray-700 font-bold text-xs tracking-widest hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm">
            {{ ux_icon('logos:google-icon', {class: 'w-4 h-4'}) }}
            <span>Sign in with Google</span>
    </a>

    <div class="mt-2 text-center pt-8">
        <p class="text-sm text-gray-500 font-medium">
            New to Mifania?
            <a href="{{ path('app_register') }}" class="font-bold text-brand tracking-widest ml-2 hover:text-brand-dark transition-colors">Create an Account</a>
        </p>
        <div class="mt-4">
                <a href="{{ path('app_shop') }}" class="text-[10px] font-bold text-gray-400 uppercase tracking-widest hover:text-brand transition-colors">Back to Store</a>
        </div>
    </div>
{% endblock %}
