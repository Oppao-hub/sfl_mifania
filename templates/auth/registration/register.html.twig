{% extends 'auth.html.twig' %}

{% block title %}Create Account | Join The Collective | Mifania{% endblock %}

{% block main_content %}
    <div class="text-left mb-10 mt-2">
        <h1 class="text-2xl font-bold text-brand-dark tracking-tight mb-2">Create Account</h1>
        <p class="text-sm text-gray-500 font-medium tracking-widest">Become a Mifania Member</p>
    </div>

    {% form_theme registrationForm 'form/error_theme.html.twig' %}

    {{ form_start(registrationForm, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

        <div class="grid grid-cols-2 gap-4">
            <div>
                {{ form_label(registrationForm.firstName, 'First Name', { label_attr: {'class': 'block text-xs font-bold text-gray-400 tracking-[0.2em] mb-2'} }) }}
                {{ form_widget(registrationForm.firstName, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
                {{ form_errors(registrationForm.firstName) }}
            </div>
            <div>
                {{ form_label(registrationForm.lastName, 'Last Name', { label_attr: {'class': 'block text-xs font-bold text-gray-400 tracking-[0.2em] mb-2'} }) }}
                {{ form_widget(registrationForm.lastName, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
                {{ form_errors(registrationForm.lastName) }}
            </div>
        </div>

        <div>
            {{ form_label(registrationForm.email, 'Email Address', { label_attr: {'class': 'block text-xs font-bold text-gray-400 tracking-[0.2em] mb-2'} }) }}
            {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        <div>
            {{ form_label(registrationForm.plainPassword, 'Password', { label_attr: {'class': 'block text-xs font-bold text-gray-400 tracking-[0.2em] mb-2'} }) }}
            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
            {{ form_errors(registrationForm.plainPassword) }}
            <p class="text-[10px] text-gray-400 mt-2 font-medium">Must be at least 8 characters long.</p>
        </div>

        <div class="flex items-start mt-2">
            <div class="flex items-center h-5">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 rounded-sm border-gray-300 text-brand focus:ring-brand cursor-pointer'}}) }}
            </div>
            <div class="ml-3 text-xs font-medium text-gray-500">
                {{ form_label(registrationForm.agreeTerms, 'I agree to the Terms of Service and Privacy Policy.') }}
                {{ form_errors(registrationForm.agreeTerms) }}
            </div>
        </div>

        <button type="submit" class="w-full bg-brand text-white h-14 rounded-sm text-sm font-bold tracking-[0.2em] hover:bg-brand-dark transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 mt-6 cursor-pointer">
            Create Account
        </button>

    {{ form_end(registrationForm) }}

    {# Google Auth matched to login #}
    <div class="relative flex items-center py-2">
        <div class="flex-grow border-t border-gray-200"></div>
        <span class="flex-shrink mx-4 text-gray-400 text-xs font-bold tracking-widest">or sign up with email</span>
        <div class="flex-grow border-t border-gray-200"></div>
    </div>

    <a href="{{ path('connect_google') }}"
        class="w-full flex items-center justify-center gap-3 py-3.5 mt-6 rounded-sm bg-white border border-gray-200 text-gray-700 font-bold text-xs tracking-widest hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm">
        {{ ux_icon('material-icon-theme:google', {class: 'w-4 h-4'}) }}
        <span>Sign up with Google</span>
    </a>

    {# Footer block perfectly matched to Login #}
    <div class="mt-2 text-center pt-8">
        <p class="text-sm text-gray-500 font-medium">
            Already have an account?
            <a href="{{ path('app_login') }}" class="font-bold text-brand tracking-widest ml-2 hover:text-brand-dark transition-colors">Sign In</a>
        </p>
        <div class="mt-4">
                <a href="{{ path('app_shop') }}" class="text-[10px] font-bold text-gray-400 uppercase tracking-widest hover:text-brand transition-colors">Back to Store</a>
        </div>
    </div>
{% endblock %}
