{% extends 'base.html.twig' %}

{% block title %}Create Account | Mifania{% endblock %}

{% block main_content %}
<div class="min-h-screen flex flex-col lg:flex-row-reverse bg-[#FBFBFA]">

    {# RIGHT SIDE: The Brand Editorial Visual (Reversed for variation) #}
    <div class="hidden lg:flex lg:w-1/2 relative bg-gray-900 overflow-hidden items-center justify-center">
        <img src="https://images.unsplash.com/photo-1604176354204-92604310e473?q=80&w=1200&auto=format&fit=crop"
             alt="Mifania Linen Details"
             class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay">

        <div class="relative z-10 text-center p-12">
            <h2 class="text-white text-5xl font-bold uppercase tracking-tighter mb-4">Join The Collective</h2>
            <p class="text-white/80 text-sm font-medium tracking-widest uppercase">Start your sustainable journey</p>
        </div>
    </div>

    {# LEFT SIDE: The Form #}
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8 sm:p-12 md:p-24">
        <div class="w-full max-w-md">

            <div class="text-center mb-10">
                <h1 class="text-3xl font-bold text-brand-dark uppercase tracking-tight mb-2">Create Account</h1>
                <p class="text-xs text-gray-500 font-medium uppercase tracking-widest">Become a Mifania Member</p>
            </div>

            {# Google OAuth Button #}
            <a href="{{ path('connect_google') }}"
               class="w-full flex items-center justify-center gap-3 py-3.5 mb-6 rounded-sm bg-white border border-gray-200 text-gray-700 font-bold text-xs uppercase tracking-widest hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm">
                <img src="{{ asset('icons/icons8-google.svg') }}" class="h-4 w-4" alt="Google">
                <span>Sign up with Google</span>
            </a>

            {# Visual Separator #}
            <div class="relative flex items-center py-2 mb-6">
                <div class="flex-grow border-t border-gray-200"></div>
                <span class="flex-shrink mx-4 text-gray-400 text-[10px] font-bold uppercase tracking-widest">or sign up with email</span>
                <div class="flex-grow border-t border-gray-200"></div>
            </div>

            {% form_theme registrationForm 'form/error_theme.html.twig' %}

            {{ form_start(registrationForm, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

                {# First & Last Name Row #}
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        {{ form_label(registrationForm.firstName, 'First Name', { label_attr: {'class': 'block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-2'} }) }}
                        {{ form_widget(registrationForm.firstName, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
                        {{ form_errors(registrationForm.firstName) }}
                    </div>
                    <div>
                        {{ form_label(registrationForm.lastName, 'Last Name', { label_attr: {'class': 'block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-2'} }) }}
                        {{ form_widget(registrationForm.lastName, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
                        {{ form_errors(registrationForm.lastName) }}
                    </div>
                </div>

                {# Email #}
                <div>
                    {{ form_label(registrationForm.email, 'Email Address', { label_attr: {'class': 'block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-2'} }) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                {# Password #}
                <div>
                    {{ form_label(registrationForm.plainPassword, 'Password', { label_attr: {'class': 'block text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-2'} }) }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors'}}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                    <p class="text-[10px] text-gray-400 mt-2 font-medium">Must be at least 8 characters long.</p>
                </div>

                {# Terms Checkbox #}
                <div class="flex items-start mt-2">
                    <div class="flex items-center h-5">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 rounded-sm border-gray-300 text-brand focus:ring-brand cursor-pointer'}}) }}
                    </div>
                    <div class="ml-3 text-xs font-medium text-gray-500">
                        {{ form_label(registrationForm.agreeTerms, 'I agree to the Terms of Service and Privacy Policy.') }}
                        {{ form_errors(registrationForm.agreeTerms) }}
                    </div>
                </div>

                {# Submit #}
                <button type="submit" class="w-full bg-brand text-white h-14 rounded-sm text-xs font-bold uppercase tracking-[0.2em] hover:bg-brand-dark transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 mt-6 cursor-pointer">
                    Create Account
                </button>

            {{ form_end(registrationForm) }}

            <div class="mt-10 text-center border-t border-gray-100 pt-8">
                <p class="text-xs text-gray-500 font-medium">
                    Already have an account?
                    <a href="{{ path('app_login') }}" class="font-bold text-brand uppercase tracking-widest ml-2 hover:text-brand-dark transition-colors">Sign In</a>
                </p>
            </div>

        </div>
    </div>
</div>
{% endblock %}
