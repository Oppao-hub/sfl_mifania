{% extends 'auth.html.twig' %}

{% block title %}Resend Verification | Mifania{% endblock %}

{% block main_content %}
    <div class="text-left mb-10 mt-10">
        <h1 class="text-2xl font-bold text-brand-dark tracking-tight mb-2 uppercase">Resend Verification</h1>
        <p class="text-sm text-gray-500 font-medium tracking-widest leading-relaxed">
            Lost your verification link? Enter your email address below and we'll send you a new one.
        </p>
    </div>

    <form method="post" class="space-y-6" novalidate>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('resend_verification') }}">
        <div>
            {% for message in app.flashes('error') %}
                <div class="bg-red-50 text-red-600 p-4 rounded-sm text-xs font-bold tracking-widest border border-red-100 flex items-center gap-3 mb-2">
                    {{ ux_icon('si:error-line', {class: 'w-4 h-4'}) }}
                    {{ message }}
                </div>
            {% endfor %}

            <label for="email" class="block text-xs font-bold text-gray-400 tracking-[0.2em] mb-2">Email Address</label>
            <input type="email" name="email" id="email"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-sm focus:border-brand focus:ring-0 text-sm font-bold text-gray-900 transition-colors"
                    placeholder="your@email.com" required autofocus>
        </div>

        <button type="submit" class="w-full bg-brand text-white h-14 rounded-sm text-sm font-bold tracking-[0.2em] hover:bg-brand-dark transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 mt-4 cursor-pointer">
            Send Link
        </button>
    </form>

    <div class="mt-8 text-center pt-8 border-t border-gray-100">
        <p class="text-sm text-gray-500 font-medium">
            Remember your password?
            <a href="{{ path('app_login') }}" class="font-bold text-brand tracking-widest ml-2 hover:text-brand-dark transition-colors">Back to Login</a>
        </p>
    </div>
{% endblock %}
