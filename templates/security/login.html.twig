{% extends 'auth.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block main_content %}
<div class="min-h-screen w-full bg-cover bg-center bg-no-repeat flex items-center justify-center p-6"
    style="background-image: url('{{ asset('uploads/auth/background.png') }}')"
>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 w-full max-w-7xl">
        <div class="flex items-center justify-center md:justify-end">
            <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Mifania Logo" class="w-full max-w-[400px] md:max-w-[500px]">
        </div>

        {# Right Column: The Glass Card #}
        <div class="flex items-center justify-center md:justify-end">
            <div class="bg-white/30 backdrop-blur-xl border border-white/40 p-10 rounded-[1rem] w-full max-w-md shadow-2xl animate-fadeIn">
                <form method="post">
                    {% if error %}
                        <div class="bg-red-100/80 border border-red-400 text-red-700 px-4 py-3 rounded-md mb-4 text-sm text-center">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <div class="space-y-6">
                        <input  type="email"
                                value="{{ last_username }}"
                                name="email"
                                placeholder="Email"
                                autocomplete="email"
                                class="w-full p-4 rounded-xl border-2 border-transparent bg-white text-gray-700 placeholder-gray-400 focus:border-[#6b703d] outline-none transition-all shadow-sm"
                                required autofocus>

                        <input  type="password"
                                name="password"
                                placeholder="Password"
                                autocomplete="current-password"
                                class="w-full p-4 rounded-xl border-2 border-transparent bg-white text-gray-700 placeholder-gray-400 focus:border-[#6b703d] outline-none transition-all shadow-sm"
                                required>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button type="submit"
                            class="w-full py-4 rounded-xl bg-[#6b703d] text-white font-bold text-lg tracking-widest hover:bg-[#5a5f33] transition-colors shadow-lg uppercase cursor-pointer">
                            Login
                        </button>

                        <div class="flex justify-between items-center text-white text-sm font-medium">
                            <a href="#" class="hover:underline">Forgot Password?</a>
                            <span class="mx-2 opacity-50">|</span>
                            <a href="{{ path('app_register') }}" class="hover:underline">Create Account</a>
                        </div>

                        {# Social Icons Placeholder #}
                        <div class="flex justify-center space-x-6 pt-4 text-white">
                            <a href="#" class="hover:scale-110 transition-transform opacity-90 hover:opacity-100">
                                {{ ux_icon('lucide:facebook', { class: 'w-6 h-6' }) }}
                            </a>
                            <a href="#" class="hover:scale-110 transition-transform opacity-90 hover:opacity-100">
                                {{ ux_icon('lucide:instagram', { class: 'w-6 h-6' }) }}
                            </a>
                            <a href="#" class="hover:scale-110 transition-transform opacity-90 hover:opacity-100">
                                {{ ux_icon('lucide:apple', { class: 'w-6 h-6' }) }}
                            </a>
                            <a href="#" class="hover:scale-110 transition-transform opacity-90 hover:opacity-100">
                                {{ ux_icon('bi:google', { class: 'w-6 h-6' }) }}
                            </a>
                        </div>
                        <p class="text-center text-white text-sm mt-8 font-medium">
                            Join a movement for a better tomorrow.
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
