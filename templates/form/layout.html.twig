{% use 'form_div_layout.html.twig' %}

{# 1. Style the Rows (Container for Label + Input) #}
{% block form_row %}
    <div class="mb-5">
        {{ form_label(form) }}
        {{ form_errors(form) }}
        {{ form_widget(form) }}
        {{ form_help(form) }}
    </div>
{% endblock %}

{# 2. Style the Labels #}
{% block form_label %}
    {% set label_attr = label_attr|merge({'class': (label_attr.class|default('') ~ ' block text-sm font-bold text-gray-700 mb-1')|trim}) %}
    {{ parent() }}
{% endblock %}

{# 3. Style the Inputs (Text, Password, Email, Date, etc.) #}
{% block widget_attributes %}
    {% set class_attr = 'w-full px-4 py-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition duration-150' %}
    {% set attr = attr|merge({'class': (attr.class|default('') ~ ' ' ~ class_attr)|trim}) %}
    {{ parent() }}
{% endblock %}

{% block form_errors %}
    {% if errors|length > 0 %}
        <ul class="mt-1 text-sm text-red-600">
            {% for error in errors %}
                <li class="flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    {{ error.message }}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
