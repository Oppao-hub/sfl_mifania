{% block form_errors %}
    {% if errors|length > 0 %}
        <ul class="mt-1.5 ml-1 space-y-1">
            {% for error in errors %}
                <li class="flex items-start text-xs font-semibold text-red-600 dark:text-red-400">
                    {# Simple SVG Warning Icon #}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    <span>{{ error.message }}</span>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
