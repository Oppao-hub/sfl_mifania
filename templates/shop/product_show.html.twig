{% extends 'base.html.twig' %}

{% block title %}Product Details{% endblock %}

{% block main_content %}
<div class="bg-white min-h-screen"
     x-data="{
        product: null,
        loading: true,
        quantity: 1,
        selectedColor: 'Brown',
        selectedSize: 'XXL',
        async init() {
            try {
                const response = await fetch(`/api/products?slug={{ slug }}`, {
                    headers: { 'Accept': 'application/ld+json' }
                });
                const data = await response.json();
                const items = data['hydra:member'] || data['member'] || [];
                if (items.length > 0) {
                    this.product = items[0];
                    this.selectedColor = this.product.color || 'Brown';
                }
            } catch (e) { console.error('Fetch error:', e); }
            finally { this.loading = false; }
        }
     }">

    <!-- Top Header & Breadcrumbs Section -->
    <div class="pt-16 pb-12 bg-gray-50/30">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-5xl text-gray-900 mb-6 tracking-tight">Product Details</h1>
            <nav class="flex justify-center items-center gap-2 text-xs uppercase tracking-widest text-gray-400">
                <a href="/" class="hover:text-gray-900 transition">Home</a>
                <span>/</span>
                <a href="/shop" class="hover:text-gray-900 transition">Shop</a>
                <span>/</span>
                <span x-text="product?.category?.name || 'Coats'" class="hover:text-gray-900 transition"></span>
                <span>/</span>
                <span class="text-gray-900 font-semibold" x-text="product?.name || 'Loading...'"></span>
            </nav>
        </div>
    </div>

    <!-- Main Product Section -->
    <div class="max-w-7xl mx-auto px-4 py-16">
        <template x-if="loading">
            <div class="flex justify-center items-center py-20">
                <div class="animate-pulse text-gray-400 text-xl">Loading Boutique...</div>
            </div>
        </template>

        <template x-if="!loading && product">
            <div class="flex flex-col lg:flex-row gap-16 items-start">

                <!-- Left: Image Gallery (Screenshot style) -->
                <div class="lg:w-1/2 w-full">
                    <div class="relative group bg-gray-100 mb-4 overflow-hidden">
                        <img :src="product.image ? '/uploads/products/' + product.image : 'https://placehold.co/800x1000?text=Product'"
                             class="w-full object-cover aspect-[4/5] shadow-sm">

                        <!-- Side Arrows -->
                        <div class="absolute inset-y-0 left-0 flex items-center p-4">
                            <button class="bg-white/90 p-3 shadow-md hover:bg-white transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                            </button>
                        </div>
                        <div class="absolute inset-y-0 right-0 flex items-center p-4">
                            <button class="bg-white/90 p-3 shadow-md hover:bg-white transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </button>
                        </div>
                    </div>

                    <!-- Thumbnails -->
                    <div class="grid grid-cols-4 gap-4">
                        <template x-for="i in 4">
                            <div class="cursor-pointer border border-transparent hover:border-gray-900 transition">
                                <img :src="product.image ? '/uploads/products/' + product.image : 'https://placehold.co/200'"
                                     class="w-full aspect-square object-cover opacity-80 hover:opacity-100">
                            </div>
                        </template>
                    </div>
                </div>

                <!-- Right: Product Information -->
                <div class="lg:w-1/2 w-full space-y-8">
                    <div>
                        <p class="text-xs uppercase tracking-[0.3em] text-gray-400 font-bold mb-2" x-text="product.category?.name || 'Coats'"></p>
                        <h2 class="text-5xl text-gray-900 leading-tight mb-4" x-text="product.name"></h2>

                        <!-- Rating -->
                        <div class="flex items-center gap-3">
                            <div class="flex text-yellow-400 text-sm">
                                ★★★★★
                            </div>
                            <span class="text-xs text-gray-400 font-medium tracking-wider">4.8 (245 Review)</span>
                        </div>
                    </div>

                    <!-- Price -->
                    <div class="flex items-baseline gap-6 border-b border-gray-100 pb-6">
                        <span class="text-4xl font-bold text-gray-900" x-text="'$' + parseFloat(product.price).toFixed(2)"></span>
                        <span class="text-xl text-gray-300 line-through font-medium">$150.00</span>
                    </div>

                    <!-- Description -->
                    <p class="text-gray-500 text-sm leading-relaxed max-w-lg" x-text="product.description || 'Elevate your wardrobe with our signature piece, crafted from ethically sourced materials for lasting comfort and timeless style.'"></p>

                    <!-- Color & Size Section -->
                    <div class="space-y-6">
                        <div>
                            <p class="text-sm font-bold text-gray-900 mb-4">Color : <span class="font-normal text-gray-500 ml-1" x-text="selectedColor"></span></p>
                            <div class="flex gap-3">
                                <button @click="selectedColor = 'Brown'" class="w-6 h-6 rounded-full bg-[#5C3D2E] transition-transform hover:scale-110 ring-offset-2" :class="selectedColor === 'Brown' ? 'ring-2 ring-[#5C3D2E]' : ''"></button>
                                <button @click="selectedColor = 'White'" class="w-6 h-6 rounded-full bg-gray-50 border ring-offset-2" :class="selectedColor === 'White' ? 'ring-2 ring-gray-300' : ''"></button>
                                <button @click="selectedColor = 'Green'" class="w-6 h-6 rounded-full bg-green-800 ring-offset-2" :class="selectedColor === 'Green' ? 'ring-2 ring-green-800' : ''"></button>
                                <button @click="selectedColor = 'Red'" class="w-6 h-6 rounded-full bg-red-700 ring-offset-2" :class="selectedColor === 'Red' ? 'ring-2 ring-red-700' : ''"></button>
                                <button @click="selectedColor = 'Blue'" class="w-6 h-6 rounded-full bg-blue-700 ring-offset-2" :class="selectedColor === 'Blue' ? 'ring-2 ring-blue-700' : ''"></button>
                            </div>
                        </div>

                        <div>
                            <div class="flex justify-between items-center mb-4">
                                <p class="text-sm font-bold text-gray-900 uppercase tracking-widest">Size : <span x-text="selectedSize" class="font-normal text-gray-500"></span></p>
                                <button class="text-[10px] uppercase font-bold text-gray-400 border-b border-gray-400 pb-0.5 hover:text-gray-900 hover:border-gray-900 transition">View Size Guide</button>
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <template x-for="s in ['S', 'M', 'L', 'XL', 'XXL', 'XXXL']">
                                    <button @click="selectedSize = s"
                                            :class="selectedSize === s ? 'bg-[#D4A373] text-white border-[#D4A373]' : 'bg-white text-gray-600 border-gray-200'"
                                            class="w-14 h-12 border text-[11px] font-bold transition-all uppercase tracking-tighter"
                                            x-text="s"></button>
                                </template>
                            </div>
                        </div>
                    </div>

                    <!-- Availability -->
                    <div class="flex items-center gap-4 text-xs font-bold">
                        <span class="text-gray-400 uppercase tracking-widest underline cursor-pointer">Clear</span>
                        <div class="px-3 py-1 bg-green-50 text-green-600 border border-green-100 uppercase tracking-tighter">In Stock</div>
                    </div>

                    <!-- Order Actions (The Mocha Palette) -->
                    <div class="flex flex-wrap items-center gap-4 pt-4">
                        <div class="flex items-center border border-gray-200 h-14">
                            <button @click="if(quantity > 1) quantity--" class="px-5 text-xl text-gray-400 hover:text-gray-900">-</button>
                            <input type="number" x-model="quantity" class="w-10 text-center border-none focus:ring-0 text-sm font-bold p-0">
                            <button @click="quantity++" class="px-5 text-xl text-gray-400 hover:text-gray-900">+</button>
                        </div>
                        <button class="bg-[#3D2B1F] text-white px-8 h-14 text-xs font-bold tracking-[0.2em] hover:bg-black transition uppercase">Add To Cart</button>
                        <button class="bg-[#F5C27C] text-gray-900 px-8 h-14 text-xs font-bold tracking-[0.2em] hover:bg-[#eab05b] transition uppercase">Buy Now</button>
                        <button class="p-4 border border-gray-200 hover:bg-gray-50 transition">
                            <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                        </button>
                    </div>

                    <!-- Meta Info -->
                    <div class="pt-10 space-y-3 border-t border-gray-100 text-[11px] text-gray-400 uppercase tracking-widest">
                        <p><span class="font-bold text-gray-900">SKU :</span> GHFT95245AAA</p>
                        <p><span class="font-bold text-gray-900">Tags :</span> Women, Coat, Fashion, Jacket</p>
                        <div class="flex items-center gap-4">
                            <span class="font-bold text-gray-900">Share :</span>
                            <div class="flex gap-4 text-gray-600">
                                <a href="#" class="hover:text-black transition">FB</a>
                                <a href="#" class="hover:text-black transition">IG</a>
                                <a href="#" class="hover:text-black transition">PI</a>
                                <a href="#" class="hover:text-black transition">TW</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </template>
    </div>

    <!-- Tabs Section (Matches screenshot) -->
    <div class="container mx-auto px-4 mt-20 border-t border-gray-100 pt-16">
        <div class="flex justify-center gap-16 mb-12">
            <button class="text-xl border-b-2 border-gray-900 pb-2 text-gray-900">Description</button>
            <button class="text-xl text-gray-400 hover:text-gray-900 transition pb-2">Additional Information</button>
            <button class="text-xl text-gray-400 hover:text-gray-900 transition pb-2">Review</button>
        </div>
        <div class="max-w-4xl mx-auto text-gray-500 text-sm leading-relaxed space-y-6">
            <p>Our boutique collections are curated with a focus on sustainable luxury. Every piece undergoes a meticulous quality check to ensure it meets our standards of excellence.</p>
            <ul class="space-y-3 list-disc list-inside text-gray-800 font-medium">
                <li>100% Premium Ethically Sourced Fabric</li>
                <li>Artisan Crafted Details and Finishing</li>
                <li>Durable Construction for Year-round wear</li>
                <li>Eco-friendly low-impact dye processes</li>
            </ul>
        </div>
    </div>

    <!-- Related Products Section -->
    <div class="container mx-auto px-4 py-32">
        <div class="text-center mb-16">
            <p class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-4">Related Products</p>
            <h3 class="text-5xl font-serif text-gray-900 tracking-tight">Explore Related Products</h3>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
            <template x-for="i in 4">
                <div class="group cursor-pointer">
                    <div class="relative overflow-hidden mb-6 bg-gray-50">
                        <img src="https://placehold.co/500x650/F8F8F8/888888?text=Collection"
                             class="w-full aspect-[4/5] object-cover transition duration-700 group-hover:scale-110">
                        <div class="absolute top-4 left-4 bg-green-50 text-green-700 text-[10px] font-bold px-3 py-1 uppercase tracking-tighter">10% off</div>
                        <!-- Icons on hover -->
                        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 translate-y-10 group-hover:translate-y-0 transition duration-300">
                             <button class="bg-white p-3 shadow-md hover:bg-black hover:text-white transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></button>
                        </div>
                    </div>
                    <div class="text-center space-y-2">
                        <h4 class="font-serif text-lg text-gray-900 group-hover:text-gray-600 transition">Classic Boutique Piece</h4>
                        <p class="text-sm font-bold text-gray-900">$120.00</p>
                    </div>
                </div>
            </template>
        </div>
    </div>
</div>
{% endblock %}
