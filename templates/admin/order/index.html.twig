{% extends 'admin/dashboard.html.twig' %} {% block title %}Order index{%
endblock %} {% block main_content %}
{% embed 'components/table/table.html.twig' with{
    title: 'Orders',
    new_path: 'app_admin_order_new',
    headers: ['ID','Order Date','Total Amount','Payment Method','Payment Status','Order Status','Reward Points','Actions'],
    id: 'admin-table'
}%}

{% block rows %}
            {% for order in orders %}
                <tr class="hover:bg-row-hover transition-colors">
                    <td class="border border-gray-300 py-3 px-4 text-sm">{{ order.id }}</td>
                    <td class="border border-gray-300 py-3 px-4 text-sm">{{ order.orderDate ? order.orderDate|date('Y-m-d') : '' }}</td>
                    <td class="border border-gray-300 py-3 px-4 text-mocha font-semibold text-sm">₱{{ order.totalAmount }}</td>
                    <td class="border border-gray-300 py-3 px-4">{{ order.paymentMethod.value }}</td>
                    <td class="border border-gray-300 py-3 px-4">
                        {% if order.paymentStatus.value == 'Paid' %}
                            <span class="px-3 py-2 text-xs font-semibold rounded-full bg-success text-white">Paid</span>
                        {% else %}
                            <span class="px-3 py-2 text-xs font-semibold rounded-full bg-warning text-white">{{ order.paymentStatus.value }}</span>
                        {% endif %}
                    </td>
                    <td class="border border-gray-300 py-3 px-4 text-sm">
                        {% if order.orderStatus.value == 'Completed' %}
                            <span class="px-3 py-2 text-xs font-semibold rounded-full bg-success text-white">Completed</span>
                        {% elseif order.orderStatus.value == 'Pending' %}
                            <span class="px-3 py-2 text-xs font-semibold rounded-full bg-warning text-white">Pending</span>
                        {% else %}
                            <span class="px-3 py-2 text-xs font-semibold rounded-full bg-info text-white">{{ order.orderStatus.value }}</span>
                        {% endif %}
                    </td>
                    <td class="border border-gray-300 py-3 px-4 text-sm">{{ order.rewardPointsEarned }}</td>
                    <td class="border border-gray-300 py-3 px-4 text-sm text-center">
                        <div class="flex justify-center items-center gap-3">
                            <twig:ActionIcon
                                path="{{ path('app_admin_order_show', { id: order.id }) }}"
                                svgPath="M12 4.5C7 4.5 2.73 8 1 12c1.73 4 6 7.5 11 7.5s9.27-3.5 11-7.5c-1.73-4-6-7.5-11-7.5z M12 16a4 4 0 110-8 4 4 0 010 8z"
                                class="w-5 h-5 text-mocha"
                                label="View"
                            />
                            <twig:ActionIcon
                                path="{{ path('app_admin_order_edit', { id: order.id }) }}"
                                svgPath="M11 4H4a1 1 0 00-1 1v16a1 1 0 001 1h16a1 1 0 001-1v-7 M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"
                                class="w-5 h-5 text-mocha"
                                label="Edit"
                            />
                            <twig:ActionIcon
                                path="#"
                                @click.prevent="$dispatch('open-delete-modal', { id: {{ order.id }}, name: 'Order #{{ order.id }}' })"
                                svgPath="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M10 7V4a1 1 0 011-1h2a1 1 0 011 1v3"
                                class="w-5 h-5 text-red-600"
                                label="Delete"
                            />
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="py-6 text-center text-text-muted">No orders found</td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
{% endblock %}
