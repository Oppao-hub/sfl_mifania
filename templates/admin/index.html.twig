                    </div>

                    <!-- Item 5: Cap -->
                    <div class="text-sm">
                        <div class="flex justify-between mb-1">
                            <span class="text-gray-600">Cap</span>
                            <span class="text-gray-900 font-semibold">50%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2.5">
                            <div
                                class="h-2.5 rounded-full"
                                style="width: 50%; background-color: #3b82f6"
                            ></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %} {# {% extends 'admin/dashboard.html.twig' %} {% block title %}{%
endblock %} {%block main_content %}
<!-- Content Area -->
<div class="content-area">
    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <h3>Total Sales</h3>
            <div class="value">
                PHP{{ (stats.total_sales ?? 0)|number_format(2) }}
            </div>
            {% set change = stats.changes.sales|round(1) %}
            <div class="trend {{ change < 0 ? 'down' : '' }}">
                {{ change >= 0 ? "↑" : "↓" }} {{ change | abs }}% from last
                month
            </div>
        </div>
        <div class="stat-card">
            <h3>Total Orders</h3>
            <div class="value">{{ stats.total_orders ?? 0 }}</div>
            {% set change = stats.changes.orders|round(1) %}
            <div class="trend {{ change < 0 ? 'down' : '' }}">
                {{ change >= 0 ? "↑" : "↓" }} {{ change | abs }}% from last
                month
            </div>
        </div>
        <div class="stat-card">
            <h3>Customers</h3>
            <div class="value">{{ stats.total_customers ?? 0 }}</div>
            {% set change = stats.changes.customers|round(1) %}
            <div class="trend {{ change < 0 ? 'down' : '' }}">
                {{ change >= 0 ? "↑" : "↓" }} {{ change | abs }}% from last
                month
            </div>
        </div>
        <div class="stat-card">
            <h3>Products</h3>
            <div class="value">{{ stats.total_products ?? 0 }}</div>
            {% set change = stats.changes.products|round(1) %}
            <div class="trend {{ change < 0 ? 'down' : '' }}">
                {{ change >= 0 ? "↑" : "↓" }} {{ change | abs }}% from last
                month
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="card">
        <div class="card-header">
            <h2>Recent Orders</h2>
        </div>
        <div class="card-body">
            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in recentOrders %}
                    <tr>
                        <td>
                            <strong>#{{ order.id }}</strong>
                        </td>
                        <td>
                            {{ order.customer.firstName }}
                            {{ order.customer.lastName }}
                        </td>
                        <td>
                            PHP{{ (order.totalAmount ?? 0)|number_format(2) }}
                        </td>
                        <td>
                            {% set status_class = 'danger' %} {% if
                            order.orderStatus == 'Completed' %}{% set
                            status_class = 'success' %} {% elseif
                            order.orderStatus == 'Pending' %}{% set status_class
                            = 'warning' %} {% elseif order.orderStatus ==
                            'Processing' %}{% set status_class = 'info' %}{%
                            endif %}
                            <span class="badge badge-{{ status_class }}">{{
                                order.orderStatus | capitalize
                            }}</span>
                        </td>
                        <td>{{ order.createdAt|date('Y-m-d') }}</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5">No recent orders found.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Top Products -->
    <div class="card">
        <div class="card-header">
            <h2>Top Selling Products</h2>
        </div>
        <div class="card-body">
            {% if topProducts is defined and topProducts|length > 0%}
            <table>
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Unit Sold</th>
                        <th>Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in topProducts %}
                    <tr>
                        <td>{{ product.productName }}</td>
                        <td>{{ product.unitsSold }}</td>
                        <td>{{ product.revenue|number_format(2) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <tr>
                <td colspan="5">No recent orders found.</td>
            </tr>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %} #}
