{% extends "admin/dashboard.html.twig" %}
{% set qrtags = qrtags|default([]) %}

{% block main_content %}
{% embed 'components/table/table.html.twig' with {
    title: 'QR Codes',
    new_path: 'app_admin_qrtag_new',
    headers: ['ID', 'Product' ,'Date Generated', 'QR Code Value', 'QR Image Path', 'Actions'],
    id: 'admin-table'
} %}

{% block rows %}
    {% for qrtag in qrtags %}
        <tr class="hover:bg-row-hover transition-colors">
            <td class="border border-gray-300 px-4 py-2 text-sm">{{ qrtag.id }}</td>

            <td class="border border-gray-300 px-4 py-2 text-sm">{{ qrtag.product.name }}</td>

            <td class="border border-gray-300 px-4 py-2 text-sm">
                {{ qrtag.dateGenerated ? qrtag.dateGenerated|date('Y-m-d H:i:s') : '—' }}
            </td>

            <td class="border border-gray-300 px-4 py-2 text-sm truncate max-w-[200px]">
                {{ qrtag.qrCodeValue ?: 'N/A' }}
            </td>

            <td class="border border-gray-300 px-4 py-2 text-sm truncate max-w-[200px]">
                {{ qrtag.qrImagePath ?: 'N/A' }}
            </td>

            <td class="border border-gray-300 py-3 px-4 text-sm text-center">
                <div class="flex justify-center items-center gap-3">
                    {# VIEW #}
                    <twig:ActionIcon
                        path="{{ path('app_admin_qrtag_show', {'id': qrtag.id}) }}"
                        svgPath="M12 4.5C7 4.5 2.73 8 1 12c1.73 4 6 7.5 11 7.5s9.27-3.5 11-7.5c-1.73-4-6-7.5-11-7.5z M12 16a4 4 0 110-8 4 4 0 010 8z"
                        class="w-5 h-5 text-mocha"
                        label="View"
                    />

                    {# EDIT #}
                    <twig:ActionIcon
                        path="{{ path('app_admin_qrtag_edit', {'id': qrtag.id}) }}"
                        svgPath="M11 4H4a1 1 0 00-1 1v16a1 1 0 001 1h16a1 1 0 001-1v-7 M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"
                        class="w-5 h-5 text-mocha"
                        label="Edit"
                    />

                    {# DELETE (Alpine modal) #}
                    <twig:ActionIcon
                        path="#"
                        @click.prevent="$dispatch('open-delete-modal', {
                            id: {{ qrtag.id }},
                            route: '/admin/qrtag/PLACEHOLDER',
                            name: 'QR Tag #{{ qrtag.id }}',
                            token: '{{ csrf_token('delete' ~ qrtag.id) }}'
                        })"
                        svgPath="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M10 7V4a1 1 0 011-1h2a1 1 0 011 1v3"
                        class="w-5 h-5 text-red-600"
                        label="Delete"
                    />
                </div>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="4" class="border border-gray-300 px-4 py-4 text-center text-gray-500">
                No QR codes found.
            </td>
        </tr>
    {% endfor %}
{% endblock %}
{% endembed %}
{% endblock %}
