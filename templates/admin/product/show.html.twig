{% extends "admin/dashboard.html.twig" %}
{% block title %}Product Details: {{ product.name }}{% endblock %}
{% block main_content %}
<div class="p-8 m-1 min-h-screen bg-white dark:bg-gray-800 shadow-md">

    <div class="mb-6">
        <h1 class="text-3xl font-bold text-mocha dark:text-white">
            Product: {{ product.name }}
        </h1>
    </div>

    <div class="bg-gray-50 p-6 mb-4 rounded-xl border border-gray-200">
        <h2 class="text-xl font-semibold text-mocha mb-4 border-b pb-2">Product Information</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
            <img
                src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('images/default-product.png') }}"
                alt="{{ product.name }}"
                class="rounded-lg shadow-md w-full object-cover"
            />

            <div class="space-y-4 text-sm">
                <p>
                    <strong class="text-gray-500">Category:</strong>
                    <span class="text-mocha font-medium">{{ product.category.name }}</span>
                </p>
                <p>
                    <strong class="text-gray-500">Material:</strong>
                    <span class="text-mocha font-medium">{{ product.material }}</span>
                </p>
                <p>
                    <strong class="text-gray-500">Size:</strong>
                    <span class="text-mocha font-medium">{{ product.size }}</span>
                </p>
                <p class="flex flex-row items-center">
                    <strong class="text-gray-500">Color:</strong>
                    <span class="text-mocha font-medium ml-1">{{ product.color }}</span>
                    <span class="h-3 w-3 ml-2 border border-gray-800" style="background-color: {{ product.color }};"></span>
                </p>
                <p>
                    <strong class="text-gray-500">Price:</strong>
                    <span class="text-mocha font-medium">₱{{ product.price|number_format(2) }}</span>
                </p>
                <p>
                    <strong class="text-gray-500">Cost:</strong>
                    <span class="text-mocha font-medium">₱{{ product.cost|number_format(2) }}</span>
                </p>
                <p>
                    <strong class="text-gray-500">Profit Margin:</strong>
                    <span class="text-mocha font-medium">{{ product.profitPercentage }}%</span>
                </p>
                <p>
                    <strong class="text-gray-500">Points:</strong>
                    <span class="text-mocha font-medium">{{ product.points }}</span>
                </p>
                    <strong class="text-gray-500">Stock Status:</strong>
                    <span class="inline-block font-medium
                        {% if product.totalStockQuantity > 50 %}
                            text-green-200
                        {% elseif product.totalStockQuantity < 50 and product.totalStockQuantity > 10 %}
                            text-yellow-800
                        {% else %}
                            text-red-800
                        {% endif %}
                    ">
                        {{ product.stockStatus }}
                    </span>
                <p>
                    <strong class="text-gray-500">Description:</strong>
                    <span class="text-mocha font-medium">{{ product.description ?: '—' }}</span>
                </p>

                {% if product.qrTag is not null and product.qrTag.qrImagePath is not null %}
                    <img src="{{ asset('uploads/qrcodes/' ~ product.qrTag.qrImagePath) }}"
                        alt="QR Code"
                        class="rounded-lg shadow-md w-36 h-36 object-cover">
                {% else %}
                    <div class="flex items-center justify-center text-center rounded-lg shadow-md w-36 h-36 bg-muted">
                        <p class="text-gray-500 font-medium">No QR Code</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <h2 class="text-xl font-semibold text-mocha dark:text-white mb-3">
            Stock Details
        </h2>
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-100 dark:bg-gray-700">
                    <tr>
                        <th class="px-4 py-2 text-left text-gray-500">Location</th>
                        <th class="px-4 py-2 text-left text-gray-500">Quantity</th>
                        <th class="px-4 py-2 text-left text-gray-500">Last Updated</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                    {% for stock in product.stocks %}
                        <tr>
                            <td class="px-4 py-2 font-medium">{{ stock.location ?? 'Default' }}</td>
                            <td class="px-4 py-2 font-medium">{{ stock.quantity }}</td>
                            <td class="px-4 py-2 font-medium">{{ stock.updatedAt|date('M d, Y H:i') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="px-4 py-4 text-center text-gray-400">
                                No stock records available
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>

    <div class="flex gap-3 justify-end">
        {# Edit button #}
        <a href="{{ path('app_admin_product_edit', { id: product.id }) }}"
            class="px-4 py-2 bg-success text-white text-sm font-semibold rounded-xl hover:bg-success-hover transition">
            Edit
        </a>

        {# Delete form #}
        <button
            type="button"
            @click.prevent="$dispatch('open-delete-modal',
                {
                    id: {{ product.id }},
                    route: '/admin/products/PLACEHOLDER',
                    name: '{{ product.name }}',
                    token: '{{ csrf_token('delete' ~ product.id) }}'
                }
            )"
            class="px-4 py-2 bg-danger text-white text-sm font-medium rounded-xl hover:bg-danger-hover transition"
        >
            Delete
        </button>

        <a href="{{ path('app_admin_product_index') }}"
            class="px-4 py-2 bg-white border border-gray-300 text-gray-500 text-sm font-semibold rounded-xl hover:bg-row-hover transition">
            Back
        </a>
    </div>
</div>
{% include 'components/modal/delete_confirmation.html.twig' %}
{% endblock %}
