{% extends 'admin/dashboard.html.twig' %}

{% block title %}Edit Stock: {{ stock.id }}{% endblock %}

{% block main_content %}
<div class="mx-1 min-h-screen bg-white p-8 rounded-xl shadow-md">
    {# Title includes the Stock ID for clear identification #}
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
        Edit Stock Record ID: 00{{ stock.id }}
    </h1>

    {# Include the reusable form fragment #}
    {{ include('admin/stock/_form.html.twig', {
        form: form,
        button_label: 'Update Stock',
        button_class: 'cursor-pointer px-4 py-2 bg-success text-sm font-semibold text-white rounded-xl hover:opacity-80 transition'
    }) }}
</div>
{% endblock %}
