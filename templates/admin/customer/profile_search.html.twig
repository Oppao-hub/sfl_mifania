{% extends "admin/dashboard.html.twig" %}

{% block main_content %}
<div class="p-8 m-1 min-h-screen bg-white dark:bg-gray-800 shadow-md">
    <div class="bg-gray-50 p-6 mb-4 rounded-xl border border-gray-200">
        <div class="max-w-xl mx-auto mb-8 bg-white shadow-lg rounded-xl p-6">
            <form method="GET" action="{{ path('app_admin_customer_search') }}" class="flex space-x-3">
                <input type="search"
                    name="q"
                    value="{{ query ?? '' }}"
                    placeholder="Enter Customer ID, Email, or Name..."
                    class="flex-grow p-3 border border-gray-300 rounded-lg focus:ring-mocha focus:border-mocha"
                    required>
                <button type="submit"
                        class="bg-success hover:bg-success-hover text-white font-semibold py-3 px-6 rounded-lg transition duration-200 shadow-md flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                    </svg>
                    Search
                </button>
            </form>
        </div>

        {# --- Search Results --- #}
        {% if query is not empty %}
            {% if customer %}
                <div class="container mx-auto p-4 md:px-8 lg:px-12">
                        <h1 class="text-2xl font-semibold text-gray-800 mb-6">Profile</h1>

                        <!-- Profile Header Card -->
                        <div class="bg-white shadow-lg rounded-lg p-6 mb-6 flex items-center justify-between border border-gray-100">
                            <div class="flex items-center">
                                {% set avatarPath = customer.avatar is defined and customer.avatar ? customer.avatar : 'images/default-avatar.png' %}
                                <img class="w-20 h-20 rounded-full object-cover mr-4 border-2 border-blue-100"
                                    src="{{ asset(avatarPath) }}"
                                    alt="{{ customer.firstName }}'s Avatar"
                                    onerror="this.onerror=null;this.src='{{ asset('images/default-avatar.png') }}';"
                                >
                                <div>
                                    <h2 class="text-xl font-semibold text-gray-900">{{ customer.firstName }} {{ customer.lastName }}</h2>
                                    {# Using the related User entity for email, as the Customer entity does not hold it directly #}
                                    <p class="text-sm text-gray-600">{{ customer.user.email ?: 'No email address' }}</p>
                                    <p class="text-sm text-gray-500">{{ customer.city ?: 'Unknown' }}, {{ customer.country ?: 'N/A' }}.</p>
                                </div>
                            </div>
                            <div class="flex items-center space-x-3">
                                {# Placeholder for social media icons - replace with actual links if you have them #}
                                <button class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 transition duration-150">
                                    <i class="fab fa-facebook-f text-sm"></i> {# Font Awesome icon #}
                                </button>
                                <button class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 transition duration-150">
                                    <i class="fab fa-twitter text-sm"></i> {# Font Awesome icon #}
                                </button>
                                <button class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 transition duration-150">
                                    <i class="fab fa-linkedin-in text-sm"></i> {# Font Awesome icon #}
                                </button>
                                <button class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 transition duration-150">
                                    <i class="fab fa-instagram text-sm"></i> {# Font Awesome icon #}
                                </button>
                                <a href="{{ path('app_admin_customer_edit', {'id': customer.id}) }}" class="ml-4 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg shadow-sm hover:bg-blue-700 transition duration-150 flex items-center">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    Edit
                                </a>
                            </div>
                        </div>

                        <!-- Personal Information Card -->
                        <div class="bg-white shadow-lg rounded-lg p-6 mb-6 border border-gray-100">
                            <div class="flex justify-between items-center mb-4 border-b pb-4">
                                <h2 class="text-xl font-semibold text-gray-800">Personal Information</h2>
                                <a href="{{ path('app_admin_customer_edit', {'id': customer.id}) }}" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition duration-150 ease-in-out">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    Edit
                                </a>
                            </div>
                            <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 text-sm">
                                <div>
                                    <dt class="font-medium text-gray-500">First Name</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.firstName }}</dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">Last Name</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.lastName }}</dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">Email address</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.user.email ?: 'N/A' }}</dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">Phone</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.contactNumber ?: 'N/A' }}</dd>
                                </div>
                                {% if customer.dateOfBirth %}
                                    <div>
                                        <dt class="font-medium text-gray-500">Date of Birth</dt>
                                        <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.dateOfBirth|date('F jS, Y') }}</dd>
                                    </div>
                                    {% set age = date('now').diff(customer.dateOfBirth).y %}
                                    <div>
                                        <dt class="font-medium text-gray-500">Age</dt>
                                        <dd class="mt-1 text-gray-900 text-base font-medium">{{ age }} years old</dd>
                                    </div>
                                {% endif %}
                                <div class="col-span-1 md:col-span-2">
                                    <dt class="font-medium text-gray-500">Street Address</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.address ?: 'No street address provided.' }}</dd>
                                </div>
                            </dl>
                        </div>

                        <!-- Address Card -->
                        <div class="bg-white shadow-lg rounded-lg p-6 mb-6 border border-gray-100">
                            <div class="flex justify-between items-center mb-4 border-b pb-4">
                                <h2 class="text-xl font-semibold text-gray-800">Geographic Information</h2>
                                <a href="{{ path('app_admin_customer_edit', {'id': customer.id}) }}" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition duration-150 ease-in-out">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    Edit
                                </a>
                            </div>
                            <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 text-sm">
                                <div>
                                    <dt class="font-medium text-gray-500">Country</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.country ?: 'N/A' }}</dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">State / Region</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.state ?: 'N/A' }}</dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">City</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.city ?: 'N/A' }}</dd>
                                </div>
                                {# Postal Code and TAX ID removed as they do not exist in the provided entity structure #}
                            </dl>
                        </div>

                        <!-- Account Status Card -->
                        <div class="bg-white shadow-lg rounded-lg p-6 mb-6 border border-gray-100">
                            <div class="flex justify-between items-center mb-4 border-b pb-4">
                                <h2 class="text-xl font-semibold text-gray-800">Account & Verification Status</h2>
                            </div>
                            <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 text-sm">
                                <div>
                                    <dt class="font-medium text-gray-500">Account Status</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">
                                        {% set status = customer.accountStatusValue|default('N/A') %}
                                        {% set color = 'bg-green-100 text-green-800' %}
                                        {% if status == 'Inactive' %}{% set color = 'bg-red-100 text-red-800' %}
                                        {% elseif status == 'Suspended' %}{% set color = 'bg-yellow-100 text-yellow-800' %}{% endif %}
                                        <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium {{ color }} capitalize">
                                            {{ status }}
                                        </span>
                                    </dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">Verification Status</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">
                                        {% set verification = customer.verificationStatusValue|default('N/A') %}
                                        {% set vColor = 'bg-red-100 text-red-800' %}
                                        {% if verification == 'Verified' %}{% set vColor = 'bg-green-100 text-green-800' %}
                                        {% elseif verification == 'Review' %}{% set vColor = 'bg-yellow-100 text-yellow-800' %}{% endif %}
                                        <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium {{ vColor }} capitalize">
                                            {{ verification }}
                                        </span>
                                    </dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">Reward Points</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.rewardPoints|number_format(0, '.', ',') }} points</dd>
                                </div>
                                <div>
                                    <dt class="font-medium text-gray-500">Customer Since</dt>
                                    <dd class="mt-1 text-gray-900 text-base font-medium">{{ customer.createdAt|date('F jS, Y') }}</dd>
                                </div>
                            </dl>
                        </div>

                    </div>
            {% else %}
                {# No Customer Found Message #}
                <div class="max-w-xl mx-auto p-6 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-lg shadow-sm" role="alert">
                    <p class="font-bold">No Match Found</p>
                    <p>The system could not find a customer matching the query: "<strong>{{ query }}</strong>".</p>
                    <p class="mt-2 text-sm">Please try searching by a different ID, the customer's full email address, or their full name.</p>
                </div>
            {% endif %}
        {% else %}
            {# Initial Message When Page is Loaded #}
            <div class="max-w-xl mx-auto p-6 bg-green-50 border-l-4 border-success text-mocha rounded-lg shadow-sm">
                <p class="font-bold">Ready to Search</p>
                <p>Use the search bar above to quickly locate a customer by their ID, email address, first name, or last name.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {# Include Font Awesome for social media icons if not already included in dashboard.html.twig #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" xintegrity="sha512-..." crossorigin="anonymous" />
{% endblock %}
