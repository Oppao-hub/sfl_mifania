{{ form_start(form, {'attr': {'class': 'bg-gray-50 border border-gray-200 p-6 md:p-8 rounded-xl shadow-lg space-y-8'}}) }}

{# Define common widget classes for all input types #}
{% set input_class = 'w-full px-4 py-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-violet focus:border-primary-violet transition duration-150' %}
{% set label_class = 'block text-sm font-bold text-mocha mb-1' %}

{# --- Section 1: General Details and Status --- #}
<section>
    <h3 class="text-xl font-bold text-mocha border-b pb-2 mb-6 flex items-center">
        <twig:icon d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" class="w-5 h-5 mr-2"/>
        General Details
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        {# First Name #}
        <div>
            {{ form_label(form.firstName, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.firstName, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.firstName) }}
        </div>

        {# Last Name #}
        <div>
            {{ form_label(form.lastName, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.lastName, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.lastName) }}
        </div>

        {# Date of Birth #}
        <div>
            {{ form_label(form.dateOfBirth, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.dateOfBirth, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.dateOfBirth) }}
        </div>

        {# Contact Number #}
        <div>
            {{ form_label(form.contactNumber, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.contactNumber, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.contactNumber) }}
        </div>

        {# Avatar (Full Width is cleaner for file uploads) #}
        <div class="md:col-span-2">
            {{ form_label(form.avatar, null, {'label_attr': {'class': label_class}}) }}
            {# Note: FileType widgets usually require minimal styling #}
            {{ form_widget(form.avatar, {'attr': {'class': 'block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-green-100 file:text-mocha hover:file:bg-green-200 cursor-pointer'}}) }}
            {{ form_errors(form.avatar) }}
        </div>

        {# Admin Fields (Renders only if form.accountStatus is defined/admin view) #}
        {% if form.accountStatus is defined %}
            <div>
                {{ form_label(form.accountStatus, null, {'label_attr': {'class': label_class}}) }}
                {{ form_widget(form.accountStatus, {'attr': {'class': input_class}}) }}
                {{ form_errors(form.accountStatus) }}
            </div>
            <div>
                {{ form_label(form.verificationStatus, null, {'label_attr': {'class': label_class}}) }}
                {{ form_widget(form.verificationStatus, {'attr': {'class': input_class}}) }}
                {{ form_errors(form.verificationStatus) }}
            </div>
        {% endif %}

    </div>
</section>

{# --- Section 2: Address and Bio Details --- #}
<section>
    <h3 class="text-xl font-bold text-mochat border-b pb-2 mb-6 flex items-center">
        <twig:icon d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"
            class="w-5 h-5 mr-2"
        />
        Address Details
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        {# Address (Full Width) #}
        <div class="md:col-span-2">
            {{ form_label(form.address, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.address, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.address) }}
        </div>

        {# City #}
        <div>
            {{ form_label(form.city, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.city, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.city) }}
        </div>

        {# State #}
        <div>
            {{ form_label(form.state, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.state, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.state) }}
        </div>

        {# Country #}
        <div>
            {{ form_label(form.country, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.country, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.country) }}
        </div>

        {# Postal Code #}
        <div>
            {{ form_label(form.postalCode, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.postalCode, {'attr': {'class': input_class}}) }}
            {{ form_errors(form.postalCode) }}
        </div>

        {# Bio (Full Width, uses Textarea so use a dedicated class for height) #}
        <div class="md:col-span-2">
            {{ form_label(form.bio, null, {'label_attr': {'class': label_class}}) }}
            {{ form_widget(form.bio, {'attr': {'class': input_class ~ ' h-32', 'rows': 4}}) }}
            {{ form_errors(form.bio) }}
        </div>
    </div>
</section>

{# --- Action Buttons --- #}
<div class="mt-6 flex justify-end gap-3">
        <button type="submit" class="{{ button_class|default('px-4 py-2 text-sm font-semibold bg-success text-white rounded-xl cursor-pointer') }}">
            {{ button_label|default('Save') }}
        </button>
        <a href="{{ path('app_admin_customer_index') }}" class="px-4 py-2 text-sm font-semibold border border-gray-300 rounded-xl text-mocha  hover:bg-gray-200 transition">
            Cancel
        </a>
    </div>
{{ form_end(form) }}
