{% extends 'admin/dashboard.html.twig' %} {% block title %}Customer index{%
endblock %}
{% block main_content %}
{% embed 'components/table/table.html.twig' with{
    title: 'Customers',
    new_path: 'app_admin_customer_new',
    headers: ['ID','First Name', 'Last Name', 'Email', 'Account Status', 'Verification Status', 'Actions'],
    id: 'admin-table'
}%}

{% block rows %}
    {% for customer in customers %}
        <tr class="hover:bg-row-hover transition-colors">
            <td class="border border-gray-300 px-4 py-2 text-sm">{{ customer.id }}</td>
            <td class="border border-gray-300 px-4 py-2 text-sm">{{ customer.firstName }}</td>
            <td class="border border-gray-300 px-4 py-2 text-sm">{{ customer.lastName }}</td>
            <td class="border border-gray-300 px-4 py-2 text-sm">{{ customer.user.email }}</td>
            <td class="border border-gray-300 px-4 py-2 text-sm">{{ customer.accountStatus.value }}</td>
            <td class="border border-gray-300 px-4 py-2 text-sm">{{ customer.verificationStatus.value }}</td>
            {# <td class="border border-gray-300 px-4 py-2 text-sm">
                {{ customer.dateOfBirth ? customer.dateOfBirth|date('d-m-Y') : '' }}
            </td> #}
            <td class="border border-gray-300 py-3 px-4 text-sm text-center">
                <div class="flex justify-center items-center gap-3">
                    <twig:ActionIcon
                        path="{{ path('app_admin_customer_show', { id: customer.id }) }}"
                        svgPath="M12 4.5C7 4.5 2.73 8 1 12c1.73 4 6 7.5 11 7.5s9.27-3.5 11-7.5c-1.73-4-6-7.5-11-7.5z M12 16a4 4 0 110-8 4 4 0 010 8z"
                        class="w-5 h-5 text-mocha"
                        label="View"
                    />
                    <twig:ActionIcon
                        path="{{ path('app_admin_customer_edit', { id: customer.id }) }}"
                        svgPath="M11 4H4a1 1 0 00-1 1v16a1 1 0 001 1h16a1 1 0 001-1v-7 M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"
                        class="w-5 h-5 text-mocha"
                        label="Edit"
                    />
                    <twig:ActionIcon
                        path="#"
                        @click.prevent="$dispatch('open-delete-modal', { id: {{ customer.id }}, name: 'Customer #{{ customer.id }}' })"
                        svgPath="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M10 7V4a1 1 0 011-1h2a1 1 0 011 1v3"
                        class="w-5 h-5 text-red-600"
                        label="Delete"
                    />
                </div>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="11">no records found</td>
        </tr>
        {% endfor %}
{% endblock %}
{% endembed %}
{% endblock %}
