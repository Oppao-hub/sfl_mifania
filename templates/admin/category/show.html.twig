{% extends 'admin/dashboard.html.twig' %}

{% block title %}Category Details: {{ category.name }}{% endblock %}

{% block main_content %}
<div class="mx-1 min-h-screen bg-white p-8 rounded-xl shadow-lg">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-3xl font-bold text-mocha">Category: {{ category.name }}</h1>
    </div>

    <div class="space-y-6">
        {# Detail Card #}
        <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
            <h2 class="text-xl font-semibold text-mocha mb-4 border-b pb-2">Category Information</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-8">
                {# Row 1: ID and Name #}
                <div>
                    <p class="text-sm font-medium text-gray-500"><strong>Category ID</strong></p>
                    <p class="text-lg font-bold text-mocha">{{ category.id }}</p>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-500"><strong>Category Name</strong></p>
                    <p class="text-lg text-mocha">{{ category.name }}</p>
                </div>

                {# Row 2: Description (takes full width) #}
                <div class="md:col-span-2">
                    <p class="text-sm font-medium text-gray-500">Description</p>
                    <div class="bg-white p-4 rounded-lg border border-gray-100 mt-1">
                        <p class="text-base text-mocha whitespace-pre-wrap">{{ category.description | default('No description provided.') }}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex space-x-2 justify-end">
            {# Assuming 'app_admin_category_edit' is your route for editing #}
            <a href="{{ path('app_admin_category_edit', {'id': category.id}) }}"
                class="px-4 py-2 text-sm font-semibold bg-success text-white rounded-xl hover:bg-success-hover transition duration-150 shadow-md">
                Edit Category
            </a>

            {# Assuming 'app_admin_category_delete' is your route for deletion #}
            <form method="post" action="{{ path('app_admin_category_delete', {'id': category.id}) }}"
                class="inline-block" onsubmit="return confirm('Are you sure you want to delete this category?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                <button type="submit" class="px-4 py-2 text-sm font-semibold bg-red-600 text-white rounded-xl hover:bg-red-700 transition duration-150 shadow-md">
                    Delete
                </button>
            </form>

            <a href="{{ path('app_admin_category_index') }}" class="px-4 py-2 text-sm text-mocha border border-gray-300 bg-gray-100 rounded-xl hover:bg-gray-200 font-semibold transition duration-150">
                Back
            </a>
        </div>
    </div>
</div>
{% endblock %}
