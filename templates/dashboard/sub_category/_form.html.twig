{% form_theme form 'form/error_theme.html.twig' %}

{% set label_style = 'text-[9px] uppercase font-black tracking-[0.3em] text-gray ml-1 block mb-2' %}
{% set input_base = 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none text-sm font-bold text-brand-dark transition-all shadow-inner' %}

{{ form_start(form, {'attr': {'class': 'relative space-y-8', 'novalidate': 'novalidate'}}) }}

    {# --- FIXED STICKY HEADER --- #}
    <div class="sticky top-24 z-40 bg-white/90 backdrop-blur-md border border-border-color rounded-2xl p-6 shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div class="flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-brand animate-pulse"></div>
            <div>
                {% set sub_category = form.vars.data %}
                <h1 class="text-xl font-black text-brand-dark tracking-tighter uppercase leading-none">
                    {{ sub_category.id ? sub_category.name : 'New Sub-Category Record' }}
                </h1>
                <p class="text-[9px] text-gray mt-1.5 uppercase font-black tracking-[0.3em]">Taxonomy Manifest #{{ sub_category.id|default('Pending') }}</p>
            </div>
        </div>

        <div class="flex items-center gap-3 w-full md:w-auto">
            <a href="{{ path('app_sub_category_index') }}"
               class="flex-1 md:flex-none text-center px-6 py-3.5 text-[10px] font-black uppercase tracking-widest text-gray border border-border-color bg-white hover:bg-row-hover hover:text-brand-dark rounded-xl transition-all shadow-sm">
                Discard
            </a>
            <button type="submit"
                    class="flex-1 md:flex-none px-8 py-3.5 bg-brand text-white rounded-xl font-black text-[10px] uppercase tracking-[0.2em] shadow-md shadow-brand/20 hover:bg-brand-dark transition-all active:scale-95 cursor-pointer">
                {{ button_label|default('Commit Record') }}
            </button>
        </div>
    </div>

    {# --- MAIN FORM CARD --- #}
    <div class="bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">
        <div class="p-8 md:p-10">
            <div class="mb-10 flex items-center gap-3 border-b border-border-color pb-6">
                <div class="p-2 bg-app-bg rounded-xl text-brand border border-border-color">
                    {{ ux_icon('lucide:layers', {class: 'w-5 h-5'}) }}
                </div>
                <h3 class="text-lg font-black text-brand-dark tracking-tighter uppercase">Sub-Category Specifications</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    {{ form_label(form.name, 'SubCategory Name', {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.name, {'attr': {'class': input_base, 'placeholder': 'e.g. Maxi Dresses'}}) }}
                    {{ form_errors(form.name) }}
                </div>

                <div>
                    {{ form_label(form.category, 'Parent Category', {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.category, {'attr': {'class': input_base}}) }}
                    {{ form_errors(form.category) }}
                </div>

                <div class="md:col-span-2">
                    {{ form_label(form.description, 'Description', {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.description, {'attr': {'class': input_base, 'rows': 4, 'placeholder': 'Enter a brief description...'}}) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="md:col-span-2">
                    {{ form_label(form.slug, 'URL Slug', {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.slug, {'attr': {'class': input_base, 'placeholder': 'e.g. maxi-dresses'}}) }}
                    {{ form_errors(form.slug) }}
                </div>
            </div>
        </div>
    </div>

{{ form_end(form) }}
