{% form_theme form 'form/error_theme.html.twig' %}

{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

<div class="bg-gray-50 p-6 mb-4 rounded-xl border border-gray-200">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            {{ form_label(form.name, 'SubCategory Name', { label_attr: {'class': 'font-semibold'} })}}
            {{ form_widget(form.name, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-green'}}) }}
            {{ form_errors(form.name) }}
        </div>

        <div>
            {{ form_label(form.category, 'Parent Category', { label_attr: {'class': 'font-semibold'} }) }}
            {{ form_widget(form.category, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-green'}}) }}
            {{ form_errors(form.category) }}
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
        <div>
            {{ form_label(form.description, 'Description', { label_attr: {'class': 'font-semibold'} }) }}
            {# Use form_widget(form.description) which is typically a TextareaType for description #}
            {{ form_widget(form.description, {'attr': {'class': 'w-full p-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-green', 'rows': 4}}) }}
            {{ form_errors(form.description) }}
        </div>

        {# Note: The 'slug' field is typically hidden or automatically generated by a listener/behavior.
        If it's manual, you would add it here. #}
        <div>
            {{ form_label(form.slug, 'Slug', { label_attr: {'class': 'font-semibold'} }) }}
            {{ form_widget(form.slug, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-green'}}) }}
            {{ form_errors(form.slug) }}
        </div>
    </dvi>
</div>

<div class="mt-6 flex justify-end gap-3">
    <button type="submit" class="{{ button_class|default('px-4 py-2 text-sm font-semibold bg-success text-white rounded-xl cursor-pointer') }}">
        {{ button_label|default('Save') }}
    </button>

    {# Assumes a route to go back to the sub_category index page #}
    <a href="{{ path('app_dashboard_sub_category_index') }}" class="px-4 py-2 text-sm font-semibold border border-gray-300 rounded-xl text-mocha hover:bg-gray-200 transition">
        Cancel
    </a>
</div>

{{ form_end(form) }}
