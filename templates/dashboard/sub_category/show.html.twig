{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}SubCategory: {{ sub_category.name }}{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_sub_category_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ sub_category.name }}
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Taxonomy Manifest #{{ sub_category.id }}</span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[10px] font-bold uppercase tracking-widest border border-brand/20">Sub-Category</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_sub_category_edit', { id: sub_category.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Record
            </a>
            <button type="button"
                @click="$dispatch('open-delete-modal', {
                    url: '{{ path('app_sub_category_delete', {id: sub_category.id}) }}',
                    name: '{{ sub_category.name|e('js') }}',
                    token: '{{ csrf_token('delete' ~ sub_category.id) }}'
                })"
                class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                Void Record
            </button>
        </div>
    </div>

    {# 2. CONTENT GRID #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        {# Main Details Card #}
        <div class="lg:col-span-8 bg-white rounded-2xl border border-border-color shadow-sm overflow-hidden h-fit">
            <div class="p-8 border-b border-border-color flex items-center gap-3">
                <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color">
                    {{ ux_icon('lucide:layers', {class: 'w-5 h-5'}) }}
                </div>
                <h2 class="text-lg font-black text-brand-dark tracking-tighter uppercase">Sub-Category Specifications</h2>
            </div>

            <div class="p-8 md:p-10">
                <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                    <div>
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">SubCategory Name</dt>
                        <dd class="text-base font-bold text-brand-dark">{{ sub_category.name }}</dd>
                    </div>
                    <div>
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">System ID</dt>
                        <dd class="text-base font-mono font-bold text-brand-dark">#{{ sub_category.id }}</dd>
                    </div>

                    <div>
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">Parent Category</dt>
                        <dd class="text-sm font-bold text-brand-dark">
                            {% if sub_category.category %}
                                <a href="{{ path('app_category_show', {'id': sub_category.category.id}) }}" class="flex items-center gap-1.5 hover:text-brand transition-colors">
                                    {{ ux_icon('lucide:link-2', {class: 'w-3.5 h-3.5'}) }}
                                    {{ sub_category.category.name }}
                                </a>
                            {% else %}
                                <span class="text-gray/50 italic font-medium">Independent / No Parent</span>
                            {% endif %}
                        </dd>
                    </div>
                    <div>
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">URL Slug</dt>
                        <dd class="text-sm font-mono font-medium text-gray">{{ sub_category.slug }}</dd>
                    </div>

                    <div class="md:col-span-2">
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">Description</dt>
                        <dd class="text-sm font-medium text-dark-gray leading-relaxed p-5 bg-app-bg rounded-xl border border-border-color">
                            {{ sub_category.description|default('No description provided for this sub-category.') }}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

        {# Quick Stats / Audit Trail #}
        <div class="lg:col-span-4 space-y-8">
            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-sm">
                <h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray mb-6 border-b border-border-color pb-4">Audit Record</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-[9px] font-black uppercase tracking-widest text-gray mb-1.5 flex items-center gap-2">
                            {{ ux_icon('lucide:calendar-plus', {class: 'w-3.5 h-3.5'}) }}
                            Creation Date
                        </p>
                        <p class="text-sm font-bold text-brand-dark">{{ sub_category.createdAt ? sub_category.createdAt|date('F d, Y / H:i') : 'Unknown' }}</p>
                    </div>

                    <div>
                        <p class="text-[9px] font-black uppercase tracking-widest text-gray mb-1.5 flex items-center gap-2">
                            {{ ux_icon('lucide:history', {class: 'w-3.5 h-3.5'}) }}
                            Last Modification
                        </p>
                        <p class="text-sm font-bold text-brand-dark">{{ sub_category.updatedAt ? sub_category.updatedAt|date('F d, Y / H:i') : 'Never modified' }}</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
