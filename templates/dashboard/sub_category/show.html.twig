{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Manifest: {{ sub_category.name }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# --- HEADER SECTION --- #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">

        {# Left: Back Button + Title & Manifest #}
        <div class="flex items-center gap-5">
            <a href="{{ path('app_sub_category_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>

            <div class="flex flex-col gap-2">
                <h1 class="text-3xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ sub_category.name }}
                </h1>

                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        Taxonomy Manifest #{{ sub_category.id }}
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Sub-Category
                    </span>
                </div>
            </div>
        </div>

        {# Right: Action Buttons #}
        <div class="flex items-center gap-3">
             <a href="{{ path('app_sub_category_edit', { id: sub_category.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Record
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '{{ path('app_sub_category_delete', {id: sub_category.id}) }}',
                        name: '{{ sub_category.name|e('js') }}',
                        token: '{{ csrf_token('delete' ~ sub_category.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div>
    </div>

    {# --- MASTER UNIFIED CONTAINER --- #}
    <div class="bg-white rounded-3xl shadow-sm border border-border-color flex flex-col lg:flex-row overflow-hidden">

        {# Left Sidebar: Visuals & Core Status #}
        <div class="w-full lg:w-4/12 p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-border-color bg-app-bg/50 flex flex-col gap-8">

            <div class="flex items-center justify-between border-b border-border-color/50 pb-4">
                <span class="text-[10px] text-gray uppercase font-black tracking-widest italic">Taxonomy Visual</span>
            </div>

            {# Taxonomy Visual #}
            <div class="relative rounded-2xl overflow-hidden shadow-sm border border-border-color bg-white p-6 flex flex-col items-center justify-center aspect-square text-center">
                <div class="p-4 bg-brand/10 rounded-full mb-4 border border-brand/20 text-brand">
                    {{ ux_icon('lucide:network', {class: 'w-10 h-10'}) }}
                </div>
                <h3 class="text-sm font-black text-brand-dark uppercase tracking-widest mb-1">Hierarchy Link</h3>
                <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray">Dependent Node</p>
            </div>

            {# Audit Block #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-3 flex items-center gap-2">
                    {{ ux_icon('lucide:history', {class: 'w-3.5 h-3.5'}) }}
                    Modification History
                </p>
                <div class="bg-white p-4 rounded-xl border border-border-color shadow-sm text-sm font-bold text-brand-dark">
                    {{ sub_category.updatedAt ? sub_category.updatedAt|date('M d, Y / H:i') : 'Never modified' }}
                </div>
            </div>
        </div>

        {# Right Column: Specifications #}
        <div class="w-full lg:w-8/12 p-8 md:p-12 flex flex-col">

            {# Data Header #}
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-border-color pb-8">
                <div>
                    <h2 class="text-2xl font-black text-brand-dark tracking-tighter leading-tight uppercase">Taxonomy Specifications</h2>
                    <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1.5 italic">Classification Record</p>
                </div>

                <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color shadow-sm">
                    {{ ux_icon('lucide:layers', {class: 'w-5 h-5'}) }}
                </div>
            </div>

            {# Information Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">SubCategory Name</label>
                    <span class="text-base font-bold text-brand-dark">{{ sub_category.name }}</span>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Parent Category</label>
                    <span class="text-sm font-bold text-brand-dark">
                        {% if sub_category.category %}
                            <a href="{{ path('app_category_show', {'id': sub_category.category.id}) }}" class="flex items-center gap-1.5 hover:text-brand transition-colors uppercase tracking-widest">
                                {{ ux_icon('lucide:link-2', {class: 'w-3.5 h-3.5 text-brand'}) }}
                                {{ sub_category.category.name }}
                            </a>
                        {% else %}
                            <span class="text-gray/50 italic font-medium">Independent / No Parent</span>
                        {% endif %}
                    </span>
                </div>

                <div class="md:col-span-2">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-3">Description</label>
                    <div class="text-sm font-medium text-dark-gray leading-relaxed p-6 bg-app-bg rounded-xl border border-border-color shadow-inner">
                        {{ sub_category.description|default('No description provided for this sub-category.') }}
                    </div>
                </div>

                <div class="md:col-span-2">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Routing Slug</label>
                    <p class="text-sm font-mono font-medium text-gray">{{ sub_category.slug }}</p>
                </div>
            </div>

            {# Spacer to push archival metadata to bottom #}
            <div class="flex-grow"></div>

            {# Archival Metadata #}
            <div class="mt-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4 text-gray/40 border-t border-border-color pt-6">
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Creation Date: <strong class="text-gray/60">{{ sub_category.createdAt ? sub_category.createdAt|date('F d, Y') : 'Unknown' }}</strong>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
