{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Sub-Category Registry | Mifania{% endblock %}

{% block main_content %}
<div class="animate-fadeIn">
    {% embed 'components/table/table.html.twig' with {
        title: 'Sub-Categories',
        entity_name: 'Sub-Category',
        icon: 'material-symbols:category-outline',
        total_count: sub_categories|length,
        new_path: 'app_sub_category_new',
        headers: ['Manifest', 'Name', 'Parent Category', 'Creation Date', 'Actions'],
    } %}
        {% block rows %}
            {% for sub_category in sub_categories|default([]) %}
                <tr class="group hover:bg-row-hover transition-colors">

                    <td class="border-y border-border-color px-6 py-4 text-[10px] uppercase font-black tracking-[0.2em] text-gray">
                        #{{ sub_category.id }}
                    </td>

                    <td class="border-y border-border-color px-6 py-4 text-sm font-black text-brand-dark tracking-tighter uppercase">
                        {{ sub_category.name }}
                    </td>

                    <td class="border-y border-border-color px-6 py-4 text-xs font-bold text-gray uppercase tracking-widest">
                        {% if sub_category.category %}
                            <a href="{{ path('app_category_show', {'id': sub_category.category.id}) }}" class="hover:text-brand transition-colors">
                                {{ sub_category.category.name }}
                            </a>
                        {% else %}
                            <span class="text-gray/50 italic">None</span>
                        {% endif %}
                    </td>

                    <td class="border-y border-border-color px-6 py-4 text-xs font-bold text-gray">
                        {{ sub_category.createdAt ? sub_category.createdAt|date('M d, Y') : 'N/A' }}
                    </td>

                    <td class="border-y border-border-color px-6 py-4">
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_sub_category_show', {'id': sub_category.id}) }}"
                               class="p-2.5 text-gray hover:text-brand bg-white border border-border-color rounded-xl hover:bg-brand/5 hover:border-brand/20 transition-all shadow-sm"
                               title="View Details">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>
                            <a href="{{ path('app_sub_category_edit', {'id': sub_category.id}) }}"
                               class="p-2.5 text-gray hover:text-brand bg-white border border-border-color rounded-xl hover:bg-brand/5 hover:border-brand/20 transition-all shadow-sm"
                               title="Edit SubCategory">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <button type="button"
                                    @click.stop="$dispatch('open-delete-modal', {
                                        url: '{{ path('app_sub_category_delete', {id: sub_category.id}) }}',
                                        name: 'SubCategory: {{ sub_category.name|e('js') }}',
                                        token: '{{ csrf_token('delete' ~ sub_category.id) }}'
                                    })"
                                    class="p-2.5 text-danger/70 hover:text-danger bg-white border border-border-color rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all shadow-sm cursor-pointer"
                                    title="Delete SubCategory">
                                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                                </button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                {# Empty State #}
                <tr>
                    <td colspan="6" class="px-6 py-16 text-center border-y border-border-color bg-app-bg/50">
                        <div class="p-4 bg-white rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4 shadow-sm border border-border-color">
                            {{ ux_icon('lucide:layers', {class: 'w-6 h-6 text-gray/40'}) }}
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-gray">No Sub-Categories Found</p>
                        <p class="text-xs text-gray/60 mt-2 font-medium">Establish your first sub-category to organize products.</p>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
