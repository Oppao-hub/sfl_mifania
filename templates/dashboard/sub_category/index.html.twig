{% extends "dashboard/dashboard.html.twig" %}

{% block title %}SubCategory Management{% endblock %}

{% block main_content %}
<div class="animate-fadeIn">
    {% embed 'components/table/table.html.twig' with {
        title: 'Manage Sub-Categories',
        new_path: 'app_sub_category_new',
        headers: ['ID', 'Name', 'Parent Category', 'Slug', 'Created At', 'Actions'],
        id: 'subcategory-table'
    } %}
        {% block rows %}
            {% for sub_category in sub_categories|default([]) %}
                <tr class="group hover:bg-row-hover transition-colors">
                    <td class="border-y border-border-color px-6 py-4 text-xs font-mono font-bold text-gray">#{{ sub_category.id }}</td>
                    <td class="border-y border-border-color px-6 py-4 text-sm font-bold text-brand-dark">{{ sub_category.name }}</td>
                    <td class="border-y border-border-color px-6 py-4 text-xs font-medium text-gray">
                        {% if sub_category.category %}
                            <a href="{{ path('app_category_show', {'id': sub_category.category.id}) }}" class="hover:text-brand transition-colors">
                                {{ sub_category.category.name }}
                            </a>
                        {% else %}
                            <span class="text-gray/50 italic">None</span>
                        {% endif %}
                    </td>
                    <td class="border-y border-border-color px-6 py-4 text-xs font-mono text-gray truncate max-w-[150px]">{{ sub_category.slug }}</td>
                    <td class="border-y border-border-color px-6 py-4 text-[11px] font-black uppercase tracking-widest text-gray/80">{{ sub_category.createdAt ? sub_category.createdAt|date('M d, Y') : 'N/A' }}</td>

                    <td class="border-y border-border-color px-6 py-4">
                        <div class="flex justify-end items-center gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                            <a href="{{ path('app_sub_category_show', {'id': sub_category.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm hover:border-brand/30 transition-all"
                               title="View Details">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>
                            <a href="{{ path('app_sub_category_edit', {'id': sub_category.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm hover:border-brand/30 transition-all"
                               title="Edit SubCategory">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>
                            <button type="button"
                                @click="$dispatch('open-delete-modal', {
                                    url: '{{ path('app_sub_category_delete', {id: sub_category.id}) }}',
                                    name: 'SubCategory: {{ sub_category.name|e('js') }}',
                                    token: '{{ csrf_token('delete' ~ sub_category.id) }}'
                                })"
                                class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm hover:border-danger/30 hover:bg-danger/5 transition-all cursor-pointer"
                                title="Delete SubCategory">
                                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                            </button>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center text-gray font-medium text-sm">
                        <div class="flex flex-col items-center justify-center gap-3">
                            {{ ux_icon('lucide:layers', {class: 'w-8 h-8 opacity-20'}) }}
                            <p>No sub-categories established yet.</p>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
