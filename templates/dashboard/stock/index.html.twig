{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Stock Inventory{% endblock %}
{% set stocks = stocks|default([]) %}

{% block main_content %}
    {% embed 'components/table/table.html.twig' with {
        title: 'Manage Stock Inventory',
        icon: 'si:inventory-line',
        entity_name: 'Stock',
        total_count: stocks|length,
        new_path: 'app_stock_new',
        headers: ['ID','Product', 'Location', 'Quantity', 'Status', 'Actions'],
    } %}

        {% block rows %}
            {% for stock in stocks %}
                <tr class="hover:bg-row-hover transition-colors group">
                    <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray">#{{ stock.id }}</td>

                    <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-brand-dark">
                        <a href="{{ path('app_product_show', { id: stock.product.id }) }}" class="hover:text-brand transition-colors">
                            {{ stock.product.name }}
                        </a>
                    </td>
                    <td class="border-y border-border-color px-4 py-3 text-xs font-bold text-gray uppercase tracking-widest">
                        {{ stock.location|default('N/A') }}
                    </td>

                    <td class="border-y border-border-color px-4 py-3 text-sm font-black text-brand-dark">
                        {{ stock.quantity }}
                    </td>

                    <td class="border-y border-border-color px-4 py-3 text-sm">
                        <span class="inline-flex px-3 py-1 text-[10px] font-black uppercase tracking-widest rounded-md border
                            {% if stock.status.value == 'In Stock' %} bg-success/10 text-success border-success/20
                            {% elseif stock.status.value == 'Low Stock' %} bg-warning/10 text-warning border-warning/20
                            {% else %} bg-danger/10 text-danger border-danger/20 {% endif %}">
                            {{ stock.status.value }}
                        </span>
                    </td>
                    <td class="border-y border-border-color py-3 px-4 text-center">
                        <div class="flex justify-center items-center gap-2">
                            <a href="{{ path('app_stock_show', {'id': stock.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>

                            <a href="{{ path('app_stock_edit', {'id': stock.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <button type="button"
                                    @click="$dispatch('open-delete-modal', {
                                        url: '{{ path('app_stock_delete', {id: stock.id}) }}',
                                        name: 'Stock for {{ stock.product.name|e('js') }}',
                                        token: '{{ csrf_token('delete' ~ stock.id) }}'
                                    })"
                                    class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer">
                                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                                </button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
{% endblock %}
