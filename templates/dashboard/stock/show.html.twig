{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Manifest: Stock #{{ stock.id }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {% set product = stock.product %}

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">

        <div class="flex items-center gap-5">
            <a href="{{ path('app_stock_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:bg-brand/10 hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>

            <div class="flex flex-col gap-2">
                <h1 class="text-3xl md:text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    Stock <span class="text-brand">#{{ stock.id }}</span>
                </h1>

                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        Logistics Manifest
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Verified Record
                    </span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_stock_edit', { 'id': stock.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Record
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '{{ path('app_stock_delete', {id: stock.id}) }}',
                        name: 'Stock for {{ product.name|e('js') }}',
                        token: '{{ csrf_token('delete' ~ stock.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div>
    </div>

    {# --- MASTER UNIFIED CONTAINER --- #}
    <div class="bg-white rounded-3xl shadow-sm border border-border-color flex flex-col lg:flex-row overflow-hidden">

        {# Left Sidebar: Visuals & Status #}
        <div class="w-full lg:w-4/12 p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-border-color bg-app-bg/50 flex flex-col gap-8">

            <div class="flex items-center justify-between border-b border-border-color/50 pb-4">
                <span class="text-[10px] text-gray uppercase font-black tracking-widest italic">Product Visual</span>
            </div>

            <div class="relative rounded-2xl overflow-hidden shadow-sm border border-border-color group bg-white p-2">
                <img src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('uploads/default/default-product.png') }}"
                     alt="{{ product.name }}"
                     class="w-full aspect-[4/5] object-cover rounded-xl hover:scale-[1.02] transition-transform duration-700">
            </div>

            {# Operational Status #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-3 flex items-center gap-2">
                    {{ ux_icon('lucide:activity', {class: 'w-3.5 h-3.5'}) }}
                    Inventory Health
                </p>

                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm border bg-white
                    {% if stock.status.value == 'In Stock' %} text-success border-success/20
                    {% elseif stock.status.value == 'Low Stock' %} text-warning border-warning/20
                    {% else %} text-danger border-danger/20 {% endif %}">

                    <span class="w-1.5 h-1.5 rounded-full
                        {% if stock.status.value == 'In Stock' %} bg-success animate-pulse
                        {% elseif stock.status.value == 'Low Stock' %} bg-warning
                        {% else %} bg-danger {% endif %}">
                    </span>
                    {{ stock.status.value ?: (stock.quantity > 0 ? 'In Stock' : 'Out of Stock') }}
                </div>
            </div>
        </div>

        {# Right Column: Specifications #}
        <div class="w-full lg:w-8/12 p-8 md:p-12 flex flex-col">

            {# Data Header #}
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-border-color pb-8">
                <div>
                    <h2 class="text-2xl font-black text-brand-dark tracking-tighter leading-tight uppercase">Inventory Details</h2>
                    <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1.5 italic">Logistics Information Record</p>
                </div>

                <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color shadow-sm">
                    {{ ux_icon('lucide:boxes', {class: 'w-5 h-5'}) }}
                </div>
            </div>

            {# Information Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">

                <div class="md:col-span-2">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Associated Product</label>
                    <a href="{{ path('app_product_show', { 'id': product.id }) }}"
                       class="text-xl font-black text-brand hover:text-brand-dark transition-colors inline-block leading-none tracking-tighter uppercase">
                        {{ product.name }}
                    </a>
                </div>

                <div class="bg-app-bg p-6 rounded-xl border border-border-color">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-brand block mb-2">Total Quantity</label>
                    <div class="flex items-baseline gap-1">
                        <span class="text-3xl font-black font-mono text-brand-dark leading-none tracking-tighter">{{ stock.quantity|number_format(0, '.', ',') }}</span>
                        <span class="text-[10px] uppercase font-black text-brand tracking-widest">Units</span>
                    </div>
                </div>

                <div class="flex flex-col justify-center">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Storage Location</label>
                    <p class="text-sm font-bold text-brand-dark uppercase tracking-widest">{{ stock.location ?: 'Unassigned' }}</p>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Archival Cost (Per Unit)</label>
                    <p class="text-sm font-bold text-gray italic">₱{{ product.cost|number_format(2) }}</p>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Authorized By</label>
                    <p class="text-sm font-bold text-brand-dark">{{ stock.addedBy.email|default('System Initialization') }}</p>
                </div>
            </div>

            {# Spacer to push archival metadata to bottom #}
            <div class="flex-grow"></div>

            {# Archival Metadata #}
            <div class="mt-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4 text-gray/40 border-t border-border-color pt-6">
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Created: {{ stock.createdAt|date('M d, Y / H:i') }}
                </div>
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Last Update: {{ stock.updatedAt|date('M d, Y / H:i') }}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
