{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Stock Manifest: #{{ stock.id }}{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {% set product = stock.product %}

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_stock_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    Stock Record <span class="text-brand font-mono">#{{ stock.id }}</span>
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Logistics Manifest</span>
                    <span class="px-2 py-0.5 bg-app-bg text-gray rounded-md text-[10px] font-bold uppercase tracking-tighter border border-border-color">Verified Record</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_stock_edit', { 'id': stock.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Record
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click="$dispatch('open-delete-modal', {
                        url: '{{ path('app_stock_delete', {id: stock.id}) }}',
                        name: 'Stock for {{ product.name|e('js') }}',
                        token: '{{ csrf_token('delete' ~ stock.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div>
    </div>

    {# 2. CONTENT GRID #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        {# Left Column: Visual #}
        <div class="lg:col-span-4 space-y-8">
            <div class="bg-white p-2 rounded-2xl shadow-sm border border-border-color group overflow-hidden">
                <img
                    src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('uploads/default/default-product.png') }}"
                    alt="{{ product.name }}"
                    class="rounded-xl w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                />
            </div>
        </div>

        {# Right Column: Specifications #}
        <div class="lg:col-span-8 bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">
            <div class="p-8 border-b border-border-color flex justify-between items-center bg-app-bg">
                <h2 class="text-lg font-black text-brand-dark tracking-tighter uppercase flex items-center gap-3">
                    {{ ux_icon('lucide:boxes', {class: 'w-5 h-5 text-brand'}) }}
                    Inventory Details
                </h2>

                <span class="px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm border
                    {% if stock.status.value == 'In Stock' %} bg-success/10 text-success border-success/20
                    {% elseif stock.status.value == 'Low Stock' %} bg-warning/10 text-warning border-warning/20
                    {% else %} bg-danger/10 text-danger border-danger/20 {% endif %}">
                    {{ stock.status.value ?: (stock.quantity > 0 ? 'In Stock' : 'Out of Stock') }}
                </span>
            </div>

            <div class="p-8 md:p-12">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">

                    <div class="md:col-span-2">
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Associated Product</label>
                        <a href="{{ path('app_product_show', { 'id': product.id }) }}"
                           class="text-xl font-black text-brand hover:text-brand-dark transition-colors inline-block leading-none tracking-tighter uppercase">
                            {{ product.name }}
                        </a>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Total Quantity</label>
                        <span class="text-3xl font-black font-mono text-brand-dark leading-none tracking-tighter">{{ stock.quantity|number_format(0, '.', ',') }}</span>
                        <span class="text-[10px] uppercase font-black text-gray tracking-widest ml-1">Units</span>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Storage Location</label>
                        <p class="text-sm font-bold text-brand-dark uppercase tracking-widest">{{ stock.location ?: 'Unassigned' }}</p>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Archival Cost (Per Unit)</label>
                        <p class="text-sm font-bold text-gray italic">₱{{ product.cost|number_format(2) }}</p>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Authorized By</label>
                        <p class="text-sm font-bold text-brand-dark">{{ stock.addedBy.email|default('System Initialization') }}</p>
                    </div>
                </div>

                {# Archival Metadata #}
                <div class="mt-16 pt-8 border-t border-border-color flex flex-wrap gap-8 text-gray/50">
                    <div class="text-[9px] uppercase font-black tracking-widest">
                        Created: {{ stock.createdAt|date('d.m.Y / H:i') }}
                    </div>
                    <div class="text-[9px] uppercase font-black tracking-widest">
                        Last Update: {{ stock.updatedAt|date('d.m.Y / H:i') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
