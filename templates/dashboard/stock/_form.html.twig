{% form_theme form 'form/error_theme.html.twig' %}

{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

{# Row 1: Product and Location (Two-column grid) #}
<div class="bg-gray-50 p-6 mb-4 rounded-xl border border-gray-200">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            {{ form_label(form.product, 'Product:', { label_attr: {'class': 'font-semibold block mb-1'} })}}
            {# Assuming 'product' is an EntityType field #}
            {{ form_widget(form.product, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-violet'}}) }}
            {{ form_errors(form.product) }}
        </div>

        <div>
            {{ form_label(form.location, 'Location:', { label_attr: {'class': 'font-semibold block mb-1'} }) }}
            {{ form_widget(form.location, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-violet'}}) }}
            {{ form_errors(form.location) }}
        </div>
    </div>

    {# Row 2: Quantity and Cost Price (Two-column grid) #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
        <div>
            {{ form_label(form.quantity, 'Quantity:', { label_attr: {'class': 'font-semibold block mb-1'} }) }}
            {{ form_widget(form.quantity, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-violet'}}) }}
            {{ form_errors(form.quantity) }}
        </div>
        <div>
            {{ form_label(form.status, 'Status:', { label_attr: {'class': 'font-semibold block mb-1'} }) }}
            {{ form_widget(form.status, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-violet'}}) }}
            {{ form_errors(form.status) }}
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
        <div>
            {{ form_label(form.addedBy, 'Added By',{ label_attr: {'class': 'font-semibold'} }) }}
            {{ form_widget(form.addedBy, {'attr': {'class': 'w-full p-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-violet'}}) }}
            {{ form_errors(form.addedBy) }}
        </div>
    </div>

    {# Add other fields like 'notes' or 'status' here if they exist in your StockType Form #}
    {# Example for a notes field (textarea):
    <div class="mt-4">
        {{ form_label(form.notes, 'Notes:', { label_attr: {'class': 'font-semibold block mb-1'} }) }}
        {{ form_widget(form.notes, {'attr': {'class': 'w-full p-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-violet', 'rows': 3}}) }}
        {{ form_errors(form.notes) }}
    </div>
    #}
</div>

<div class="mt-6 flex justify-end gap-3">
        {# Submit Button #}
        <button type="submit" class="{{ button_class|default('px-4 py-2 text-sm bg-success text-white rounded-xl cursor-pointer hover:opacity-80 transition') }}">
            {{ button_label|default('Save Stock Record') }}
        </button>

        {# Cancel/Back Button #}
        {# This link assumes you'll go back to the Stock index page #}
        <a href="{{ path('app_dashboard_stock_index') }}" class="px-4 py-2 text-sm font-semibold border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-200 transition">
            Cancel
        </a>
    </div>
{{ form_end(form) }}
