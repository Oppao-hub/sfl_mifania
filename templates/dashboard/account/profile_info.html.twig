{% extends "dashboard/account/index.html.twig" %}

{% block title %}Profile Information{% endblock %}

{% block account_content %}

{# --- 1. SETUP VARIABLES --- #}
{% set profile = app.user.admin ? app.user.admin : (app.user.staff ? app.user.staff : null) %}

{# --- 2. CONTENT CARD --- #}
<div class="bg-white p-8 sm:p-10 rounded-3xl shadow-sm border border-border-color animate-fadeIn">

    <div class="flex items-center gap-3 mb-8 pb-6 border-b border-border-color">
        <div class="w-10 h-10 rounded-xl bg-brand/5 flex items-center justify-center text-brand">
            {{ ux_icon('lucide:user-check', {class: 'w-5 h-5'}) }}
        </div>
        <h2 class="text-lg font-black text-brand-dark uppercase tracking-[0.2em]">Profile Details</h2>
    </div>

    {# Info Fields Grid #}
    <div class="space-y-10">

        {# Row 1: Names #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1">First Name</label>
                <div class="w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm">
                    {{ profile ? profile.firstName : 'Not set' }}
                </div>
            </div>
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1">Last Name</label>
                <div class="w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm">
                    {{ profile ? profile.lastName : 'Not set' }}
                </div>
            </div>
        </div>

        {# Row 2: Account Details #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1">Email Address</label>
                <div class="w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm flex items-center gap-3">
                    {{ ux_icon('lucide:mail', {class: 'w-4 h-4 text-gray/40'}) }}
                    <span>{{ app.user.email }}</span>
                </div>
            </div>
            <div class="space-y-2">
                <label class="block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1">Account Role</label>
                <div class="w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm flex items-center gap-3">
                    {{ ux_icon('lucide:shield-check', {class: 'w-4 h-4 text-gray/40'}) }}
                    <span>
                        {% if app.user.admin %}
                            System Administrator
                        {% elseif app.user.staff %}
                            Support Staff
                        {% endif %}
                    </span>
                </div>
            </div>
        </div>

        {# Row 3: Timestamps #}
        <div class="pt-6 border-t border-border-color">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="flex items-center gap-3 text-xs font-bold text-gray/40 uppercase tracking-widest">
                    {{ ux_icon('lucide:clock-3', {class: 'w-4 h-4'}) }}
                    <span>Member since {{ profile.createdAt|date('M d, Y') }}</span>
                </div>
                <div class="flex items-center gap-3 text-xs font-bold text-gray/40 uppercase tracking-widest md:justify-end">
                    {{ ux_icon('lucide:refresh-cw', {class: 'w-4 h-4'}) }}
                    <span>Last updated {{ profile.updatedAt|date('M d, Y') }}</span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
