{% extends "dashboard/account/index.html.twig" %}

{% block title %}Profile Information{% endblock %}

{% block account_content %}

{# --- 1. SETUP VARIABLES --- #}
{% set profile = app.user.admin ? app.user.admin : (app.user.staff ? app.user.staff : null) %}

{# --- 2. CONTENT CARD --- #}
<div class="bg-white p-6 md:p-10 rounded-lg shadow-sm border border-border-color h-full animate-fadeIn">

    {# Header Section #}
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8 border-b border-border-color pb-6">
        <div>
            <h2 class="text-2xl font-black text-brand-dark uppercase tracking-tighter">Personal Information</h2>
            <p class="text-sm font-bold text-gray uppercase tracking-widest mt-1">Manage your personal details and contact info.</p>
        </div>

        {# Edit Button #}
        <a href="{{ is_granted('ROLE_ADMIN') ? path('app_account_admin_edit') : path('app_staff_account_edit') }}"
           class="inline-flex items-center justify-center px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 font-bold text-[10px] uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm cursor-pointer">
            {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4 mr-2'}) }}
            Edit Details
        </a>
    </div>

    {# Info Fields Grid #}
    <div class="space-y-8">

        {# Row 1: Names #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1">
                <label class="block text-[10px] font-black text-gray uppercase tracking-widest ml-1">First Name</label>
                <div class="w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm">
                    {{ profile ? profile.firstName : 'Not set' }}
                </div>
            </div>
            <div class="space-y-1">
                <label class="block text-[10px] font-black text-gray uppercase tracking-widest ml-1">Last Name</label>
                <div class="w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm">
                    {{ profile ? profile.lastName : 'Not set' }}
                </div>
            </div>
        </div>

        {# Row 2: Account Details #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1">
                <label class="block text-[10px] font-black text-gray uppercase tracking-widest ml-1">Email Address</label>
                <div class="w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm flex items-center gap-3">
                    {{ ux_icon('lucide:mail', {class: 'w-4 h-4 text-gray'}) }}
                    <span>{{ app.user.email }}</span>
                </div>
            </div>
            <div class="space-y-1">
                <label class="block text-[10px] font-black text-gray uppercase tracking-widest ml-1">Account Role</label>
                <div class="w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm flex items-center gap-3">
                    {{ ux_icon('lucide:shield-check', {class: 'w-4 h-4 text-gray'}) }}
                    <span>
                        {% if app.user.admin %}
                            System Administrator
                        {% elseif app.user.staff %}
                            Support Staff
                        {% endif %}
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
