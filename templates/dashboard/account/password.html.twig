{% extends 'dashboard/account/index.html.twig' %}

{% block title %}Security & Password{% endblock %}

{% block account_content %}
<div class="bg-white p-6 md:p-10 rounded-2xl shadow-sm border border-border-color h-full animate-fadeIn">

    {# Header #}
    <div class="mb-8 border-b border-border-color pb-6">
        <h2 class="text-2xl font-black text-brand-dark uppercase tracking-tighter">Security Settings</h2>
        <p class="text-sm font-bold text-gray uppercase tracking-widest mt-1">Update your password to keep your account secure.</p>
    </div>

    {% form_theme form 'form/error_theme.html.twig' %}
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'max-w-2xl'}}) }}

        <input type="hidden" name="username" value="{{ app.user.email }}" autocomplete="username">
        <div class="space-y-8" x-data="{ showPasswords: false }">

            {# Current Password #}
            <div class="space-y-1">
                {{ form_label(form.currentPassword, 'Current Password', {label_attr: {'class': 'block text-[10px] font-black text-gray uppercase tracking-widest ml-1'}}) }}
                <div class="relative group">
                    {{ form_widget(form.currentPassword, {
                        'attr': {
                            'class': 'w-full pl-4 pr-12 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all shadow-inner',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': '••••••••'
                        }
                    }) }}
                    <button type="button" @click="showPasswords = !showPasswords" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray hover:text-brand transition-colors cursor-pointer">
                        <template x-if="!showPasswords">{{ ux_icon('lucide:eye', {class: 'w-5 h-5'}) }}</template>
                        <template x-if="showPasswords">{{ ux_icon('lucide:eye-off', {class: 'w-5 h-5'}) }}</template>
                    </button>
                </div>
                {{ form_errors(form.currentPassword) }}
            </div>

            <hr class="border-border-color">

            {# New Password Row #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {# First Field #}
                <div class="space-y-1">
                    {{ form_label(form.plainPassword.first, 'New Password', {label_attr: {'class': 'block text-[10px] font-black text-gray uppercase tracking-widest ml-1'}}) }}
                    {{ form_widget(form.plainPassword.first, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all shadow-inner',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': 'New password'
                        }
                    }) }}
                    {{ form_errors(form.plainPassword.first) }}
                </div>

                {# Second Field #}
                <div class="space-y-1">
                    {{ form_label(form.plainPassword.second, 'Confirm Password', {label_attr: {'class': 'block text-[10px] font-black text-gray uppercase tracking-widest ml-1'}}) }}
                    {{ form_widget(form.plainPassword.second, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all shadow-inner',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': 'Repeat password'
                        }
                    }) }}
                    {{ form_errors(form.plainPassword.second) }}
                </div>
            </div>

            {# Submit Button #}
            <div class="flex justify-end pt-4">
                <button type="submit" class="group flex items-center gap-3 bg-brand px-8 py-3.5 rounded-xl text-white font-bold text-[10px] uppercase tracking-widest hover:bg-brand-dark transition-all shadow-md shadow-brand/20 cursor-pointer">
                    Update Password
                    {{ ux_icon('lucide:shield-check', {class: 'w-4 h-4'}) }}
                </button>
            </div>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
