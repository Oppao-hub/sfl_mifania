{% extends 'dashboard/account/index.html.twig' %}

{% block title %}Security & Password{% endblock %}

{% block account_content %}
<div class="bg-white p-8 sm:p-10 rounded-3xl shadow-sm border border-border-color animate-fadeIn">

    <div class="flex items-center gap-3 mb-8 pb-6 border-b border-border-color">
        <div class="w-10 h-10 rounded-xl bg-brand/5 flex items-center justify-center text-brand">
            {{ ux_icon('lucide:shield-check', {class: 'w-5 h-5'}) }}
        </div>
        <h2 class="text-lg font-black text-brand-dark uppercase tracking-[0.2em]">Security Settings</h2>
    </div>

    {% form_theme form 'form/error_theme.html.twig' %}
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'w-full'}}) }}

        <input type="hidden" name="username" value="{{ app.user.email }}" autocomplete="username">
        <div class="space-y-10" x-data="{ showPasswords: false }">

            {# Current Password #}
            <div class="space-y-2 max-w-lg">
                {{ form_label(form.currentPassword, 'Current Password', {label_attr: {'class': 'block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1'}}) }}
                <div class="relative group">
                    {{ form_widget(form.currentPassword, {
                        'attr': {
                            'class': 'w-full pl-5 pr-14 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm focus:ring-4 focus:ring-brand/5 focus:border-brand outline-none transition-all shadow-inner',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': '••••••••'
                        }
                    }) }}
                    <button type="button" @click="showPasswords = !showPasswords" class="absolute right-5 top-1/2 -translate-y-1/2 text-gray/40 hover:text-brand transition-colors cursor-pointer">
                        <template x-if="!showPasswords">{{ ux_icon('lucide:eye', {class: 'w-5 h-5'}) }}</template>
                        <template x-if="showPasswords">{{ ux_icon('lucide:eye-off', {class: 'w-5 h-5'}) }}</template>
                    </button>
                </div>
                {{ form_errors(form.currentPassword) }}
            </div>

            <div class="h-px bg-border-color"></div>

            {# New Password Row #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {# First Field #}
                <div class="space-y-2">
                    {{ form_label(form.plainPassword.first, 'New Password', {label_attr: {'class': 'block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1'}}) }}
                    {{ form_widget(form.plainPassword.first, {
                        'attr': {
                            'class': 'w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm focus:ring-4 focus:ring-brand/5 focus:border-brand outline-none transition-all shadow-inner',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': 'New password'
                        }
                    }) }}
                    {{ form_errors(form.plainPassword.first) }}
                </div>

                {# Second Field #}
                <div class="space-y-2">
                    {{ form_label(form.plainPassword.second, 'Confirm Password', {label_attr: {'class': 'block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1'}}) }}
                    {{ form_widget(form.plainPassword.second, {
                        'attr': {
                            'class': 'w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm focus:ring-4 focus:ring-brand/5 focus:border-brand outline-none transition-all shadow-inner',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': 'Repeat password'
                        }
                    }) }}
                    {{ form_errors(form.plainPassword.second) }}
                </div>
            </div>

            {# Submit Button #}
            <div class="flex justify-end pt-6 border-t border-border-color">
                <button type="submit" class="group flex items-center gap-3 bg-brand px-10 py-4 rounded-2xl text-white font-black text-[10px] uppercase tracking-widest hover:bg-brand-dark transition-all shadow-lg shadow-brand/20 cursor-pointer">
                    Update Password
                    {{ ux_icon('lucide:shield-check', {class: 'w-4 h-4'}) }}
                </button>
            </div>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
