{% extends 'dashboard/account/index.html.twig' %}

{% block title %}Security & Password{% endblock %}

{% block account_content %}
<div class="bg-dashboard-surface p-6 md:p-10 rounded-[2.5rem] shadow-sm border border-dashboard-border h-full animate-fadeIn">

    {# Header #}
    <div class="mb-8 border-b border-dashboard-bg pb-6">
        <h2 class="text-2xl font-bold text-dashboard-mocha">Security Settings</h2>
        <p class="text-sm text-gray-400 mt-1">Update your password to keep your account secure.</p>
    </div>

    {% form_theme form 'form/error_theme.html.twig' %}
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'max-w-2xl'}}) }}

        <div class="space-y-6" x-data="{ showPasswords: false }">

            {# Current Password #}
            <div class="space-y-1">
                {{ form_label(form.currentPassword, 'Current Password', {label_attr: {'class': 'block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1'}}) }}
                <div class="relative group">
                    {{ form_widget(form.currentPassword, {
                        'attr': {
                            'class': 'w-full pl-4 pr-12 py-3.5 bg-dashboard-bg/50 border border-gray-100 rounded-2xl text-dashboard-mocha font-medium text-sm focus:ring-2 focus:ring-dashboard-mint focus:border-dashboard-olive outline-none transition-all',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': '••••••••'
                        }
                    }) }}
                    <button type="button" @click="showPasswords = !showPasswords" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-300 hover:text-dashboard-olive transition-colors">
                        <template x-if="!showPasswords">{{ ux_icon('lucide:eye', {class: 'w-5 h-5'}) }}</template>
                        <template x-if="showPasswords">{{ ux_icon('lucide:eye-off', {class: 'w-5 h-5'}) }}</template>
                    </button>
                </div>
                {{ form_errors(form.currentPassword) }}
            </div>

            <hr class="border-dashboard-bg my-8">

            {# New Password Row #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {# First Field #}
                <div class="space-y-1">
                    {{ form_label(form.plainPassword.first, 'New Password', {label_attr: {'class': 'block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1'}}) }}
                    {{ form_widget(form.plainPassword.first, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-dashboard-bg/50 border border-gray-100 rounded-2xl text-dashboard-mocha font-medium text-sm focus:ring-2 focus:ring-dashboard-mint focus:border-dashboard-olive outline-none transition-all',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': 'New password'
                        }
                    }) }}
                    {{ form_errors(form.plainPassword.first) }}
                </div>

                {# Second Field #}
                <div class="space-y-1">
                    {{ form_label(form.plainPassword.second, 'Confirm New Password', {label_attr: {'class': 'block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1'}}) }}
                    {{ form_widget(form.plainPassword.second, {
                        'attr': {
                            'class': 'w-full px-4 py-3.5 bg-dashboard-bg/50 border border-gray-100 rounded-2xl text-dashboard-mocha font-medium text-sm focus:ring-2 focus:ring-dashboard-mint focus:border-dashboard-olive outline-none transition-all',
                            ':type': "showPasswords ? 'text' : 'password'",
                            'placeholder': 'Repeat password'
                        }
                    }) }}
                    {{ form_errors(form.plainPassword.second) }}
                </div>
            </div>

            {# Submit Button #}
            <div class="flex justify-end pt-4">
                <button type="submit" class="group flex items-center gap-2 bg-dashboard-olive px-8 py-3.5 rounded-2xl text-white font-bold text-xs uppercase tracking-widest hover:bg-dashboard-mocha transition-all shadow-lg shadow-dashboard-olive/20 active:scale-95">
                    Update Password
                    {{ ux_icon('lucide:check-circle', {class: 'w-4 h-4'}) }}
                </button>
            </div>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
