{% extends 'dashboard/account/index.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block account_content %}
<div class="lg:w-full bg-gray-50 p-8 rounded-lg shadow-lg h-full">

    {# Header #}
    <div class="flex justify-between items-center mb-6 pb-4 border-b border-gray-100">
        <div>
            <h2 class="text-2xl font-bold text-brand">Edit Profile</h2>
            <p class="text-sm text-gray-500 mt-1">Update your personal information.</p>
        </div>
    </div>

    {% form_theme form 'form/error_theme.html.twig' %}

    {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
        {# --- AVATAR UPLOAD SECTION --- #}
        <div class="flex items-center space-x-6">
            <div class="shrink-0 relative">
                {% set avatarPath = 'images/default/default_avatar.jpg' %}

                {# Check if the entity has an existing avatar filename #}
                {% if form.vars.value.avatar %}
                     {% if is_granted('ROLE_ADMIN') %}
                          {% set avatarPath = 'uploads/admin/avatars/' ~ form.vars.value.avatar %}
                     {% elseif is_granted('ROLE_STAFF') %}
                          {% set avatarPath = 'uploads/staff/avatars/' ~ form.vars.value.avatar %}
                     {% endif %}
                {% endif %}

                <img
                    class="h-20 w-20 object-cover rounded-full border-4 border-gray-100 shadow-sm"
                    src="{{ asset(avatarPath) }}"
                    alt="Current profile photo"
                />
            </div>

            <div class="w-full">
                {{ form_label(form.avatar, 'Profile Photo', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}

                <div class="mt-1 flex items-center">
                    {{ form_widget(form.avatar, {'attr': {
                        'class': 'block w-full text-sm text-gray-500
                                  file:mr-4 file:py-2.5 file:px-4
                                  file:rounded-full file:border-0
                                  file:text-sm file:font-semibold
                                  file:bg-mocha file:text-white
                                  hover:file:bg-mocha/90
                                  cursor-pointer'
                    }}) }}
                </div>
                {{ form_errors(form.avatar, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                <p class="mt-1 text-xs text-gray-500">JPG or PNG. Max size of 5MB.</p>
            </div>
        </div>

        <div class="border-t border-gray-100 my-6"></div>

        {# --- NAME FIELDS --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                {{ form_label(form.firstName, 'First Name', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.firstName, {'attr': {'class': 'mt-1 block w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-mocha focus:border-mocha sm:text-sm'}}) }}
                {{ form_errors(form.firstName, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>

            <div>
                {{ form_label(form.lastName, 'Last Name', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.lastName, {'attr': {'class': 'mt-1 block w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-mocha focus:border-mocha sm:text-sm'}}) }}
                {{ form_errors(form.lastName, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
        </div>

        {# --- SUBMIT BUTTON --- #}
        <div class="pt-6 flex justify-end border-t border-gray-100 mt-6">
            <a href="{{ path('app_account') }}" class="mr-3 inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none transition">
                Cancel
            </a>
            <button type="submit" class="inline-flex justify-center py-2 px-6 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-mocha hover:bg-mocha/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-mocha transition">
                Save Changes
            </button>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}
