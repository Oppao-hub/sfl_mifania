{% extends 'dashboard/account/index.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block account_content %}
<div class="bg-white p-8 sm:p-10 rounded-3xl shadow-sm border border-border-color animate-fadeIn">

    <div class="flex items-center gap-3 mb-8 pb-6 border-b border-border-color">
        <div class="w-10 h-10 rounded-xl bg-brand/5 flex items-center justify-center text-brand">
            {{ ux_icon('lucide:edit-3', {class: 'w-5 h-5'}) }}
        </div>
        <h2 class="text-lg font-black text-brand-dark uppercase tracking-[0.2em]">Update Information</h2>
    </div>

    {% form_theme form 'form/error_theme.html.twig' %}

    {{ form_start(form, {'attr': {'class': 'space-y-10', 'novalidate': 'novalidate'}}) }}

        {# --- AVATAR UPLOAD SECTION --- #}
        <div class="p-8 bg-app-bg border border-border-color rounded-2xl">
            <div class="flex flex-col sm:flex-row items-center gap-8">
                <div class="shrink-0 relative">
                    {% set avatarPath = 'uploads/default/default-avatar.jpg' %}

                    {# Check if the entity has an existing avatar filename #}
                    {% if form.vars.value.avatar %}
                         {% if is_granted('ROLE_ADMIN') %}
                              {% set avatarPath = 'uploads/admin/avatars/' ~ form.vars.value.avatar %}
                         {% elseif is_granted('ROLE_STAFF') %}
                              {% set avatarPath = 'uploads/staff/avatars/' ~ form.vars.value.avatar %}
                         {% endif %}
                    {% endif %}

                    <img
                        class="h-24 w-24 object-cover rounded-2xl border-2 border-white shadow-md"
                        src="{{ asset(avatarPath) }}"
                        alt="Current profile photo"
                    />
                </div>

                <div class="flex-1 space-y-4 text-center sm:text-left">
                    {{ form_label(form.avatar, 'Profile Photo', {'label_attr': {'class': 'block text-[10px] font-black text-gray/50 uppercase tracking-widest'}}) }}

                    <div class="flex items-center justify-center sm:justify-start">
                        {{ form_widget(form.avatar, {'attr': {
                            'class': 'block text-sm text-gray font-medium
                                      file:mr-4 file:py-2.5 file:px-6
                                      file:rounded-xl file:border-0
                                      file:text-[10px] file:font-black file:uppercase file:tracking-widest
                                      file:bg-brand file:text-white
                                      hover:file:bg-brand-dark file:transition-colors file:shadow-sm
                                      cursor-pointer'
                        }}) }}
                    </div>
                    {{ form_errors(form.avatar, {'attr': {'class': 'text-red-500 text-xs mt-1 font-bold'}}) }}
                    <p class="text-[9px] font-bold text-gray/40 uppercase tracking-widest">Supports JPG, PNG. Max 5MB.</p>
                </div>
            </div>
        </div>

        {# --- FORM FIELDS --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
                {{ form_label(form.firstName, 'First Name', {'label_attr': {'class': 'block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1'}}) }}
                {{ form_widget(form.firstName, {'attr': {'class': 'w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm focus:ring-4 focus:ring-brand/5 focus:border-brand outline-none transition-all shadow-inner'}}) }}
                {{ form_errors(form.firstName, {'attr': {'class': 'text-red-500 text-xs mt-1 font-bold'}}) }}
            </div>

            <div class="space-y-2">
                {{ form_label(form.lastName, 'Last Name', {'label_attr': {'class': 'block text-[10px] font-black text-gray/50 uppercase tracking-[0.2em] ml-1'}}) }}
                {{ form_widget(form.lastName, {'attr': {'class': 'w-full px-5 py-4 bg-app-bg border border-border-color rounded-2xl text-brand-dark font-bold text-sm focus:ring-4 focus:ring-brand/5 focus:border-brand outline-none transition-all shadow-inner'}}) }}
                {{ form_errors(form.lastName, {'attr': {'class': 'text-red-500 text-xs mt-1 font-bold'}}) }}
            </div>
        </div>

        {# --- SUBMIT BUTTON --- #}
        <div class="pt-8 flex justify-end gap-4 border-t border-border-color">
            <a href="{{ path(is_granted('ROLE_ADMIN') ? 'app_account_admin' : 'app_staff_account') }}" 
               class="px-8 py-4 bg-app-bg text-gray border border-border-color rounded-2xl hover:bg-row-hover hover:text-brand-dark font-black text-[10px] uppercase tracking-widest transition-all cursor-pointer">
                Cancel
            </a>
            <button type="submit" 
                    class="px-8 py-4 bg-brand text-white rounded-2xl hover:bg-brand-dark font-black text-[10px] uppercase tracking-widest shadow-lg shadow-brand/20 transition-all cursor-pointer">
                Save Changes
            </button>
        </div>


    {{ form_end(form) }}
</div>
{% endblock %}
