{% extends 'dashboard/account/index.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block account_content %}
<div class="bg-white p-6 md:p-10 rounded-lg shadow-sm border border-border-color h-full animate-fadeIn">

    {# Header #}
    <div class="mb-8 border-b border-border-color pb-6">
        <h2 class="text-2xl font-black text-brand-dark uppercase tracking-tighter">Edit Profile</h2>
        <p class="text-sm font-bold text-gray uppercase tracking-widest mt-1">Update your personal information.</p>
    </div>

    {% form_theme form 'form/error_theme.html.twig' %}

    {{ form_start(form, {'attr': {'class': 'space-y-8', 'novalidate': 'novalidate'}}) }}

        {# --- AVATAR UPLOAD SECTION --- #}
        <div class="flex items-center gap-6 p-6 bg-app-bg border border-border-color rounded-2xl">
            <div class="shrink-0 relative">
                {% set avatarPath = 'images/default/default_avatar.jpg' %}

                {# Check if the entity has an existing avatar filename #}
                {% if form.vars.value.avatar %}
                     {% if is_granted('ROLE_ADMIN') %}
                          {% set avatarPath = 'uploads/admin/avatars/' ~ form.vars.value.avatar %}
                     {% elseif is_granted('ROLE_STAFF') %}
                          {% set avatarPath = 'uploads/staff/avatars/' ~ form.vars.value.avatar %}
                     {% endif %}
                {% endif %}

                <img
                    class="h-20 w-20 object-cover rounded-xl border border-border-color shadow-sm"
                    src="{{ asset(avatarPath) }}"
                    alt="Current profile photo"
                />
            </div>

            <div class="w-full">
                {{ form_label(form.avatar, 'Profile Photo', {'label_attr': {'class': 'block text-[10px] font-black text-gray uppercase tracking-widest mb-2'}}) }}

                <div class="flex items-center">
                    {{ form_widget(form.avatar, {'attr': {
                        'class': 'block w-full text-sm text-gray font-medium
                                  file:mr-4 file:py-2.5 file:px-6
                                  file:rounded-xl file:border-0
                                  file:text-[10px] file:font-black file:uppercase file:tracking-widest
                                  file:bg-brand file:text-white
                                  hover:file:bg-brand-dark file:transition-colors file:shadow-sm
                                  cursor-pointer'
                    }}) }}
                </div>
                {{ form_errors(form.avatar, {'attr': {'class': 'text-red-500 text-xs mt-1 font-bold'}}) }}
                <p class="mt-2 text-[10px] font-bold text-gray uppercase tracking-widest">JPG or PNG. Max size of 5MB.</p>
            </div>
        </div>

        {# --- NAME FIELDS --- #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-1">
                {{ form_label(form.firstName, 'First Name', {'label_attr': {'class': 'block text-[10px] font-black text-gray uppercase tracking-widest ml-1'}}) }}
                {{ form_widget(form.firstName, {'attr': {'class': 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all shadow-inner'}}) }}
                {{ form_errors(form.firstName, {'attr': {'class': 'text-red-500 text-xs mt-1 font-bold'}}) }}
            </div>

            <div class="space-y-1">
                {{ form_label(form.lastName, 'Last Name', {'label_attr': {'class': 'block text-[10px] font-black text-gray uppercase tracking-widest ml-1'}}) }}
                {{ form_widget(form.lastName, {'attr': {'class': 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl text-brand-dark font-bold text-sm focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition-all shadow-inner'}}) }}
                {{ form_errors(form.lastName, {'attr': {'class': 'text-red-500 text-xs mt-1 font-bold'}}) }}
            </div>
        </div>

        {# --- SUBMIT BUTTON --- #}
        <div class="pt-8 flex justify-end gap-3 border-t border-border-color">
            <a href="{{ path('app_account') }}" class="px-6 py-3.5 bg-app-bg text-dark-gray border border-border-color rounded-xl hover:bg-row-hover hover:text-brand-dark font-bold text-[10px] uppercase tracking-widest transition-all cursor-pointer">
                Cancel
            </a>
            <button type="submit" class="px-6 py-3.5 bg-brand text-white rounded-xl hover:bg-brand-dark font-bold text-[10px] uppercase tracking-widest shadow-md shadow-brand/20 transition-all cursor-pointer">
                Save Changes
            </button>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}
