{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}My Account{% endblock %}

{% block main_content %}

{# --- 1. SETUP VARIABLES (Determine Role & Avatar) --- #}
{% set avatarPath = 'images/default/default_avatar.jpg' %}
{% set userRole = 'User' %}
{% set profileName = app.user.userIdentifier %}

{% if is_granted('ROLE_ADMIN') and app.user.admin %}
    {% set userRole = 'Administrator' %}
    {% set profileName = app.user.admin.firstName ~ ' ' ~ app.user.admin.lastName %}
    {% if app.user.admin.avatar %}
        {% set avatarPath = 'uploads/admin/avatars/' ~ app.user.admin.avatar %}
    {% endif %}
{% elseif is_granted('ROLE_STAFF') and app.user.staff %}
    {% set userRole = 'Staff' %}
    {% set profileName = app.user.staff.firstName ~ ' ' ~ app.user.staff.lastName %}
    {% if app.user.staff.avatar %}
        {% set avatarPath = 'uploads/staff/avatars/' ~ app.user.staff.avatar %}
    {% endif %}
{% endif %}

{# --- 2. ROUTING HELPERS --- #}
{% set current_route = app.request.attributes.get('_route') %}
{% set is_profile_active = current_route in ['app_admin_account', 'app_staff_account'] %}
{% set is_security_active = current_route in ['app_admin_account_password', 'app_staff_account_password'] %}
{% set is_logs_active = current_route == 'app_activity_log_index' %}

{# --- 3. LAYOUT --- #}
<div class="animate-fadeIn max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row gap-8 items-start">

        {# Left Sidebar Navigation #}
        <aside class="w-full lg:w-80 bg-white p-8 rounded-2xl shadow-sm border border-border-color lg:sticky lg:top-24 shrink-0">

            {# PROFILE HEADER #}
            <div class="flex flex-col items-center text-center mb-8 pb-8 border-b border-border-color">
                <div class="relative w-24 h-24 mb-5">
                    <img
                        src="{{ asset(avatarPath) }}"
                        alt="Profile Picture"
                        class="w-full h-full rounded-2xl object-cover border border-border-color shadow-sm"
                    >
                    <span class="absolute -bottom-1 -right-1 w-4 h-4 bg-success border-2 border-white rounded-full shadow-sm"></span>
                </div>

                <h2 class="text-xl font-black text-brand-dark uppercase tracking-tighter">
                    {{ profileName }}
                </h2>
                <p class="text-xs font-bold text-gray mb-3">
                    {{ app.user.email }}
                </p>
                <span class="inline-block px-3 py-1 text-[9px] font-black text-brand bg-brand/10 rounded-sm border border-brand/20 uppercase tracking-[0.2em]">
                    {{ userRole }}
                </span>
            </div>

            {# NAVIGATION MENU #}
            <nav>
                <div class="mb-4 px-2">
                    <h3 class="text-[9px] font-black text-gray uppercase tracking-[0.3em]">Account Settings</h3>
                </div>

                <ul class="space-y-2">
                    {# Profile Link #}
                    <li>
                        <a href="{{ is_granted('ROLE_ADMIN') ? path('app_admin_account') : path('app_staff_account') }}"
                           class="flex items-center gap-3 px-4 py-3.5 rounded-xl transition-all text-xs font-bold uppercase tracking-widest border
                                  {{ is_profile_active ? 'bg-brand/10 text-brand border-brand/20 shadow-sm' : 'text-gray border-transparent hover:bg-row-hover hover:text-brand-dark hover:border-border-color' }}">
                            {{ ux_icon('lucide:user-circle', {class: 'w-4 h-4'}) }}
                            Profile Information
                        </a>
                    </li>

                    {# Security Link #}
                    <li>
                        <a href="{{ is_granted('ROLE_ADMIN') ? path('app_admin_account_password') : path('app_staff_account_password') }}"
                           class="flex items-center gap-3 px-4 py-3.5 rounded-xl transition-all text-xs font-bold uppercase tracking-widest border
                                  {{ is_security_active ? 'bg-brand/10 text-brand border-brand/20 shadow-sm' : 'text-gray border-transparent hover:bg-row-hover hover:text-brand-dark hover:border-border-color' }}">
                            {{ ux_icon('lucide:shield-check', {class: 'w-4 h-4'}) }}
                            Security Settings
                        </a>
                    </li>

                    {# Admin Only: System Logs #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="pt-6 mt-6 border-t border-border-color">
                             <div class="mb-4 px-2">
                                <h3 class="text-[9px] font-black text-gray uppercase tracking-[0.3em]">System</h3>
                            </div>
                        </li>
                        <li>
                             <a href="{{ path('app_activity_log_index') }}"
                                class="flex items-center gap-3 px-4 py-3.5 rounded-xl transition-all text-xs font-bold uppercase tracking-widest border
                                       {{ is_logs_active ? 'bg-brand/10 text-brand border-brand/20 shadow-sm' : 'text-gray border-transparent hover:bg-row-hover hover:text-brand-dark hover:border-border-color' }}">
                                {{ ux_icon('lucide:clipboard-list', {class: 'w-4 h-4'}) }}
                                Activity Logs
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        </aside>

        {# Right Content Area #}
        <main class="w-full flex-1">
            {% block account_content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
