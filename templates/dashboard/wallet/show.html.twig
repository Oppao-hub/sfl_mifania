{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Wallet Details{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# --- HEADER SECTION --- #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_dashboard_wallet_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:bg-brand/10 hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>

            <div class="flex flex-col gap-2">
                <h1 class="text-3xl md:text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    Wallet <span class="text-brand">#{{ wallet.id }}</span>
                </h1>

                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        Financial Asset
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Wallet Registry
                    </span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_dashboard_wallet_edit', { id: wallet.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Wallet
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '#',
                        name: 'Wallet #{{ wallet.id }}',
                        token: '{{ csrf_token('delete' ~ wallet.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div>
    </div>

        {# --- Main Card --- #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden dark:bg-mocha dark:border-gray-700 mb-3">

            {# Card Body: Details Grid #}
            <div class="p-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">

                    {# Left Side: Big Balance Display #}
                    <div class="bg-green-50 rounded-2xl p-6 border border-green-100 text-center md:text-left dark:bg-green-900/20 dark:border-green-800">
                        <label class="block text-xs font-bold text-green-600 uppercase tracking-wider mb-1 dark:text-green-400">Current Balance</label>
                        <div class="text-4xl font-extrabold text-green-700 font-mono tracking-tight dark:text-green-300">
                            ${{ wallet.balance|number_format(2) }}
                        </div>
                    </div>

                    {# Right Side: Other Details #}
                    <div class="space-y-6">
                        {# Wallet ID #}
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Wallet ID</label>
                            <div class="text-sm font-medium text-gray-900 dark:text-white">#{{ wallet.id }}</div>
                        </div>

                        {# Reward Points #}
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Reward Points</label>
                            <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-yellow-100 text-yellow-800 border border-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-300 dark:border-yellow-700">
                                <svg class="w-4 h-4 mr-1.5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                {{ wallet.rewardPoints|number_format }} PTS
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex gap-3 justify-end">
            {# Edit button #}
            <a href="{{ path('app_dashboard_wallet_edit', { id: wallet.id }) }}"
                class="px-4 py-2 bg-success text-white text-sm font-semibold rounded-xl hover:bg-success-hover transition">
                Edit
            </a>

            {# Delete form #}
            <a
                href="#"
                onclick="openDeleteModal({{ wallet.id }}, '{{ wallet.id }}', '{{ csrf_token('delete' ~ wallet.id) }}')"
                class="px-4 py-2 bg-danger text-white text-sm font-medium rounded-xl hover:bg-danger-hover transition"
            >
                Delete
            <a href="{{ path('app_dashboard_wallet_index') }}"
                class="px-4 py-2 bg-white border border-gray-300 text-gray-500 text-sm font-semibold rounded-xl hover:bg-row-hover transition">
                Back
            </a>
        </div>
</div>
{% endblock %}
