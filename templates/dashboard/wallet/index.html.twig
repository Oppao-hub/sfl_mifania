{% extends 'dashboard/dashboard.html.twig' %}
{% block title %}Wallet index{% endblock %}
{% block main_content %}
{% embed 'components/table/table.html.twig' with{
title: 'Wallets',
new_path: 'app_dashboard_wallet_new',
headers: ['ID', 'Owner', 'Balance', 'Reward Points', 'Actions'],
id: 'dashboard-table'
} %}
{% block rows %}
        {% for wallet in wallets %}
            <tr>
                <td class="border border-gray-300 px-4 py-2 text-sm">{{ wallet.id }}</td>
                <td class="border border-gray-300 px-4 py-2 text-sm">{{ wallet.customer.firstName }} {{ wallet.customer.lastName }}</td>
                <td class="border border-gray-300 px-4 py-2 text-sm">{{ wallet.balance }}</td>
                <td class="border border-gray-300 px-4 py-2 text-sm">{{ wallet.rewardPoints }}</td>
                <td class="border border-gray-300 py-3 px-4 text-sm text-center">
                    <div class="flex justify-center items-center gap-3">
                        <twig:ActionIcon
                            path="{{ path('app_dashboard_wallet_show', { id: wallet.id }) }}"
                            svgPath="M12 4.5C7 4.5 2.73 8 1 12c1.73 4 6 7.5 11 7.5s9.27-3.5 11-7.5c-1.73-4-6-7.5-11-7.5z M12 16a4 4 0 110-8 4 4 0 010 8z"
                            class="w-5 h-5 text-brand"
                            label="View"
                        />
                        <twig:ActionIcon
                            path="{{ path('app_dashboard_wallet_edit', { id: wallet.id }) }}" svgPath="M11 4H4a1 1 0 00-1 1v16a1 1 0 001 1h16a1 1 0 001-1v-7 M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"
                            class="w-5 h-5 text-brand"
                            label="Edit"
                        />
                        <button type="button"
                            @click="$dispatch('open-delete-modal', {
                                url: '{{ path('app_dashboard_wallet_delete', {id: wallet.id}) }}',
                                name: '{{ wallet.customer.firstName|e('js') }} {{ wallet.customer.lastName|e('js') }} Wallet',
                                token: '{{ csrf_token('delete' ~ wallet.id) }}'
                            })"
                            class="p-2 text-red-600 hover:text-danger hover:bg-red-50 bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer"
                            title="Delete">
                            {{ ux_icon('lucide:trash-2', {class: 'w-5 h-5'}) }}
                        </button>
                    </div>
                </td>
            </tr>
        {% endfor %}
{% endblock %}
{% endembed %}
{% endblock %}
