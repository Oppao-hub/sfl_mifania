{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Manifest: Log #{{ log.id }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">

        <div class="flex items-center gap-5">
            <a href="{{ path('app_activity_log_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:bg-brand/10 hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>

            <div class="flex flex-col gap-2">
                <h1 class="text-3xl md:text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    Audit Log <span class="text-brand">#{{ log.id }}</span>
                </h1>

                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        System Audit Trail
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Immutable Record
                    </span>
                </div>
            </div>
        </div>

        {# Right: Immutable Badge (No Edit/Delete actions) #}
        <div class="flex items-center gap-3">
             <div class="px-6 py-3.5 bg-success/10 text-success border border-success/20 text-[10px] font-black uppercase tracking-widest rounded-xl shadow-sm flex items-center gap-2">
                {{ ux_icon('lucide:shield-check', {class: 'w-4 h-4'}) }}
                Record Secured
            </div>
        </div>
    </div>

    {# --- MASTER UNIFIED CONTAINER --- #}
    <div class="bg-white rounded-3xl shadow-sm border border-border-color flex flex-col lg:flex-row overflow-hidden">

        {# Left Sidebar: Visuals & Core Status #}
        <div class="w-full lg:w-4/12 p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-border-color bg-app-bg/50 flex flex-col gap-8">

            <div class="flex items-center justify-between border-b border-border-color/50 pb-4">
                <span class="text-[10px] text-gray uppercase font-black tracking-widest italic">Data Integrity Status</span>
            </div>

            {# Audit Visual #}
            <div class="relative rounded-2xl overflow-hidden shadow-sm border border-border-color bg-white p-6 flex flex-col items-center justify-center aspect-square text-center">
                <div class="p-4 bg-success/10 rounded-full mb-4 border border-success/20 text-success">
                    {{ ux_icon('lucide:fingerprint', {class: 'w-12 h-12'}) }}
                </div>
                <h3 class="text-sm font-black text-brand-dark uppercase tracking-widest mb-1">Cryptographic Match</h3>
                <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray">Audit Verified</p>
            </div>

            {# Timestamp Block #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-3 flex items-center gap-2">
                    {{ ux_icon('lucide:clock', {class: 'w-3.5 h-3.5'}) }}
                    Action Timestamp
                </p>
                <div class="bg-white p-4 rounded-xl border border-border-color shadow-sm text-sm font-bold text-brand-dark font-mono">
                    {{ log.createdAt|date('M d, Y / H:i:s') }}
                </div>
            </div>
        </div>

        {# Right Column: Specifications & Logistics #}
        <div class="w-full lg:w-8/12 p-8 md:p-12 flex flex-col">

            {# Data Header #}
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-border-color pb-8">
                <div>
                    <h2 class="text-2xl font-black text-brand-dark tracking-tighter leading-tight uppercase">Action Specifications</h2>
                    <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1.5 italic">Detailed System Event Record</p>
                </div>

                <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color shadow-sm">
                    {{ ux_icon('lucide:clipboard-list', {class: 'w-5 h-5'}) }}
                </div>
            </div>

            {# Information Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Actor (User)</label>
                    <span class="text-base font-bold text-brand-dark tracking-tight">
                        {% if log.user %}
                            {{ log.user.userIdentifier }}
                        {% else %}
                            <span class="text-gray italic font-medium">System / Anonymous</span>
                        {% endif %}
                    </span>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Privilege Role</label>
                    <span class="inline-flex px-3 py-1.5 bg-brand/10 text-brand rounded-md text-[10px] font-black uppercase tracking-widest border border-brand/20 shadow-sm">
                        {{ log.role|default('N/A')|replace({'ROLE_': ''}) }}
                    </span>
                </div>

                <div class="md:col-span-2">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Action Taken</label>
                    <span class="text-2xl font-black text-brand-dark uppercase tracking-tighter">{{ log.action }}</span>
                </div>

                <div class="md:col-span-2">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-3">Target Data / Context</label>
                    <div class="text-sm font-medium text-brand-dark bg-app-bg p-6 rounded-xl border border-border-color leading-relaxed break-words shadow-inner font-mono">
                        {{ log.targetData|default('No additional context provided for this action.') }}
                    </div>
                </div>
            </div>

            {# Spacer to push archival metadata to bottom #}
            <div class="flex-grow"></div>

            {# Archival Metadata #}
            <div class="mt-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4 text-gray/40 border-t border-border-color pt-6">
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Event Type: <strong class="text-gray/60">System Security Log</strong>
                </div>
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Log Identity: #{{ log.id }}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
