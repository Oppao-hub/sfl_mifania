{% extends 'dashboard/account/index.html.twig' %}

{% block title %}System Activity Logs | Mifania{% endblock %}

{% block account_content %}
    {% embed 'components/table/table.html.twig' with {
        title: 'Activity Logs',
        icon: 'tabler:logs',
        headers: ['User / Actor', 'Action Taken', 'Target Data', 'Date' ,'Actions'],
    } %}
        {% block rows %}
            {% for log in logs %}
                <tr class="hover:bg-row-hover transition-colors group">

                    {# User Column #}
                    <td class="border-y border-border-color px-3 py-4 text-sm font-bold text-brand-dark tracking-tight">
                        {% if log.user %}
                            {{ log.user.userIdentifier }}
                        {% else %}
                            <span class="text-gray italic font-medium text-xs">System / Anonymous</span>
                        {% endif %}
                    </td>

                    <td class="border-y border-border-color px-3 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-brand">
                        {{ log.action }}
                    </td>
                    <td class="border-y border-border-color px-3 py-4">
                        <span class="block text-xs text-brand-dark/70 font-medium truncate max-w-[250px] xl:max-w-[400px]">
                            {{ log.targetData|default('—') }}
                        </span>
                    </td>
                    <td class="border-y border-border-color px-3 py-4">
                        <span class="block text-xs text-brand-dark/70 font-medium">{{ log.createdAt|date('M d, Y') }}</span>
                    </td>
                    <td class="border-y border-border-color px-3 py-4">
                        <div class="flex justify-center items-center gap-2">
                            <a href="{{ path('app_activity_log_show', {'id': log.id}) }}"
                               class="p-2.5 text-gray hover:text-brand bg-white border border-border-color rounded-xl hover:bg-brand/5 hover:border-brand/20 transition-all shadow-sm" title="View Audit Details">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="px-6 py-16 text-center border-y border-border-color bg-app-bg/50">
                        <div class="p-4 bg-white rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4 shadow-sm border border-border-color">
                            {{ ux_icon('lucide:search-x', {class: 'w-6 h-6 text-gray/40'}) }}
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-gray">
                            {% if searchQuery %}
                                No logs match your search criteria.
                            {% else %}
                                No activity logs found.
                            {% endif %}
                        </p>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
{% endblock %}
