{% form_theme form 'form/error_theme.html.twig' %}

{# 1. Centralized Boutique Styles #}
{% set label_style = 'text-[10px] uppercase font-black tracking-[0.2em] text-gray ml-1 block mb-2' %}
{% set input_base = 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none text-sm font-bold text-brand-dark transition-all placeholder:text-gray/50 shadow-inner' %}

{{ form_start(form, {'attr': {'id': 'staff-form', 'class': 'relative space-y-8', 'novalidate': 'novalidate'}}) }}

    {# --- STICKY HEADER --- #}
    <div class="sticky top-24 z-40 bg-white/90 backdrop-blur-md border border-border-color rounded-2xl p-6 shadow-sm flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-brand animate-pulse"></div>
            <div>
                {% set staff = form.vars.data %}
                <h1 class="text-xl font-black text-brand-dark tracking-tighter uppercase leading-none">
                    {{ staff.id ? staff.firstName ~ ' ' ~ staff.lastName : 'New Staff Record' }}
                </h1>
                <p class="text-[9px] text-gray mt-1 uppercase font-black tracking-[0.3em]">Staff Manifest #{{ staff.id|default('000') }}</p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <a href="{{ path('app_staff_index') }}"
               class="px-5 py-3 text-[10px] font-black uppercase tracking-widest text-gray border border-border-color bg-white hover:bg-row-hover hover:text-brand-dark rounded-xl transition-all">
                Discard
            </a>
            <button type="submit"
                    class="px-8 py-3 bg-brand text-white rounded-xl font-black text-[10px] uppercase tracking-[0.2em] shadow-md shadow-brand/20 hover:bg-brand-dark transition-all active:scale-95 cursor-pointer">
                {{ button_label|default('Commit Record') }}
            </button>
        </div>
    </div>

    {# --- MAIN FORM CARD --- #}
    <div class="bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">

        {# SECTION 1: Identity & Credentials #}
        <div class="p-8 md:p-10 border-b border-border-color">
            <div class="mb-10 flex items-center gap-3">
                <div class="p-2 bg-app-bg rounded-xl text-brand border border-border-color">
                    {{ ux_icon('lucide:user-cog', {class: 'w-5 h-5'}) }}
                </div>
                <h3 class="text-lg font-black text-brand-dark tracking-tighter uppercase">Staff Credentials</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    {{ form_label(form.firstName, null, {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.firstName, {'attr': {'class': input_base, 'placeholder': 'First Name'}}) }}
                    {{ form_errors(form.firstName) }}
                </div>
                <div>
                    {{ form_label(form.lastName, null, {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.lastName, {'attr': {'class': input_base, 'placeholder': 'Last Name'}}) }}
                    {{ form_errors(form.lastName) }}
                </div>
                <div class="md:col-span-2">
                    {{ form_label(form.email, null, {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.email, {'attr': {'class': input_base, 'placeholder': 'staff@mifania.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                {% if form.password is defined %}
                    <div class="md:col-span-2">
                        {{ form_label(form.password, null, {'label_attr': {'class': label_style}}) }}
                        {{ form_widget(form.password, {'attr': {'class': input_base}}) }}
                        <p class="text-[9px] uppercase font-bold text-terracotta tracking-widest mt-3 ml-1 italic opacity-80">Security: Passwords are hashed via Mifania Archival Protocol</p>
                    </div>
                {% endif %}

                <div>
                    {{ form_label(form.status, null, {'label_attr': {'class': label_style}}) }}
                    {{ form_widget(form.status, {'attr': {'class': input_base}}) }}
                    {{ form_errors(form.status) }}
                </div>

                <div class="flex flex-col">
                    {{ form_label(form.isVerified, null, {'label_attr': {'class': label_style}}) }}
                    <div class="flex items-center h-full">
                        {{ form_widget(form.isVerified, {'attr': {'class': 'w-5 h-5 rounded border-gray-300 text-brand focus:ring-brand'}}) }}
                        <span class="ml-3 text-[10px] font-black uppercase text-brand-dark">Verified Account</span>
                    </div>
                    {{ form_errors(form.isVerified) }}
                </div>
            </div>
        </div>

        {# SECTION 2: Media & Avatar #}
        <div class="p-8 md:p-10 bg-app-bg grid grid-cols-1 md:grid-cols-12 gap-10 items-center">
            {% if staff.avatar is defined and staff.avatar %}
                <div class="md:col-span-3">
                    <label class="{{ label_style }}">Current Visual ID</label>
                    <div class="p-1 border border-border-color rounded-2xl bg-white mt-2 shadow-sm">
                        <img src="{{ asset('uploads/staff/avatars/' ~ staff.avatar) }}"
                             class="w-full aspect-square object-cover rounded-xl">
                    </div>
                </div>
            {% endif %}

            <div class="{{ staff.avatar is defined and staff.avatar ? 'md:col-span-9' : 'md:col-span-12' }}">
                <label class="{{ label_style }}">Update Staff Imagery</label>
                <div class="bg-white border-2 border-dashed border-border-color rounded-2xl p-8 hover:border-brand/30 transition-all cursor-pointer">
                    {{ form_widget(form.avatar, {
                        'attr': {
                            'class': 'block w-full text-xs text-gray
                                      file:mr-6 file:py-2.5 file:px-6
                                      file:rounded-xl file:border-0
                                      file:text-[10px] file:font-black file:uppercase file:tracking-widest
                                      file:bg-brand/10 file:text-brand hover:file:bg-brand hover:file:text-white file:transition-colors cursor-pointer'
                        }
                    }) }}
                    {{ form_errors(form.avatar) }}
                </div>
            </div>
        </div>

        {# SECTION 3: ACCOUNT SECURITY (Reset Actions) #}
        {% if staff.id is defined and staff.id and staff.user is defined %}
            <div class="p-8 border-t border-border-color flex justify-start bg-white">
                <button type="button"
                    @click="$dispatch('open-confirm', {
                        title: 'Reset Credentials',
                        message: 'Are you sure you want to send an archival credential reset to this staff member? They will receive an email to reset their password.',
                        actionUrl: '{{ path('app_staff_reset_password', {'id': staff.user.id}) }}',
                        confirmText: 'Confirm Reset',
                        isDanger: false
                    })"
                    class="group flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-warning hover:text-warning transition-all cursor-pointer">
                    <div class="p-2.5 bg-warning/10 rounded-xl group-hover:bg-warning group-hover:text-white transition-all shadow-sm">
                        {{ ux_icon('lucide:refresh-cw', {class: 'w-4 h-4'}) }}
                    </div>
                    Reset Password
                </button>
            </div>
        {% endif %}
    </div>

{{ form_end(form) }}
