{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Staff{% endblock %}

{% block main_content %}
<div class="mx-1 min-h-screen bg-white p-8 shadow-md">
    <div class="container mx-auto p-4 md:px-8 lg:px-12">
    <h1 class="text-2xl font-semibold text-gray-800 mb-6">Profile</h1>
    <div class="bg-white shadow-lg p-6 mb-6 flex justify-center border border-gray-100">
        <div class="flex items-center">
            <img class="w-48 h-48 rounded-md object-cover border-2 border-mocha-100"
                src="{{ staff.avatar ? asset('uploads/staff/avatars/' ~ staff.avatar) : asset('uploads/default/default-avatar.jpg') }}"
                alt="{{ staff.firstName }}'s Avatar"
            >
        </div>
    </div>

    <!-- Personal Information Card -->
    <div class="bg-white shadow-lg rounded-lg p-6 mb-6 border border-gray-100">
        <div class="flex justify-between items-center mb-4 border-b pb-4">
            <h2 class="text-xl font-semibold text-gray-800">Personal Information</h2>
        </div>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 text-sm">
            <div>
                <dt class="font-medium text-gray-500">First Name</dt>
                <dd class="mt-1 text-gray-900 text-base font-medium">{{ staff.firstName }}</dd>
            </div>
            <div>
                <dt class="font-medium text-gray-500">Last Name</dt>
                <dd class="mt-1 text-gray-900 text-base font-medium">{{ staff.lastName }}</dd>
            </div>
            <div>
                <dt class="font-medium text-gray-500">Email address</dt>
                <dd class="mt-1 text-gray-900 text-base font-medium">{{ staff.user.email ?: 'N/A' }}</dd>
            </div>
        </dl>
    </div>

    <!-- Address Card -->
    <div class="bg-white shadow-lg rounded-lg p-6 mb-6 border border-gray-100">
        <div class="flex justify-between items-center mb-4 border-b pb-4">
            <h2 class="text-xl font-semibold text-gray-800">Geographic Information</h2>
        </div>
    </div>

    <div class="bg-white shadow-lg rounded-lg p-6 mb-6 border border-gray-100">
        <div class="flex justify-between items-center mb-4 border-b pb-4">
            <h2 class="text-xl font-semibold text-gray-800">Account Information</h2>
        </div>
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 text-sm">
            <div>
                <dt class="font-medium text-gray-500">staff Since</dt>
                <dd class="mt-1 text-gray-900 text-base font-medium">{{ staff.createdAt|date('F jS, Y') }}</dd>
            </div>
        </dl>
    </div>

    <div class="flex gap-3 justify-end">
        {# Edit button #}
        <a href="{{ path('app_staff_edit', { id: staff.id }) }}"
            class="px-4 py-2 bg-success text-white text-sm font-semibold rounded-xl hover:bg-success-hover transition">
            Edit
        </a>

        {# Delete form #}
        <a
            href="#"
            onclick="openDeleteModal({{ staff.id }}, '{{ staff.firstName ~ ' ' ~ staff.lastName|e('js') }}', '{{ csrf_token('delete' ~ staff.id) }}')"
            class="px-4 py-2 bg-danger text-white text-sm font-medium rounded-xl hover:bg-danger-hover transition"
        >
            Delete
        <a href="{{ path('app_staff_index') }}"
            class="px-4 py-2 bg-white border border-gray-300 text-gray-500 text-sm font-semibold rounded-xl hover:bg-row-hover transition">
            Back
        </a>
    </div>
</div>
{% endblock %}
