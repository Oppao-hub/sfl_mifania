{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Staff Management{% endblock %}

{% block main_content %}
    {% embed 'components/table/table.html.twig' with {
        title: 'Manage Staffs',
        new_path: 'app_staff_new',
        headers: ['ID', 'First Name', 'Last Name', 'Email', 'Account Status', 'Actions'],
        id: 'dashboard-table'
    } %}

        {% block rows %}
            {% for staff in staffs %}
                <tr class="hover:bg-row-hover transition-colors group">
                    <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray">#{{ staff.id }}</td>
                    <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-brand-dark">{{ staff.firstName }}</td>
                    <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-brand-dark">{{ staff.lastName }}</td>
                    <td class="border-y border-border-color px-4 py-3 text-sm font-medium text-gray">{{ staff.user.email }}</td>

                    <td class="border-y border-border-color px-4 py-3 text-sm text-center">
                        <form method="post" action="{{ path('app_admin_user_toggle_status', {'id': staff.user.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ staff.user.id) }}">

                            <select name="status"
                                    @change="$dispatch('open-status-modal', {
                                        url: '{{ path('app_admin_user_toggle_status', {id: staff.user.id}) }}',
                                        email: '{{ staff.user.email|e('js') }}',
                                        currentStatus: '{{ staff.user.status.value }}',
                                        token: '{{ csrf_token('toggle' ~ staff.user.id) }}'
                                    }); this.value = '{{ staff.user.status.value }}';"
                                    class="text-[10px] font-black uppercase tracking-widest py-1.5 pl-3 pr-8 rounded-lg cursor-pointer outline-none transition-colors border
                                    {% if staff.user.status.value == 'Active' %}
                                        text-success bg-success/10 border-success/20 hover:bg-success/20
                                    {% else %}
                                        text-danger bg-danger/10 border-danger/20 hover:bg-danger/20
                                    {% endif %}">

                                <option value="Active" {% if staff.user.status.value == 'Active' %}selected{% endif %}>Active</option>
                                <option value="Deactivated" {% if staff.user.status.value != 'Active' %}selected{% endif %}>Deactivated</option>
                            </select>
                        </form>
                    </td>

                    <td class="border-y border-border-color py-3 px-4 text-center">
                        <div class="flex justify-center items-center gap-2">
                            <a href="{{ path('app_staff_show', { id: staff.id }) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>

                            <a href="{{ path('app_staff_edit', { id: staff.id }) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>

                            <button type="button"
                                @click="$dispatch('open-delete-modal', {
                                    url: '{{ path('app_staff_delete', {id: staff.id}) }}',
                                    name: '{{ staff.firstName|e('js') }} {{ staff.lastName|e('js') }}',
                                    token: '{{ csrf_token('delete' ~ staff.id) }}'
                                })"
                                class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer">
                                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                            </button>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
{% endblock %}
