{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Category Registry | Mifania{% endblock %}

{% block main_content %}
<div class="animate-fadeIn">
    {% embed 'components/table/table.html.twig' with {
        title: 'Taxonomy Hierarchy',
        icon: 'lucide:folder-tree',
        entity_name: 'Category',
        total_count: categories|length,
        new_path: 'app_category_new',
        headers: ['Manifest', 'Name', 'Description', 'Actions']
    } %}
        {% block rows %}
            {% for category in categories %}
                <tr class="group hover:bg-row-hover transition-colors">

                    <td class="border-y border-border-color px-6 py-4 text-[10px] uppercase font-black tracking-[0.2em] text-gray">
                        #{{ category.id }}
                    </td>

                    <td class="border-y border-border-color px-6 py-4 text-sm font-black text-brand-dark tracking-tighter uppercase">
                        {{ category.name }}
                    </td>

                    <td class="border-y border-border-color px-6 py-4 text-xs font-medium text-gray">
                        <span class="block max-w-[200px] truncate">
                            {{ category.description|default('—') }}
                        </span>
                    </td>

                    <td class="border-y border-border-color px-6 py-4">
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_category_show', {'id': category.id}) }}"
                               class="p-2.5 text-gray hover:text-brand bg-white border border-border-color rounded-xl hover:bg-brand/5 hover:border-brand/20 transition-all shadow-sm"
                               title="View Details">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>

                            <a href="{{ path('app_category_edit', {'id': category.id}) }}"
                               class="p-2.5 text-gray hover:text-brand bg-white border border-border-color rounded-xl hover:bg-brand/5 hover:border-brand/20 transition-all shadow-sm"
                               title="Edit Category">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <button type="button"
                                    @click.stop="$dispatch('open-delete-modal', {
                                        url: '{{ path('app_category_delete', {id: category.id}) }}',
                                        name: 'Category: {{ category.name|e('js') }}',
                                        token: '{{ csrf_token('delete' ~ category.id) }}'
                                    })"
                                    class="p-2.5 text-danger/70 hover:text-danger bg-white border border-border-color rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all shadow-sm cursor-pointer"
                                    title="Delete Category">
                                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                                </button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                {# Empty State #}
                <tr>
                    <td colspan="5" class="px-6 py-16 text-center border-y border-border-color bg-app-bg/50">
                        <div class="p-4 bg-white rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4 shadow-sm border border-border-color">
                            {{ ux_icon('lucide:folder-tree', {class: 'w-6 h-6 text-gray/40'}) }}
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-gray">No Categories Found</p>
                        <p class="text-xs text-gray/60 mt-2 font-medium">Establish your first master category to organize the store.</p>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
