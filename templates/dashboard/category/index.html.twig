{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Category Management{% endblock %}

{% block main_content %}
    {% embed 'components/table/table.html.twig' with {
        title: 'Manage Categories',
        new_path: 'app_dashboard_category_new',
        headers: ['ID', 'Name', 'Description', 'Created At', 'Actions'],
        id: 'dashboard-table'
    } %}
        {% block rows %}
            {% for category in categories %}
                <tr class="hover:bg-row-hover transition-colors">
                    <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray">#{{ category.id }}</td>
                    <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-brand-dark">{{ category.name }}</td>
                    <td class="border-y border-border-color px-4 py-3 text-sm font-medium text-gray truncate max-w-xs">{{ category.description|default('—') }}</td>
                    <td class="border-y border-border-color px-4 py-3 text-xs font-bold text-gray">{{ category.createdAt ? category.createdAt|date('M d, Y') : 'N/A' }}</td>

                    <td class="border-y border-border-color py-3 px-4 text-sm text-center">
                        <div class="flex justify-center items-center gap-2">
                            <a href="{{ path('app_dashboard_category_show', {'id': category.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>
                            <a href="{{ path('app_dashboard_category_edit', {'id': category.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>
                            <button type="button"
                                @click="$dispatch('open-delete-modal', {
                                    url: '{{ path('app_category_delete', {id: category.id}) }}',
                                    name: 'Category: {{ category.name|e('js') }}',
                                    token: '{{ csrf_token('delete' ~ category.id) }}'
                                })"
                                class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer">
                                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                            </button>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
{% endblock %}
