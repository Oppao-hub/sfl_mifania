{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Edit Category: {{ category.name|default('Unnamed Category') }}{% endblock %}

{% block main_content %}
{# This structure now exactly matches the product edit template for consistent styling #}
<div class="mx-1 min-h-screen bg-white p-8 mb-1 shadow-md">
    {# Assuming 'category' object is passed to the template #}
    <h1 class="text-2xl font-bold text-brand mb-6">
        Edit Category: {{ category.name|default('Unnamed Category') }}
    </h1>

    {{ include('dashboard/category/_form.html.twig', {
        form: form,
        button_label: 'Update Category',
        button_class: 'cursor-pointer px-4 py-2 bg-success text-white text-sm font-semibold rounded-xl hover:bg-success-hover'
    }) }}

</div>
{% endblock %}
