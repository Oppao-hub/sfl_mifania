{# templates/dashboard/admin/show.html.twig #}
{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Admin: {{ admin.firstName }} {{ admin.lastName }}{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_admin_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ admin.firstName }} <span class="text-brand">{{ admin.lastName }}</span>
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Manifest #{{ admin.id }}</span>
                    <span class="px-2 py-0.5 bg-app-bg text-gray rounded-md text-[10px] font-bold uppercase tracking-tighter border border-border-color">System Authority</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_admin_edit', { id: admin.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2">
                {{ ux_icon('lucide:shield-check', {class: 'w-4 h-4'}) }}
                Modify Access
            </a>
            <button type="button"
                @click="$dispatch('open-delete-modal', {
                    url: '{{ path('app_admin_delete', {id: admin.id}) }}',
                    name: '{{ admin.firstName|e('js') }} {{ admin.lastName|e('js') }}',
                    token: '{{ csrf_token('delete' ~ admin.id) }}'
                })"
                class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                Void Authority
            </button>
        </div>
    </div>

    {# 2. QUICK STATS SUMMARY #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        {% macro quickStat(label, value, icon, colorClass = 'text-brand') %}
            <div class="bg-white p-6 rounded-2xl border border-border-color shadow-sm flex items-start gap-4">
                <div class="p-3 bg-app-bg rounded-xl {{ colorClass }} border border-border-color">
                    {{ ux_icon(icon, {class: 'w-5 h-5'}) }}
                </div>
                <div>
                    <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-1.5 leading-none">{{ label }}</p>
                    <div class="text-sm font-bold text-brand-dark leading-tight">{{ value|raw }}</div>
                </div>
            </div>
        {% endmacro %}

        {{ _self.quickStat('Access Email', admin.user.email, 'lucide:mail') }}

        {# Dynamic Status Stat #}
        {% set statusLabel = admin.user.status.value|default('Unknown') %}
        {% set statusColor = admin.user.status.value == 'Active' ? 'text-emerald-500' : 'text-rose-500' %}
        {{ _self.quickStat('Operational Status',
            '<span class="flex items-center gap-1.5 ' ~ statusColor ~ '">' ~
            '<span class="w-1.5 h-1.5 rounded-full bg-current ' ~ (admin.user.status.value == 'Active' ? 'animate-pulse' : '') ~ '"></span>' ~
            statusLabel ~ '</span>',
            'lucide:activity', statusColor)
        }}

        {{ _self.quickStat('Authority Since', admin.createdAt|date('M d, Y'), 'lucide:calendar') }}
    </div>

    {# 3. MAIN CONTENT GRID #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        {# Left Column: Identity Card #}
        <div class="lg:col-span-8 bg-white rounded-2xl border border-border-color shadow-sm overflow-hidden">
            <div class="p-8 border-b border-border-color flex items-center gap-3">
                <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color">
                    {{ ux_icon('lucide:fingerprint', {class: 'w-5 h-5'}) }}
                </div>
                <h2 class="text-lg font-black text-brand-dark tracking-tighter uppercase">Identity Specifications</h2>
            </div>

            <div class="p-8 md:p-10">
                <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                    {% macro manifestRow(label, value) %}
                        <div>
                            <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">{{ label }}</dt>
                            <dd class="text-base font-bold text-brand-dark">{{ value|default('—') }}</dd>
                        </div>
                    {% endmacro %}

                    {{ _self.manifestRow('Administrative First Name', admin.firstName) }}
                    {{ _self.manifestRow('Administrative Last Name', admin.lastName) }}
                    <div class="md:col-span-2">
                        {{ _self.manifestRow('Official Communication Channel', admin.user.email) }}
                    </div>
                </dl>
            </div>
        </div>

        {# Right Column: Visual Reference & Audit #}
        <div class="lg:col-span-4 space-y-8">

            {# Visual Profile Reference #}
            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-sm">
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-6 text-center">Visual ID Reference</p>
                <div class="p-1 border border-border-color rounded-2xl mx-auto w-44 bg-app-bg shadow-inner">
                    <img class="w-full aspect-square rounded-xl object-cover hover:scale-[1.02] transition-transform duration-500"
                         src="{{ admin.avatar ? asset('uploads/admin/avatars/' ~ admin.avatar) : asset('uploads/default/default-avatar.jpg') }}"
                         alt="Admin Visual">
                </div>
            </div>

            {# Audit Trail Section #}
            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-sm">
                <h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray mb-6 border-b border-border-color pb-4">Audit Record</h3>
                <div class="space-y-6">
                    {# Onboarding Date #}
                    <div>
                        <p class="text-[9px] font-black uppercase tracking-widest text-gray mb-1.5">Onboarding Date</p>
                        <p class="text-sm font-bold text-brand-dark">{{ admin.createdAt|date('F d, Y') }}</p>
                    </div>

                    {# Verification Status #}
                    <div>
                        <p class="text-[9px] font-black uppercase tracking-widest text-gray mb-1.5">Identity Verification</p>
                        {% if admin.user.isVerified %}
                            <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-100 rounded-md text-[10px] font-black text-emerald-600 uppercase tracking-widest">
                                {{ ux_icon('lucide:badge-check', {class: 'w-4 h-4'}) }}
                                Cleared / Verified
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-amber-50 border border-amber-100 rounded-md text-[10px] font-black text-amber-600 uppercase tracking-widest">
                                {{ ux_icon('lucide:shield-alert', {class: 'w-4 h-4'}) }}
                                Pending Review
                            </span>
                        {% endif %}
                    </div>

                    {# Account Role #}
                    <div>
                        <p class="text-[9px] font-black uppercase tracking-widest text-gray mb-1.5">Account Role</p>
                        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-brand/10 border border-brand/20 rounded-md text-[10px] font-black text-brand uppercase tracking-widest">
                            <span class="w-1.5 h-1.5 bg-brand rounded-full"></span>
                            Full Administrator
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
