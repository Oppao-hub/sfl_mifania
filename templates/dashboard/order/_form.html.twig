{% form_theme form 'form/error_theme.html.twig' %}

{% set label_style = 'text-[10px] uppercase font-black tracking-[0.2em] text-gray ml-1 block mb-2' %}
{% set input_base = 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none text-sm font-bold text-brand-dark transition-all' %}
{% set readonly_base = 'w-full px-4 py-3.5 bg-gray/5 border border-border-color rounded-xl text-sm font-black text-gray/60 cursor-not-allowed' %}
{% set select_style = 'boutique-select ' ~ input_base %}

{# --- MACRO FOR ORDER ITEM ROW --- #}
{% macro print_order_item_row(itemForm, label_style, input_base, readonly_base, select_style) %}
    <div class="order-item-row group animate-fadeIn mb-4 p-6 border border-border-color rounded-2xl bg-white shadow-sm hover:shadow-md transition-all flex flex-col lg:flex-row items-start lg:items-end gap-6">

        <div class="flex-grow w-full">
            <label class="{{ label_style }}">Piece Selection</label>
            {{ form_widget(itemForm.product, {'attr': {'class': select_style ~ ' item-product-select'}}) }}
            {{ form_errors(itemForm.product) }}
        </div>

        <div class="w-full lg:w-24">
            <label class="{{ label_style }} text-center lg:ml-0">Qty</label>
            {{ form_widget(itemForm.quantity, {'attr': {'class': input_base ~ ' text-center item-quantity'}}) }}
            {{ form_errors(itemForm.quantity) }}
        </div>

        <div class="w-full lg:w-32">
            <label class="{{ label_style }}">Unit Value</label>
            {{ form_widget(itemForm.price, {'attr': {'class': readonly_base ~ ' item-price', 'readonly': true}}) }}
        </div>

        <div class="w-full lg:w-40">
            <label class="{{ label_style }}">Line Total</label>
            {{ form_widget(itemForm.subtotal, {'attr': {'class': readonly_base ~ ' item-subtotal text-right font-mono', 'readonly': true}}) }}
        </div>

        <button type="button" class="remove-item-btn p-3.5 bg-white border border-danger/20 text-danger rounded-xl hover:bg-danger/10 transition-all active:scale-95 cursor-pointer shadow-sm" aria-label="Remove item">
            {{ ux_icon('lucide:trash-2', {class: 'w-5 h-5'}) }}
        </button>
    </div>
{% endmacro %}

{{ form_start(form, {'attr': {'id': 'order-form', 'class': 'relative space-y-8', 'novalidate': 'novalidate'}}) }}

    {# --- FIXED STICKY HEADER --- #}
    <div class="sticky top-24 z-40 bg-white/90 backdrop-blur-md border border-border-color rounded-2xl p-6 shadow-sm flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-brand animate-pulse"></div>
            <div>
                <h1 class="text-xl font-black text-brand-dark tracking-tighter uppercase leading-none">
                    Order <span class="text-brand">#{{ form.vars.value.id|default('New') }}</span>
                </h1>
                <p class="text-[9px] text-gray mt-1 uppercase font-black tracking-[0.3em]">Collection Manifest</p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <a href="{{ path('app_order_index') }}"
               class="px-5 py-3 text-[10px] font-black uppercase tracking-widest text-gray border border-border-color bg-white hover:bg-row-hover hover:text-brand-dark rounded-xl transition-all cursor-pointer">
                Discard
            </a>
            <button type="submit"
                    class="px-8 py-3 bg-brand text-white rounded-xl font-black text-[10px] uppercase tracking-[0.2em] shadow-md shadow-brand/20 hover:bg-brand-dark transition-all active:scale-95 cursor-pointer">
                {{ button_label|default('Save Manifest') }}
            </button>
        </div>
    </div>

    {# --- MAIN FORM CARD --- #}
    <div class="bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">

        {# SECTION 1: Credentials #}
        <div class="p-8 md:p-10 border-b border-border-color bg-app-bg">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    {{ form_label(form.customer, null, { label_attr: {'class': label_style} })}}
                    {{ form_widget(form.customer, {'attr': {'class': select_style}}) }}
                    {{ form_errors(form.customer) }}
                </div>
                {% if form.orderDate is defined %}
                    <div class="space-y-2">
                        {{ form_label(form.orderDate, null, { label_attr: {'class': label_style} }) }}
                        {{ form_widget(form.orderDate, {'attr': {'class': input_base}}) }}
                        {{ form_errors(form.orderDate) }}
                    </div>
                {% endif %}
            </div>
        </div>

        {# SECTION 2: Items Manifest (Dynamic Collection) #}
        <div class="p-8 md:p-10 border-b border-border-color">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-8 gap-4">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color">
                        {{ ux_icon('lucide:package', {class: 'w-5 h-5'}) }}
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-brand-dark uppercase tracking-[0.2em] leading-none">Line Items</h3>
                        <p class="text-[9px] text-gray mt-1.5 uppercase font-bold tracking-widest">Product distribution</p>
                    </div>
                </div>

                <button type="button" id="add-item-btn"
                        class="group px-6 py-3 bg-white text-brand text-[10px] font-black uppercase tracking-[0.2em] rounded-xl border border-border-color hover:bg-brand/5 hover:border-brand/20 transition-all flex items-center gap-2 active:scale-95 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:plus', {class: 'w-4 h-4 transition-transform group-hover:rotate-90'}) }}
                    Add Piece
                </button>
            </div>

            <div id="order-items-fields"
                data-prototype="{{ _self.print_order_item_row(form.orderItems.vars.prototype, label_style, input_base, readonly_base)|e('html_attr') }}"
                data-widget-counter="{{ form.orderItems|length }}"
                class="space-y-6">

                {% if form.orderItems|length > 0 %}
                    {% for item in form.orderItems %}
                        {{ _self.print_order_item_row(item, label_style, input_base, readonly_base) }}
                    {% endfor %}
                {% else %}
                    <div class="text-center py-16 border-2 border-dashed border-border-color rounded-2xl bg-app-bg">
                        <div class="p-4 bg-white rounded-full w-14 h-14 flex items-center justify-center mx-auto mb-4 shadow-sm border border-border-color">
                            {{ ux_icon('lucide:package-open', {class: 'w-6 h-6 text-gray/50'}) }}
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-[0.2em] text-gray">No pieces added to this manifest yet</p>
                    </div>
                {% endif %}
            </div>
        </div>

        {# SECTION 3: Financial Settlement #}
        <div class="p-8 md:p-10 border-b border-border-color grid grid-cols-1 md:grid-cols-3 gap-8 bg-app-bg">
            <div>
                {{ form_label(form.totalAmount, null, { label_attr: {'class': label_style} }) }}
                <div class="relative group">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray font-black group-focus-within:text-brand transition-colors">₱</span>
                    {{ form_widget(form.totalAmount, {'attr': {'class': readonly_base ~ ' pl-10 text-lg font-black text-brand-dark bg-white shadow-sm', 'readonly': true}}) }}
                </div>
            </div>
            <div class="space-y-2">
                {{ form_label(form.paymentMethod, null, { label_attr: {'class': label_style} }) }}
                {{ form_widget(form.paymentMethod, {'attr': {'class': select_style ~ ' bg-white shadow-sm'}}) }}
            </div>
            <div class="space-y-2">
                {{ form_label(form.paymentStatus, null, { label_attr: {'class': label_style} }) }}
                {{ form_widget(form.paymentStatus, {'attr': {'class': select_style ~ ' bg-white shadow-sm'}}) }}
            </div>
        </div>

        {# SECTION 4: Processing Status & Loyalty #}
        <div class="p-8 md:p-10 grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
                {{ form_label(form.orderStatus, null, { label_attr: {'class': label_style} }) }}
                {{ form_widget(form.orderStatus, {'attr': {'class': select_style}}) }}
            </div>
            <div>
                {{ form_label(form.rewardPoints, 'Loyalty Points Earned', { label_attr: {'class': label_style} }) }}
                <div class="relative">
                    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-terracotta">{{ ux_icon('lucide:sparkles', {class: 'w-4 h-4'}) }}</div>
                    {{ form_widget(form.rewardPoints, {'attr': {'class': readonly_base ~ ' pl-12 text-terracotta', 'readonly': true}}) }}
                </div>
                <p class="text-[9px] uppercase font-bold text-gray tracking-widest mt-2 ml-1 italic leading-none">Credited upon manifest completion</p>
            </div>
        </div>
    </div>

{{ form_end(form) }}

<script src="{{ asset('js/order_calculations.js') }}" defer></script>
