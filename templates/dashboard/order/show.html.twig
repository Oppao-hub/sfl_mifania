{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Manifest: Order #{{ order.id }}{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_order_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    Order <span class="text-brand">#{{ order.id }}</span>
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Electronic Manifest</span>
                    <span class="px-2 py-0.5 bg-app-bg text-gray rounded-md text-[10px] font-bold uppercase tracking-tighter border border-border-color">Processed: {{ order.createdAt|date('M d, Y') }}</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_order_edit', { id: order.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Manifest
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click="$dispatch('open-delete-modal', {
                        url: '{{ path('app_order_delete', {id: order.id}) }}',
                        name: 'Order #{{ order.id }}',
                        token: '{{ csrf_token('delete' ~ order.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div> {# End of flex items-center gap-3 #}
    </div>

    {# 2. SUMMARY DASHBOARD GRID #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        {% macro detailCard(label, value, icon, color='text-brand-dark') %}
            <div class="bg-white p-6 rounded-2xl border border-border-color shadow-sm flex items-start gap-4">
                <div class="p-3 bg-app-bg rounded-xl text-brand border border-border-color">
                    {{ ux_icon(icon, {class: 'w-5 h-5'}) }}
                </div>
                <div>
                    <p class="text-[9px] font-black uppercase tracking-[0.2em] text-gray mb-1.5 leading-none">{{ label }}</p>
                    <p class="text-sm font-bold {{ color }} leading-tight">{{ value|default('N/A') }}</p>
                </div>
            </div>
        {% endmacro %}

        {{ _self.detailCard('Customer Record', order.customer ? order.customer.firstName ~ ' ' ~ order.customer.lastName : 'Guest Client', 'lucide:user') }}
        {{ _self.detailCard('Financial Total', '₱' ~ order.totalAmount|number_format(2), 'lucide:banknote', 'text-brand') }}

        {# Custom Status Badge #}
        <div class="bg-white p-6 rounded-2xl border border-border-color shadow-sm flex items-start gap-4">
            <div class="p-3 bg-app-bg rounded-xl text-brand border border-border-color">
                {{ ux_icon('lucide:package-check', {class: 'w-5 h-5'}) }}
            </div>
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.2em] text-gray mb-1.5 leading-none">Order Status</p>
                <span class="text-[10px] font-black uppercase tracking-widest
                    {% if order.orderStatus.value == 'Completed' %} text-success {% elseif order.orderStatus.value == 'Cancelled' %} text-danger {% else %} text-warning {% endif %}">
                    {{ order.orderStatus.value }}
                </span>
            </div>
        </div>

        {{ _self.detailCard('Loyalty Points', order.rewardPoints|default(0) ~ ' Credited', 'lucide:sparkles', 'text-terracotta') }}
    </div>

    {# 3. DETAILED LOGISTICS GRID #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

        {# Left: Line Items Table #}
        <div class="lg:col-span-8 bg-white rounded-2xl border border-border-color shadow-sm overflow-hidden">
            <div class="p-8 border-b border-border-color flex justify-between items-center bg-app-bg">
                <h2 class="text-lg font-black text-brand-dark tracking-tighter uppercase flex items-center gap-3">
                    {{ ux_icon('lucide:list-ordered', {class: 'w-5 h-5 text-brand'}) }}
                    Order Inventory
                </h2>
                <span class="px-3 py-1.5 bg-white text-gray rounded-md text-[9px] font-black tracking-widest border border-border-color uppercase shadow-sm">
                    {{ order.orderItems|length }} SKUs
                </span>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white border-b border-border-color text-[10px] font-black uppercase tracking-[0.2em] text-gray">
                            <th class="px-8 py-4">Article</th>
                            <th class="px-8 py-4 text-center">Qty</th>
                            <th class="px-8 py-4 text-right">Unit Value</th>
                            <th class="px-8 py-4 text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-color">
                        {% for item in order.orderItems %}
                            <tr class="hover:bg-row-hover transition-colors bg-white">
                                <td class="px-8 py-5">
                                    <span class="text-sm font-bold text-brand-dark block">{{ item.product.name }}</span>
                                    <span class="text-[9px] text-gray font-black uppercase tracking-tighter">REF: #{{ item.product.id }}</span>
                                </td>
                                <td class="px-8 py-5 text-center text-sm font-bold text-brand-dark">
                                    {{ item.quantity }}
                                </td>
                                <td class="px-8 py-5 text-right text-sm font-bold text-gray italic">
                                    ₱{{ item.price|number_format(2) }}
                                </td>
                                <td class="px-8 py-5 text-right text-sm font-black text-brand-dark">
                                    ₱{{ item.subtotal|number_format(2) }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot class="bg-app-bg border-t border-border-color">
                        <tr>
                            <td colspan="3" class="px-8 py-6 text-right text-[10px] font-black uppercase tracking-[0.3em] text-gray">Manifest Total:</td>
                            <td class="px-8 py-6 text-right text-xl font-black text-brand tracking-tighter">
                                ₱{{ order.totalAmount|number_format(2) }}
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        {# Right: Payment & Processing Info #}
        <div class="lg:col-span-4 space-y-6">

            <div class="bg-brand-dark p-8 rounded-2xl text-white shadow-md relative overflow-hidden">
                <div class="absolute -right-6 -top-6 opacity-5">{{ ux_icon('lucide:shield-check', {class: 'w-32 h-32'}) }}</div>
                <h3 class="text-xs font-black uppercase tracking-[0.3em] text-white/40 mb-6 relative z-10">Payment Resolution</h3>

                <div class="space-y-6 relative z-10">
                    <div>
                        <label class="text-[9px] font-black uppercase tracking-widest text-white/50 block mb-1">Method</label>
                        <p class="text-sm font-bold flex items-center gap-2 text-white">
                            {{ ux_icon('lucide:credit-card', {class: 'w-4 h-4 opacity-60'}) }}
                            {{ order.paymentMethod.value|default('Pending') }}
                        </p>
                    </div>
                    <div>
                        <label class="text-[9px] font-black uppercase tracking-widest text-white/50 block mb-1">Status</label>
                        <div class="flex items-center gap-2">
                            {{ order.paymentStatus.value|default('Unpaid') }}
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-sm">
                <h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray mb-6 border-b border-border-color pb-4">Audit Trail</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center text-[10px]">
                        <span class="font-black uppercase tracking-widest text-gray">Initialized</span>
                        <span class="font-bold text-brand-dark">{{ order.createdAt|date('d.m.Y / H:i') }}</span>
                    </div>
                    <div class="flex justify-between items-center text-[10px]">
                        <span class="font-black uppercase tracking-widest text-gray">Last Revision</span>
                        <span class="font-bold text-brand-dark">{{ order.updatedAt|date('d.m.Y / H:i') }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
