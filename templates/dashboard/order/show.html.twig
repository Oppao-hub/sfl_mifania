{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Manifest: Order #{{ order.id }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_order_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div class="flex flex-col gap-2">
                <h1 class="text-3xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    Order <span class="text-brand">#{{ order.id }}</span>
                </h1>
                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        Manifest #{{ order.id }}
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Transactional Record
                    </span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_order_edit', { id: order.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Manifest
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '{{ path('app_order_delete', {id: order.id}) }}',
                        name: 'Order #{{ order.id }}',
                        token: '{{ csrf_token('delete' ~ order.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div>
    </div>

    {# 2. MASTER UNIFIED CONTAINER #}
    <div class="bg-white rounded-3xl shadow-sm border border-border-color flex flex-col lg:flex-row overflow-hidden">

        {# Left Sidebar: Logistics & Summary Data (Subtle Background) #}
        <div class="w-full lg:w-4/12 p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-border-color bg-app-bg/50 flex flex-col gap-10">

            {# MOVED: Electronic Manifest and Date tags are now here #}
            <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-3 border-b border-border-color/50 pb-4">
                <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                    Electronic Manifest
                </span>
                <span class="px-3 py-1 bg-brand/10 text-brand rounded-lg text-[9px] font-black uppercase tracking-widest border border-brand/20 whitespace-nowrap">
                    Processed: {{ order.createdAt|date('M.d.Y') }}
                </span>
            </div>

            {# Status Indicator #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-3 flex items-center gap-2">
                    {{ ux_icon('lucide:package-check', {class: 'w-3.5 h-3.5'}) }}
                    Order Status
                </p>
                <div class="inline-flex px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm border bg-white
                    {% if order.orderStatus.value == 'Completed' %} text-success border-success/20
                    {% elseif order.orderStatus.value == 'Cancelled' %} text-danger border-danger/20
                    {% else %} text-warning border-warning/20 {% endif %}">
                    <span class="w-1.5 h-1.5 rounded-full mr-2 my-auto
                        {% if order.orderStatus.value == 'Completed' %} bg-success
                        {% elseif order.orderStatus.value == 'Cancelled' %} bg-danger
                        {% else %} bg-warning animate-pulse {% endif %}">
                    </span>
                    {{ order.orderStatus.value }}
                </div>
            </div>

            {# Customer Record #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-2">Customer Record</p>
                <p class="text-sm font-bold text-brand-dark flex items-center gap-3 bg-white p-4 rounded-xl border border-border-color shadow-sm">
                    <span class="p-2 bg-app-bg rounded-lg text-brand border border-border-color">
                        {{ ux_icon('lucide:user', {class: 'w-4 h-4'}) }}
                    </span>
                    {{ order.customer ? order.customer.firstName ~ ' ' ~ order.customer.lastName : 'Guest Client' }}
                </p>
            </div>

            {# Payment Resolution #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-2">Payment Resolution</p>
                <div class="bg-brand-dark p-6 rounded-xl text-white shadow-md relative overflow-hidden">
                    <div class="absolute -right-4 -top-4 opacity-5">{{ ux_icon('lucide:shield-check', {class: 'w-24 h-24'}) }}</div>

                    <div class="space-y-4 relative z-10">
                        <div class="flex justify-between items-center">
                            <span class="text-[9px] font-black uppercase tracking-widest text-white/50">Method</span>
                            <span class="text-xs font-bold flex items-center gap-1.5 text-white">
                                {{ ux_icon('lucide:credit-card', {class: 'w-3.5 h-3.5 opacity-60'}) }}
                                {{ order.paymentMethod.value|default('Pending') }}
                            </span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-[9px] font-black uppercase tracking-widest text-white/50">Status</span>
                            <span class="text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded-md bg-white/10 border border-white/20">
                                {{ order.paymentStatus.value|default('Unpaid') }}
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            {# Spacer #}
            <div class="flex-grow"></div>

            {# Audit Trail #}
            <div class="border-t border-border-color pt-6 space-y-3">
                <h3 class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-4">Audit Trail</h3>
                <div class="flex justify-between items-center text-[9px]">
                    <span class="font-black uppercase tracking-widest text-gray/60">Initialized</span>
                    <span class="font-bold text-brand-dark">{{ order.createdAt|date('d.m.Y / H:i') }}</span>
                </div>
                <div class="flex justify-between items-center text-[9px]">
                    <span class="font-black uppercase tracking-widest text-gray/60">Last Revision</span>
                    <span class="font-bold text-brand-dark">{{ order.updatedAt|date('d.m.Y / H:i') }}</span>
                </div>
            </div>

        </div>

        {# Right Column: Order Inventory & Financials #}
        <div class="w-full lg:w-8/12 flex flex-col">

            {# Table Header #}
            <div class="p-8 md:p-10 border-b border-border-color flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <h2 class="text-xl font-black text-brand-dark tracking-tighter uppercase flex items-center gap-3">
                    {{ ux_icon('lucide:list-ordered', {class: 'w-5 h-5 text-brand'}) }}
                    Order Inventory
                </h2>
                <span class="px-4 py-2 bg-app-bg text-brand-dark rounded-lg text-[10px] font-black tracking-[0.2em] border border-border-color uppercase shadow-sm">
                    {{ order.orderItems|length }} SKUs
                </span>
            </div>

            {# The Table #}
            <div class="overflow-x-auto flex-grow">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead>
                        <tr class="bg-white border-b border-border-color text-[9px] font-black uppercase tracking-[0.3em] text-gray">
                            <th class="px-8 py-5">Article</th>
                            <th class="px-8 py-5 text-center">Qty</th>
                            <th class="px-8 py-5 text-right">Unit Value</th>
                            <th class="px-8 py-5 text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-color bg-white">
                        {% for item in order.orderItems %}
                            <tr class="hover:bg-app-bg/50 transition-colors group">
                                <td class="px-8 py-6">
                                    <span class="text-sm font-bold text-brand-dark block mb-1 group-hover:text-brand transition-colors">{{ item.product.name }}</span>
                                    <span class="text-[9px] text-gray font-black uppercase tracking-tighter">REF: #{{ item.product.id }}</span>
                                </td>
                                <td class="px-8 py-6 text-center text-sm font-bold text-brand-dark">
                                    {{ item.quantity }}
                                </td>
                                <td class="px-8 py-6 text-right text-sm font-bold text-gray italic">
                                    ₱{{ item.price|number_format(2) }}
                                </td>
                                <td class="px-8 py-6 text-right text-sm font-black text-brand-dark">
                                    ₱{{ item.subtotal|number_format(2) }}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="px-8 py-12 text-center text-gray font-medium text-sm">
                                    No items found in this order.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Financial Totals Footer #}
            <div class="bg-app-bg border-t border-border-color p-8 md:p-10 flex flex-col sm:flex-row justify-between items-center gap-6">

                {# Loyalty Points #}
                <div class="flex items-center gap-3 bg-white px-5 py-3 rounded-xl border border-border-color shadow-sm w-full sm:w-auto">
                    <div class="p-2 bg-terracotta/10 rounded-lg text-terracotta">
                        {{ ux_icon('lucide:sparkles', {class: 'w-4 h-4'}) }}
                    </div>
                    <div>
                        <p class="text-[9px] font-black uppercase tracking-[0.2em] text-gray leading-none mb-1">Loyalty Points</p>
                        <p class="text-sm font-bold text-terracotta leading-tight">{{ order.rewardPoints|default(0) }} Credited</p>
                    </div>
                </div>

                {# Grand Total #}
                <div class="flex items-center gap-6 w-full sm:w-auto justify-between sm:justify-end">
                    <span class="text-[10px] font-black uppercase tracking-[0.3em] text-gray">Manifest Total:</span>
                    <span class="text-3xl font-black text-brand tracking-tighter leading-none">
                        ₱{{ order.totalAmount|number_format(2) }}
                    </span>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
