<form
    method="post"
    action="{{ path('app_admin_qr_tag_delete', { id: qr_tag.id }) }}"
    onsubmit="return confirm('Are you sure you want to delete this item?');"
>
    <input
        type="hidden"
        name="_token"
        value="{{ csrf_token('delete' ~ qr_tag.id) }}"
    />
    <button class="btn">Delete</button>
</form>
