{% block main_content %}
<div class="mx-1 min-h-screen bg-white p-8 rounded-xl shadow-md">
    <h1 class="text-2xl font-bold text-mocha mb-6">Edit QR of : {{ qrTag.product.name }}</h1>

    {{ include('dashboard/qrTag/_form.html.twig', {
