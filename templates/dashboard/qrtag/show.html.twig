{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}QR Tag Details{% endblock %}

{% block main_content %}
<div class="p-8 m-1 min-h-screen show-wrapper sm:p-10 bg-white">
        {# Header #}
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-mocha dark:text-white">
                QR Product: {{ qrTag.product.name }}
            </h1>
        </div>

    <div class="bg-gray-50 p-6 mb-4 rounded-xl border border-gray-200">
        <h2 class="text-xl font-semibold text-mocha mb-4 border-b pb-2">QR Tag Details</h2>
        <div class="show-body flex flex-col lg:flex-row gap-8">

            {# Details Table #}
            <div class="show-details flex-1 min-w-0">
                <table id="adminTable" class="show-table w-full text-left text-sm text-mocha border-separate border-spacing-0">
                    <tbody>
                        {% set rowClasses = "hover:bg-row-hover transition-colors" %}

                        <tr class="{{ rowClasses }}">
                            <th class="py-3 px-4 font-medium text-gray-500 bg-gray-50 rounded-tl-lg w-1/3">ID</th>
                            <td class="py-3 px-4 border-b border-gray-200">{{ qrTag.id }}</td>
                        </tr>

                        <tr class="{{ rowClasses }}">
                            <th class="py-3 px-4 font-medium bg-gray-50 w-1/3 text-gray-500">Product Name</th>
                            <td class="py-3 px-4 border-b border-gray-200">{{ qrTag.product.name }}</td>
                        </tr>

                        <tr class="{{ rowClasses }}">
                            <th class="py-3 px-4 font-medium bg-gray-50 w-1/3 text-gray-500">QR Code Value</th>
                            <td class="py-3 px-4 border-b border-gray-200 break-all font-mono text-xs">{{ qrTag.qrCodeValue }}</td>
                        </tr>

                        <tr class="{{ rowClasses }}">
                            <th class="py-3 px-4 font-medium bg-gray-50 w-1/3 text-gray-500">Date Generated</th>
                            <td class="py-3 px-4 border-b border-gray-200">
                                {{ qrTag.dateGenerated ? qrTag.dateGenerated|date('Y-m-d H:i:s') : 'N/A' }}
                            </td>
                        </tr>

                        <tr class="{{ rowClasses }}">
                            <th class="py-3 px-4 font-medium bg-gray-50 w-1/3 text-gray-500">Qr Image Path</th>
                            <td class="py-3 px-4 border-b border-gray-200 truncate">{{ qrTag.qrImagePath }}</td>
                        </tr>

                    </tbody>
                </table>
            </div>

            {# QR Code Image #}
            {% if qrTag.qrImagePath %}
            <div class="show-image lg:w-72 flex-shrink-0 bg-white p-4 rounded-lg shadow-md flex justify-center items-start border border-gray-200">
                <div class="w-full max-w-xs p-2 bg-white shadow-lg border border-gray-100">
                    <img
                        src="{{ asset('uploads/qrcodes/' ~ qrTag.qrImagePath) }}"
                        alt="QR Code for {{ qrTag.product.name }}"
                        class="w-full h-auto object-contain block"
                    />
                    <p class="mt-2 text-center text-xs text-gray-500 italic">Scan to verify</p>
                </div>
            </div>
            {% endif %}

        </div>
    </div>
    <div class="flex gap-3 justify-end">
    {# Edit button #}
        <a href="{{ path('app_dashboard_qrTag_edit', { id: qrTag.id }) }}"
            class="px-4 py-2 bg-success text-white text-sm font-semibold rounded-xl hover:bg-success-hover transition">
            Edit
        </a>

        <button
            type="button"
            onclick="openDeleteModal({{ qrTag.id }}, '{{ qrTag.product.name|e('js') }}', '{{ csrf_token('delete' ~ qrTag.id) }}')"
            class="px-4 py-2 bg-danger text-white text-sm font-medium rounded-xl hover:bg-danger-hover transition"
        >
            Delete
        </button>

        <a href="{{ path('app_dashboard_qrTag_index') }}"
            class="px-4 py-2 bg-white border border-gray-300 text-gray-500 text-sm font-semibold rounded-xl hover:bg-gray-200 transition">
            Back
        </a>
    </div>
</div>
{% endblock %}
