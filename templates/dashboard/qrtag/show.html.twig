{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}QR Tag: {{ qrTag.product.name }}{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_qrTag_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ qrTag.product.name }}
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Tag Manifest #{{ qrTag.id }}</span>
                    <span class="px-2 py-0.5 bg-app-bg text-gray rounded-md text-[10px] font-bold uppercase tracking-tighter border border-border-color">Digital Provenance</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_qrTag_edit', { id: qrTag.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Tag
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click="$dispatch('open-delete-modal', {
                        url: '{{ path('app_qrTag_delete', {id: qrTag.id}) }}',
                        name: 'QR for {{ qrTag.product.name|e('js') }}',
                        token: '{{ csrf_token('delete' ~ qrTag.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Tag
                </button>
            {% endif %}
        </div>
    </div>

    {# 2. CONTENT GRID #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        {# Main Details Card #}
        <div class="lg:col-span-8 bg-white rounded-2xl border border-border-color shadow-sm overflow-hidden">
            <div class="p-8 border-b border-border-color flex items-center gap-3">
                <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color">
                    {{ ux_icon('lucide:tag', {class: 'w-5 h-5'}) }}
                </div>
                <h2 class="text-lg font-black text-brand-dark tracking-tighter uppercase">Tag Specifications</h2>
            </div>

            <div class="p-8 md:p-10">
                <dl class="grid grid-cols-1 gap-y-10">
                    <div>
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">Linked Product</dt>
                        <dd class="text-base font-bold text-brand-dark">{{ qrTag.product.name }}</dd>
                    </div>

                    <div class="bg-app-bg p-6 rounded-xl border border-border-color">
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">Destination Value (URL/Data)</dt>
                        <dd class="text-sm font-mono font-bold text-brand-dark break-all">{{ qrTag.qrCodeValue ?: 'N/A' }}</dd>
                    </div>

                    <div>
                        <dt class="text-[9px] uppercase font-black tracking-[0.3em] text-gray mb-2">Image File Reference</dt>
                        <dd class="text-sm font-mono font-bold text-gray">{{ qrTag.qrImagePath ?: 'N/A' }}</dd>
                    </div>
                </dl>
            </div>
        </div>

        {# Visual Reference & Audit #}
        <div class="lg:col-span-4 space-y-8">

            {# The Actual QR Code Visual #}
            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-sm text-center">
                <h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray mb-6 border-b border-border-color pb-4">Digital Asset</h3>

                {% if qrTag.qrImagePath %}
                    <div class="inline-block p-3 bg-white border border-border-color rounded-2xl shadow-inner mb-4">
                        <img src="{{ asset('uploads/qrcodes/' ~ qrTag.qrImagePath) }}"
                             alt="QR Code"
                             class="w-48 h-48 object-contain rounded-lg">
                    </div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-gray">Ready for Print</p>
                {% else %}
                    <div class="mx-auto w-48 h-48 rounded-2xl bg-app-bg border-2 border-dashed border-border-color flex flex-col items-center justify-center text-gray/40">
                        {{ ux_icon('lucide:qr-code', {class: 'w-10 h-10 mb-2'}) }}
                        <span class="text-[10px] font-black uppercase tracking-widest">Awaiting Generation</span>
                    </div>
                {% endif %}
            </div>

            {# Audit Trail #}
            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-sm">
                <h3 class="text-xs font-black uppercase tracking-[0.3em] text-gray mb-6 border-b border-border-color pb-4">Audit Record</h3>
                <div>
                    <p class="text-[9px] font-black uppercase tracking-widest text-gray mb-1.5">Generation Date</p>
                    <p class="text-sm font-bold text-brand-dark">
                        {{ qrTag.dateGenerated ? qrTag.dateGenerated|date('F d, Y / H:i') : 'Pending creation' }}
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
