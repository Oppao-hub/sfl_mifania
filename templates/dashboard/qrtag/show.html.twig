{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Manifest: {{ qrTag.product.name }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">

        <div class="flex items-center gap-5">
            <a href="{{ path('app_qrTag_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>

            <div class="flex flex-col gap-2">
                <h1 class="text-3xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ qrTag.product.name }}
                </h1>

                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        Manifest #{{ qrTag.id }}
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Digital Provenance
                    </span>
                </div>
            </div>
        </div>

        {# Right: Action Buttons #}
        <div class="flex items-center gap-3">
             <a href="{{ path('app_qrTag_edit', { id: qrTag.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Tag
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '{{ path('app_qrTag_delete', {id: qrTag.id}) }}',
                        name: 'QR for {{ qrTag.product.name|e('js') }}',
                        token: '{{ csrf_token('delete' ~ qrTag.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Tag
                </button>
            {% endif %}
        </div>
    </div>

    {# --- MASTER UNIFIED CONTAINER --- #}
    <div class="bg-white rounded-3xl shadow-sm border border-border-color flex flex-col lg:flex-row overflow-hidden">

        {# Left Sidebar: Visuals & Core Status #}
        <div class="w-full lg:w-4/12 p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-border-color bg-app-bg/50 flex flex-col gap-8">

            <div class="flex items-center justify-between border-b border-border-color/50 pb-4">
                <span class="text-[10px] text-gray uppercase font-black tracking-widest italic">Asset Visual</span>
            </div>

            {# The Actual QR Code Visual #}
            <div class="relative rounded-2xl overflow-hidden shadow-sm border border-border-color bg-white p-6 flex items-center justify-center aspect-square">
                {% if qrTag.qrImagePath %}
                    <img src="{{ asset('uploads/qrcodes/' ~ qrTag.qrImagePath) }}"
                         alt="QR Code"
                         class="w-full h-full object-contain hover:scale-[1.02] transition-transform duration-700">
                {% else %}
                    <div class="flex flex-col items-center justify-center text-gray/40">
                        {{ ux_icon('lucide:qr-code', {class: 'w-12 h-12 mb-3'}) }}
                        <span class="text-[10px] font-black uppercase tracking-widest text-center">Awaiting<br>Generation</span>
                    </div>
                {% endif %}
            </div>

            {# Audit Block #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-3 flex items-center gap-2">
                    {{ ux_icon('lucide:clock', {class: 'w-3.5 h-3.5'}) }}
                    Generation Timestamp
                </p>
                <div class="bg-white p-4 rounded-xl border border-border-color shadow-sm text-sm font-bold text-brand-dark">
                    {{ qrTag.dateGenerated ? qrTag.dateGenerated|date('M d, Y / H:i') : 'Pending creation' }}
                </div>
            </div>
        </div>

        {# Right Column: Specifications & Logistics #}
        <div class="w-full lg:w-8/12 p-8 md:p-12 flex flex-col">

            {# Data Header #}
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-border-color pb-8">
                <div>
                    <h2 class="text-2xl font-black text-brand-dark tracking-tighter leading-tight uppercase">Tag Specifications</h2>
                    <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1.5 italic">Digital Routing Information</p>
                </div>

                <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color shadow-sm">
                    {{ ux_icon('lucide:tag', {class: 'w-5 h-5'}) }}
                </div>
            </div>

            {# Information Grid #}
            <div class="grid grid-cols-1 gap-y-10">
                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Linked Collection Piece</label>
                    <span class="text-lg font-black text-brand-dark tracking-tighter uppercase">{{ qrTag.product.name }}</span>
                </div>

                <div class="bg-app-bg p-6 rounded-xl border border-border-color">
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-brand block mb-3">Destination Value (URL / Data)</label>
                    <p class="text-sm font-mono font-bold text-brand-dark break-all selection:bg-brand/20">
                        {{ qrTag.qrCodeValue ?: 'N/A' }}
                    </p>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Internal File Reference</label>
                    <p class="text-sm font-mono font-bold text-gray">{{ qrTag.qrImagePath ?: 'N/A' }}</p>
                </div>
            </div>

            {# Spacer to push archival metadata to bottom #}
            <div class="flex-grow"></div>

            {# Archival Metadata #}
            <div class="mt-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4 text-gray/40 border-t border-border-color pt-6">
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Asset Type: <strong class="text-gray/60">Digital Matrix Barcode</strong>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
