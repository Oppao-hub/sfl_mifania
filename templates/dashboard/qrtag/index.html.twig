{% extends "dashboard/dashboard.html.twig" %}
{% set qrTags = qrTags|default([]) %}

{% block title %}QR Tag Management{% endblock %}

{% block main_content %}
    {% embed 'components/table/table.html.twig' with {
        title: 'Manage QR Codes',
        new_path: 'app_qrTag_new',
        headers: ['ID', 'Product', 'QR Code Value', 'Date Generated', 'Image Path', 'Actions'],
        id: 'dashboard-table'
    } %}

        {% block rows %}
            {% for qrTag in qrTags %}
                <tr class="hover:bg-row-hover transition-colors group">
                    <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray">#{{ qrTag.id }}</td>
                    <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-brand-dark">{{ qrTag.product.name }}</td>

                    <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray truncate max-w-[200px]">
                        {{ qrTag.qrCodeValue ?: 'N/A' }}
                    </td>

                    <td class="border-y border-border-color px-4 py-3 text-xs font-bold text-gray">
                        {{ qrTag.dateGenerated ? qrTag.dateGenerated|date('M d, Y H:i') : '—' }}
                    </td>

                    <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray truncate max-w-[150px]">
                        {{ qrTag.qrImagePath ?: 'Pending' }}
                    </td>

                    <td class="border-y border-border-color py-3 px-4 text-center">
                        <div class="flex justify-center items-center gap-2">
                            <a href="{{ path('app_qrTag_show', {'id': qrTag.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>

                            <a href="{{ path('app_qrTag_edit', {'id': qrTag.id}) }}"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>
                            {% if is_granted('ROLE_ADMIN') %} {# This is the line that was added #}
                                <button type="button"
                                    @click="$dispatch('open-delete-modal', {
                                        url: '{{ path('app_qrTag_delete', {id: qrTag.id}) }}',
                                        name: 'QR for {{ qrTag.product.name|e('js') }}',
                                        token: '{{ csrf_token('delete' ~ qrTag.id) }}'
                                    })"
                                    class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer">
                                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                                </button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
    {% endembed %}
{% endblock %}
