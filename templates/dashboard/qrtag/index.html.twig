{% extends "dashboard/dashboard.html.twig" %}
{% set qrTags = qrTags|default([]) %}

{% block main_content %}
	{% embed 'components/table/table.html.twig' with {
    title: 'Manage QR Codes',
    new_path: 'app_qrTag_new',
    headers: ['ID', 'Product', 'QR Code Value', 'Date Generated', 'QR Image Path', 'Actions'],
    id: 'dashboard-table'
} %}

		{% block rows %}
			{% for qrTag in qrTags %}
				<tr class="hover:bg-row-hover transition-colors">
					<td class="border border-gray-300 px-4 py-2 text-sm">{{ qrTag.id }}</td>

					<td class="border border-gray-300 px-4 py-2 text-sm">{{ qrTag.product.name }}</td>

					<td class="border border-gray-300 px-4 py-2 text-sm">
						{{ qrTag.dateGenerated ? qrTag.dateGenerated|date('Y-m-d H:i:s') : '—' }}
					</td>

					<td class="border border-gray-300 px-4 py-2 text-sm truncate max-w-[200px]">
						{{ qrTag.qrCodeValue ?: 'N/A' }}
					</td>

					<td class="border border-gray-300 px-4 py-2 text-sm truncate max-w-[200px]">
						{{ qrTag.qrImagePath ?: 'N/A' }}
					</td>

					<td class="border border-gray-300 py-3 px-4 text-sm text-center">
						<div
							class="flex justify-center items-center gap-3">
							{# VIEW #}
							<twig:ActionIcon
							path="{{ path('app_qrTag_show', {'id': qrTag.id}) }}" svgPath="M12 4.5C7 4.5 2.73 8 1 12c1.73 4 6 7.5 11 7.5s9.27-3.5 11-7.5c-1.73-4-6-7.5-11-7.5z M12 16a4 4 0 110-8 4 4 0 010 8z" class="w-5 h-5 text-brand" label="View"/>

							{# EDIT #}
							<twig:ActionIcon
							path="{{ path('app_qrTag_edit', {'id': qrTag.id}) }}" svgPath="M11 4H4a1 1 0 00-1 1v16a1 1 0 001 1h16a1 1 0 001-1v-7 M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" class="w-5 h-5 text-brand" label="Edit"/>

							{# DELETE (Alpine modal) #}
							<twig:ActionIcon path="#" onclick="openDeleteModal({{ qrTag.id }}, '{{ qrTag.product.name|e('js') }}', '{{ csrf_token('delete' ~ qrTag.id) }}')" svgPath="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M10 7V4a1 1 0 011-1h2a1 1 0 011 1v3" class="w-5 h-5 text-red-600" label="Delete"/>
						</div>
					</td>
				</tr>
			{% endfor %}
		{% endblock %}
	{% endembed %}
{% endblock %}
