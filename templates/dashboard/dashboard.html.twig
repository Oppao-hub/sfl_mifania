<!DOCTYPE html>
<html lang="en" :class="{ 'dark': darkMode }" x-data="{
    darkMode: localStorage.getItem('darkMode') === 'true',
    toggleDarkMode() {
        this.darkMode = !this.darkMode;
        localStorage.setItem('darkMode', this.darkMode);
        if (this.darkMode) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    }
}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Mifania | Dashboard{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}" />

    {# Flicker Prevention Script #}
    <script>
        if (localStorage.getItem('darkMode') === 'true') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>

    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_script_tags('app') }}

    {% block javascripts %}
        <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    {% endblock %}
</head>
<body x-data="{
    sidebarOpen: false,
    isCollapsed: true,
    isHovered: false,
    ecommerceOpen: false,
    get isExpanded() { return !this.isCollapsed || this.isHovered }
}"
class="min-h-screen flex overflow-x-hidden bg-app-bg/30 relative dark:bg-brand-dark/95 transition-colors duration-300">

    {# Impersonation Banner #}
    {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
        <div class="fixed top-0 left-0 right-0 bg-brand-dark text-white text-center py-2 z-[200] flex items-center justify-center gap-4 shadow-lg animate-fadeIn">
            <span class="text-xs font-semibold italic">Impersonating: {{ app.user.userIdentifier }}</span>
            <a href="{{ path('app_dashboard', {'_switch_user': '_exit'}) }}"
               class="bg-white text-brand-dark px-3 py-1 rounded-full text-[10px] font-bold hover:bg-app-bg transition-all">
                Exit Impersonation
            </a>
        </div>
    {% endif %}

    {# Mobile Overlay #}
    <div x-show="sidebarOpen"
         x-transition.opacity.duration.300ms
         class="fixed inset-0 bg-brand-dark/40 backdrop-blur-sm z-40 lg:hidden"
         @click="sidebarOpen = false" x-cloak></div>

    {# Sidebar #}
    <aside
           @mouseenter="isHovered = true"
           @mouseleave="isHovered = false"
           :class="[
                sidebarOpen ? 'translate-x-0' : '-translate-x-full',
                isExpanded ? 'w-72' : 'lg:w-20'
           ]"
           class="fixed inset-y-0 left-0 bg-white border-r border-border-color flex flex-col z-[100] p-4 shadow-2xl transition-all duration-300 ease-in-out lg:translate-x-0 lg:h-screen lg:shadow-sm">

        {# Logo Section #}
        <div class="mb-8 flex items-center shrink-0 transition-all duration-300"
             :class="isExpanded ? 'px-2' : 'justify-center'">
            <div class="flex items-center gap-3 overflow-hidden">
                <img src="{{ asset('uploads/logo/logo.svg') }}" alt="MIFANIA"
                     class="transition-all duration-300 shrink-0"
                     :class="isExpanded ? 'h-10 w-auto' : 'h-8 w-8 object-contain'">

                <span x-show="isExpanded"
                      x-transition:enter="transition ease-out duration-200 delay-100"
                      x-transition:enter-start="opacity-0 -translate-x-4"
                      x-transition:enter-end="opacity-100 translate-x-0"
                      class="text-3xl font-medium tracking-tight text-brand whitespace-nowrap">MIFANIA</span>
            </div>

            <button @click="sidebarOpen = false" class="lg:hidden p-2 text-gray hover:bg-row-hover rounded-xl transition-colors ml-auto">
                {{ ux_icon('lucide:x', {class: 'w-5 h-5'}) }}
            </button>
        </div>

        {# Navigation #}
        <nav class="border-t border-border-color flex-grow space-y-1.5 overflow-y-auto min-h-0 py-4 custom-scrollbar">
            <a href="{{ path('app_dashboard') }}"
               @click="if(window.innerWidth > 1024) isCollapsed = true"
               class="flex items-center p-3 transition-all group
               {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'bg-brand/5 text-brand border-l-4 border-brand rounded-r-xl' : 'text-gray hover:bg-row-hover hover:text-brand-dark rounded-xl border-l-4 border-transparent' }}">
                <div class="shrink-0 transition-transform duration-300 group-hover:scale-110">
                    {{ ux_icon('lucide:layout-dashboard', {class: 'w-5 h-5'}) }}
                </div>
                <span x-show="isExpanded"
                      x-transition:enter="transition ease-out duration-200 delay-100"
                      x-transition:enter-start="opacity-0 translate-x-2"
                      x-transition:enter-end="opacity-100 translate-x-0"
                      class="ml-3 font-bold text-sm whitespace-nowrap">Dashboard</span>
            </a>

            {# E-commerce Dropdown #}
            {% set ecommerce_items = {
                'Products': {'icon': 'lucide:package', 'route_prefix': 'app_product_'},
                'Orders': {'icon': 'lucide:shopping-bag', 'route_prefix': 'app_order_'},
                'Inventory': {'icon': 'lucide:boxes', 'route_prefix': 'app_stock_'},
                'Category': {'icon': 'tabler:category', 'route_prefix': 'app_category_'},
                'Sub-Category': {'icon': 'material-symbols-light:category-outline-rounded', 'route_prefix': 'app_sub_category_'},
                'QR Tags': {'icon': 'lucide:qr-code', 'route_prefix': 'app_qrTag_'},
            } %}

            {% set is_ecommerce_active = false %}
            {% for label, item in ecommerce_items %}
                {% if app.request.attributes.get('_route') starts with item.route_prefix %}
                    {% set is_ecommerce_active = true %}
                {% endif %}
            {% endfor %}

            <div x-data="{ open: {{ is_ecommerce_active ? 'true' : 'false' }} }" class="space-y-1">
                <button @click="open = !open"
                        class="flex items-center w-full p-3 transition-all group cursor-pointer
                        {{ is_ecommerce_active ? 'text-brand-dark border-l-4 border-brand bg-brand/5 rounded-r-xl' : 'text-gray hover:bg-row-hover hover:text-brand-dark rounded-xl border-l-4 border-transparent' }}">
                    <div class="shrink-0 transition-transform duration-300 group-hover:scale-110">
                        {{ ux_icon('lucide:shopping-cart', {class: 'w-5 h-5'}) }}
                    </div>
                    <span x-show="isExpanded"
                          x-transition:enter="transition ease-out duration-200 delay-100"
                          x-transition:enter-start="opacity-0 translate-x-2"
                          x-transition:enter-end="opacity-100 translate-x-0"
                          class="ml-3 font-bold text-sm whitespace-nowrap">E-commerce</span>
                    <div x-show="isExpanded" class="ml-auto transition-transform duration-200" :class="open ? 'rotate-180' : ''">
                        {{ ux_icon('lucide:chevron-down', {class: 'w-3 h-3'}) }}
                    </div>
                </button>

                <div x-show="open && isExpanded"
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 -translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     class="pl-4 space-y-1">
                    {% for label, item in ecommerce_items %}
                        <a href="{{ path(item.route_prefix ~ 'index') }}"
                           class="flex items-center p-2.5 rounded-xl transition-all group
                           {{ app.request.attributes.get('_route') starts with item.route_prefix ? 'bg-brand/10 text-brand shadow-sm' : 'text-gray/70 hover:text-brand-dark' }}">
                            <div class="shrink-0 transition-transform duration-300 group-hover:scale-110">
                                {{ ux_icon(item.icon, {class: 'w-4 h-4'}) }}
                            </div>
                            <span class="ml-3 font-semibold text-xs whitespace-nowrap">{{ label }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>

            {# Additional Apps #}
            <div x-show="isExpanded" class="pt-4 pb-2 px-3">
                <p class="text-[10px] font-bold text-gray/40">Communication & Analysis</p>
            </div>

            <a href="{{ path('app_chat') }}" class="flex items-center p-3 transition-all group {{ app.request.attributes.get('_route') == 'app_chat' ? 'bg-brand/5 text-brand border-l-4 border-brand rounded-r-xl' : 'text-gray hover:bg-row-hover hover:text-brand-dark rounded-xl border-l-4 border-transparent' }}">
                <div class="shrink-0 transition-transform duration-300 group-hover:scale-110">
                    {{ ux_icon('lucide:message-square', {class: 'w-5 h-5'}) }}
                </div>
                <span x-show="isExpanded"
                      x-transition:enter="transition ease-out duration-200 delay-100"
                      x-transition:enter-start="opacity-0 translate-x-2"
                      x-transition:enter-end="opacity-100 translate-x-0"
                      class="ml-3 font-bold text-sm whitespace-nowrap">Chat</span>
            </a>

            <a href="{{ path('app_analytics') }}" class="flex items-center p-3 transition-all group
               {{ app.request.attributes.get('_route') == 'app_analytics' ? 'bg-brand/5 text-brand border-l-4 border-brand rounded-r-xl' : 'text-gray hover:bg-row-hover hover:text-brand-dark rounded-xl border-l-4 border-transparent' }}">
                <div class="shrink-0 transition-transform duration-300 group-hover:scale-110">
                    {{ ux_icon('lucide:bar-chart-3', {class: 'w-5 h-5'}) }}
                </div>
                <span x-show="isExpanded"
                      x-transition:enter="transition ease-out duration-200 delay-100"
                      x-transition:enter-start="opacity-0 translate-x-2"
                      x-transition:enter-end="opacity-100 translate-x-0"
                      class="ml-3 font-bold text-sm whitespace-nowrap">Analytics</span>
            </a>

            <a href="{{ path('app_customer_index') }}" class="flex items-center p-3 transition-all group {{ app.request.attributes.get('_route') == 'app_customer_index' ? 'bg-brand/5 text-brand border-l-4 border-brand rounded-r-xl' : 'text-gray hover:bg-row-hover hover:text-brand-dark rounded-xl border-l-4 border-transparent' }}">
                <div class="shrink-0 transition-transform duration-300 group-hover:scale-110">
                    {{ ux_icon('lucide:contact', {class: 'w-5 h-5'}) }}
                </div>
                <span x-show="isExpanded"
                      x-transition:enter="transition ease-out duration-200 delay-100"
                      x-transition:enter-start="opacity-0 translate-x-2"
                      x-transition:enter-end="opacity-100 translate-x-0"
                      class="ml-3 font-bold text-sm whitespace-nowrap">Customers</span>
            </a>

            {# Other Management #}
            <div x-show="isExpanded" class="pt-4 pb-2 px-3">
                <p class="text-[10px] font-bold text-gray/40">Management</p>
            </div>

            {% set other_items = {
                'Narratives': {'icon': 'lucide:book-open', 'route_prefix': 'app_story_'},
            } %}

            {% if is_granted('ROLE_ADMIN') %}
                {% set other_items = other_items|merge({
                    'Admins': {'icon': 'lucide:user-star', 'route_prefix': 'app_admin_'},
                    'Staffs': {'icon': 'lucide:user-cog', 'route_prefix': 'app_staff_'},
                }) %}
            {% endif %}

            {% for label, item in other_items %}
                <a href="{{ path(item.route_prefix ~ 'index') }}"
                   @click="if(window.innerWidth > 1024) isCollapsed = true"
                   class="flex items-center p-3 transition-all group
                   {{ app.request.attributes.get('_route') starts with item.route_prefix ? 'bg-brand/5 text-brand border-l-4 border-brand rounded-r-xl' : 'text-gray hover:bg-row-hover hover:text-brand-dark rounded-xl border-l-4 border-transparent' }}">
                    <div class="shrink-0 transition-transform duration-300 group-hover:scale-110">
                        {{ ux_icon(item.icon, {class: 'w-5 h-5'}) }}
                    </div>
                    <span x-show="isExpanded"
                          x-transition:enter="transition ease-out duration-200 delay-100"
                          x-transition:enter-start="opacity-0 translate-x-2"
                          x-transition:enter-end="opacity-100 translate-x-0"
                          class="ml-3 font-bold text-sm whitespace-nowrap">{{ label }}</span>
                </a>
            {% endfor %}
        </nav>
    </aside>

    <div class="flex-1 flex flex-col min-w-0 transition-all duration-300 ease-in-out"
         :class="isCollapsed ? 'lg:pl-20' : 'lg:pl-72'">
        <header class="bg-white/80 backdrop-blur-md sticky top-0 z-60 p-4 lg:px-6 flex justify-between items-center border-b border-border-color gap-4 dark:bg-brand-dark/80 dark:border-border-color/10">

            <div class="flex items-center gap-4 flex-1">
                {# Sidebar Toggle (Desktop) #}
                <button @click="isCollapsed = !isCollapsed"
                        class="hidden lg:flex items-center justify-center cursor-pointer group">
                    <div class="w-10 h-10 bg-brand/5 text-brand rounded-xl flex items-center justify-center group-hover:bg-brand/10 transition-all duration-300">
                        {{ ux_icon('lucide:menu', {class: 'w-5 h-5'}) }}
                    </div>
                </button>

                {# Mobile Menu Button #}
                <button @click="sidebarOpen = true" class="lg:hidden p-2 text-brand bg-brand/10 rounded-xl hover:opacity-80 transition-opacity shrink-0">
                    {{ ux_icon('lucide:menu', {class: 'w-5 h-5'}) }}
                </button>

                {# Short Greeting #}
                <div class="hidden md:block">
                    <p class="text-xl font-semibold text-brand-dark">
                        {% set firstName = 'Staff' %}
                        {% if app.user.admin %}
                            {% set firstName = app.user.admin.firstName|default('Admin') %}
                        {% elseif app.user.staff %}
                            {% set firstName = app.user.staff.firstName|default('Staff') %}
                        {% endif %}
                        Good {{ "now"|date("H") < 12 ? 'Morning' : ("now"|date("H") < 17 ? 'Afternoon' : 'Evening') }}, {{ firstName }}!
                    </p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                {# Global Search #}
                <div x-data="{ searchOpen: false }"
                     @click.away="searchOpen = false"
                     class="relative flex items-center">

                    <div class="flex items-center bg-app-bg border border-transparent rounded-xl transition-all duration-300 ease-in-out shadow-inner overflow-hidden"
                         :class="searchOpen ? 'w-[200px] sm:w-[300px] lg:w-[450px] bg-white border-brand/20 ring-4 ring-brand/10' : 'w-10 h-10 lg:w-11 lg:h-11'">

                        <button type="button"
                                @click="searchOpen = !searchOpen; if(searchOpen) $nextTick(() => $refs.searchInput.focus())"
                                class="w-10 h-10 lg:w-11 lg:h-11 flex items-center justify-center shrink-0 text-gray hover:text-brand transition-colors cursor-pointer focus:outline-none">
                            {{ ux_icon('lucide:search', {class: 'w-4 h-4 lg:w-5 lg:h-5'}) }}
                        </button>

                        <form action="{{ path('app_global_search') }}" method="GET"
                              x-show="searchOpen"
                              x-transition:enter="transition ease-out duration-200"
                              x-transition:enter-start="opacity-0 -translate-x-2"
                              x-transition:enter-end="opacity-100 translate-x-0"
                              class="flex-1 min-w-0"
                              x-cloak>
                            <input x-ref="searchInput" type="search" name="q" placeholder="Search..."
                                   class="w-full bg-transparent outline-none text-sm font-medium pr-2 py-1.5">
                        </form>
                    </div>
                </div>

                {# --- NOTIFICATION BELL --- #}
                {% set all_notifs_debug = get_recent_notifications(50) %}
                <!-- DEBUG: 
                     Logged In User ID: {{ app.user.id }}
                     Total Notifs Found for this user: {{ all_notifs_debug|length }}
                     Unread Count for this user: {{ get_unread_notifications_count() }}
                -->
                <div class="relative" x-data="{
                    notifOpen: false,
                    unreadCount: {{ get_unread_notifications_count() }},
                    notifications: [
                        {% for n in get_recent_notifications(10) %}
                        {
                            id: {{ n.id }},
                            title: '{{ n.title|e('js') }}',
                            message: '{{ n.message|e('js') }}',
                            type: '{{ n.type|e('js') }}',
                            isRead: {{ n.isRead ? 'true' : 'false' }},
                            createdAt: '{{ n.createdAt|date('Y-m-d H:i:s') }}',
                            relativeTime: '{{ n.createdAt|date('g:i a') }}',
                            targetUrl: '{{ n.targetUrl ? path('app_notification_read_and_redirect', {id: n.id}) : '#' }}'
                        }{% if not loop.last %},{% endif %}
                        {% endfor %}
                    ],

                    init() {
                        window.addEventListener('notify', (event) => {
                            this.unreadCount++;
                            // Add new notification to the top
                            this.notifications.unshift({
                                id: Date.now(),
                                title: event.detail.title || 'New Notification',
                                message: event.detail.message,
                                type: event.detail.type,
                                isRead: false,
                                relativeTime: 'Just now',
                                targetUrl: event.detail.targetUrl || '#'
                            });
                        });
                    },

                    markAllRead() {
                        fetch('{{ path('app_notifications_mark_read') }}', {
                            method: 'POST',
                            headers: {
                                'X-CSRF-TOKEN': '{{ csrf_token('mark_notifications_read') }}',
                                'Content-Type': 'application/json'
                            }
                        })
                        .then(res => res.json())
                        .then(data => {
                            if (data.status === 'success') {
                                this.unreadCount = 0;
                                this.notifications.forEach(n => n.isRead = true);
                            }
                        });
                    },

                    dismiss(notif) {
                        // If it's a real notification (has a proper ID)
                        if (notif.id > 1000000000000) { // Temp ID from Date.now()
                            this.notifications = this.notifications.filter(n => n.id !== notif.id);
                            if (!notif.isRead) this.unreadCount--;
                            return;
                        }

                        fetch(`/dashboard/notifications/${notif.id}/dismiss`, {
                            method: 'POST',
                            headers: {
                                'X-CSRF-TOKEN': '{{ csrf_token('dismiss_notification') }}'
                            }
                        })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                this.notifications = this.notifications.filter(n => n.id !== notif.id);
                                if (!notif.isRead) this.unreadCount--;
                            }
                        });
                    }
                }" @click.outside="notifOpen = false">
                    {# 1. The Bell Button #}
                    <button @click="notifOpen = !notifOpen" 
                            class="relative w-10 h-10 lg:w-11 lg:h-11 flex items-center justify-center rounded-full bg-white border border-border-color shadow-sm text-gray hover:text-brand dark:bg-brand-dark dark:border-brand/20 dark:text-brand-light transition-all cursor-pointer hover:bg-app-bg/50 focus:outline-none">
                        {{ ux_icon('lucide:bell', {class: 'w-5 h-5'}) }}

                        {# The Unread Badge (Only shows if unreadCount > 0) #}
                        <span x-show="unreadCount > 0"
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="scale-0 opacity-0"
                            x-transition:enter-end="scale-100 opacity-100"
                            class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-danger text-[10px] font-black text-white border-2 border-white box-content shadow-sm"
                            x-text="unreadCount"></span>
                    </button>

                    {# 2. The Dropdown Panel #}
                    <div x-show="notifOpen"
                        @click.stop
                        x-transition:enter="transition ease-out duration-200"
                        x-transition:enter-start="opacity-0 translate-y-3 scale-95"
                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                        x-transition:leave="transition ease-in duration-150"
                        x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                        x-transition:leave-end="opacity-0 translate-y-2 scale-95"
                        class="absolute right-0 mt-3 w-80 sm:w-96 bg-white border border-border-color rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.08)] z-50 overflow-hidden flex flex-col transform origin-top-right"
                        style="display: none;"
                        x-cloak>

                        {# Header #}
                        <div class="px-5 py-4 border-b border-border-color flex items-center justify-between bg-app-bg/50">
                            <div class="flex items-center gap-2">
                                <h3 class="text-sm font-black text-brand-dark tracking-tight">Notifications</h3>
                                <span x-show="unreadCount > 0" x-text="unreadCount + ' new'" class="bg-brand/10 text-brand text-[10px] font-black px-2 py-0.5 rounded-full uppercase tracking-widest"></span>
                            </div>
                            <button @click="markAllRead()" class="text-[9px] font-bold text-gray hover:text-brand uppercase tracking-widest transition-colors cursor-pointer">
                                Mark all read
                            </button>
                        </div>

                        {# Notification List (Scrollable) #}
                        <div class="max-h-[400px] overflow-y-auto overscroll-contain flex flex-col divide-y divide-border-color">
                            <template x-for="notif in notifications" :key="notif.id">
                                <div class="relative group">
                                    <a :href="notif.targetUrl" 
                                       class="p-5 flex gap-4 hover:bg-app-bg/80 transition-colors relative"
                                       :class="!notif.isRead ? 'bg-brand/5' : ''">

                                        {# Unread Indicator Bar #}
                                        <div x-show="!notif.isRead" class="absolute left-0 top-0 bottom-0 w-1 bg-brand rounded-r-full"></div>

                                        <div class="w-10 h-10 rounded-full bg-white border border-brand/20 flex items-center justify-center shrink-0 shadow-sm text-brand group-hover:scale-105 transition-transform duration-300">
                                            <template x-if="notif.type === 'order'">{{ ux_icon('lucide:shopping-bag', {class: 'w-4 h-4'}) }}</template>
                                            <template x-if="notif.type === 'chat'">{{ ux_icon('lucide:message-square', {class: 'w-4 h-4'}) }}</template>
                                            <template x-if="notif.type === 'system' || !notif.type">{{ ux_icon('lucide:bell', {class: 'w-4 h-4'}) }}</template>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-xs text-brand-dark leading-snug">
                                                <span class="font-bold" x-text="notif.title"></span>
                                                <span x-text="notif.message"></span>
                                            </p>
                                            <p class="text-[10px] font-bold text-brand/60 uppercase tracking-widest mt-1.5" x-text="notif.relativeTime"></p>
                                        </div>
                                    </a>
                                    
                                    {# Dismiss Button #}
                                    <button @click.stop="dismiss(notif)" 
                                            class="absolute top-4 right-4 p-1.5 text-gray/40 hover:text-danger hover:bg-danger/5 rounded-lg transition-all opacity-0 group-hover:opacity-100 cursor-pointer">
                                        {{ ux_icon('lucide:x', {class: 'w-3 h-3'}) }}
                                    </button>
                                </div>
                            </template>

                            <template x-if="notifications.length === 0">
                                <div class="p-10 text-center">
                                    <p class="text-xs font-bold text-gray/40 uppercase tracking-widest">No notifications</p>
                                </div>
                            </template>
                        </div>

                        {# Footer #}
                        <div class="p-3 border-t border-border-color bg-app-bg/30 text-center shrink-0">
                            <a href="#" class="text-[10px] font-bold text-brand hover:text-brand-dark transition-colors uppercase tracking-widest block py-2">
                                View All Activity
                            </a>
                        </div>
                    </div>
                </div>
                {# Theme Toggle #}
                <button @click="toggleDarkMode()"
                        class="w-10 h-10 lg:w-11 lg:h-11 flex items-center justify-center rounded-full bg-white border border-border-color shadow-sm text-gray hover:text-brand dark:bg-brand-dark dark:border-brand/20 dark:text-brand-light transition-all cursor-pointer">
                    <template x-if="!darkMode">
                        {{ ux_icon('lucide:moon', {class: 'w-5 h-5'}) }}
                    </template>
                    <template x-if="darkMode">
                        {{ ux_icon('lucide:sun', {class: 'w-5 h-5'}) }}
                    </template>
                </button>

                {# User Profile Dropdown #}
                <div x-data="{ userOpen: false, switchOpen: false }"
                     @mouseenter="userOpen = true"
                     @mouseleave="userOpen = false; switchOpen = false"
                     class="relative">

                    <button class="relative w-10 h-10 lg:w-11 lg:h-11 flex items-center justify-center p-0 cursor-pointer transition-all border border-border-color hover:border-brand/30 rounded-full bg-white shadow-sm overflow-hidden aspect-square dark:bg-brand-dark dark:border-brand/20">
                        {% set avatarPath = 'uploads/default/default-avatar.jpg' %}
                        {% set userRole = 'User' %}
                        {% if is_granted('ROLE_ADMIN') %}
                            {% set userRole = 'System Administrator' %}
                        {% elseif is_granted('ROLE_STAFF') %}
                            {% set userRole = 'Support Staff' %}
                        {% endif %}

                        {% if app.user.admin and app.user.admin.avatar %}
                            {% set avatarPath = 'uploads/admin/avatars/' ~ app.user.admin.avatar %}
                        {% elseif app.user.staff and app.user.staff.avatar %}
                            {% set avatarPath = 'uploads/staff/avatars/' ~ app.user.staff.avatar %}
                        {% endif %}
                        <img src="{{ asset(avatarPath) }}" class="w-full h-full rounded-full object-cover border-2 border-white shadow-sm aspect-square" alt="Profile" />
                        <span class="absolute bottom-0.5 right-0.5 block h-2.5 w-2.5 rounded-full border-2 border-white bg-green-500 shadow-sm z-10"></span>
                    </button>

                    <div x-show="userOpen"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 scale-95 translate-y-1"
                         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100 scale-100 translate-y-0"
                         x-transition:leave-end="opacity-0 scale-95 translate-y-1"
                         class="absolute right-0 top-full mt-2 w-64 bg-white rounded-2xl shadow-2xl border border-border-color overflow-hidden z-[110]"
                         style="display: none;">

                        {# 1. Avatar Header #}
                        <div class="px-5 py-5 bg-app-bg/50 flex items-center gap-4 border-b border-border-color">
                            <div class="relative w-10 h-10 shrink-0">
                                <img src="{{ asset(avatarPath) }}" class="w-full h-full rounded-xl object-cover border-2 border-white shadow-sm" alt="Profile" />
                                <span class="absolute -bottom-0.5 -right-0.5 block h-3 w-3 rounded-full border-2 border-white bg-green-500 shadow-sm"></span>
                            </div>
                            <div class="min-w-0">
                                <p class="text-xs font-black text-brand-dark truncate uppercase tracking-tighter">
                                    {% if app.user.admin %}
                                        {{ app.user.admin.firstName }} {{ app.user.admin.lastName }}
                                    {% elseif app.user.staff %}
                                        {{ app.user.staff.firstName }} {{ app.user.staff.lastName }}
                                    {% else %}
                                        {{ app.user.userIdentifier }}
                                    {% endif %}
                                </p>
                                <p class="text-[9px] text-gray font-black uppercase tracking-widest opacity-50">
                                    {{ userRole }}
                                </p>
                            </div>
                        </div>

                        <div class="p-2 space-y-4">
                            {# 2. Account Section #}
                            <div>
                                <p class="px-3 mb-2 text-[9px] font-black text-gray/40 uppercase tracking-[0.2em]">Account</p>
                                <div class="space-y-1">
                                    <a href="{{ is_granted('ROLE_ADMIN') ? path('app_account_admin') : path('app_staff_account') }}"
                                       class="flex items-center gap-3 px-3 py-2 text-xs font-bold text-gray hover:text-brand hover:bg-brand/5 rounded-xl transition-all">
                                        <div class="w-7 h-7 rounded-lg bg-app-bg flex items-center justify-center border border-border-color text-gray/40">
                                            {{ ux_icon('lucide:user', {class: 'w-3.5 h-3.5'}) }}
                                        </div>
                                        Profile
                                    </a>
                                </div>
                            </div>

                            {# 3. Settings Section #}
                            <div>
                                <p class="px-3 mb-2 text-[9px] font-black text-gray/40 uppercase tracking-[0.2em]">Settings</p>
                                <div class="space-y-1">
                                    <a href="{{ is_granted('ROLE_ADMIN') ? path('app_account_admin_edit') : path('app_staff_account_edit') }}"
                                       class="flex items-center gap-3 px-3 py-2 text-xs font-bold text-gray hover:text-brand hover:bg-brand/5 rounded-xl transition-all">
                                        <div class="w-7 h-7 rounded-lg bg-app-bg flex items-center justify-center border border-border-color text-gray/40">
                                            {{ ux_icon('lucide:settings', {class: 'w-3.5 h-3.5'}) }}
                                        </div>
                                        Account Settings
                                    </a>
                                    <a href="{{ is_granted('ROLE_ADMIN') ? path('app_account_admin_password') : path('app_staff_account_password') }}"
                                       class="flex items-center gap-3 px-3 py-2 text-xs font-bold text-gray hover:text-brand hover:bg-brand/5 rounded-xl transition-all">
                                        <div class="w-7 h-7 rounded-lg bg-app-bg flex items-center justify-center border border-border-color text-gray/40">
                                            {{ ux_icon('lucide:shield-check', {class: 'w-3.5 h-3.5'}) }}
                                        </div>
                                        Security
                                    </a>
                                    <a href="{{ path('app_dashboard') }}"
                                       class="flex items-center gap-3 px-3 py-2 text-xs font-bold text-gray hover:text-brand hover:bg-brand/5 rounded-xl transition-all">
                                        <div class="w-7 h-7 rounded-lg bg-app-bg flex items-center justify-center border border-border-color text-gray/40">
                                            {{ ux_icon('lucide:help-circle', {class: 'w-3.5 h-3.5'}) }}
                                        </div>
                                        Help Center
                                    </a>

                                    {% if is_granted('ROLE_ALLOWED_TO_SWITCH') and not is_granted('ROLE_PREVIOUS_ADMIN') %}
                                        <div class="relative pt-2">
                                            <button @click="switchOpen = !switchOpen"
                                                    class="w-full flex items-center gap-3 px-3 py-2 text-xs font-bold text-brand hover:bg-brand/5 rounded-xl transition-all cursor-pointer">
                                                <div class="w-7 h-7 rounded-lg bg-brand/5 flex items-center justify-center border border-brand/20 text-brand">
                                                    {{ ux_icon('lucide:user-cog', {class: 'w-3.5 h-3.5'}) }}
                                                </div>
                                                Switch Account
                                            </button>

                                            <div x-show="switchOpen" x-transition class="p-2 bg-app-bg rounded-xl mt-1 border border-border-color">
                                                <form method="GET" action="{{ path('app_dashboard') }}" class="relative">
                                                    <input type="email" name="_switch_user" placeholder="Enter user email..."
                                                           class="w-full pl-3 pr-8 py-2 bg-white border border-transparent rounded-lg focus:border-brand/20 outline-none text-[10px] font-semibold shadow-inner">
                                                    <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-brand hover:scale-110 transition-transform">
                                                        {{ ux_icon('lucide:arrow-right', {class: 'w-3 h-3'}) }}
                                                    </button>
                                                </form>
                                                <p class="text-[9px] text-gray/50 font-medium mt-2 px-1 italic">Type email to impersonate</p>
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        {# 4. Logout Section #}
                        <div class="p-2 border-t border-border-color bg-app-bg/30">
                            <button @click="$dispatch('open-confirm', {
                                        title: 'Sign Out',
                                        message: 'Are you sure you want to end your session?',
                                        actionUrl: '{{ path('app_logout') }}',
                                        confirmText: 'Sign Out',
                                        isDanger: false
                                    })"
                                    class="w-full flex items-center gap-3 px-3 py-2.5 text-xs font-black uppercase tracking-widest text-red-500 hover:bg-red-50 rounded-xl transition-all cursor-pointer">
                                <div class="w-7 h-7 rounded-lg bg-red-100/50 flex items-center justify-center text-red-500">
                                    {{ ux_icon('lucide:log-out', {class: 'w-3.5 h-3.5'}) }}
                                </div>
                                Sign Out
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <main class="p-6 md:p-10 max-w-[1600px] mx-auto w-full flex-grow">
            {% block main_content %}{% endblock %}
        </main>

        {# Dashboard Footer #}
        <footer class="mt-auto px-6 md:px-10 py-6 border-t border-border-color bg-white/50 backdrop-blur-sm">
            <div class="max-w-[1600px] mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-4 text-[10px] font-semibold text-gray/60 tracking-widest">
                    <span>&copy; {{ "now"|date("Y") }} Mifania Sustainable Fashion Line</span>
                    <span class="hidden md:inline w-1 h-1 bg-gray/30 rounded-full"></span>
                    <span class="hidden md:inline">v1.0.4-beta</span>
                </div>

                <div class="flex items-center gap-6">
                    <a href="#" class="text-[10px] font-bold text-gray hover:text-brand transition-colors tracking-tighter">Support Center</a>
                    <a href="#" class="text-[10px] font-bold text-gray hover:text-brand transition-colors tracking-tighter">Documentation</a>
                    <a href="#" class="text-[10px] font-bold text-gray hover:text-brand transition-colors tracking-tighter">Privacy Policy</a>
                </div>
            </div>
        </footer>

    </div>

    {{ include('components/dashboard/flash/flash_messages.html.twig') }}
    {{ include('components/dashboard/modal/global_confirm.html.twig') }}

    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                // Connect to the specific Admin channel
                const url = new URL('{{ mercure('/notifications/user/' ~ app.user.id)|escape('js') }}');
                const eventSource = new EventSource(url);

                // When a live message arrives from PHP...
                eventSource.onmessage = (event) => {
                    const data = JSON.parse(event.data);

                    // Fire the event that makes the Bell badge tick up +1
                    window.dispatchEvent(new CustomEvent('notify', {
                        detail: {
                            type: data.type || 'success',
                            message: data.message,
                            title: data.title || 'New Notification',
                            targetUrl: data.targetUrl || '#'
                        }
                    }));
                };
            });
        </script>
    {% endif %}
</body>
</html>
