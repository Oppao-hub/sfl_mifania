<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Mifania | Dashboard{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}" />

    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_script_tags('app') }}

    {% block javascripts %}
        <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    {% endblock %}
</head>
<body x-data="{ sidebarOpen: false }" class="bg-app-bg min-h-screen flex text-dark-gray font-sans antialiased overflow-x-hidden">

    {# Mobile Overlay #}
    <div x-show="sidebarOpen"
         x-transition.opacity.duration.300ms
         class="fixed inset-0 bg-brand-dark/40 backdrop-blur-sm z-40 lg:hidden"
         @click="sidebarOpen = false" x-cloak></div>

    {# Sidebar #}
    <aside :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'"
           class="fixed inset-y-0 left-0 w-72 bg-white border-r border-border-color flex flex-col z-50 p-6 shadow-2xl transition-transform duration-300 ease-in-out lg:translate-x-0 lg:sticky lg:h-screen lg:shadow-sm">

        <div class="mb-10 flex items-center justify-between">
            <img src="{{ asset('uploads/logo/logo.svg') }}" alt="MIFANIA" class="h-8 w-auto">
            <button @click="sidebarOpen = false" class="lg:hidden p-2 text-gray hover:bg-row-hover rounded-xl transition-colors">
                {{ ux_icon('lucide:x', {class: 'w-5 h-5'}) }}
            </button>
        </div>

        <nav class="flex-grow space-y-2">
            <a href="{{ path('app_dashboard') }}"
               class="flex items-center space-x-3 p-3.5 rounded-xl transition-all
               {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'bg-brand/10 text-brand shadow-sm' : 'text-gray hover:bg-row-hover hover:text-brand-dark' }}">
                {{ ux_icon('lucide:layout-dashboard', {class: 'w-4 h-4'}) }}
                <span class="font-bold text-xs uppercase tracking-widest">Dashboard</span>
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                {% set menu_items = {
                    'Products': {'icon': 'lucide:package', 'route_prefix': 'app_product_'},
                    'Orders': {'icon': 'lucide:shopping-bag', 'route_prefix': 'app_order_'},
                    'Customers': {'icon': 'lucide:users', 'route_prefix': 'app_customer_'},
                    'Admins': {'icon': 'lucide:user-star', 'route_prefix': 'app_admin_'},
                    'Staffs': {'icon': 'lucide:user-cog', 'route_prefix': 'app_staff_'},
                    'Narratives': {'icon': 'lucide:book-open', 'route_prefix': 'app_story_'},
                    'QR Tags': {'icon': 'lucide:qr-code', 'route_prefix': 'app_qrTag_'},
                    'Inventory': {'icon': 'lucide:boxes', 'route_prefix': 'app_stock_'},
                } %}
            {% else %}
                {% set menu_items = {
                    'Products': {'icon': 'lucide:package', 'route_prefix': 'app_product_'},
                    'Orders': {'icon': 'lucide:shopping-bag', 'route_prefix': 'app_order_'},
                    'Customers': {'icon': 'lucide:users', 'route_prefix': 'app_customer_'},
                } %}
            {% endif %}

            {% for label, item in menu_items %}
                <a href="{{ path(item.route_prefix ~ 'index') }}"
                   class="flex items-center space-x-3 p-3.5 rounded-xl transition-all
                   {{ app.request.attributes.get('_route') starts with item.route_prefix ? 'bg-brand/10 text-brand shadow-sm' : 'text-gray hover:bg-row-hover hover:text-brand-dark' }}">
                    {{ ux_icon(item.icon, {class: 'w-4 h-4'}) }}
                    <span class="font-bold text-xs uppercase tracking-widest">{{ label }}</span>
                </a>
            {% endfor %}
        </nav>

        <div class="mt-auto pt-6 border-t border-border-color space-y-2">
            <a href="#" class="flex items-center space-x-3 p-3.5 rounded-xl text-gray hover:bg-row-hover hover:text-brand-dark transition-all">
                {{ ux_icon('lucide:settings', {class: 'w-4 h-4'}) }}
                <span class="font-bold text-xs uppercase tracking-widest">Settings</span>
            </a>
            <button @click="$dispatch('open-logout-modal')"
                    class="flex items-center w-full text-left p-3.5 rounded-xl gap-3 text-red-500 hover:bg-red-50 hover:text-red-700 transition-colors font-bold uppercase tracking-widest text-xs cursor-pointer">
                {{ ux_icon('lucide:log-out', {class: 'w-4 h-4'}) }}
                <span>Sign out</span>
            </button>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
        <header class="bg-white/80 backdrop-blur-md sticky top-0 z-30 p-4 px-6 lg:px-10 flex justify-between items-center border-b border-border-color gap-4">
            <div class="flex items-center gap-4 flex-1">
                <button @click="sidebarOpen = true" class="lg:hidden p-2 text-brand bg-brand/10 rounded-xl hover:opacity-80 transition-opacity shrink-0">
                    {{ ux_icon('lucide:menu', {class: 'w-5 h-5'}) }}
                </button>

                {# Global Search Form #}
                <form action="{{ path('app_global_search') }}" method="GET" class="relative hidden sm:block w-full max-w-md group">
                    <span class="absolute inset-y-0 left-4 flex items-center text-gray group-focus-within:text-brand transition-colors">
                        {{ ux_icon('lucide:search', {class: 'w-4 h-4'}) }}
                    </span>
                    <input type="search" name="q" placeholder="Search products, orders, or customers..." class="w-full pl-12 pr-4 py-3 bg-app-bg border border-transparent rounded-xl focus:bg-white focus:border-brand/20 focus:ring-4 focus:ring-brand/10 outline-none text-sm font-medium transition-all shadow-inner">
                </form>
            </div>

            {# User Profile #}
            <a href="{{ is_granted('ROLE_ADMIN') ? path('app_admin_account') : path('app_staff_account') }}" class="relative flex items-center gap-3 cursor-pointer group hover:bg-app-bg p-2 pr-4 rounded-xl transition-all shrink-0 border border-transparent hover:border-border-color">
                <div class="text-right hidden md:block">
                    <p class="text-xs font-black text-brand-dark group-hover:text-brand transition-colors uppercase tracking-widest">
                        {% if app.user.admin %}
                            {{ app.user.admin.firstName ? (app.user.admin.firstName ~ ' ' ~ app.user.admin.lastName) : 'Admin' }}
                        {% elseif app.user.staff %}
                            {{ app.user.staff.firstName ? (app.user.staff.firstName ~ ' ' ~ app.user.staff.lastName) : 'Staff' }}
                        {% else %}
                            {{ app.user.userIdentifier }}
                        {% endif %}
                    </p>
                    <p class="text-[9px] text-gray uppercase tracking-[0.2em] font-bold mt-0.5">
                        {% if is_granted('ROLE_ADMIN') %}Administrator{% elseif is_granted('ROLE_STAFF') %}Staff Member{% endif %}
                    </p>
                </div>
                <div class="relative">
                    {% set avatarPath = 'images/default/default_avatar.jpg' %}
                    {% if app.user.admin and app.user.admin.avatar %}
                        {% set avatarPath = 'uploads/admin/avatars/' ~ app.user.admin.avatar %}
                    {% elseif app.user.staff and app.user.staff.avatar %}
                        {% set avatarPath = 'uploads/staff/avatars/' ~ app.user.staff.avatar %}
                    {% endif %}
                    <img src="{{ asset(avatarPath) }}" class="w-10 h-10 rounded-xl object-cover border border-border-color group-hover:border-brand transition-all shadow-sm" alt="Profile" />
                    <span class="absolute -bottom-1 -right-1 block h-3 w-3 rounded-full border-2 border-white bg-green-500 shadow-sm"></span>
                </div>
            </a>
        </header>

        <main class="p-6 md:p-10 max-w-[1600px] mx-auto w-full flex-grow">
            {% block main_content %}{% endblock %}
        </main>
    </div>

    {{ include('components/dashboard/flash/flash_messages.html.twig') }}
    {{ include('components/dashboard/modal/global_confirm.html.twig') }}
</body>
</html>
