{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Manifest: {{ product.name }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_product_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div class="flex flex-col gap-2">
                <h1 class="text-3xl md:text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ product.name }}
                </h1>
                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        Manifest #{{ product.id }}
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Product Specification
                    </span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <a href="{{ path('app_product_edit', { id: product.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Product
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '{{ path('app_product_delete', {id: product.id}) }}',
                        name: '{{ product.name|e('js') }}',
                        token: '{{ csrf_token('delete' ~ product.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Retire Product
                </button>
            {% endif %}
        </div>
    </div>

    {# 2. MASTER UNIFIED CONTAINER #}
    <div class="bg-white rounded-3xl shadow-sm border border-border-color flex flex-col lg:flex-row overflow-hidden">

        {# Left Column: Visuals & QR (Subtle Background) #}
        <div class="w-full lg:w-5/12 p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-border-color bg-app-bg/50 flex flex-col gap-6">

            {# MOVED: Reference Number and Category tags are now here #}
            <div class="flex items-center justify-between border-b border-border-color/50 pb-4">
                <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                    Ref #{{ product.id }}
                </span>
                <span class="px-3 py-1 bg-brand/10 text-brand rounded-lg text-[10px] font-black uppercase tracking-widest border border-brand/20">
                    {{ product.subCategory.name|default('Uncategorized') }}
                </span>
            </div>

            {# Primary Image #}
            <div class="relative rounded-2xl overflow-hidden shadow-sm border border-border-color group bg-white p-2">
                <img
                    src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('uploads/default/default-product.png') }}"
                    alt="{{ product.name }}"
                    class="rounded-xl w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                />
            </div>

            {# Digital Identity / QR Code #}
            <div class="bg-white p-6 rounded-2xl border border-border-color shadow-sm flex items-center justify-between mt-2">
                <div class="max-w-[55%]">
                    <h3 class="text-[10px] font-black text-brand-dark uppercase tracking-[0.2em] mb-1.5 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></span>
                        Digital Identity
                    </h3>
                    <p class="text-[10px] text-gray leading-relaxed font-bold italic">
                        Encoded provenance for ethical tracking.
                    </p>
                </div>

                <div class="relative shrink-0">
                    {% if product.qrTag and product.qrTag.qrImagePath %}
                        <img src="{{ asset('uploads/qrcodes/' ~ product.qrTag.qrImagePath) }}"
                             class="w-20 h-20 rounded-xl border border-border-color p-2 shadow-inner bg-white">
                    {% else %}
                        <div class="w-20 h-20 rounded-xl bg-app-bg flex flex-col items-center justify-center border border-dashed border-border-color">
                            {{ ux_icon('lucide:qr-code', {class: 'w-5 h-5 text-gray/40 mb-1'}) }}
                            <span class="text-[7px] uppercase font-black tracking-widest text-gray/50">No Tag</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Right Column: Specifications & Data #}
        <div class="w-full lg:w-7/12 p-8 md:p-12 flex flex-col">

            {# Data Header #}
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-border-color pb-8">
                <div>
                    <h2 class="text-2xl font-black text-brand-dark tracking-tighter leading-tight uppercase">Specifications</h2>
                    <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1.5 italic">Sustainable Production Record</p>
                </div>

                <div class="px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm border
                    {% if product.totalStockQuantity > 50 %} bg-success/10 text-success border-success/20
                    {% elseif product.totalStockQuantity > 10 %} bg-warning/10 text-warning border-warning/20
                    {% else %} bg-danger/10 text-danger border-danger/20 {% endif %}">
                    {{ product.stockStatus }} • {{ product.totalStockQuantity }} in stock
                </div>
            </div>

            {# Information Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Retail Price</label>
                    <span class="text-3xl font-black text-brand leading-none tracking-tighter">₱{{ product.price|number_format(2) }}</span>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Archival Cost</label>
                    <span class="text-xl font-bold text-gray italic leading-none tracking-tighter">₱{{ product.cost|number_format(2) }}</span>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Primary Material</label>
                    <p class="text-sm font-bold text-brand-dark">{{ product.material }}</p>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Size Scale</label>
                    <p class="text-sm font-bold text-brand-dark uppercase">{{ product.size.value }}</p>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Color Palette</label>
                    <div class="flex items-center gap-3">
                        <span class="h-5 w-5 rounded-full border border-border-color shadow-inner" style="background-color: {{ product.color.value }};"></span>
                        <p class="text-sm font-bold text-brand-dark capitalize">{{ product.color.value }}</p>
                    </div>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Eco Initiative</label>
                    <p class="text-sm font-bold text-brand flex items-center gap-2">
                        {{ ux_icon('lucide:leaf', {class: 'w-4 h-4'}) }}
                        {{ product.ecoInfo ?: 'Standard Production' }}
                    </p>
                </div>
            </div>

            {# Spacer to push narrative to bottom if the grid is short #}
            <div class="flex-grow"></div>

            {# Product Narrative Section #}
            <div class="mt-12 pt-8 border-t border-border-color">
                <label class="text-[9px] uppercase font-black tracking-[0.3em] text-brand block mb-4 flex items-center gap-2">
                    {{ ux_icon('lucide:book-open', {class: 'w-3 h-3'}) }}
                    The Narrative
                </label>
                <div class="bg-app-bg p-6 rounded-2xl border border-border-color shadow-inner">
                    <p class="text-sm leading-relaxed text-dark-gray italic font-medium">
                        "{{ product.description ?: 'No narrative description provided for this collection piece.' }}"
                    </p>
                </div>
            </div>

            {# Archival Metadata #}
            <div class="mt-8 flex items-center justify-between text-gray/40 border-t border-border-color pt-6">
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Cataloged: {{ product.createdAt|date('d.m.Y') }}
                </div>
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Revised: {{ product.updatedAt|date('d.m.Y') }}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
