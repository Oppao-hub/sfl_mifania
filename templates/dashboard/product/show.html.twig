{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Manifest: {{ product.name }}{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# 1. TOP NAVIGATION & ACTION HEADER #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_product_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ product.name }}
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Inventory Ref #{{ product.id }}</span>
                    <span class="px-2 py-0.5 bg-app-bg text-gray rounded-md text-[10px] font-bold uppercase tracking-tighter border border-border-color">{{ product.category.name|default('Uncategorized') }}</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_product_edit', { id: product.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Product
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click="$dispatch('open-delete-modal', {
                        url: '{{ path('app_product_delete', {id: product.id}) }}',
                        name: '{{ product.name|e('js') }}',
                        token: '{{ csrf_token('delete' ~ product.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Retire Product
                </button>
            {% endif %}
        </div>
    </div>

    {# 2. MAIN CONTENT GRID #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">

        {# Left Column: Visual & Identity #}
        <div class="lg:col-span-5 space-y-8">

            {# Primary Image Card #}
            <div class="relative bg-white p-2 rounded-2xl shadow-sm border border-border-color group overflow-hidden">
                <img
                    src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('uploads/default/default-product.png') }}"
                    alt="{{ product.name }}"
                    class="rounded-xl w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                />
            </div>

            {# Provenance / QR Card #}
            <div class="bg-white p-8 rounded-2xl border border-border-color shadow-sm flex items-center justify-between">
                <div class="max-w-[60%]">
                    <h3 class="text-[10px] font-black text-brand-dark uppercase tracking-[0.2em] mb-2 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-brand"></span>
                        Digital Identity
                    </h3>
                    <p class="text-xs text-gray leading-relaxed font-medium italic">Encoded provenance for ethical verification and tracking.</p>
                </div>

                <div class="relative">
                    {% if product.qrTag and product.qrTag.qrImagePath %}
                        <img src="{{ asset('uploads/qrcodes/' ~ product.qrTag.qrImagePath) }}"
                             class="w-24 h-24 rounded-xl border border-border-color p-2 shadow-inner bg-white">
                    {% else %}
                        <div class="w-24 h-24 rounded-xl bg-app-bg flex flex-col items-center justify-center border border-dashed border-border-color">
                            {{ ux_icon('lucide:qr-code', {class: 'w-6 h-6 text-gray/40 mb-1'}) }}
                            <span class="text-[8px] uppercase font-black tracking-widest text-gray/50">No Tag</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Right Column: Specifications #}
        <div class="lg:col-span-7 bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">
            <div class="p-8 md:p-12">

                {# Header Section #}
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-border-color pb-8">
                    <div>
                        <h2 class="text-2xl font-black text-brand-dark tracking-tighter leading-tight uppercase">Specifications</h2>
                        <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1.5 italic">Sustainable Production Record</p>
                    </div>

                    <div class="px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm border
                        {% if product.totalStockQuantity > 50 %} bg-success/10 text-success border-success/20
                        {% elseif product.totalStockQuantity > 10 %} bg-warning/10 text-warning border-warning/20
                        {% else %} bg-danger/10 text-danger border-danger/20 {% endif %}">
                        {{ product.stockStatus }} • {{ product.totalStockQuantity }} in stock
                    </div>
                </div>

                {# Information Grid #}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Retail Price</label>
                        <span class="text-2xl font-black text-brand leading-none tracking-tighter">₱{{ product.price|number_format(2) }}</span>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Category</label>
                        <p class="text-sm font-bold text-brand-dark">{{ product.category.name|default('—') }}</p>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Primary Material</label>
                        <p class="text-sm font-bold text-brand-dark">{{ product.material }}</p>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Size Scale</label>
                        <p class="text-sm font-bold text-brand-dark uppercase">{{ product.size.value }}</p>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Color Palette</label>
                        <div class="flex items-center gap-3">
                            <span class="h-5 w-5 rounded-full border border-border-color shadow-inner" style="background-color: {{ product.color.value }};"></span>
                            <p class="text-sm font-bold text-brand-dark capitalize">{{ product.color.value }}</p>
                        </div>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Archival Cost</label>
                        <p class="text-sm font-bold text-gray italic">₱{{ product.cost|number_format(2) }}</p>
                    </div>

                    <div class="md:col-span-2">
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Eco Initiative</label>
                        <p class="text-sm font-bold text-brand flex items-center gap-2">
                            {{ ux_icon('lucide:leaf', {class: 'w-4 h-4'}) }}
                            {{ product.ecoInfo ?: 'Standard Production' }}
                        </p>
                    </div>
                </div>

                {# Product Narrative Section #}
                <div class="mt-12 pt-10 border-t border-border-color relative">
                    <label class="absolute -top-3 left-8 bg-white px-4 text-[9px] uppercase font-black tracking-[0.3em] text-gray italic">The Narrative</label>
                    <div class="bg-app-bg p-8 rounded-xl border border-border-color">
                        <p class="text-sm leading-relaxed text-dark-gray italic font-medium">
                            "{{ product.description ?: 'No narrative description provided for this collection piece.' }}"
                        </p>
                    </div>
                </div>

                {# Archival Metadata #}
                <div class="mt-12 flex flex-wrap gap-8 text-gray/50">
                    <div class="text-[9px] uppercase font-black tracking-widest">
                        Cataloged: {{ product.createdAt|date('d.m.Y') }}
                    </div>
                    <div class="text-[9px] uppercase font-black tracking-widest">
                        Revised: {{ product.updatedAt|date('d.m.Y') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
