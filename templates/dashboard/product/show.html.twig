{# templates/dashboard/product/show.html.twig #}
{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Product: {{ product.name }}{% endblock %}

{% block main_content %}
<div class="p-4 md:p-10 animate-fadeIn">

    {# 1. Top Navigation & Action Header #}
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            {# Back Button #}
            <a href="{{ path('app_dashboard_product_index') }}"
               class="p-3 bg-white rounded-xl border border-cream-200 text-dashboard-mocha hover:text-dashboard-olive hover:border-dashboard-olive/30 transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-dashboard-mocha tracking-tighter leading-none uppercase">
                    {{ product.name }}
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-dashboard-mocha/40 uppercase font-black tracking-widest italic">Inventory Ref</span>
                    <span class="px-2 py-0.5 bg-dashboard-bg text-dashboard-mocha/60 rounded-md text-[10px] font-bold font-mono">#{{ product.id }}</span>
                </div>
            </div>
        </div>

        {# Action Cluster #}
        <div class="flex items-center gap-3">
             <a href="{{ path('app_dashboard_product_edit', { id: product.id }) }}"
               class="px-6 py-3 bg-dashboard-olive text-white text-xs font-black uppercase tracking-widest rounded-xl hover:bg-dashboard-mocha transition-all shadow-xl shadow-dashboard-olive/10 flex items-center gap-2 active:scale-95">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Edit Product
            </a>
            <button type="button"
                @click="$dispatch('open-delete-modal', {
                    url: '{{ path('app_dashboard_product_delete', {id: product.id}) }}',
                    name: '{{ product.name|e('js') }}',
                    token: '{{ csrf_token('delete' ~ product.id) }}'
                })"
                class="px-6 py-3 bg-white border border-red-100 text-red-500 text-xs font-black uppercase tracking-widest rounded-xl hover:bg-red-50 transition-all flex items-center gap-2 active:scale-95">
                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                Delete
            </button>
        </div>
    </div>

    {# 2. Main Content Grid #}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">

        {# Left Column: Visual & Identity #}
        <div class="lg:col-span-5 space-y-8">
            {# Primary Image Card #}
            <div class="relative bg-white p-3 rounded-xl shadow-[0_20px_50px_rgba(62,50,43,0.08)] border border-cream-200 group overflow-hidden">
                <img
                    src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('images/default-product.png') }}"
                    alt="{{ product.name }}"
                    class="rounded-lg w-full aspect-[4/5] object-cover transition-transform duration-700 group-hover:scale-105"
                />
            </div>

            {# Provenance / QR Card #}
            <div class="bg-white p-8 rounded-xl border border-cream-200 shadow-sm flex items-center justify-between">
                <div class="max-w-[60%]">
                    <h3 class="text-xs font-black text-dashboard-mocha uppercase tracking-widest mb-2 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-dashboard-olive"></span>
                        Digital Identity
                    </h3>
                    <p class="text-[11px] text-gray-400 leading-relaxed font-medium italic">Encoded provenance for ethical verification and inventory tracking.</p>
                </div>

                <div class="relative">
                    {% if product.qrTag and product.qrTag.qrImagePath %}
                        <img src="{{ asset('uploads/qrcodes/' ~ product.qrTag.qrImagePath) }}"
                             class="w-24 h-24 rounded-lg border border-gray-100 p-2 shadow-inner bg-white">
                    {% else %}
                        <div class="w-24 h-24 rounded-lg bg-dashboard-bg flex flex-col items-center justify-center border border-dashed border-gray-300">
                            {{ ux_icon('lucide:qr-code', {class: 'w-6 h-6 text-gray-300 mb-1'}) }}
                            <span class="text-[8px] uppercase font-black text-gray-400">No QR</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="lg:col-span-7 bg-white rounded-xl shadow-[0_20px_50px_rgba(66,43,28,0.05)] border border-cream-200 overflow-hidden">
            <div class="p-10 md:p-12">

                {# Header Section #}
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-gray-100 pb-8">
                    <div>
                        <h2 class="text-2xl font-black text-dashboard-mocha tracking-tighter leading-tight uppercase">Details</h2>
                        <p class="text-[10px] uppercase font-black tracking-[0.2em] text-dashboard-mocha/30 mt-1 italic">Sustainable Production Record</p>
                    </div>
                    <div class="px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-inner
                        {% if product.totalStockQuantity > 50 %} bg-green-50 text-green-700
                        {% elseif product.totalStockQuantity > 10 %} bg-orange-50 text-orange-700
                        {% else %} bg-red-50 text-red-700 {% endif %}">
                        {{ product.stockStatus }} • {{ product.totalStockQuantity }} items
                    </div>
                </div>

                {# Information Grid #}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                    <div>
                        <label class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/30 block mb-2">MSRP</label>
                        <span class="text-2xl font-black text-dashboard-olive leading-none tracking-tighter">₱{{ product.price|number_format(2) }}</span>
                    </div>

                    <div>
                        <label class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/30 block mb-2">Category</label>
                        <p class="text-sm font-bold text-dashboard-mocha">{{ product.category.name }}</p>
                    </div>

                    <div>
                        <label class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/30 block mb-2">Primary Material</label>
                        <p class="text-sm font-bold text-dashboard-mocha">{{ product.material }}</p>
                    </div>

                    <div>
                        <label class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/30 block mb-2">Size Scale</label>
                        <p class="text-sm font-bold text-dashboard-mocha uppercase">{{ product.size.value }}</p>
                    </div>

                    <div>
                        <label class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/30 block mb-2">Color Palette</label>
                        <div class="flex items-center gap-3">
                            <span class="h-5 w-5 rounded-full border border-gray-100 shadow-sm" style="background-color: {{ product.color.value }};"></span>
                            <p class="text-sm font-bold text-dashboard-mocha capitalize">{{ product.color.value }}</p>
                        </div>
                    </div>

                    <div>
                        <label class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/30 block mb-2">Archival Cost</label>
                        <p class="text-sm font-bold text-gray-400 italic">₱{{ product.cost|number_format(2) }}</p>
                    </div>

                    <div>
                        <label class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/30 block mb-2">Eco Initiative</label>
                        <p class="text-sm font-bold text-dashboard-olive">{{ product.ecoInfo ?: 'Standard Production' }}</p>
                    </div>
                </div>

                {# Product Story Section #}
                <div class="mt-14 pt-10 border-t border-gray-100 relative">
                    <label class="absolute -top-3 left-8 bg-white px-4 text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-mocha/20 italic">The Story</label>
                    <div class="bg-dashboard-bg/20 p-8 rounded-xl border border-dashboard-bg">
                        <p class="text-sm leading-relaxed text-dashboard-mocha/70 italic font-medium">
                            "{{ product.description ?: 'No narrative description provided for this collection piece.' }}"
                        </p>
                    </div>
                </div>

                {# Archival Metadata #}
                <div class="mt-12 flex flex-wrap gap-8 opacity-40">
                    <div class="text-[9px] uppercase font-black tracking-widest">
                        Cataloged: {{ product.createdAt|date('d.m.Y') }}
                    </div>
                    <div class="text-[9px] uppercase font-black tracking-widest">
                        Revised: {{ product.updatedAt|date('d.m.Y') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
