{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Product Inventory | Mifania{% endblock %}

{% block main_content %}
    <div class="animate-fadeIn">
        {% embed 'components/table/table.html.twig' with {
            title: 'Manage Products',
            icon: 'lucide:shopping-bag',
            entity_name: 'Product',
            total_count: total_products|default(0),
            new_path: 'app_product_new',
            headers: ['ID', 'Product Details', 'Color', 'Price', 'Actions']
        } %}

        {% block rows %}
            {% for product in products %}
                <tr class="hover:bg-row-hover transition-colors group">
                    <td class="px-6 py-4 text-xs font-mono text-gray">
                        #{{ product.id }}
                    </td>
                    <td class="px-3 py-4">
                        <div class="flex items-center gap-4">
                            <div class="h-10 w-10 rounded-lg overflow-hidden border border-border-color bg-white shadow-sm shrink-0 p-0.5">
                                <img src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('uploads/default/default-product.png') }}"
                                     class="h-full w-full object-cover rounded-md" alt="{{ product.name }}">
                            </div>
                            <div>
                                <div class="font-bold text-sm text-brand-dark leading-tight">{{ product.name }}</div>
                                <div class="text-[9px] text-gray uppercase font-black tracking-widest mt-1">
                                    {{ product.subCategory.name|default('Uncategorized') }}
                                </div>
                            </div>
                        </div>
                    </td>
                    <td class="px-3 py-4">
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full border border-border-color shadow-inner"
                                  style="background-color: {{ product.color.value|default('#eee') }};"></span>
                            <span class="text-sm font-bold text-dark-gray capitalize">{{ product.color.value|default('—') }}</span>
                        </div>
                    </td>
                    <td class="px-3 py-4 text-brand font-black text-sm">₱{{ product.price|number_format(2) }}</td>
                    <td class="px-3 py-4">
                        <div class="flex items-center gap-2">

                            <a href="{{ path('app_product_show', { id: product.id }) }}" title="View"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                            </a>

                            <a href="{{ path('app_product_edit', { id: product.id }) }}" title="Edit"
                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                                {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <button type="button" title="Delete"
                                    @click.stop="$dispatch('open-delete-modal', {
                                        url: '{{ path('app_product_delete', {id: product.id}) }}',
                                        name: 'Product: {{ product.name|e('js') }}',
                                        token: '{{ csrf_token('delete' ~ product.id) }}'
                                    })"
                                    class="p-2 text-terracotta hover:text-danger hover:bg-red-50 bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer">
                                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                                </button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="px-6 py-12 text-center text-gray font-medium">
                        <div class="flex flex-col items-center justify-center gap-3">
                            {{ ux_icon('lucide:shopping-bag', {class: 'w-8 h-8 opacity-20'}) }}
                            <p>No products found in the inventory.</p>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        {% endblock %}
        {% endembed %}
    </div>
{% endblock %}
