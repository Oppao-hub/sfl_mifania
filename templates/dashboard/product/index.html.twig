{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Product Inventory{% endblock %}

{% block main_content %}
    {% embed 'components/table/table.html.twig' with {
        title: 'Manage Products',
        total_count: total_products,
        new_path: 'app_product_new',
        headers: ['ID', 'Product Details', 'Gender', 'Size', 'Color', 'Price', 'Cost', 'Actions'],
        id: 'dashboard-table'
    } %}

    {% block rows %}
        {% for product in products %}
            <tr class="hover:bg-row-hover transition-colors group">
                <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray">
                    #{{ product.id }}
                </td>

                <td class="border-y border-border-color px-4 py-3 text-sm">
                    <div class="flex items-center gap-4">
                        <div class="h-12 w-12 rounded-xl overflow-hidden border border-border-color bg-app-bg shadow-sm shrink-0 p-0.5">
                            <img src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('uploads/default/default-product.png') }}" class="h-full w-full object-cover rounded-lg">
                        </div>
                        <div>
                            <div class="font-bold text-brand-dark">{{ product.name }}</div>
                            <div class="text-[9px] text-gray uppercase font-black tracking-widest mt-0.5">{{ product.category.name|default('Uncategorized') }}</div>
                        </div>
                    </div>
                </td>

                <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-dark-gray">{{ product.gender.value }}</td>
                <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-dark-gray">{{ product.size.value }}</td>
                <td class="border-y border-border-color px-4 py-3 text-sm">
                    <div class="flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full border border-border-color shadow-inner" style="background-color: {{ product.color.value }};"></span>
                        <span class="font-bold text-dark-gray capitalize">{{ product.color.value }}</span>
                    </div>
                </td>

                <td class="border-y border-border-color px-4 py-3 text-brand font-black text-sm">₱{{ product.price|number_format(2) }}</td>
                <td class="border-y border-border-color px-4 py-3 text-gray font-bold text-sm italic">₱{{ product.cost|number_format(2) }}</td>

                <td class="border-y border-border-color px-4 py-3 text-center">
                    <div class="flex justify-center items-center gap-2">
                        <a  href="{{ path('app_product_show', { id: product.id }) }}"
                            class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">{{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}</a>

                        <a  href="{{ path('app_product_edit', { id: product.id }) }}"
                            class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">{{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <button type="button"
                                @click="$dispatch('open-delete-modal', { url: '{{ path('app_product_delete', {id: product.id}) }}', name: 'Product {{ product.name|e('js') }}', token: '{{ csrf_token('delete' ~ product.id) }}' })"
                                class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer">{{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                            </button>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% endfor %}
    {% endblock %}
    {% endembed %}
{% endblock %}
