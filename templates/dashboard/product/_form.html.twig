{% form_theme form 'form/error_theme.html.twig' %}

{% set label_style = 'text-[10px] uppercase font-black tracking-[0.2em] text-gray ml-1 block mb-2' %}
{% set input_base = 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none text-sm font-bold text-brand-dark transition-all shadow-inner' %}
{% set select_style = 'boutique-select ' ~ input_base %}

{{ form_start(form, {'attr': {'class': 'relative space-y-8', 'novalidate': 'novalidate'}}) }}

    {# --- STICKY HEADER --- #}
    <div class="sticky top-24 z-40 bg-white/90 backdrop-blur-md border border-border-color rounded-2xl p-6 shadow-sm flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-brand animate-pulse"></div>
            <div>
                <h1 class="text-xl font-black text-brand-dark tracking-tighter uppercase leading-none">
                    {{ form.vars.value.name|default('New Product') }}
                </h1>
                <p class="text-[9px] text-gray mt-1 uppercase font-black tracking-[0.3em]">Spec. Manifest #{{ form.vars.value.id|default('000') }}</p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <a href="{{ path('app_product_index') }}"
               class="px-5 py-3 text-[10px] font-black uppercase tracking-widest text-gray border border-border-color bg-white hover:bg-row-hover hover:text-brand-dark rounded-xl transition-all cursor-pointer">
                Discard
            </a>
            <button type="submit"
                    class="px-8 py-3 bg-brand text-white rounded-xl font-black text-[10px] uppercase tracking-[0.2em] shadow-md shadow-brand/20 hover:bg-brand-dark transition-all active:scale-95 cursor-pointer">
                {{ button_label|default('Save Manifest') }}
            </button>
        </div>
    </div>

    {# --- MAIN FORM CARD --- #}
    <div class="bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">

        {# SECTION 1: Taxonomy #}
        <div class="p-8 md:p-10 border-b border-border-color grid grid-cols-1 md:grid-cols-2 gap-8">
            {% for field in [form.name, form.subCategory] %}
                <div>
                    {{ form_label(field, null, { label_attr: {'class': label_style} }) }}
                    {{ form_widget(field, {'attr': {'class': field.vars.block_prefixes.1 == 'choice' ? select_style : input_base}}) }}
                    <div class="mt-2">{{ form_errors(field) }}</div>
                </div>
            {% endfor %}
        </div>

        {# SECTION 2: Physical Attributes #}
        <div class="p-8 md:p-10 bg-app-bg border-b border-border-color grid grid-cols-1 md:grid-cols-4 gap-6">
            {% for field in [form.material, form.size, form.color] %}
                <div>
                    {{ form_label(field, null, { label_attr: {'class': label_style} }) }}
                    {{ form_widget(field, {'attr': {'class': select_style}}) }}
                    <div class="mt-2">{{ form_errors(field) }}</div>
                </div>
            {% endfor %}
        </div>

        {# SECTION 3: Financials #}
        <div class="p-8 md:p-10 border-b border-border-color grid grid-cols-1 md:grid-cols-2 gap-8">
            {% for field in [form.price, form.cost] %}
                <div>
                    {{ form_label(field, null, { label_attr: {'class': label_style} }) }}
                    <div class="relative group">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray font-black group-focus-within:text-brand transition-colors">₱</span>
                        {{ form_widget(field, {'attr': {'class': input_base ~ ' pl-10'}}) }}
                    </div>
                    <div class="mt-2">{{ form_errors(field) }}</div>
                </div>
            {% endfor %}
        </div>

        {# SECTION 4: NARRATIVE & SUSTAINABILITY #}
        <div class="p-8 md:p-10 border-b border-border-color space-y-8 bg-app-bg">
            <div>
                {{ form_label(form.description, null, { label_attr: {'class': label_style} }) }}
                {{ form_widget(form.description, {'attr': {'class': input_base ~ ' min-h-[150px] italic leading-relaxed bg-white', 'placeholder': 'Describe the collection piece...'}}) }}
                <div class="mt-2">{{ form_errors(form.description) }}</div>
            </div>
            <div>
                {{ form_label(form.ecoInfo, 'Sustainability Impact (Eco Info)', { label_attr: {'class': label_style ~ ' text-brand'} }) }}
                <div class="relative">
                    <div class="absolute left-4 top-4 text-brand/40">{{ ux_icon('lucide:leaf', {class: 'w-4 h-4'}) }}</div>
                    {{ form_widget(form.ecoInfo, {'attr': {'class': input_base ~ ' pl-12 bg-brand/5 border-brand/20 italic text-brand placeholder:text-brand/50', 'placeholder': 'Materials used, ethical sourcing details...'}}) }}
                </div>
                <div class="mt-2">{{ form_errors(form.ecoInfo) }}</div>
            </div>
            <div>
                {{ form_label(form.story, 'Transparency Narrative', { label_attr: {'class': label_style ~ ' text-brand'} }) }}
                <div class="relative">
                    <div class="absolute left-4 top-4 text-brand/40">{{ ux_icon('lucide:book-open', {class: 'w-4 h-4'}) }}</div>
                    {{ form_widget(form.story, {'attr': {'class': select_style ~ ' pl-12 bg-brand/5 border-brand/20 text-brand font-bold'}}) }}
                </div>
                <div class="mt-2">{{ form_errors(form.story) }}</div>
            </div>
        </div>

        {# SECTION 5: Media #}
        <div class="p-8 md:p-10 grid grid-cols-1 md:grid-cols-12 gap-10 bg-white">
            {% if form.vars.value and form.vars.value.image %}
                <div class="md:col-span-3">
                    <label class="{{ label_style }}">Current Visual</label>
                    <div class="aspect-square rounded-xl overflow-hidden border border-border-color p-1 shadow-sm mt-2">
                        <img src="{{ asset('uploads/products/' ~ form.vars.value.image) }}" class="w-full h-full object-cover rounded-lg">
                    </div>
                </div>
            {% endif %}

            <div class="{{ form.vars.value and form.vars.value.image ? 'md:col-span-9' : 'md:col-span-12' }}">
                <label class="{{ label_style }}">Update Imagery</label>
                <div class="bg-app-bg border-2 border-dashed border-border-color rounded-2xl p-8 hover:border-brand/30 transition-all cursor-pointer">
                    {{ form_widget(form.image, {'attr': {'class': 'text-xs text-gray file:mr-6 file:py-2.5 file:px-6 file:rounded-xl file:border-0 file:text-[10px] file:font-black file:uppercase file:tracking-widest file:bg-brand/10 file:text-brand hover:file:bg-brand hover:file:text-white transition-all cursor-pointer'}}) }}
                    <div class="mt-4">{{ form_errors(form.image) }}</div>
                </div>
            </div>
        </div>
    </div>

{{ form_end(form) }}
