{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Customers Analytics | Mifania Dashboard{% endblock %}

{% block main_content %}
<div class="space-y-6 animate-fadeIn">

    {# Header #}
    <div class="flex justify-between items-end mb-8">
        <div>
            <h1 class="text-2xl font-black text-brand-dark tracking-tighter">Customers Analytics</h1>
            <p class="text-[10px] font-bold uppercase tracking-widest text-gray mt-1">Mifania » Analytics » Customers</p>
        </div>
    </div>

    {# ROW 1: Summary Stats #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color flex justify-between items-center group hover:shadow-md transition-shadow">
            <div>
                <h3 class="text-sm font-black text-brand-dark mb-1">Total Customers</h3>
                <div class="flex items-baseline gap-1">
                    <span class="text-2xl font-black text-brand-dark tracking-tight">{{ stats.totalCustomers|number_format }}</span>
                </div>
            </div>
            <div class="w-14 h-14 rounded-full bg-brand/5 flex items-center justify-center shadow-inner group-hover:scale-105 transition-transform">
                {{ ux_icon('lucide:users', {class: 'w-6 h-6 text-brand'}) }}
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color flex justify-between items-center group hover:shadow-md transition-shadow">
            <div>
                <h3 class="text-sm font-black text-brand-dark mb-1">New This Month</h3>
                <div class="flex items-baseline gap-1">
                    <span class="text-2xl font-black text-brand-dark tracking-tight">{{ stats.newCustomers|number_format }}</span>
                </div>
            </div>
            <div class="w-14 h-14 rounded-full bg-success/5 flex items-center justify-center shadow-inner group-hover:scale-105 transition-transform">
                {{ ux_icon('lucide:user-plus', {class: 'w-6 h-6 text-success'}) }}
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color flex justify-between items-center group hover:shadow-md transition-shadow">
            <div>
                <h3 class="text-sm font-black text-brand-dark mb-1">Total Reward Points</h3>
                <div class="flex items-baseline gap-1">
                    <span class="text-2xl font-black text-brand-dark tracking-tight">{{ stats.totalPoints|number_format }}</span>
                </div>
            </div>
            <div class="w-14 h-14 rounded-full bg-warning/5 flex items-center justify-center shadow-inner group-hover:scale-105 transition-transform">
                {{ ux_icon('lucide:coins', {class: 'w-6 h-6 text-warning'}) }}
            </div>
        </div>
    </div>

    {# ROW 2: Charts #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Left: Customer Growth Chart #}
        <div class="lg:col-span-2 bg-white p-8 rounded-2xl shadow-sm border border-border-color flex flex-col">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest">Registration Growth</h2>
                <span class="text-[10px] font-bold text-gray uppercase">Last 6 Months</span>
            </div>

            {# Chart Container #}
            <div class="w-full flex-1 min-h-[300px]">
                {{ render_chart(regChart) }}
            </div>
        </div>

        {# Right: City Distribution #}
        <div class="lg:col-span-1 bg-white p-8 rounded-2xl shadow-sm border border-border-color flex flex-col">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest">Top Cities</h2>
            </div>

            {# Chart Container #}
            <div class="w-full flex-1 min-h-[300px] flex items-center justify-center">
                {{ render_chart(cityChart) }}
            </div>
        </div>
    </div>

    {# ROW 3: Ranking Tables #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        {# Top Spenders #}
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-border-color">
            <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest border-b border-border-color pb-4 mb-6">Top 5 Spenders</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr>
                            <th class="py-3 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color rounded-l-xl">Customer</th>
                            <th class="py-3 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color text-right rounded-r-xl">Total Spent</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-color">
                        {% for spender in topSpenders %}
                            <tr class="hover:bg-app-bg/50 transition-colors">
                                <td class="py-4 px-4 text-sm font-bold text-brand-dark">{{ spender.firstName }} {{ spender.lastName }}</td>
                                <td class="py-4 px-4 text-sm font-black text-brand-dark text-right">₱{{ spender.totalSpent|number_format(2) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Top Reward Holders #}
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-border-color">
            <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest border-b border-border-color pb-4 mb-6">Top 5 Reward Points</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr>
                            <th class="py-3 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color rounded-l-xl">Customer</th>
                            <th class="py-3 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color text-right rounded-r-xl">Points</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-color">
                        {% for holder in topRewardHolders %}
                            <tr class="hover:bg-app-bg/50 transition-colors">
                                <td class="py-4 px-4 text-sm font-bold text-brand-dark">{{ holder.firstName }} {{ holder.lastName }}</td>
                                <td class="py-4 px-4 text-sm font-black text-warning text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        {{ ux_icon('lucide:star', {class: 'w-3 h-3'}) }}
                                        {{ holder.wallet.rewardPoints|number_format }}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ROW 4: Recent Customers #}
    <div class="bg-white p-8 rounded-2xl shadow-sm border border-border-color">
        <div class="mb-6">
            <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest border-b border-border-color pb-4">Recent Registrations</h2>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr>
                        <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color rounded-l-xl">Customer</th>
                        <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color">City</th>
                        <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color">Contact</th>
                        <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color rounded-r-xl">Member Since</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-color">
                    {% for customer in recentCustomers %}
                        <tr class="hover:bg-app-bg/50 transition-colors">
                            <td class="py-4 px-4 flex items-center gap-4">
                                {% set avatar = customer.avatar ? asset('uploads/customer/avatars/' ~ customer.avatar) : asset('uploads/default/default-avatar.jpg') %}
                                <img src="{{ avatar }}" alt="{{ customer.firstName }}" class="w-10 h-10 rounded-full border border-border-color object-cover shadow-sm">
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold text-brand-dark leading-tight">{{ customer.firstName }} {{ customer.lastName }}</span>
                                    <span class="text-[9px] font-bold text-gray uppercase tracking-widest">{{ customer.user.email|default('') }}</span>
                                </div>
                            </td>
                            <td class="py-4 px-4 text-xs font-medium text-gray">{{ customer.city|default('N/A') }}</td>
                            <td class="py-4 px-4 text-xs font-medium text-gray">{{ customer.contactNumber|default('N/A') }}</td>
                            <td class="py-4 px-4 text-xs font-bold text-brand-dark">{{ customer.createdAt|date('M d, Y') }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
