{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Manifest: {{ story.title }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_story_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:bg-brand/10 hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div class="flex flex-col gap-2">
                <h1 class="text-3xl md:text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ story.title }}
                </h1>
                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Narrative Ref #{{ story.id }}</span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">Brand Registry</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_story_edit', { id: story.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Modify Narrative
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '{{ path('app_story_delete', {id: story.id}) }}',
                        name: 'Narrative: {{ story.title|e('js') }}',
                        token: '{{ csrf_token('delete' ~ story.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-border-color overflow-hidden flex flex-col">

        <div class="p-8 md:p-10 border-b border-border-color bg-app-bg/50 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-white rounded-lg text-brand border border-border-color shadow-sm">
                    {{ ux_icon('lucide:book-open', {class: 'w-5 h-5'}) }}
                </div>
                <div>
                    <h2 class="text-xl font-black text-brand-dark tracking-tighter uppercase">The Three Pillars of Transparency</h2>
                    <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1 italic">Manifest Core Contents</p>
                </div>
            </div>
        </div>

        <div class="p-8 md:p-12 grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

            <div>
                <h3 class="text-[10px] uppercase font-black tracking-[0.3em] text-gray flex items-center gap-2 mb-6 border-b border-border-color pb-4">
                    {{ ux_icon('lucide:leaf', {class: 'w-4 h-4 text-brand'}) }} Raw Materials
                </h3>
                <p class="text-sm leading-relaxed text-brand-dark italic font-medium">
                    {% if story.materialContent %}
                        {{ story.materialContent|nl2br }}
                    {% else %}
                        <span class="text-gray/50 not-italic font-normal">No material content written.</span>
                    {% endif %}
                </p>
            </div>

            <div>
                <h3 class="text-[10px] uppercase font-black tracking-[0.3em] text-gray flex items-center gap-2 mb-6 border-b border-border-color pb-4">
                    {{ ux_icon('lucide:scissors', {class: 'w-4 h-4 text-brand'}) }} Ethical Craft
                </h3>
                <p class="text-sm leading-relaxed text-brand-dark italic font-medium">
                    {% if story.artisanContent %}
                        {{ story.artisanContent|nl2br }}
                    {% else %}
                        <span class="text-gray/50 not-italic font-normal">No artisan content written.</span>
                    {% endif %}
                </p>
            </div>

            <div>
                <h3 class="text-[10px] uppercase font-black tracking-[0.3em] text-gray flex items-center gap-2 mb-6 border-b border-border-color pb-4">
                    {{ ux_icon('lucide:droplet', {class: 'w-4 h-4 text-brand'}) }} Eco-Dyeing
                </h3>
                <p class="text-sm leading-relaxed text-brand-dark italic font-medium">
                    {% if story.dyeingContent %}
                        {{ story.dyeingContent|nl2br }}
                    {% else %}
                        <span class="text-gray/50 not-italic font-normal">No dyeing content written.</span>
                    {% endif %}
                </p>
            </div>

        </div>
    </div>
</div>
{% endblock %}
