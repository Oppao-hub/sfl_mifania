{# templates/dashboard/story/show.html.twig #}
{% extends "dashboard/dashboard.html.twig" %}

{% block title %}Story: {{ story.title }}{% endblock %}

{% block main_content %}
<div class="p-4 md:p-10 animate-fadeIn">

    {# 1. Top Navigation & Action Header #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_story_index') }}"
               class="p-3 bg-white rounded-xl border border-cream-200 text-dashboard-mocha hover:text-dashboard-olive hover:border-dashboard-olive/30 transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-dashboard-mocha tracking-tighter leading-none uppercase">
                    {{ story.title }}
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-dashboard-mocha/40 uppercase font-black tracking-widest italic">Narrative Ref</span>
                    <span class="px-2 py-0.5 bg-dashboard-bg text-dashboard-mocha/60 rounded-md text-[10px] font-bold font-mono">#{{ story.id }}</span>
                </div>
            </div>
        </div>

        {# Action Cluster #}
        <div class="flex items-center gap-3">
             <a href="{{ path('app_story_edit', { id: story.id }) }}"
               class="px-6 py-3 bg-dashboard-olive text-white text-xs font-black uppercase tracking-widest rounded-xl hover:bg-dashboard-mocha transition-all shadow-xl shadow-dashboard-olive/10 flex items-center gap-2 active:scale-95">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Edit Story
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click="$dispatch('open-delete-modal', {
                        url: '{{ path('app_story_delete', {id: story.id}) }}',
                        name: '{{ story.title|e('js') }}',
                        token: '{{ csrf_token('delete' ~ story.id) }}'
                    })"
                    class="px-6 py-3 bg-white border border-red-100 text-red-500 text-xs font-black uppercase tracking-widest rounded-xl hover:bg-red-50 transition-all flex items-center gap-2 active:scale-95 cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Delete
                </button>
            {% endif %}
        </div>
    </div>

    {# 2. The Manuscript Content #}
    <div class="bg-white rounded-xl shadow-[0_20px_50px_rgba(66,43,28,0.05)] border border-cream-200 overflow-hidden">
        <div class="p-10 md:p-14 grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

            {# Material Block #}
            <div>
                <h3 class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-olive flex items-center gap-2 mb-4 border-b border-gray-100 pb-3">
                    {{ ux_icon('lucide:leaf', {class: 'w-4 h-4'}) }} Raw Materials
                </h3>
                <p class="text-sm leading-relaxed text-dashboard-mocha/80 italic font-medium">
                    {% if story.materialContent %}
                        {{ story.materialContent|nl2br }}
                    {% else %}
                        No material content written.
                    {% endif %}
                </p>
            </div>

            {# Artisan Block #}
            <div>
                <h3 class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-olive flex items-center gap-2 mb-4 border-b border-gray-100 pb-3">
                    {{ ux_icon('lucide:scissors', {class: 'w-4 h-4'}) }} Ethical Craft
                </h3>
                <p class="text-sm leading-relaxed text-dashboard-mocha/80 italic font-medium">
                    {% if story.artisanContent %}
                        {{ story.artisanContent|nl2br }}
                    {% else %}
                        No artisan content written.
                    {% endif %}
                </p>
            </div>

            {# Dyeing Block #}
            <div>
                <h3 class="text-[10px] uppercase font-black tracking-[0.3em] text-dashboard-olive flex items-center gap-2 mb-4 border-b border-gray-100 pb-3">
                    {{ ux_icon('lucide:droplet', {class: 'w-4 h-4'}) }} Eco-Dyeing
                </h3>
                <p class="text-sm leading-relaxed text-dashboard-mocha/80 italic font-medium">
                    {% if story.dyeingContent %}
                        {{ story.dyeingContent|nl2br }}
                    {% else %}
                        No dyeing content written.
                    {% endif %}
                </p>
            </div>

        </div>
    </div>
</div>
{% endblock %}
