{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Brand Narratives{% endblock %}

{% block main_content %}
    {% embed 'components/table/table.html.twig' with {
        title: 'Manage Stories',
        total_count: stories|length,
        new_path: 'app_story_new',
        headers: ['ID', 'Story Headline', 'Material Preview', 'Artisan Preview', 'Dyeing Preview', 'Actions'],
        id: 'dashboard-story-table'
    } %}

    {% block rows %}
        {% for story in stories %}
            <tr class="hover:bg-row-hover transition-colors group">

                <td class="border-y border-border-color px-4 py-3 text-xs font-mono text-gray">
                    #{{ story.id }}
                </td>

                <td class="border-y border-border-color px-4 py-3 text-sm font-bold text-brand-dark">
                    {{ story.title }}
                </td>

                <td class="border-y border-border-color px-4 py-3 text-xs font-medium text-gray italic">
                    "{{ story.materialContent|length > 25 ? story.materialContent|slice(0, 25) ~ '...' : story.materialContent }}"
                </td>

                <td class="border-y border-border-color px-4 py-3 text-xs font-medium text-gray italic">
                    "{{ story.artisanContent|length > 25 ? story.artisanContent|slice(0, 25) ~ '...' : story.artisanContent }}"
                </td>

                <td class="border-y border-border-color px-4 py-3 text-xs font-medium text-gray italic">
                    "{{ story.dyeingContent|length > 25 ? story.dyeingContent|slice(0, 25) ~ '...' : story.dyeingContent }}"
                </td>

                <td class="border-y border-border-color py-3 px-4 text-center">
                    <div class="flex justify-center items-center gap-2">
                        <a href="{{ path('app_story_show', { id: story.id }) }}"
                           class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                           {{ ux_icon('lucide:eye', {class: 'w-4 h-4'}) }}
                        </a>

                        <a href="{{ path('app_story_edit', { id: story.id }) }}"
                           class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all">
                           {{ ux_icon('lucide:edit-2', {class: 'w-4 h-4'}) }}
                        </a>

                        {% if is_granted('ROLE_ADMIN') %}                        if
                            <button type="button"
                                    @click="$dispatch('open-delete-modal', { url: '{{ path('app_story_delete', {id: story.id}) }}', name: 'Story: {{ story.title|e('js') }}', token: '{{ csrf_token('delete' ~ story.id) }}' })"
                                    class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer">
                                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                            </button>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% endfor %}
    {% endblock %}
    {% endembed %}
{% endblock %}
