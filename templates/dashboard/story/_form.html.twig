{% form_theme form 'form/error_theme.html.twig' %}

{% set label_style = 'text-[10px] uppercase font-black tracking-[0.2em] text-gray ml-1 block mb-2' %}
{% set input_base = 'w-full px-4 py-3.5 bg-app-bg border border-border-color rounded-xl focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none text-sm font-bold text-brand-dark transition-all shadow-inner placeholder:text-gray/50' %}

{{ form_start(form, {'attr': {'class': 'relative space-y-8', 'novalidate': 'novalidate'}}) }}

    {# --- STICKY HEADER --- #}
    <div class="sticky top-24 z-40 bg-white/90 backdrop-blur-md border border-border-color rounded-2xl p-6 shadow-sm flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-brand animate-pulse"></div>
            <div>
                {% set story = form.vars.data %}
                <h1 class="text-xl font-black text-brand-dark tracking-tighter uppercase leading-none">
                    {{ story.title|default('New Brand Narrative') }}
                </h1>
                <p class="text-[9px] text-gray mt-1 uppercase font-black tracking-[0.3em]">
                    {% if story.id %}Narrative Ref #{{ story.id }}{% else %}Drafting Mode{% endif %}
                </p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <a href="{{ path('app_story_index') }}"
               class="px-5 py-3 text-[10px] font-black uppercase tracking-widest text-gray border border-border-color bg-white hover:bg-row-hover hover:text-brand-dark rounded-xl transition-all cursor-pointer">
                Discard
            </a>
            <button type="submit"
                    class="px-8 py-3 bg-brand text-white rounded-xl font-black text-[10px] uppercase tracking-[0.2em] shadow-md shadow-brand/20 hover:bg-brand-dark transition-all active:scale-95 cursor-pointer">
                {{ button_label|default('Save Narrative') }}
            </button>
        </div>
    </div>

    {# --- MAIN FORM CARD --- #}
    <div class="bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">

        {# SECTION 1: Identity #}
        <div class="p-8 md:p-10 border-b border-border-color">
            <div class="mb-8 flex items-center gap-3">
                <div class="p-2 bg-app-bg rounded-xl text-brand border border-border-color">
                    {{ ux_icon('lucide:book-open', {class: 'w-5 h-5'}) }}
                </div>
                <h3 class="text-lg font-black text-brand-dark tracking-tighter uppercase">Narrative Identity</h3>
            </div>

            <div>
                {{ form_label(form.title, 'Story Headline', { label_attr: {'class': label_style} }) }}
                {{ form_widget(form.title, {'attr': {'class': input_base ~ ' bg-white', 'placeholder': 'e.g., The Regenerative Hemp Journey'}}) }}
                <div class="mt-2">{{ form_errors(form.title) }}</div>
            </div>
        </div>

        {# SECTION 2: The Three Pillars of Transparency #}
        <div class="p-8 md:p-10 bg-app-bg">
            <div class="mb-8 flex items-center gap-3">
                <div class="p-2 bg-white rounded-xl text-brand border border-border-color shadow-sm">
                    {{ ux_icon('lucide:layers', {class: 'w-5 h-5'}) }}
                </div>
                <h3 class="text-lg font-black text-brand-dark tracking-tighter uppercase">The Three Pillars of Transparency</h3>
            </div>

            <div class="grid grid-cols-1 gap-10">
                <div>
                    <div class="flex items-center gap-2 mb-2 ml-1">
                        {{ ux_icon('lucide:leaf', {class: 'w-4 h-4 text-brand'}) }}
                        {{ form_label(form.materialContent, 'Raw Materials Origin', { label_attr: {'class': label_style ~ ' !mb-0 !ml-0'} }) }}
                    </div>
                    {{ form_widget(form.materialContent, {'attr': {'class': input_base ~ ' min-h-[120px] bg-white italic leading-relaxed', 'placeholder': 'Describe where the fibers come from...'}}) }}
                    <div class="mt-2">{{ form_errors(form.materialContent) }}</div>
                </div>

                <div>
                    <div class="flex items-center gap-2 mb-2 ml-1">
                        {{ ux_icon('lucide:scissors', {class: 'w-4 h-4 text-brand'}) }}
                        {{ form_label(form.artisanContent, 'Ethical Craft & Artisans', { label_attr: {'class': label_style ~ ' !mb-0 !ml-0'} }) }}
                    </div>
                    {{ form_widget(form.artisanContent, {'attr': {'class': input_base ~ ' min-h-[120px] bg-white italic leading-relaxed', 'placeholder': 'Describe the people who made this...'}}) }}
                    <div class="mt-2">{{ form_errors(form.artisanContent) }}</div>
                </div>

                <div>
                    <div class="flex items-center gap-2 mb-2 ml-1">
                        {{ ux_icon('lucide:droplet', {class: 'w-4 h-4 text-brand'}) }}
                        {{ form_label(form.dyeingContent, 'Eco-Dyeing Process', { label_attr: {'class': label_style ~ ' !mb-0 !ml-0'} }) }}
                    </div>
                    {{ form_widget(form.dyeingContent, {'attr': {'class': input_base ~ ' min-h-[120px] bg-white italic leading-relaxed', 'placeholder': 'Describe the natural dyeing process...'}}) }}
                    <div class="mt-2">{{ form_errors(form.dyeingContent) }}</div>
                </div>
            </div>
        </div>
    </div>

{{ form_end(form) }}
