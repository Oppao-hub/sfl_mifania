{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Customer History{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# Header #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_customer_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ customer.firstName }} <span class="text-brand">{{ customer.lastName }}</span>
                </h1>
                <div class="flex items-center gap-2 mt-2">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">Customer ID #{{ customer.id }}</span>
                    <span class="px-2 py-0.5 bg-app-bg text-gray rounded-md text-[10px] font-bold uppercase tracking-tighter border border-border-color">Purchase History</span>
                </div>
            </div>
        </div>
    </div>

    {# Quick Info Cards #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color">
            <h3 class="text-[9px] uppercase font-black tracking-widest text-gray mb-2">Contact Info</h3>
            <p class="text-brand-dark font-bold">{{ customer.user.email }}</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color">
            <h3 class="text-[9px] uppercase font-black tracking-widest text-gray mb-2">Shipping Address</h3>
            <p class="text-dark-gray font-medium text-sm leading-relaxed">{{ customer.address }}</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color">
            <h3 class="text-[9px] uppercase font-black tracking-widest text-gray mb-2">Lifetime Orders</h3>
            <p class="text-2xl font-black text-brand-dark tracking-tighter">{{ orders|length }}</p>
        </div>
    </div>

    {# Order History Table #}
    <div class="bg-white rounded-2xl shadow-sm border border-border-color overflow-hidden">
        <div class="px-8 py-6 border-b border-border-color flex items-center gap-3">
            <div class="p-2 bg-app-bg rounded-lg text-brand border border-border-color">
                {{ ux_icon('lucide:shopping-bag', {class: 'w-5 h-5'}) }}
            </div>
            <h2 class="text-lg font-black text-brand-dark tracking-tighter uppercase">Order History</h2>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr>
                        <th class="py-4 px-6 text-[10px] font-bold text-gray uppercase tracking-widest">Order ID</th>
                        <th class="py-4 px-6 text-[10px] font-bold text-gray uppercase tracking-widest">Date</th>
                        <th class="py-4 px-6 text-[10px] font-bold text-gray uppercase tracking-widest">Status</th>
                        <th class="py-4 px-6 text-[10px] font-bold text-gray uppercase tracking-widest">Items</th>
                        <th class="py-4 px-6 text-[10px] font-bold text-gray uppercase tracking-widest">Total</th>
                        <th class="py-4 px-6 text-[10px] font-bold text-gray uppercase tracking-widest text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-color">
                {% for order in orders %}
                    <tr class="hover:bg-row-hover transition-colors">
                        <td class="px-6 py-4 font-mono font-bold text-dark-gray text-xs">#{{ order.id }}</td>
                        <td class="px-6 py-4 text-xs font-bold text-gray">{{ order.createdAt|date('M d, Y') }}</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex px-3 py-1 text-[10px] font-black uppercase tracking-widest rounded-sm
                                {% if order.orderStatus.value == 'Completed' %}
                                    bg-success/10 text-success border border-success/20
                                {% elseif order.orderStatus.value == 'Cancelled' %}
                                    bg-danger/10 text-danger border border-danger/20
                                {% else %}
                                    bg-brand/10 text-brand border border-brand/20
                                {% endif %}">
                                {{ order.orderStatus.value }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm font-medium text-dark-gray">{{ order.orderItems|length }} Items</td>
                        <td class="px-6 py-4 font-bold text-brand-dark">₱{{ order.totalAmount|number_format(2) }}</td>
                        <td class="px-6 py-4 text-right">
                            <a href="{{ path('app_order_show', {id: order.id }) }}" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-gray hover:text-brand transition-colors">
                                View {{ ux_icon('lucide:arrow-right', {class: 'w-3 h-3'}) }}
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="px-6 py-10 text-center text-sm font-bold text-gray uppercase tracking-widest">No orders found for this customer.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
