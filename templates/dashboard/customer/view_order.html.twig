{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Order #{{ order.id }}{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    {# Header #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10 border-b border-border-color pb-6">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_customer_history', { id: order.customer.id }) }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand-dark transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>
            <div>
                <h1 class="text-3xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    Order <span class="text-brand font-mono">#{{ order.id }}</span>
                </h1>
                <p class="text-[10px] text-gray uppercase font-black tracking-widest italic mt-2">Logistics Overview</p>
            </div>
        </div>

        <div class="flex gap-3">
            <a href="{{ path('app_order_edit', { id: order.id }) }}"
                class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2">
                {{ ux_icon('lucide:edit-3', {class: 'w-4 h-4'}) }}
                Edit Order
            </a>
            <button type="button"
                @click="$dispatch('open-delete-modal', {
                    url: '{{ path('app_order_delete', {id: order.id}) }}',
                    name: 'Order #{{ order.id }}',
                    token: '{{ csrf_token('delete' ~ order.id) }}'
                })"
                class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                Delete
            </button>
        </div>
    </div>

    {# Order Summary Grid #}
    <h2 class="text-lg font-black text-brand-dark uppercase tracking-tighter mb-4">Summary & Status</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">

        {% macro detailCard(label, value, is_bold=false, color_class='text-brand-dark') %}
            <div class="bg-white p-6 rounded-2xl border border-border-color shadow-sm">
                <p class="text-[9px] font-black uppercase tracking-widest text-gray mb-1.5">{{ label }}</p>
                <p class="text-sm {{ is_bold ? 'font-black' : 'font-bold' }} {{ color_class }} truncate">
                    {{ value|default('N/A') }}
                </p>
            </div>
        {% endmacro %}

        {{ _self.detailCard('Customer', order.customer ? order.customer.firstName ~ ' ' ~ order.customer.lastName : 'N/A', true) }}
        {{ _self.detailCard('Order Date', order.orderDate ? order.orderDate|date('M d, Y') : 'N/A') }}
        {{ _self.detailCard('Total Amount', '₱ ' ~ order.totalAmount|number_format(2), true, 'text-brand') }}
        {{ _self.detailCard('Order Status', order.orderStatus.value|default('N/A'), true, 'text-terracotta') }}

        {{ _self.detailCard('Payment Method', order.paymentMethod.value|default('N/A')) }}
        {{ _self.detailCard('Payment Status', order.paymentStatus.value|default('N/A')) }}
        {{ _self.detailCard('Rewards Earned', order.rewardPointsEarned|default(0) ~ ' pts') }}
        {{ _self.detailCard('Last Updated', order.updatedAt ? order.updatedAt|date('M d, Y H:i') : 'N/A', false, 'text-gray') }}
    </div>

    {# Order Items Table #}
    <h2 class="text-lg font-black text-brand-dark uppercase tracking-tighter mb-4">
        Items Ordered ({{ order.orderItems|length }})
    </h2>

    <div class="bg-white rounded-2xl border border-border-color shadow-sm overflow-hidden mb-6">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-app-bg border-b border-border-color">
                    <tr>
                        <th class="py-4 px-6 text-[10px] font-black text-gray uppercase tracking-widest">Product</th>
                        <th class="py-4 px-6 text-[10px] font-black text-gray uppercase tracking-widest text-center">Qty</th>
                        <th class="py-4 px-6 text-[10px] font-black text-gray uppercase tracking-widest text-right">Unit Price</th>
                        <th class="py-4 px-6 text-[10px] font-black text-gray uppercase tracking-widest text-right">Subtotal</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border-color">
                    {% for item in order.orderItems %}
                        <tr class="hover:bg-row-hover transition-colors">
                            <td class="py-4 px-6">
                                <span class="text-sm font-bold text-brand-dark block">{{ item.product.name }}</span>
                                <span class="text-[9px] font-black uppercase tracking-widest text-gray">ID: {{ item.product.id }}</span>
                            </td>
                            <td class="py-4 px-6 text-sm font-bold text-dark-gray text-center">{{ item.quantity }}</td>
                            <td class="py-4 px-6 text-sm font-medium text-dark-gray text-right">₱ {{ item.price|number_format(2) }}</td>
                            <td class="py-4 px-6 text-sm font-black text-brand-dark text-right">₱ {{ item.subtotal|number_format(2) }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="px-6 py-10 text-center text-sm font-bold text-gray uppercase tracking-widest">This order contains no items.</td></tr>
                    {% endfor %}
                </tbody>
                <tfoot class="bg-brand/5 border-t-2 border-brand/20">
                    <tr>
                        <td colspan="3" class="px-6 py-5 text-right text-[10px] font-black uppercase tracking-widest text-brand">Grand Total:</td>
                        <td class="px-6 py-5 text-right text-lg font-black text-brand-dark">
                            ₱ {{ order.totalAmount|number_format(2) }}
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
{% endblock %}
