{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Manifest: {{ customer.firstName }} {{ customer.lastName }} | Mifania{% endblock %}

{% block main_content %}
<div class="p-6 md:p-10 animate-fadeIn max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8">
        <div class="flex items-center gap-5">
            <a href="{{ path('app_customer_index') }}"
               class="p-3 bg-white rounded-xl border border-border-color text-gray hover:text-brand transition-all shadow-sm active:scale-95">
                {{ ux_icon('lucide:arrow-left', {class: 'w-5 h-5'}) }}
            </a>

            <div class="flex flex-col gap-2">
                <h1 class="text-3xl md:text-4xl font-black text-brand-dark tracking-tighter leading-none uppercase">
                    {{ customer.firstName }} <span class="text-brand">{{ customer.lastName }}</span>
                </h1>

                <div class="flex items-center gap-3">
                    <span class="text-[10px] text-gray uppercase font-black tracking-widest italic font-mono">
                        Manifest #{{ customer.id }}
                    </span>
                    <span class="px-2 py-0.5 bg-brand/10 text-brand rounded-md text-[9px] font-black uppercase tracking-widest border border-brand/20">
                        Client Registry
                    </span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3">
             <a href="{{ path('app_customer_edit', { id: customer.id }) }}"
               class="px-6 py-3.5 bg-brand/10 text-brand border border-brand/20 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-brand/20 transition-all shadow-sm flex items-center gap-2 cursor-pointer">
                {{ ux_icon('lucide:user-cog', {class: 'w-4 h-4'}) }}
                Modify Profile
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <button type="button"
                    @click.stop="$dispatch('open-delete-modal', {
                        url: '{{ path('app_customer_delete', {id: customer.id}) }}',
                        name: '{{ customer.firstName|e('js') }} {{ customer.lastName|e('js') }}',
                        token: '{{ csrf_token('delete' ~ customer.id) }}'
                    })"
                    class="px-6 py-3.5 bg-white border border-danger/20 text-danger text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-danger/10 hover:border-danger/30 transition-all flex items-center gap-2 shadow-sm cursor-pointer">
                    {{ ux_icon('lucide:trash-2', {class: 'w-4 h-4'}) }}
                    Void Record
                </button>
            {% endif %}
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-border-color flex flex-col lg:flex-row overflow-hidden">

        <div class="w-full lg:w-4/12 p-8 md:p-10 border-b lg:border-b-0 lg:border-r border-border-color bg-app-bg/50 flex flex-col gap-8">

            <div class="relative rounded-2xl overflow-hidden shadow-sm border border-border-color group bg-white p-2">
                <img class="w-full aspect-square rounded-xl object-cover hover:scale-[1.02] transition-transform duration-700"
                     src="{{ customer.avatar ? asset('uploads/customer/avatars/' ~ customer.avatar) : asset('uploads/default/default-avatar.jpg') }}"
                     alt="{{ customer.firstName }} Visual ID">
            </div>

            {# Operational Status #}
            {% set statusValue = customer.user.status.value|default('Active') %}
            {% set isStatusActive = statusValue|lower == 'active' %}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-3 flex items-center gap-2">
                    {{ ux_icon('lucide:activity', {class: 'w-3.5 h-3.5'}) }}
                    Operational Status
                </p>
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm border bg-white
                    {% if isStatusActive %} text-success border-success/20 {% else %} text-danger border-danger/20 {% endif %}">
                    <span class="w-1.5 h-1.5 rounded-full {% if isStatusActive %} bg-success animate-pulse {% else %} bg-danger {% endif %}"></span>
                    {{ statusValue }}
                </div>
            </div>

            {# Wallet Balance #}
            <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-gray mb-2">Digital Wallet</p>
                <p class="text-xl font-black text-terracotta flex items-center gap-3 bg-white p-4 rounded-xl border border-border-color shadow-sm">
                    <span class="p-2 bg-terracotta/10 rounded-lg text-terracotta border border-terracotta/20">
                        {{ ux_icon('lucide:wallet', {class: 'w-4 h-4'}) }}
                    </span>
                    ₱{{ customer.wallet.balance|number_format(2) }}
                </p>
            </div>
        </div>

        {# Right Column: Specifications & Logistics #}
        <div class="w-full lg:w-8/12 p-8 md:p-12 flex flex-col">

            {# Data Header #}
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-10 border-b border-border-color pb-8">
                <div>
                    <h2 class="text-2xl font-black text-brand-dark tracking-tighter leading-tight uppercase">Identity Specifications</h2>
                    <p class="text-[10px] uppercase font-black tracking-[0.2em] text-gray mt-1.5 italic">Client Information Record</p>
                </div>

                {# Verification Badge #}
                <div class="px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm border flex items-center gap-2
                    {% if customer.user.isVerified %} bg-success/10 text-success border-success/20
                    {% else %} bg-warning/10 text-warning border-warning/20 {% endif %}">
                    {% if customer.user.isVerified %}
                        {{ ux_icon('lucide:badge-check', {class: 'w-3.5 h-3.5'}) }} Verified
                    {% else %}
                        {{ ux_icon('lucide:shield-alert', {class: 'w-3.5 h-3.5'}) }} Not Verified
                    {% endif %}
                </div>
            </div>

            {# Information Grid #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Given Name</label>
                    <span class="text-sm font-bold text-brand-dark">{{ customer.firstName }}</span>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Family Name</label>
                    <span class="text-sm font-bold text-brand-dark">{{ customer.lastName }}</span>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Communication Channel</label>
                    <p class="text-sm font-bold text-brand-dark">{{ customer.user.email }}</p>
                </div>

                <div>
                    <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Contact Line</label>
                    <p class="text-sm font-bold text-brand-dark">{{ customer.contactNumber|default('—') }}</p>
                </div>
            </div>

            {# Logistics Divider #}
            <div class="mt-12 mb-10 border-t border-border-color pt-10">
                <h2 class="text-lg font-black text-brand-dark tracking-tighter uppercase flex items-center gap-3 mb-8">
                    {{ ux_icon('lucide:map-pin', {class: 'w-5 h-5 text-brand'}) }}
                    Logistics Destination
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">City / District</label>
                        <p class="text-sm font-bold text-brand-dark">{{ customer.city|default('—') }}</p>
                    </div>

                    <div>
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">State / Province</label>
                        <p class="text-sm font-bold text-brand-dark">{{ customer.state|default('—') }}</p>
                    </div>

                    <div class="md:col-span-2">
                        <label class="text-[9px] uppercase font-black tracking-[0.3em] text-gray block mb-2">Physical Address</label>
                        <p class="text-sm font-bold text-brand-dark">{{ customer.address|default('—') }}</p>
                    </div>
                </div>
            </div>

            {# Spacer to push audit trail to bottom #}
            <div class="flex-grow"></div>

            {# Archival Metadata / Audit Trail #}
            <div class="mt-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4 text-gray/40 border-t border-border-color pt-6">
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Account Tier: <strong class="text-gray/60">Registered Customer</strong>
                </div>
                <div class="text-[9px] uppercase font-black tracking-widest">
                    Onboarded: {{ customer.createdAt|date('F d, Y') }}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
