{% extends 'dashboard/dashboard.html.twig' %}

{% block main_content %}
<div class="space-y-8 animate-fadeIn">

    {# Row 1: Statistic Cards #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        {% set stats = [
            {'label': 'Total Customers', 'value': totalCustomers, 'icon': 'users'},
            {'label': 'Total Products', 'value': totalProducts, 'icon': 'package'},
            {'label': 'Total Orders', 'value': totalOrders, 'icon': 'shopping-bag'},
            {'label': 'Total Sales', 'value': '₱' ~ totalSales|number_format(2), 'icon': 'credit-card'}
        ] %}

        {% for stat in stats %}
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color flex items-center gap-5 group hover:shadow-md hover:border-brand/30 transition-all">
                <div class="p-4 rounded-xl bg-app-bg text-brand group-hover:bg-brand/10 transition-colors shrink-0">
                    {{ ux_icon('lucide:' ~ stat.icon, {class: 'w-6 h-6'}) }}
                </div>
                <div class="min-w-0">
                    <p class="text-[10px] text-gray font-bold uppercase tracking-widest mb-1 truncate">{{ stat.label }}</p>
                    <p class="text-2xl font-black text-brand-dark tracking-tighter truncate">{{ stat.value }}</p>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Row 2: Data Tables #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Recent Orders #}
        <div class="lg:col-span-2 bg-white p-8 rounded-2xl shadow-sm border border-border-color">
            <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest mb-6 border-b border-border-color pb-4">
                Recent Orders
            </h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr>
                            <th class="py-3 px-4 text-[10px] font-bold text-gray uppercase tracking-widest">Product</th>
                            <th class="py-3 px-4 text-[10px] font-bold text-gray uppercase tracking-widest">Order ID</th>
                            <th class="py-3 px-4 text-[10px] font-bold text-gray uppercase tracking-widest">Customer</th>
                            <th class="py-3 px-4 text-[10px] font-bold text-gray uppercase tracking-widest">Date</th>
                            <th class="py-3 px-4 text-[10px] font-bold text-gray uppercase tracking-widest text-right">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-color">
                        {% for order in orders %}
                            <tr class="hover:bg-row-hover transition-colors">
                                <td class="py-4 px-4 flex items-center gap-3">
                                    {% set firstItem = order.orderItems|first %}
                                    {% if firstItem and firstItem.product %}
                                        <img class="h-10 w-10 rounded-sm object-cover border border-border-color" src="{{ asset('/uploads/products/' ~ firstItem.product.image) }}" alt="{{ firstItem.product.name }}"/>
                                        <span class="text-sm font-bold text-brand-dark truncate max-w-[150px]">{{ firstItem.product.name }}</span>
                                    {% else %}
                                        <div class="h-10 w-10 rounded-sm bg-app-bg border border-border-color flex items-center justify-center">{{ ux_icon('lucide:image-off', {class: 'w-4 h-4 text-gray'}) }}</div>
                                        <span class="text-sm font-medium text-gray italic">No Items</span>
                                    {% endif %}
                                </td>
                                <td class="py-4 px-4 text-xs font-mono font-bold text-dark-gray">#{{ order.id }}</td>
                                <td class="py-4 px-4 text-sm font-medium text-dark-gray">{{ order.customer.firstName }} {{ order.customer.lastName }}</td>
                                <td class="py-4 px-4 text-xs font-bold text-gray">{{ order.createdAt|date('M d, Y') }}</td>
                                <td class="py-4 px-4 text-right">
                                    <span class="inline-flex px-3 py-1 text-[10px] font-black uppercase tracking-widest rounded-sm bg-brand/10 text-brand border border-brand/20">
                                        {{ order.orderStatus.value }}
                                    </span>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="py-8 text-center text-sm font-bold text-gray">No recent orders found.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# Top Selling Products #}
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-border-color flex flex-col h-full">
            <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest mb-6 border-b border-border-color pb-4">
                Top Sellers
            </h2>
            <div class="overflow-x-auto flex-grow">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr>
                            <th class="py-3 px-2 text-[10px] font-bold text-gray uppercase tracking-widest w-12">Rank</th>
                            <th class="py-3 px-2 text-[10px] font-bold text-gray uppercase tracking-widest">Product</th>
                            <th class="py-3 px-2 text-right text-[10px] font-bold text-gray uppercase tracking-widest">Sold</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-color">
                        {% for product in topSellingProducts %}
                            <tr class="group hover:bg-row-hover transition-colors">
                                <td class="py-4 px-2">
                                    <span class="text-sm font-black {% if loop.index == 1 %}text-yellow-500{% elseif loop.index == 2 %}text-gray{% elseif loop.index == 3 %}text-orange-400{% else %}text-gray{% endif %}">
                                        #{{ loop.index }}
                                    </span>
                                </td>
                                <td class="py-4 px-2">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-bold text-brand-dark truncate max-w-[120px]">{{ product.name }}</span>
                                        <span class="text-[10px] font-bold text-brand uppercase tracking-widest mt-0.5">₱{{ product.revenue|number_format(2) }}</span>
                                    </div>
                                </td>
                                <td class="py-4 px-2 text-right">
                                    <span class="inline-flex px-2 py-1 text-[10px] font-black bg-app-bg text-dark-gray rounded-sm border border-border-color">
                                        {{ product.unitsSold }}
                                    </span>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="3" class="py-8 text-center text-sm font-bold text-gray">No sales data available yet.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
