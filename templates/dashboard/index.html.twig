{% extends 'dashboard/dashboard.html.twig' %}

{% block main_content %}
<div class="space-y-8 animate-fadeIn">

    {# Row 1: Statistic Cards #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        {% set stat_items = [
            {'label': 'Total Customers', 'value': totalCustomers|short_num, 'icon': 'users', 'change': stats.changes.customers},
            {'label': 'Total Products', 'value': totalProducts|short_num, 'icon': 'package', 'change': stats.changes.products},
            {'label': 'Total Orders', 'value': totalOrders|short_num, 'icon': 'shopping-bag', 'change': stats.changes.orders},
            {'label': 'Total Sales', 'value': '₱' ~ totalSales|short_num, 'icon': 'credit-card', 'change': stats.changes.sales}
        ] %}

        {% for stat in stat_items %}
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-border-color flex flex-col gap-4 group hover:shadow-md hover:border-brand/30 transition-all">
                <div class="flex items-center gap-5">
                    <div class="p-4 rounded-xl bg-app-bg text-brand group-hover:bg-brand/10 transition-colors shrink-0">
                        {{ ux_icon('lucide:' ~ stat.icon, {class: 'w-6 h-6'}) }}
                    </div>
                    <div class="min-w-0">
                        <p class="text-[10px] text-gray font-bold uppercase tracking-widest mb-1 truncate">{{ stat.label }}</p>
                        <p class="text-2xl font-black text-brand-dark tracking-tighter truncate">{{ stat.value }}</p>
                    </div>
                </div>

                <div class="flex items-center gap-2 pt-4 border-t border-border-color">
                    <span class="flex items-center gap-1 text-[10px] font-black uppercase tracking-widest {{ stat.change >= 0 ? 'text-green-600' : 'text-danger' }}">
                        {{ ux_icon(stat.change >= 0 ? 'lucide:trending-up' : 'lucide:trending-down', {class: 'w-3 h-3'}) }}
                        {{ stat.change|abs|number_format(1) }}%
                    </span>
                    <span class="text-[9px] text-gray font-bold uppercase tracking-widest opacity-60">vs last month</span>
                </div>
            </div>
        {% endfor %}
    </div>

    {# --- THE CHART SECTION --- #}
    <div class="bg-white p-8 rounded-2xl shadow-sm border border-border-color mb-6 animate-fadeIn">
        <div class="flex items-center gap-3 mb-6 border-b border-border-color pb-4">
            <div class="p-2 bg-app-bg rounded-xl text-brand border border-border-color">
                {{ ux_icon('lucide:chart-line', {class: 'w-5 h-5'}) }}
            </div>
            <div>
                <h2 class="text-sm font-black text-brand-dark uppercase tracking-widest">Revenue Overview</h2>
                <p class="text-[10px] text-gray mt-1 uppercase font-bold tracking-widest">Last 6 Months</p>
            </div>
        </div>

        <div class="w-full h-[300px] flex items-center justify-center">
            {{ render_chart(chart) }}
        </div>
    </div>

    {# Row 2: Data Tables #}
    <div class="grid grid-cols-1 gap-6">

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-border-color">
            <turbo-frame id="top-selling-products">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-lg font-black text-brand-dark tracking-tight">Top Selling Products</h2>

                    <div class="relative" x-data="{ open: false }">
                        <button
                            @click="open = !open"
                            @click.outside="open = false"
                            class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-gray-700 bg-gray-50 hover:bg-gray-100 rounded-md transition-colors border border-gray-100 cursor-pointer"
                        >
                            {{ ux_icon('lucide:calendar', {class: 'w-4 h-4'}) }}
                            {% set ranges = {
                                'today': 'Today',
                                'this_week': 'This Week',
                                'this_month': 'This Month',
                                'this_year': 'This Year',
                                'all_time': 'All Time'
                            } %}
                            {{ ranges[app.request.query.get('range', 'this_year')]|default('This Year') }}
                            {{ ux_icon('lucide:chevron-down', {class: 'w-4 h-4'}) }}
                        </button>

                        <div
                            x-show="open"
                            x-transition:enter="transition ease-out duration-100"
                            x-transition:enter-start="transform opacity-0 scale-95"
                            x-transition:enter-end="transform opacity-100 scale-100"
                            x-transition:leave="transition ease-in duration-75"
                            x-transition:leave-start="transform opacity-100 scale-100"
                            x-transition:leave-end="transform opacity-0 scale-95"
                            class="absolute right-0 mt-2 w-48 bg-white border border-border-color rounded-xl shadow-lg z-50 overflow-hidden"
                            style="display: none;"
                        >
                            <div class="py-1">
                                {% for key, label in ranges %}
                                    <a
                                        href="{{ path('app_dashboard', {range: key}) }}"
                                        data-turbo-frame="top-selling-products"
                                        @click="open = false"
                                        class="block px-4 py-3 text-[10px] font-black uppercase tracking-widest hover:bg-app-bg hover:text-brand transition-colors {{ app.request.query.get('range', 'this_year') == key ? 'text-brand bg-app-bg' : 'text-gray' }}"
                                    >
                                        {{ label }}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr>
                                <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color rounded-l-xl">Product</th>
                                <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color">Price</th>
                                <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color">Sold</th>
                                <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color">Status</th>
                                <th class="py-4 px-4 text-[10px] font-black uppercase tracking-widest text-gray/70 bg-app-bg border-y border-border-color text-right rounded-r-xl">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-color">
                            {% for item in topProducts %}
                                <tr class="hover:bg-app-bg/50 transition-colors group">

                                    <td class="py-5 px-4">
                                        <div class="flex items-center gap-4">
                                            <div class="h-12 w-12 rounded-xl bg-white border border-border-color flex items-center justify-center overflow-hidden shrink-0 shadow-sm p-1">
                                                <img src="{{ asset('/uploads/products/' ~ item.image) }}" alt="{{ item.name }}" class="object-cover w-full h-full rounded-lg"/>
                                            </div>
                                            <div class="flex flex-col">
                                                <span class="text-sm font-bold text-brand-dark leading-tight">{{ item.name }}</span>
                                                <span class="text-[9px] font-black text-brand/50 mt-1 uppercase tracking-widest">ID: #{{ item.product.id }}</span>
                                            </div>
                                        </div>
                                    </td>

                                    {# 2. Price #}
                                    <td class="py-5 px-4 whitespace-nowrap">
                                        <span class="text-sm font-black text-brand-dark">₱{{ item.price|number_format(0) }}</span>
                                        <span class="text-[10px] font-bold text-gray/40 line-through ml-1">₱{{ (item.price * 1.2)|number_format(0) }}</span>
                                    </td>

                                    {# 3. Sell Metrics #}
                                    <td class="py-5 px-4 whitespace-nowrap">
                                        <span class="text-sm font-black text-brand-dark">{{ item.unitsSold }}</span>
                                        <span class="text-[10px] font-bold text-gray/40 ml-1">({{ item.product.getTotalStockQuantity() + item.unitsSold }})</span>
                                    </td>

                                    {# 4. Status Badges #}
                                    <td class="py-5 px-4">
                                        {% set status = item.product.getStockStatus() %}
                                        <span class="inline-flex px-2 py-1 text-[11px] font-bold uppercase tracking-wider rounded-md border
                                            {% if status == 'In Stock' %} bg-success/10 text-success border-success/20
                                            {% elseif status == 'Low Stock' %} bg-warning/10 text-warning border-warning/20
                                            {% else %} bg-danger/10 text-danger border-danger/20 {% endif %}">
                                            {{ status }}
                                        </span>
                                    </td>

                                    {# 5. Actions #}
                                    <td class="py-5 px-4 text-right">
                                        <div class="flex items-center justify-end gap-2 transition-all transform translate-x-2 group-hover:translate-x-0">
                                            <a href="{{ path('app_product_edit', {id: item.product.id}) }}"
                                               data-turbo="false"
                                               class="p-2 text-gray hover:text-brand bg-white border border-border-color rounded-lg hover:shadow-sm transition-all"
                                               title="Edit">
                                                {{ ux_icon('lucide:pencil', {class: 'w-3.5 h-3.5'}) }}
                                            </a>

                                            {% if is_granted('ROLE_ADMIN') %}
                                                <button
                                                    type="button"
                                                    @click.stop="$dispatch('open-delete-modal', {
                                                        url: '{{ path('app_product_delete', {id: item.product.id}) }}',
                                                        name: '{{ item.name|e('js') }}',
                                                        token: '{{ csrf_token('delete' ~ item.product.id) }}'
                                                    })"
                                                    class="p-2 text-terracotta hover:text-danger bg-white border border-border-color rounded-lg hover:shadow-sm transition-all cursor-pointer"
                                                    title="Delete"
                                                >
                                                    {{ ux_icon('lucide:trash-2', {class: 'w-3.5 h-3.5'}) }}
                                                </button>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="py-12 text-center">
                                        <div class="flex flex-col items-center justify-center gap-2 opacity-20">
                                            {{ ux_icon('lucide:package-search', {class: 'w-10 h-10'}) }}
                                            <p class="text-[10px] font-black uppercase tracking-[0.2em]">No products found</p>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </turbo-frame>
        </div>
    </div>
</div>
{% endblock %}
