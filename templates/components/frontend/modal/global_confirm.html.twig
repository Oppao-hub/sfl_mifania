<div x-data="{
        isOpen: false,
        title: '',
        message: '',
        actionUrl: '',
        confirmText: 'Confirm',
        csrfToken: '',
        isDanger: false
    }"
    @open-confirm.window="
        title = $event.detail.title;
        message = $event.detail.message;
        actionUrl = $event.detail.actionUrl;
        confirmText = $event.detail.confirmText || 'Confirm';
        csrfToken = $event.detail.csrfToken || '';
        isDanger = $event.detail.isDanger || false;
        isOpen = true;
    "
    @keydown.escape.window="isOpen = false"
    x-show="isOpen"
    style="display: none;"
    class="relative z-[100]"
    aria-labelledby="modal-title"
    role="dialog"
    aria-modal="true"
>
    {# Background Backdrop #}
    <div x-show="isOpen"
         x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="fixed inset-0 bg-black/40 backdrop-blur-sm transition-opacity"></div>

    {# Modal Panel #}
    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">

        {# FIX 1: Changed min-h-full to min-h-screen, and forced items-center on all screen sizes #}
        <div class="flex min-h-screen items-center justify-center p-4 text-center sm:p-0">

            <div x-show="isOpen"
                 @click.away="isOpen = false"
                 x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 class="relative transform overflow-hidden rounded-sm bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-lg border border-gray-100">

                <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        {# Dynamic Icon: Red warning for danger, Brand color for normal actions #}
                        <div class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full sm:mx-0 sm:h-10 sm:w-10"
                             :class="isDanger ? 'bg-red-50 text-red-500' : 'bg-brand/10 text-brand'">
                            <template x-if="isDanger">{{ ux_icon('lucide:alert-triangle', { class: 'w-5 h-5' }) }}</template>
                            <template x-if="!isDanger">{{ ux_icon('lucide:info', { class: 'w-5 h-5' }) }}</template>
                        </div>

                        <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
                            <h3 class="text-lg font-bold uppercase tracking-tighter text-gray-900" id="modal-title" x-text="title"></h3>
                            <div class="mt-2">
                                <p class="text-sm text-gray-500 leading-relaxed" x-text="message"></p>
                            </div>
                        </div>
                    </div>
                </div>

                {# FIX 2: Modern Flexbox Layout. flex-col-reverse keeps Cancel on bottom for mobile, sm:flex-row puts them side-by-side on desktop. gap-4 gives perfect spacing! #}
                <div class="bg-gray-50 px-4 py-4 sm:px-6 border-t border-gray-100 flex flex-col-reverse sm:flex-row sm:justify-end gap-3 sm:gap-4">

                    <button type="button" @click="isOpen = false" class="inline-flex w-full justify-center rounded-sm bg-white px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:w-auto transition-colors cursor-pointer">
                        Cancel
                    </button>

                    {# The Form that actually submits the action #}
                    <form :action="actionUrl" method="POST" class="w-full sm:w-auto">
                        <input type="hidden" name="_token" :value="csrfToken">
                        <button type="submit"
                                class="inline-flex w-full justify-center rounded-sm px-5 py-2.5 text-xs font-bold uppercase tracking-widest text-white shadow-sm transition-colors sm:w-auto cursor-pointer"
                                :class="isDanger ? 'bg-red-500 hover:bg-red-600' : 'bg-brand hover:bg-brand-dark'"
                                x-text="confirmText">
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
