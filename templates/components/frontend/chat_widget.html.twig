<div x-data="customerChat()" 
     x-init="initMercure()"
     class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
    
    {# Chat Window #}
    <div x-show="open" 
         x-transition:enter="transition ease-out duration-300 transform"
         x-transition:enter-start="opacity-0 translate-y-10 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         x-transition:leave="transition ease-in duration-200 transform"
         x-transition:leave-start="opacity-100 translate-y-0 scale-100"
         x-transition:leave-end="opacity-0 translate-y-10 scale-95"
         class="mb-4 w-[350px] sm:w-[400px] h-[500px] bg-white rounded-3xl shadow-2xl border border-border-color flex flex-col overflow-hidden"
         x-cloak>
        
        {# Header #}
        <div class="bg-brand p-6 text-white flex justify-between items-center shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
                    {{ ux_icon('lucide:headset', {class: 'w-6 h-6'}) }}
                </div>
                <div>
                    <h3 class="font-bold text-sm leading-tight">Mifania Support</h3>
                    <div class="flex items-center gap-1.5 mt-0.5">
                        <span class="w-1.5 h-1.5 rounded-full" :class="mercureConnected ? 'bg-success' : 'bg-white/30'"></span>
                        <p class="text-[9px] uppercase tracking-widest font-bold" 
                           :class="mercureConnected ? 'text-white' : 'text-white/50'"
                           x-text="mercureConnected ? 'Real-time active' : 'Connecting...'"></p>
                    </div>
                </div>
            </div>
            <button @click="open = false" class="hover:bg-white/10 p-2 rounded-full transition-colors">
                {{ ux_icon('lucide:x', {class: 'w-5 h-5'}) }}
            </button>
        </div>

        {# Messages #}
        <div class="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar bg-app-bg/50" x-ref="chatWindow">
            <template x-for="msg in messages" :key="msg.id">
                <div class="flex flex-col" :class="msg.sender.id === {{ app.user ? app.user.id : 'null' }} ? 'items-end' : 'items-start'">
                    <div class="max-w-[85%] px-4 py-2.5 rounded-2xl text-sm shadow-sm border"
                         :class="msg.sender.id === {{ app.user ? app.user.id : 'null' }} ? 'bg-brand text-white border-brand rounded-br-none' : 'bg-white text-brand-dark border-border-color rounded-bl-none'">
                        <span x-text="msg.content"></span>
                    </div>
                    <span class="text-[9px] font-bold text-gray/40 mt-1" x-text="formatTime(msg.createdAt)"></span>
                </div>
            </template>
            <div x-show="messages.length === 0" class="h-full flex flex-col items-center justify-center text-center space-y-3 opacity-40 py-10">
                {{ ux_icon('lucide:messages-square', {class: 'w-12 h-12 text-brand'}) }}
                <p class="text-xs font-bold uppercase tracking-widest text-brand-dark">How can we help you today?</p>
            </div>
        </div>

        {# Input #}
        <div class="p-4 bg-white border-t border-border-color">
            <form @submit.prevent="sendMessage()" class="flex items-center gap-2 bg-app-bg rounded-full px-2 py-1.5 border border-border-color focus-within:border-brand/30 transition-colors">
                <input type="text" x-model="newMessage" placeholder="Type your message..." 
                       class="flex-1 bg-transparent border-none focus:ring-0 text-sm py-1 px-3 outline-none">
                <button type="submit" 
                        :disabled="!newMessage.trim() || sending"
                        class="w-9 h-9 bg-brand text-white rounded-full flex items-center justify-center hover:bg-brand-dark transition-colors shadow-sm shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
                    <template x-if="!sending">
                        {{ ux_icon('lucide:send', {class: 'w-4 h-4 ml-0.5'}) }}
                    </template>
                    <template x-if="sending">
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                    </template>
                </button>
            </form>
        </div>
    </div>

    {# Toggle Button #}
    <button @click="toggleChat()" 
            class="w-14 h-14 bg-brand text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 transition-all duration-300 group relative">
        <div class="relative">
            <template x-if="!open">
                {{ ux_icon('lucide:message-circle', {class: 'w-7 h-7 group-hover:rotate-12 transition-transform'}) }}
            </template>
            <template x-if="open">
                {{ ux_icon('lucide:chevron-down', {class: 'w-7 h-7'}) }}
            </template>
            
            {# Notification Dot #}
            <div x-show="!open && (hasNew || unreadCount > 0)" 
                 class="absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 bg-danger border-2 border-white rounded-full flex items-center justify-center shadow-sm animate-bounce">
                <span class="text-[9px] font-black text-white leading-none" x-text="unreadCount || '!'"></span>
            </div>
        </div>
    </button>

    <script>
        function customerChat() {
            return {
                open: false,
                messages: [],
                newMessage: '',
                sending: false,
                hasNew: false,
                initialized: false,
                mercureConnected: false,
                unreadCount: 0,

                init() {
                    this.initMercure();
                    this.fetchUnreadCount();
                },

                async fetchUnreadCount() {
                    try {
                        const response = await fetch('/chat/unread-count');
                        const data = await response.json();
                        this.unreadCount = data.count;
                        if (this.unreadCount > 0 && !this.open) {
                            this.hasNew = true;
                        }
                    } catch (error) {
                        console.error('Failed to fetch unread count:', error);
                    }
                },

                async toggleChat() {
                    this.open = !this.open;
                    if (this.open) {
                        this.hasNew = false;
                        this.unreadCount = 0;
                        if (!this.initialized) {
                            await this.loadMessages();
                            this.initialized = true;
                        } else {
                            await this.markAsRead();
                        }
                        this.$nextTick(() => this.scrollToBottom());
                    }
                },

                async markAsRead() {
                    try {
                        await fetch('/chat/mark-read', { method: 'POST' });
                    } catch (error) {
                        console.error('Failed to mark as read:', error);
                    }
                },

                async loadMessages() {
                    try {
                        const response = await fetch('/chat/messages');
                        this.messages = await response.json();
                    } catch (error) {
                        console.error('Failed to load messages:', error);
                    }
                },

                async sendMessage() {
                    if (!this.newMessage.trim() || this.sending) return;
                    
                    const content = this.newMessage;
                    this.newMessage = '';
                    this.sending = true;

                    try {
                        const response = await fetch('/chat/send', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ content: content })
                        });
                        
                        if (response.ok) {
                            const sentMessage = await response.json();
                            // Optimistic update
                            if (!this.messages.find(m => m.id === sentMessage.id)) {
                                this.messages.push(sentMessage);
                                this.$nextTick(() => this.scrollToBottom());
                            }
                        } else {
                            this.newMessage = content;
                            console.error('Failed to send message');
                        }
                    } catch (error) {
                        this.newMessage = content;
                        console.error('Error sending message:', error);
                    } finally {
                        this.sending = false;
                    }
                },

                initMercure() {
                    {% if app.user %}
                        try {
                            const url = new URL('{{ mercure("/chat/user/" ~ app.user.id)|escape("js") }}');
                            console.log('Customer: Connecting to Mercure at', url.toString());
                            const eventSource = new EventSource(url);

                            eventSource.onopen = () => {
                                console.log('Customer: Mercure connection opened!');
                                this.mercureConnected = true;
                            };

                            eventSource.onmessage = (event) => {
                                const message = JSON.parse(event.data);
                                console.log('Customer: New message received:', message);
                                
                                // Prevent duplicates
                                if (!this.messages.find(m => m.id === message.id)) {
                                    this.messages.push(message);
                                    
                                    if (!this.open) {
                                        this.hasNew = true;
                                        this.unreadCount++;
                                    } else {
                                        this.markAsRead();
                                        this.$nextTick(() => this.scrollToBottom());
                                    }
                                }
                            };

                            eventSource.onerror = (err) => {
                                this.mercureConnected = false;
                                console.error('Customer: Mercure connection error.', err);
                            };
                        } catch (e) {
                            console.error('Customer: Failed to init Mercure:', e);
                        }
                    {% endif %}
                },

                scrollToBottom() {
                    const el = this.$refs.chatWindow;
                    if (el) {
                        el.scrollTop = el.scrollHeight;
                    }
                },

                formatTime(dateStr) {
                    const date = new Date(dateStr);
                    return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                }
            }
        }
    </script>
</div>
