<nav class="flex items-center justify-between px-4 md:px-8 lg:px-12 bg-white sticky top-0 z-50 shadow-sm h-20">

    <div class="flex flex-shrink-0 items-center">
        {% if app.user %}
            <a href="{{ path('app_shop') }}">
                <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Mifania Logo" class="w-auto h-8 md:h-10 transition-transform hover:scale-105" />
            </a>
        {% else %}
            <a href="{{ path('app_home') }}">
                <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Mifania Logo" class="w-auto h-8 md:h-10 transition-transform hover:scale-105" />
            </a>
        {% endif %}
    </div>

    {# DESKTOP MEGA MENUS (Center) #}
    <div class="hidden lg:flex items-center h-full gap-8 text-sm font-semibold text-brand animation-fadeIn">

        <div class="group h-full flex items-center static">
            <a href="{{ path('app_shop') }}" class="h-full flex items-center hover:text-brand-dark transition-colors cursor-pointer">
                Shop
            </a>

            <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[900px] bg-white shadow-2xl border-b-4 border-brand opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-500 flex pointer-events-none group-hover:pointer-events-auto text-left">
                <div class="flex-1 p-10 flex justify-between gap-8">
                    {% for category in categories %}
                        <div class="flex-1">
                            <h4 class="font-black text-brand-dark mb-6 uppercase tracking-wider">
                                <a href="{{ path('app_shop', {department: category.name|lower}) }}" class="hover:text-brand transition-colors">
                                    {{ category.name }}
                                </a>
                            </h4>
                            <ul class="space-y-4 text-gray-500 font-medium text-sm">
                                {% for subCat in category.subCategories %}
                                    <li>
                                        <a href="{{ path('app_shop', {category: subCat.slug}) }}" class="hover:text-brand transition-colors">
                                            {{ subCat.name }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endfor %}
                </div>

                <div class="w-[300px] bg-brand/10 p-8 flex flex-col items-center justify-center text-center relative overflow-hidden border-l border-brand/20">
                    <span class="text-brand font-black text-[10px] uppercase tracking-widest mb-2">- The Full Collection</span>
                    <h3 class="text-2xl font-black text-brand-dark mb-6">Discover<br>Everything</h3>
                    <a href="{{ path('app_shop') }}" class="px-6 py-3 bg-brand text-white text-xs font-bold uppercase tracking-widest shadow-md hover:bg-brand-dark transition-colors rounded-lg">Shop</a>
                </div>
            </div>
        </div>

        {% for category in categories %}
            <div class="group h-full flex items-center static">
                {# FIXED: Uses app_shop with the department parameter #}
                <a href="{{ path('app_shop', {department: category.name|lower}) }}" class="h-full flex items-center hover:text-brand-dark transition-colors cursor-pointer">
                    {{ category.name }}
                </a>

                <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] bg-white shadow-2xl border-b-4 border-brand opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 flex pointer-events-none group-hover:pointer-events-auto text-left">
                    <div class="flex-1 p-10 flex gap-12">
                        {% for column in category.subCategories|batch(4) %}
                            <div class="min-w-[150px]">
                                <h4 class="font-black text-brand-dark mb-6 uppercase tracking-wider">
                                    {% if loop.first %}Categories{% else %}More{% endif %}
                                </h4>
                                <ul class="space-y-4 text-gray-500 font-medium text-sm">
                                    {% for subCat in column %}
                                        <li>
                                            <a href="{{ path('app_shop', {category: subCat.slug}) }}" class="hover:text-brand transition-colors">
                                                {{ subCat.name }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="w-[250px] bg-brand/10 p-8 flex flex-col items-center justify-center text-center relative overflow-hidden border-l border-brand/20">
                        <span class="text-brand font-black text-[10px] uppercase tracking-widest mb-2">- Collection</span>
                        <h3 class="text-xl font-black text-brand-dark mb-6">Explore<br>{{ category.name }}</h3>

                        <a href="{{ path('app_shop', {department: category.name|lower}) }}" class="px-6 py-3 bg-brand text-white text-xs font-bold uppercase tracking-widest shadow-md hover:bg-brand-dark transition-colors rounded-lg">Shop Now</a>
                    </div>
                </div>
            </div>
        {% endfor %}

        <a href="{{ path('app_about') }}" class="h-full flex items-center hover:text-brand-dark transition-colors">About Us</a>
        <a href="{{ path('app_contact') }}" class="h-full flex items-center hover:text-brand-dark transition-colors">Contact Us</a>
    </div>

    {# RIGHT ICONS & AUTH (Right) #}
    <div class="flex items-center gap-4 lg:gap-6 text-brand">
        <button @click="searchOpen = !searchOpen" class="hidden sm:block hover:text-brand-dark transition-all duration-300 hover:scale-110 focus:outline-none cursor-pointer" title="Search">
            {{ ux_icon('ic:round-search', { class: 'h-5 w-5' }) }}
        </button>

        <a href="{{ path('app_wishlist') }}" class="hover:text-brand-dark transition-all duration-300 hover:scale-110" title="Wishlist">
            {{ ux_icon('mdi:favourite-border', { class: 'h-5 w-5 lg:h-5 lg:w-5' }) }}
        </a>

        <a href="{{ path('app_cart_show') }}" class="hover:text-brand-dark transition-all duration-300 hover:scale-110" title="Cart">
            {{ ux_icon('lucide:shopping-cart', { class: 'h-5 w-5 lg:h-5 lg:w-5' }) }}
        </a>

        <div class="hidden lg:flex items-center">
            {% if app.user %}
                <div class="flex items-center gap-4 border-l border-gray-200 pl-4 ml-2 relative" x-data="{ userMenuOpen: false }">
                    <button @click="userMenuOpen = !userMenuOpen" class="bg-light-gray text-brand-dark hover:bg-gray-100 flex items-center gap-2 px-5 py-2.5 rounded-full transition-all duration-300 focus:outline-none cursor-pointer">
                        {{ ux_icon('lucide:user-check', { class: 'h-4 w-4' }) }}
                        <span class="text-xs font-bold">Hi, {{ app.user.customer.firstName|default('Paolo') }}</span>
                    </button>
                    <div x-cloak x-show="userMenuOpen" @click.away="userMenuOpen = false" class="absolute right-0 top-full mt-3 w-56 bg-white rounded-sm shadow-lg border border-gray-100 py-2 z-50 text-left">
                        {# Logic to send different roles to their specific profile page #}
                        {% set profile_url = path('app_account') %}
                        {% if is_granted('ROLE_ADMIN') %}
                            {% set profile_url = path('app_account_admin') %}
                        {% elseif is_granted('ROLE_STAFF') %}
                            {% set profile_url = path('app_staff_account') %}
                        {% endif %}

                        <a href="{{ profile_url }}" class="flex items-center gap-3 px-4 py-2.5 text-sm font-semibold text-gray-600 hover:bg-gray-50 hover:text-brand transition-colors">My Profile</a>
                        <a href="{{ path('app_logout') }}" data-turbo="false" class="flex items-center gap-3 px-4 py-2.5 text-sm font-bold text-gray-500 hover:bg-red-50 hover:text-red-600 transition-colors">Logout</a>
                    </div>
                </div>
            {% else %}
                <div class="pl-4 ml-2 border-l border-gray-200">
                    <a href="{{ path('app_login') }}" class="bg-brand text-white hover:bg-brand-dark flex items-center gap-2 px-6 py-2.5 rounded-full transition-all duration-300">
                        <span class="text-xs font-bold uppercase tracking-widest">Login</span>
                    </a>
                </div>
            {% endif %}
        </div>

        <button @click="mobileMenuOpen = !mobileMenuOpen" class="lg:hidden p-2 text-brand hover:text-brand-dark transition-colors focus:outline-none">
            {{ ux_icon('lucide:menu', { class: 'h-6 w-6' }) }}
        </button>
    </div>

    {# 4. SEARCH DROPDOWN #}
    <div x-cloak x-show="searchOpen"
         @click.away="searchOpen = false"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 -translate-y-2"
         class="absolute top-full left-0 w-full bg-white border-b border-gray-100 shadow-md z-40 px-6 py-6 flex justify-center">

        <form action="{{ path('app_shop') }}" method="GET" class="w-full max-w-3xl relative flex items-center">
            {{ ux_icon('ic:round-search', { class: 'absolute left-4 h-5 w-5 text-gray-400' }) }}
            <input type="text" name="q" placeholder="Search for sustainable fashion..."
                   class="w-full pl-12 pr-12 py-4 bg-gray-50 border border-gray-200 rounded-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors text-sm"
                   x-ref="searchInput"
                   x-effect="if(searchOpen) $nextTick(() => $refs.searchInput.focus())">

            <button type="button" @click="searchOpen = false" class="absolute right-4 text-gray-400 hover:text-brand transition-colors">
                {{ ux_icon('lucide:x', { class: 'h-5 w-5' }) }}
            </button>
        </form>
    </div>
</nav>

{# 5. MOBILE SLIDE-OUT MENU #}
<div x-cloak x-show="mobileMenuOpen" class="relative z-[100] lg:hidden" aria-labelledby="slide-over-title" role="dialog" aria-modal="true">
    <div x-show="mobileMenuOpen"
         x-transition:enter="ease-in-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in-out duration-300"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 bg-gray-900/80 backdrop-blur-sm transition-opacity"
         @click="mobileMenuOpen = false"></div>

    <div x-show="mobileMenuOpen"
         x-transition:enter="transform transition ease-in-out duration-300"
         x-transition:enter-start="translate-x-full"
         x-transition:enter-end="translate-x-0"
         x-transition:leave="transform transition ease-in-out duration-300"
         x-transition:leave-start="translate-x-0"
         x-transition:leave-end="translate-x-full"
         class="fixed inset-y-0 right-0 z-50 w-full max-w-sm bg-white shadow-2xl flex flex-col">

        <div class="px-6 py-5 flex justify-between items-center border-b border-gray-100">
            <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Mifania Logo" class="h-8 w-auto" />
            <button type="button" class="p-2 -mr-2 rounded-md text-gray-400 hover:text-brand transition-colors focus:outline-none" @click="mobileMenuOpen = false">
                <span class="sr-only">Close panel</span>
                {{ ux_icon('lucide:x', { class: 'h-6 w-6' }) }}
            </button>
        </div>

        <div class="flex-1 overflow-y-auto px-6 py-8 space-y-8">
            <div class="flex flex-col space-y-6 text-lg font-medium text-gray-900 text-left">
                <a href="{{ path('app_home') }}" class="hover:text-brand transition-colors">Home</a>
                <a href="{{ path('app_shop') }}" class="hover:text-brand transition-colors">Shop</a>

                {% for category in categories %}
                    <a href="{{ path('app_shop', {department: category.name|lower}) }}" class="hover:text-brand transition-colors">{{ category.name }}</a>
                {% endfor %}
            </div>

            <div class="pt-8 border-t border-gray-100">
                {% if app.user %}
                    <div class="flex flex-col space-y-6">
                        {# Dynamic Profile Logic for Mobile #}
                        {% set profile_url = path('app_account') %}
                        {% if is_granted('ROLE_ADMIN') %}
                            {% set profile_url = path('app_account_admin') %}
                        {% elseif is_granted('ROLE_STAFF') %}
                            {% set profile_url = path('app_staff_account') %}
                        {% endif %}

                        <a href="{{ profile_url }}" class="flex items-center gap-3 text-brand">
                            {{ ux_icon('lucide:user-check', { class: 'h-5 w-5' }) }}
                            <span class="font-bold">My Account</span>
                        </a>
                        <a href="{{ path('app_logout') }}" data-turbo="false" class="flex items-center gap-3 text-red-600">
                            {{ ux_icon('lucide:log-out', { class: 'h-5 w-5' }) }}
                            <span class="font-bold">Logout</span>
                        </a>
                    </div>
            {% else %}

                    <a href="{{ path('app_login') }}" class="flex justify-center w-full bg-brand text-white px-4 py-3.5 rounded-lg font-bold uppercase tracking-widest hover:bg-brand-dark transition-colors shadow-sm">
                        Login / Register
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
