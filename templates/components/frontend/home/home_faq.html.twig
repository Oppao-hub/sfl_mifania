<section id="faq" class="bg-light-gray py-24 px-6" x-data="{ active: null }">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-brand mb-4">Frequently Asked Questions</h2>
            <p class="text-gray-500">Transparency is our policy. Here is everything you need to know about our materials and process.</p>
        </div>

        <div class="space-y-3">
            <template x-for="(item, index) in [
                { q: 'How do you source your materials?', a: 'We source directly from GOTS certified farms in India and Turkey.' },
                { q: 'Is your packaging plastic-free?', a: 'Yes! Every order ships in 100% compostable mailers made from cornstarch, and we use soy-based inks for all our tags.' },
                { q: 'What is your return policy?', a: 'We offer a 30-day window for circular exchanges.' },
                { q: 'Do you ship international?', a: 'Currently we ship to 15 countries with carbon-neutral carriers.' },
                { q: 'How should I care for my organic garments?', a: 'Wash cold, hang dry.' },
                { q: 'Are your workers paid fair wages?', a: 'Yes, we are SA8000 certified.' },
                { q: 'Do you have a recycling program for old clothes?', a: 'Yes, check our Circle program.' }
            ]">
                <div class="bg-white rounded shadow-sm overflow-hidden transition-all duration-300 border border-gray-100"
                     :class="{ 'bg-brand text-white border-brand': active === index, 'bg-white text-gray-700': active !== index }">
                    <button @click="active = active === index ? null : index"
                            class="flex justify-between items-center w-full px-6 py-4 text-left font-bold text-sm hover:opacity-90 transition-colors cursor-pointer">
                        <span x-text="item.q"></span>
                        <span class="text-xl font-normal" x-text="active === index ? '-' : '+'"></span>
                    </button>
                    <div x-show="active === index" x-collapse class="px-6 pb-4 text-xs opacity-90 leading-relaxed">
                        <p x-text="item.a"></p>
                    </div>
                </div>
            </template>
        </div>
    </div>
</section>
