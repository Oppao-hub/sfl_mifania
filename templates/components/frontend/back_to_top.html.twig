<div x-data="{ show: false }"
     @scroll.window="show = window.pageYOffset > 300"
     class="fixed bottom-8 right-8 z-[90]">

    <button @click="window.scrollTo({ top: 0, behavior: 'smooth' })"
            x-show="show"
            x-transition:enter="transition ease-out duration-300 transform"
            x-transition:enter-start="opacity-0 translate-y-8"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-300 transform"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-8"
            style="display: none;"
            class="p-3 bg-brand text-white rounded-full shadow-lg hover:bg-brand-dark hover:shadow-2xl hover:-translate-y-1 transition-all focus:outline-none cursor-pointer"
            aria-label="Back to top">

        {{ ux_icon('lucide:chevron-up', { class: 'w-5 h-5' }) }}

    </button>
</div>
