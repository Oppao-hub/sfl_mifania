{% set cx = cx|default('0') %}
{% set cy = cy|default('0') %}
{% set r = r|default('0') %}
{% set d1 = d1|default('0') %}
{% set d2 = d2|default('0') %}

{# 1. Determine Initial State & Generate Unique ID #}
{% set isOpen = items|filter(i => i.isActive)|length > 0 %}
{% set dropdownId = 'dropdown-' ~ random() %}

<div class="relative">
    {# 2. Button with OnClick Handler #}
    <a href="#"
       onclick="toggleSidebarDropdown('{{ dropdownId }}'); return false;"
       class="w-full flex justify-left items-center px-5 py-3 rounded-md focus:outline-none transition-colors
              {{ isOpen ? 'bg-dark-gray text-cream' : 'text-dark-gray hover:bg-cream hover:text-dark-gray'}}">

        <twig:icon
            d1="{{ d1 }}" cx="{{ cx }}" cy="{{ cy }}" r="{{ r }}" d2="{{ d2 }}"
            class="w-5 h-5 flex-shrink-0"
        />

        <span class="whitespace-nowrap overflow-hidden ml-7">{{ label }}</span>

        {# 3. Chevron Icon #}
        <svg id="{{ dropdownId }}-icon"
             class="w-4 h-4 ml-auto transition-transform duration-300 lg:block hidden {{ isOpen ? 'rotate-180' : '' }}"
             fill="none"
             stroke="currentColor"
             viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 9l-7 7-7-7"/>
        </svg>
    </a>

    {# 4. Dropdown Menu with Transition Classes #}
    {# Key Change: We use max-h-0 for closed and max-h-96 (approx 400px) for open.
       We also toggle opacity for a smoother effect. #}
    <ul id="{{ dropdownId }}-menu"
        class="space-y-1 pl-4 overflow-hidden transition-all duration-300 ease-in-out
               {{ isOpen ? 'max-h-96 opacity-100 mt-2' : 'max-h-0 opacity-0 mt-0' }}">
        {% for item in items %}
            <li>
                <a href="{{ path(item.route, item.params) }}"
                   class="flex items-center gap-x-4 px-5 py-3 rounded-lg text-sm font-medium whitespace-nowrap overflow-hidden transition-all
                        {{ item.isActive ? 'bg-dark-gray-300 text-cream' : 'text-dark-gray hover:bg-cream hover:text-dark-gray' }}">
                    {{ item.label }}
                </a>
            </li>
        {% endfor %}
    </ul>
</div>

{# 5. Updated Javascript #}
<script>
    function toggleSidebarDropdown(id) {
        const menu = document.getElementById(id + '-menu');
        const icon = document.getElementById(id + '-icon');

        if (menu) {
            // Toggle the 'Closed' state classes
            menu.classList.toggle('max-h-0');
            menu.classList.toggle('opacity-0');
            menu.classList.toggle('mt-0');

            // Toggle the 'Open' state classes
            // Note: max-h-96 allows the menu to grow up to ~384px.
            // If your menu is huge, increase this number (e.g., max-h-[500px]).
            menu.classList.toggle('max-h-96');
            menu.classList.toggle('opacity-100');
            menu.classList.toggle('mt-2');
        }

        if (icon) {
            icon.classList.toggle('rotate-180');
        }
    }
</script>
