{% for label, messages in app.flashes %}
    {% for message in messages %}

        {# --- Determine Styles based on Mifania Brand Palette --- #}
        {% set title = 'Notice' %}
        {# Base Brand Color: #6b703d #}
        {% set colorClass = 'text-[#6b703d]' %}
        {% set btnClass = 'bg-[#6b703d] hover:bg-[#5a5f33]' %}
        {% set iconPath = 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z' %}

        {% if label == 'success' %}
            {% set title = 'Success!' %}
            {% set colorClass = 'text-[#6b703d]' %} {# Keeping it brand-consistent #}
            {% set btnClass = 'bg-[#6b703d] hover:bg-[#5a5f33]' %}
            {% set iconPath = 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' %}

        {% elseif label == 'error' or label == 'danger' %}
            {% set title = 'Error!' %}
            {% set colorClass = 'text-red-600' %}
            {% set btnClass = 'bg-red-600 hover:bg-red-700' %}
            {% set iconPath = 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z' %}

        {% elseif label == 'warning' %}
            {% set title = 'Warning!' %}
            {% set colorClass = 'text-amber-600' %}
            {% set btnClass = 'bg-amber-600 hover:bg-amber-700' %}
            {% set iconPath = 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' %}
        {% endif %}

        <div
            x-data="{ show: true }"
            x-show="show"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 flex items-center justify-center bg-black/40 z-[100] backdrop-blur-sm p-4"
            style="display: none;"
            x-init="$el.style.display = 'flex'"
        >
            {# Glassmorphism Card to match Login/Register #}
            <div
                @click.away="show = false"
                class="bg-white/90 backdrop-blur-2xl border border-white/40 p-8 rounded-[2rem] max-w-sm w-full text-center shadow-2xl transform transition-all"
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="scale-95 translate-y-4"
                x-transition:enter-end="scale-100 translate-y-0"
            >
                {# Icon Container #}
                <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-white/50 mb-6 shadow-inner">
                    <svg class="h-10 w-10 {{ colorClass }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="{{ iconPath }}" />
                    </svg>
                </div>

                <h3 class="text-2xl font-bold {{ colorClass }} mb-3 uppercase tracking-tight">
                    {{ title }}
                </h3>

                <p class="text-gray-600 mb-8 leading-relaxed font-medium">
                    {{ message }}
                </p>

                <button
                    @click="show = false"
                    class="w-full py-4 rounded-xl text-white font-bold text-lg tracking-widest transition-all shadow-lg uppercase cursor-pointer transform active:scale-95 {{ btnClass }}"
                >
                    Continue
                </button>
            </div>
        </div>
    {% endfor %}
{% endfor %}
