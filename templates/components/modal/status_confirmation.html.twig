{# templates/components/modal/status_confirmation.html.twig #}

<div id="statusModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">

    {# Backdrop #}
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity backdrop-blur-sm" aria-hidden="true" onclick="closeStatusModal()"></div>

        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        {# Modal Panel #}
        <div class="relative inline-block align-bottom bg-white rounded-xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-gray-100">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">

                    {# Dynamic Icon (Green or Red) #}
                    <div id="statusModalIconBg" class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full sm:mx-0 sm:h-10 sm:w-10 bg-red-100 transition-colors duration-200">
                        {# Warning Icon (Default) #}
                        <svg id="statusModalIcon" class="h-6 w-6 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>

                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                        <h3 class="text-lg leading-6 font-bold text-gray-900" id="statusModalTitle">
                            Change Status
                        </h3>
                        <div class="mt-2">
                            <p class="text-sm text-gray-500" id="statusModalMessage">
                                Are you sure you want to change the status for <span id="statusModalUserName" class="font-bold text-gray-800"></span>?
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            {# Buttons #}
            <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse gap-3">
                <form id="statusModalForm" method="post" action="">
                    <input type="hidden" name="_token" id="statusModalToken">

                    <button type="submit" id="statusModalConfirmBtn" class="w-full inline-flex justify-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:w-auto sm:text-sm transition">
                        Confirm
                    </button>
                </form>

                <button type="button" onclick="closeStatusModal()" class="mt-3 w-full inline-flex justify-center rounded-lg border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:w-auto sm:text-sm transition">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function openStatusModal(userId, userEmail, currentStatus, token) {
        const modal = document.getElementById('statusModal');
        const form = document.getElementById('statusModalForm');
        const title = document.getElementById('statusModalTitle');
        const messageUser = document.getElementById('statusModalUserName');
        const confirmBtn = document.getElementById('statusModalConfirmBtn');
        const tokenInput = document.getElementById('statusModalToken');

        // Icon Elements
        const iconBg = document.getElementById('statusModalIconBg');
        const icon = document.getElementById('statusModalIcon');

        // 1. Set Form Action & Data
        // IMPORTANT: Adjust this path to match your actual route
        form.action = `/admin/user/${userId}/toggle-status`;
        tokenInput.value = token;
        messageUser.textContent = userEmail;

        // 2. Dynamic Styling based on Status
        if (currentStatus === 'Active') {
            // --- DEACTIVATE MODE (Red) ---
            title.textContent = 'Deactivate Account?';
            confirmBtn.textContent = 'Deactivate';
            confirmBtn.className = "w-full inline-flex justify-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 sm:w-auto sm:text-sm transition";

            // Red Icon Style
            iconBg.className = "mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full sm:mx-0 sm:h-10 sm:w-10 bg-red-100";
            icon.classList.add('text-red-600');
            icon.classList.remove('text-green-600');
        } else {
            // --- ACTIVATE MODE (Green) ---
            title.textContent = 'Activate Account?';
            confirmBtn.textContent = 'Activate';
            confirmBtn.className = "w-full inline-flex justify-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-green-600 text-base font-medium text-white hover:bg-green-700 sm:w-auto sm:text-sm transition";

            // Green Icon Style
            iconBg.className = "mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full sm:mx-0 sm:h-10 sm:w-10 bg-green-100";
            icon.classList.remove('text-red-600');
            icon.classList.add('text-green-600');
        }

        // 3. Show Modal
        modal.classList.remove('hidden');
    }

    function closeStatusModal() {
        document.getElementById('statusModal').classList.add('hidden');
    }
</script>
