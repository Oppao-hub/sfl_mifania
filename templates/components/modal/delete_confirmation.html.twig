<div
    x-data="{
        open: false,
        url: '',
        name: '',
        token: ''
    }"
    x-show="open"
    @open-delete-modal.window="
        open = true;
        url = $event.detail.url;
        name = $event.detail.name;
        token = $event.detail.token;
    "
    class="fixed inset-0 z-[100] flex items-center justify-center p-4"
    x-cloak
>
    <div
        x-show="open"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="absolute inset-0 bg-dashboard-mocha/20 backdrop-blur-md"
    ></div>

    <div
        x-show="open"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0 scale-95 translate-y-4"
        x-transition:enter-end="opacity-100 scale-100 translate-y-0"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100 scale-100 translate-y-0"
        x-transition:leave-end="opacity-0 scale-95 translate-y-4"
        @click.away="open = false"
        class="relative bg-white rounded-[2rem] shadow-[0_20px_50px_rgba(66,43,28,0.15)] w-full max-w-md overflow-hidden border border-cream-200"
    >
        <div class="p-8 pt-10 text-center">
            <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-red-50/50 mb-6 border border-red-100">
                <svg class="h-10 w-10 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                </svg>
            </div>

            <h3 class="text-2xl font-black text-dashboard-mocha tracking-tight">Delete Item?</h3>
            <p class="text-sm text-gray-500 mt-3 leading-relaxed">
                You are about to remove <span x-text="name" class="font-bold text-dashboard-mocha underline decoration-dashboard-olive/30 underline-offset-4"></span>.
                This action is permanent and cannot be undone.
            </p>
        </div>

        <form :action="url" method="post" class="px-8 pb-10 flex flex-col sm:flex-row gap-3">
            <input type="hidden" name="_token" :value="token">

            <button
                type="button"
                @click="open = false"
                class="flex-1 order-2 sm:order-1 px-6 py-3.5 bg-gray-50 text-dashboard-mocha rounded-2xl hover:bg-gray-100 font-bold text-sm transition-all active:scale-95"
            >
                No, keep it
            </button>

            <button
                type="submit"
                class="flex-1 order-1 sm:order-2 px-6 py-3.5 bg-red-500 text-white rounded-2xl hover:bg-red-600 font-bold text-sm shadow-lg shadow-red-200 transition-all active:scale-95"
            >
                Yes, delete
            </button>
        </form>
    </div>
</div>
