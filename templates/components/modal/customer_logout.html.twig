{# Customer Glassmorphism Logout Modal #}
<div x-data="{ customerLogout: false }"
     @open-customer-logout.window="customerLogout = true"
     x-cloak>

    <div x-show="customerLogout"
         class="fixed inset-0 z-[100] flex items-center justify-center p-4">

        {# Brighter, Glassy Backdrop #}
        <div x-show="customerLogout"
             x-transition:enter="opacity-0"
             x-transition:enter-end="opacity-100"
             class="absolute inset-0 bg-white/10 backdrop-blur-md"></div>

        {# Glass Card #}
        <div @click.outside="customerLogout = false"
             x-show="customerLogout"
             x-transition:enter="transition ease-out duration-300 transform opacity-0 scale-95"
             x-transition:enter-end="opacity-100 scale-100"
             class="relative bg-white/30 backdrop-blur-xl border border-white/40 p-10 rounded-[2.5rem] w-full max-w-sm shadow-2xl text-center">

            <div class="mb-6">
                <img src="{{ asset('uploads/logo/logo.svg') }}" class="h-8 mx-auto opacity-80" alt="Mifania">
            </div>

            <h3 class="text-white text-xl font-bold mb-2">Leaving so soon?</h3>
            <p class="text-white/80 text-sm mb-8">We hope to see you back soon for more sustainable choices.</p>

            <div class="space-y-3">
                <a href="{{ path('app_logout') }}"
                   class="block w-full py-4 rounded-2xl bg-[#6b703d] text-white font-bold uppercase tracking-widest text-xs hover:bg-[#5a5f33] transition-all">
                    Confirm Logout
                </a>
                <button @click="customerLogout = false"
                        class="block w-full py-4 rounded-2xl bg-white/20 text-white font-bold uppercase tracking-widest text-xs hover:bg-white/30 transition-all border border-white/20">
                    Keep Browsing
                </button>
            </div>
        </div>
    </div>
</div>
