<svg
    xmlns="http://www.w3.org/2000/svg"
    class="{{ class|default('w-5 h-5')}}"
    fill="{{ fill| default('none') }}"
    stroke="currentColor"
    viewBox="0 0 24 24"
    stroke-width="{{ strokeWidth|default('2') }}"
    area-hidden="true"
    stroke-linecap="round"
    stroke-linejoin="round"
>
    <path d="{{ d1|default('0') }}"/>
    <circle cx="{{ cx|default('0') }}" cy="{{ cy|default('0') }}" r="{{ r|default('0') }}"/>
    <path d="{{ d2|default('0') }}" />
</svg>
