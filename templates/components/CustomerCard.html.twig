{# templates/components/customer_card.html.twig #}
<div class="p-6 bg-white rounded-xl shadow-md flex gap-4 items-center">
    {% if customer.avatar != 'No Avatar Yet' %}
        <img src="{{ asset('uploads/customer/avatars/' ~ customer.avatar) }}" alt="{{ customer.firstName }}" class="w-16 h-16 rounded-full object-cover">
    {% else %}
        <div class="w-16 h-16 rounded-full bg-gray-200 flex items-center justify-center text-xl font-bold text-gray-500">
            {{ customer.firstName|first }}
        </div>
    {% endif %}
    <div class="flex-1">
        <h2 class="text-lg font-semibold text-gray-800">{{ customer.firstName }} {{ customer.lastName }}</h2>
        <p class="text-gray-600">{{ customer.contactNumber }}</p>
        <p class="text-gray-600">{{ customer.email }}</p>
        <p class="text-gray-500 text-sm">Account Status: {{ customer.accountStatus }}</p>
    </div>
</div>
