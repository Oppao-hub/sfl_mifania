{# components/table/product_row.html.twig #}
{% set current_stock = product.totalStockQuantity %}
{% set stock_status = current_stock > 50 ? 'In Stock' : (current_stock > 0) ? 'Low Stock' : 'Sold Out' %}
{% set profit_class = product.profitPercentage >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %}

{% set category_class = product.category == 'Computer' ? 'bg-blue-100 text-blue-800 dark:bg-blue-800/20 dark:text-blue-400' :
                        (product.category == 'Accessories' ? 'bg-purple-100 text-purple-800 dark:bg-purple-800/20 dark:text-purple-400' :
                        (product.category == 'Handphone' ? 'bg-orange-100 text-orange-800 dark:bg-orange-800/20 dark:text-orange-400' :
                        'bg-gray-100 text-gray-800 dark:bg-gray-800/20 dark:text-gray-400')) %}

{% set stock_class = stock_status == 'In Stock' ? 'bg-green-100 text-green-800 dark:bg-green-800/20 dark:text-green-400' :
                    (stock_status == 'Low Stock' ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-800/20 dark:text-yellow-400' :
                    'bg-red-100 text-red-800 dark:bg-red-800/20 dark:text-red-400') %}


<tr
    class="hover:bg-indigo-50/50 dark:hover:bg-gray-700/50 transition duration-150"
>
    {# Row Checkbox #}
    <td class="px-6 py-4 w-10">
        <input type="checkbox" class="rounded border-gray-300 dark:border-gray-600 text-indigo-600 shadow-sm focus:ring-indigo-500">
    </td>

    {# ID Product #}
    <td
        class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400"
    >
        {{ product.id | format_id }}
    </td>

    {# Product Name & Image #}
    <td class="px-6 py-4 whitespace-nowrap">
        <div class="flex items-center">
            <div class="flex-shrink-0 h-10 w-10">
                <img
                    class="h-10 w-10 rounded-lg object-cover ring-1 ring-gray-100 dark:ring-gray-700"
                    src="{{ asset('/uploads/products/' ~ product.image) }}"
                    alt="{{ product.productName }}"
                />
            </div>
            <div class="ml-4">
                <div
                    class="text-sm font-semibold text-gray-900 dark:text-white"
                >
                    {{ product.productName }}
                </div>
            </div>
        </div>
    </td>

    {# Category Tag #}
    <td class="px-6 py-4 whitespace-nowrap">
        <span
            class="px-2 py-1 inline-flex text-xs leading-5 font-medium rounded-full {{ category_class }}"
        >
            {{ product.category }}
        </span>
    </td>

    {# Stock Status Badge #}
    <td class="px-6 py-4 whitespace-nowrap">
        <span
            class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full {{ stock_class }}"
        >
            {{ stock_status }}
        </span>
    </td>

    {# Price #}
    <td
        class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 dark:text-white"
    >
        PHP {{ product.price|number_format(0, '.', ',') }}
    </td>

    {# Net Profit #}
    <td
        class="px-6 py-4 whitespace-nowrap text-sm font-medium {{ profit_class }}"
    >
        {{ product.profitPercentage > 0 ? "+" : "" }}{{ product.profitPercentage }}%
    </td>

    {# Action Button (Ellipsis) #}
    <td
        class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium"
    >
        {# Dropdown Menu #}
        {% include 'components/table/action_dropdown.html.twig' with {
            actions: [
                {
                    label: "View",
                    path: path('app_admin_product_show', {'id': product.id}),
                    is_danger: false,
                },
                {
                    label: "Edit",
                    path: path('app_admin_product_edit', {'id': product.id}),
                    is_danger: false,
                },
                {
                    label: "Delete",
                    id: product.id,
                    name: product.productName,
                    is_danger: true,
                    is_delete: true
                }
            ]
        } only %}
    </td>
</tr>
