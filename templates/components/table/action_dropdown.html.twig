{# templates/components/table/action_dropdown.html.twig #}

{#
    @param array actions: An array of action links
#}

{% set default_actions = [] %}
{% set actions = actions|default(default_actions) %}

<div x-data="{ open: false }" class="relative inline-block text-left">
    {# Button to Toggle Dropdown #}
    <button
        @click="open = !open"
        type="button"
        class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 p-1 rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
        aria-expanded="false"
        aria-haspopup="true"
    >
        {# Ellipsis Icon SVG #}
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path
                d="M10 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4z"
            ></path>
        </svg>
    </button>

    {# Dropdown Menu (Hidden by default) #}
    <div
        x-show="open"
        @click.outside="open = false"
        x-transition:enter="transition ease-out duration-100"
        x-transition:enter-start="transform opacity-0 scale-95"
        x-transition:enter-end="transform opacity-100 scale-100"
        x-transition:leave="transition ease-in duration-75"
        x-transition:leave-start="transform opacity-100 scale-100"
        x-transition:leave-end="transform opacity-0 scale-95"
        class="origin-top-right absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none z-30"
        role="menu"
        tabindex="-1"
    >
        <div class="py-1" role="none">
            {% for action in actions %}
                {% set link_class = action.is_danger ?
                    'text-red-600 hover:bg-red-50' :
                    'text-gray-700 hover:bg-gray-100'
                %}

                {% if action.is_delete|default(false) %}
                    {# DELETE ACTION: Triggers the Alpine.js modal event #}
                    <a href="#"
                        @click.prevent="
                            $dispatch('open-delete-modal', {
                                id: {{ action.id }},
                                name: '{{ action.name|e('js') }}'
                            });
                            open = false;
                        "
                        class="{{ link_class }} block px-4 py-2 text-sm"
                        role="menuitem"
                        tabindex="-1"
                    >
                        {{ action.label }}
                    </a>
                {% else %}
                    {# STANDARD ACTION: Regular link (View, Edit) #}
                    <a href="{{ action.path }}"
                        class="{{ link_class }} block px-4 py-2 text-sm"
                        role="menuitem"
                        tabindex="-1"
                    >
                        {{ action.label }}
                    </a>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>
