{# templates/components/dashboard/toasts.html.twig #}

<div class="fixed top-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none">
    {% for label, messages in app.flashes %}
        {% for message in messages %}

            {% set config = {
                'success': {'color': 'text-green-600', 'bg': 'bg-green-50', 'border': 'border-green-200', 'icon': 'lucide:check-circle'},
                'error':   {'color': 'text-red-600', 'bg': 'bg-red-50', 'border': 'border-red-200', 'icon': 'lucide:alert-circle'},
                'danger':  {'color': 'text-red-600', 'bg': 'bg-red-50', 'border': 'border-red-200', 'icon': 'lucide:alert-circle'},
                'warning': {'color': 'text-yellow-600', 'bg': 'bg-yellow-50', 'border': 'border-yellow-200', 'icon': 'lucide:alert-triangle'}
            } %}

            {% set style = config[label]|default({'color': 'text-dashboard-mocha', 'bg': 'bg-white', 'border': 'border-gray-200', 'icon': 'lucide:info'}) %}

            <div x-data="{ show: false }"
                 x-init="setTimeout(() => show = true, 100); setTimeout(() => show = false, 5000)"
                 x-show="show"
                 x-transition:enter="transition ease-out duration-300 transform"
                 x-transition:enter-start="opacity-0 translate-x-8"
                 x-transition:enter-end="opacity-100 translate-x-0"
                 x-transition:leave="transition ease-in duration-200 transform"
                 x-transition:leave-start="opacity-100 translate-x-0"
                 x-transition:leave-end="opacity-0 translate-x-8"
                 class="pointer-events-auto flex items-start gap-4 p-4 w-[350px] bg-white rounded-xl shadow-2xl shadow-dashboard-mocha/10 border {{ style.border }} border-l-4 overflow-hidden"
                 style="border-left-color: currentColor;"
                 x-cloak>

                <div class="{{ style.color }} shrink-0 mt-0.5">
                    {{ ux_icon(style.icon, {class: 'w-5 h-5'}) }}
                </div>

                <div class="flex-1">
                    <h4 class="text-[10px] font-black uppercase tracking-widest {{ style.color }} mb-1">{{ label|capitalize }}</h4>
                    <p class="text-xs font-bold text-gray-600 leading-relaxed">{{ message }}</p>
                </div>

                <button @click="show = false" class="text-gray-400 hover:text-gray-600 transition-colors cursor-pointer">
                    {{ ux_icon('lucide:x', {class: 'w-4 h-4'}) }}
                </button>
            </div>

        {% endfor %}
    {% endfor %}
</div>
