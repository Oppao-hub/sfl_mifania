<div class="fixed top-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none">
    {% for label, messages in app.flashes %}
        {% for message in messages %}

            {# Semantic Theme Config Map #}
            {% set config = {
                'success': {'color': 'text-success', 'bg': 'bg-success/5', 'border': 'border-success/20', 'icon': 'lucide:check-circle'},
                'error':   {'color': 'text-danger', 'bg': 'bg-danger/5', 'border': 'border-danger/20', 'icon': 'lucide:alert-circle'},
                'danger':  {'color': 'text-danger', 'bg': 'bg-danger/5', 'border': 'border-danger/20', 'icon': 'lucide:alert-circle'},
                'warning': {'color': 'text-warning', 'bg': 'bg-warning/5', 'border': 'border-warning/20', 'icon': 'lucide:alert-triangle'}
            } %}

            {% set style = config[label]|default({'color': 'text-brand-dark', 'bg': 'bg-app-bg', 'border': 'border-border-color', 'icon': 'lucide:info'}) %}

            <div x-data="{ show: false }"
                 x-init="setTimeout(() => show = true, 100); setTimeout(() => show = false, 5000)"
                 x-show="show"
                 x-transition:enter="transition ease-out duration-300 transform"
                 x-transition:enter-start="opacity-0 translate-x-8"
                 x-transition:enter-end="opacity-100 translate-x-0"
                 x-transition:leave="transition ease-in duration-200 transform"
                 x-transition:leave-start="opacity-100 translate-x-0"
                 x-transition:leave-end="opacity-0 translate-x-8"
                 class="pointer-events-auto flex items-start gap-4 p-4 w-[350px] bg-white rounded-xl shadow-2xl shadow-brand-dark/10 border {{ style.border }} border-l-4 overflow-hidden"
                 style="border-left-color: currentColor;"
                 x-cloak>

                <div class="{{ style.color }} shrink-0 mt-0.5">
                    {{ ux_icon(style.icon, {class: 'w-5 h-5'}) }}
                </div>

                <div class="flex-1">
                    <h4 class="text-[10px] font-black uppercase tracking-widest {{ style.color }} mb-1">{{ label|capitalize }}</h4>
                    <p class="text-xs font-bold text-dark-gray leading-relaxed">{{ message }}</p>
                </div>

                <button @click="show = false" class="text-gray/50 hover:text-brand-dark transition-colors cursor-pointer mt-0.5">
                    {{ ux_icon('lucide:x', {class: 'w-4 h-4'}) }}
                </button>
            </div>

        {% endfor %}
    {% endfor %}
</div>
