<div x-data="{
        isOpen: false,
        title: '',
        message: '',
        actionUrl: '',
        confirmText: 'Confirm',
        csrfToken: '',
        isDanger: false,
        extraField: { name: '', value: '' },

        open(detail) {
            this.reset();
            this.title = detail.title || 'Confirm Action';
            this.message = detail.message || 'Are you sure you want to proceed?';
            this.actionUrl = detail.actionUrl || detail.url || '';
            this.confirmText = detail.confirmText || 'Confirm';
            this.csrfToken = detail.csrfToken || detail.token || '';
            this.isDanger = detail.isDanger || false;
            this.isOpen = true;
        },

        openDelete(detail) {
            this.reset();
            this.title = 'Delete Confirmation';
            this.message = 'Are you sure you want to delete ' + (detail.name || 'this item') + '? This action cannot be undone.';
            this.actionUrl = detail.url || '';
            this.confirmText = 'Delete';
            this.csrfToken = detail.token || '';
            this.isDanger = true;
            this.isOpen = true;
        },

        openStatus(detail) {
            this.reset();
            const identifier = detail.email || detail.name || 'this item';
            const current = detail.currentStatus || 'current';
            const target = detail.newStatus || 'the selected';
            
            this.title = detail.title || 'Update Status';
            this.message = detail.message || `Are you sure you want to change the status of <b>${identifier}</b> from <span class='text-gray'>${current}</span> to <b class='text-brand'>${target}</b>?`;
            this.actionUrl = detail.url || '';
            this.confirmText = detail.confirmText || 'Update Status';
            this.csrfToken = detail.token || '';
            this.isDanger = detail.isDanger || false;
            
            if (detail.fieldName && detail.newStatus) {
                this.extraField.name = detail.fieldName;
                this.extraField.value = detail.newStatus;
            }
            
            this.isOpen = true;
        },

        reset() {
            this.title = '';
            this.message = '';
            this.actionUrl = '';
            this.confirmText = 'Confirm';
            this.csrfToken = '';
            this.isDanger = false;
            this.extraField = { name: '', value: '' };
        }
    }"
    @open-confirm.window="open($event.detail)"
    @open-delete-modal.window="openDelete($event.detail)"
    @open-status-modal.window="openStatus($event.detail)"
    @keydown.escape.window="isOpen = false"
    x-init="$watch('isOpen', value => document.body.classList.toggle('overflow-hidden', value))"
    x-show="isOpen"
    style="display: none;"
    class="fixed inset-0 z-[100]"
    aria-labelledby="modal-title"
    role="dialog"
    aria-modal="true">

    {# Background Backdrop #}
    <div x-show="isOpen"
         x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
         class="fixed inset-0 bg-brand-dark/40 backdrop-blur-md transition-opacity"></div>

    {# Modal Panel #}
    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
        <div class="flex min-h-screen items-center justify-center p-4 text-center sm:p-0">

            <div x-show="isOpen"
                 @click.away="isOpen = false"
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100" x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-md border border-border-color">

                <div class="bg-white px-6 pt-8 pb-6">
                    <div class="flex flex-col items-center text-center">

                        {# Dynamic Icon #}
                        <div class="mb-5 flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-2xl shadow-sm border transition-all duration-300"
                             :class="isDanger ? 'bg-red-50 text-red-600 border-red-100' : 'bg-brand/5 text-brand border-brand/10'">
                            <template x-if="isDanger">
                                {{ ux_icon('lucide:alert-triangle', { class: 'w-8 h-8' }) }}
                            </template>
                            <template x-if="!isDanger">
                                {{ ux_icon('lucide:refresh-cw', { class: 'w-8 h-8' }) }}
                            </template>
                        </div>

                        <h3 class="text-xl font-black uppercase tracking-widest text-brand-dark mb-3" id="modal-title" x-text="title"></h3>
                        <div class="text-sm text-dark-gray leading-relaxed font-medium px-2" x-html="message"></div>
                    </div>
                </div>

                {# Action Buttons #}
                <div class="bg-app-bg px-6 py-6 flex flex-col gap-3 border-t border-border-color">
                    <template x-if="csrfToken">
                        <form :action="actionUrl" method="POST" class="w-full">
                            <input type="hidden" name="_token" :value="csrfToken">
                            <template x-if="extraField.name">
                                <input type="hidden" :name="extraField.name" :value="extraField.value">
                            </template>
                            <button type="submit"
                                    class="w-full flex items-center justify-center rounded-xl px-6 py-3.5 text-xs font-black uppercase tracking-[0.2em] text-white shadow-lg shadow-brand/20 transition-all hover:-translate-y-0.5 active:translate-y-0 cursor-pointer"
                                    :class="isDanger ? 'bg-danger hover:bg-red-700 shadow-danger/20' : 'bg-brand hover:bg-brand-dark'"
                                    x-text="confirmText">
                            </button>
                        </form>
                    </template>

                    <template x-if="!csrfToken">
                        <a :href="actionUrl"
                           class="w-full flex items-center justify-center rounded-xl px-6 py-3.5 text-xs font-black uppercase tracking-[0.2em] text-white shadow-lg shadow-brand/20 transition-all hover:-translate-y-0.5 active:translate-y-0 cursor-pointer"
                           :class="isDanger ? 'bg-danger hover:bg-red-700 shadow-danger/20' : 'bg-brand hover:bg-brand-dark'"
                           x-text="confirmText">
                        </a>
                    </template>

                    <button type="button" @click="isOpen = false"
                            class="w-full flex items-center justify-center rounded-xl bg-white px-6 py-3.5 text-xs font-black uppercase tracking-[0.2em] text-gray shadow-sm border border-border-color hover:bg-row-hover hover:text-brand-dark transition-all cursor-pointer">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Global function for non-Alpine triggers (like onclick in legacy tables)
    window.openDeleteModal = function(id, name, token) {
        window.dispatchEvent(new CustomEvent('open-delete-modal', {
            detail: {
                url: '/dashboard/wallet/' + id + '/delete', // Note: this needs to be smarter or passed
                name: name,
                token: token
            }
        }));
    };
</script>
