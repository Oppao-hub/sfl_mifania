{% extends 'customer/account/index.html.twig' %}

{% block title %}My Wallet{% endblock %}

{% block account_content %}
<div class="container mx-auto">

    {# --- 1. BALANCE CARD --- #}
    <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-8">
        <div class="p-8 md:p-10 bg-gradient-to-r from-mocha to-[#5C3D2E] text-white relative">

            {# Decorative background circle #}
            <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-white opacity-10 rounded-full blur-2xl"></div>

            <h2 class="text-sm font-medium uppercase tracking-wider opacity-80 mb-2">Total Balance</h2>

            <div class="flex items-baseline gap-2 mb-8">
                <span class="text-5xl font-bold tracking-tight">
                    {# Use null coalescing to prevent errors if wallet doesn't exist yet #}
                    ₱ {{ wallet ? wallet.balance|number_format(2) : '0.00' }}
                </span>
                <span class="text-lg opacity-80 font-medium">PHP</span>
            </div>

            <div class="flex flex-wrap gap-4">
                {# Top Up Button #}
                <button class="bg-white text-mocha px-6 py-2.5 rounded-lg font-bold hover:bg-gray-100 transition shadow-sm flex items-center group">
                    <div class="mr-2 p-1 bg-mocha/10 rounded-full group-hover:bg-mocha/20 transition">
                        <svg class="w-4 h-4 text-mocha" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                    </div>
                    Top Up Wallet
                </button>

                {# Withdraw/Transfer Button #}
                <button class="bg-black/20 text-white border border-white/20 px-6 py-2.5 rounded-lg font-bold hover:bg-black/30 transition flex items-center backdrop-blur-sm">
                    <svg class="w-5 h-5 mr-2 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                    </svg>
                    Transfer Funds
                </button>
            </div>
        </div>
    </div>

    {# --- 2. TRANSACTION HISTORY --- #}
    <div class="bg-white rounded-xl shadow-md border border-gray-100 p-6">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-gray-800">Transaction History</h3>

            {# Filter (Visual Only) #}
            <div class="relative">
                <select class="appearance-none bg-gray-50 border border-gray-200 text-gray-700 py-2 pl-4 pr-8 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-mocha focus:border-transparent cursor-pointer">
                    <option>All Transactions</option>
                    <option>Deposits</option>
                    <option>Withdrawals</option>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-500">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </div>
            </div>
        </div>

        {# Check if transactions exist (Assuming wallet.transactions is a collection) #}
        {% if wallet and wallet.transactions is defined and wallet.transactions|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-gray-400 border-b border-gray-100 text-xs uppercase tracking-wider">
                            <th class="pb-3 font-semibold pl-2">Date</th>
                            <th class="pb-3 font-semibold">Description</th>
                            <th class="pb-3 font-semibold">Status</th>
                            <th class="pb-3 font-semibold text-right pr-2">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-50">
                        {% for transaction in wallet.transactions %}
                            <tr class="hover:bg-gray-50 transition duration-150">
                                <td class="py-4 pl-2 text-gray-500">
                                    {{ transaction.createdAt|date('M d, Y') }}
                                    <span class="block text-xs text-gray-400">{{ transaction.createdAt|date('h:i A') }}</span>
                                </td>
                                <td class="py-4">
                                    <p class="font-medium text-gray-800">{{ transaction.description }}</p>
                                    <p class="text-xs text-gray-500">ID: #{{ transaction.id }}</p>
                                </td>
                                <td class="py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        Completed
                                    </span>
                                </td>
                                <td class="py-4 pr-2 text-right">
                                    {% if transaction.type == 'credit' %}
                                        <span class="text-green-600 font-bold">+ ₱ {{ transaction.amount|number_format(2) }}</span>
                                    {% else %}
                                        <span class="text-gray-800 font-bold">- ₱ {{ transaction.amount|number_format(2) }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            {# --- EMPTY STATE --- #}
            <div class="text-center py-12 border-2 border-dashed border-gray-100 rounded-lg">
                <div class="bg-gray-50 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                    </svg>
                </div>
                <h4 class="text-gray-900 font-medium mb-1">No transactions yet</h4>
                <p class="text-gray-500 text-sm max-w-xs mx-auto">
                    You haven't made any transactions yet. Top up your wallet to get started!
                </p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
