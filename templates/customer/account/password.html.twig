{% extends 'customer/account/index.html.twig' %}
{% block title %}Password{% endblock %}
{% block account_content %}
<div class="lg:w-3/4 bg-white p-8 rounded-lg shadow-md">
    <h1 class="mb-2 text-2xl font-bold text-mocha">Change password</h1>

    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="flex flex-col gap-4" x-data="{ showPassword: false }">
            {{ form_label(form.currentPassword, '', {label_attr: {'class': ''}}) }}
            <div class="relative">
                {{ form_widget(form.currentPassword, {'attr': {'class':
                    'text-lg w-full p-2 border border-gray-300 rounded',
                    'x-bind:type': "showPassword ? 'text' : 'password'"}})}}
            </div>
            {{ form_errors(form.currentPassword) }}

            {{ form_label(form.plainPassword.first, '', {label_attr: {'class': ''}}) }}
            {{ form_widget(form.plainPassword.first, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded'}})}}
            {{ form_errors(form.plainPassword.first) }}

            {{ form_label(form.plainPassword.second, '', {label_attr: {'class': ''}}) }}
            {{ form_widget(form.plainPassword.second, {'attr': {'class': 'w-full p-2 border border-gray-300 rounded'}})}}
            {{ form_errors(form.plainPassword.second) }}

            <div class="flex justify-end mt-4">
                <button type="submit" class="bg-brand px-4 py-2 rounded-xl text-white font-semibold hover:bg-mocha-400 transition">
                    Change password
                </button>
            </div>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
