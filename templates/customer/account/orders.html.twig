{% extends 'customer/account/index.html.twig' %}

{% block title %}My Orders{% endblock %}

{% block account_content %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">My Orders</h1>
        <a href="{{ path('app_order_new') }}" class="bg-[#6B7C57] text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-[#556345] transition-colors">
            Place New Order
        </a>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-600">
                <thead class="bg-[#F3C476] text-gray-900 uppercase font-bold text-xs">
                    <tr>
                        <th class="px-6 py-4">Order ID</th>
                        <th class="px-6 py-4">Date</th>
                        <th class="px-6 py-4">Total</th>
                        <th class="px-6 py-4">Payment</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4">Reward Points</th>
                        <th class="px-6 py-4 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                {% for order in orders %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 font-medium text-gray-900">
                            #{{ order.id }}
                        </td>
                        <td class="px-6 py-4">
                            {{ order.createdAt ? order.createdAt|date('M d, Y') : '-' }}
                            <div class="text-xs text-gray-400">{{ order.createdAt ? order.createdAt|date('H:i') : '' }}</div>
                        </td>
                        <td class="px-6 py-4 font-semibold text-gray-900">
                            ${{ order.totalAmount|number_format(2) }}
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col">
                                <span class="font-medium">{{ order.paymentMethod.value }}</span>
                                <span class="text-xs
                                    {% if order.paymentStatus.value == 'Paid' or order.paymentStatus.value == 'Completed' %}text-green-600
                                    {% elseif order.paymentStatus.value == 'Pending' %}text-orange-500
                                    {% else %}text-red-500{% endif %}">
                                    {{ order.paymentStatus.value }}
                                </span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                {% if order.orderStatus.value == 'Delivered' or order.orderStatus.value == 'Completed' %} bg-green-100 text-green-800
                                {% elseif order.orderStatus.value == 'Processing' or order.orderStatus.value == 'Shipped' %} bg-blue-100 text-blue-800
                                {% elseif order.orderStatus.value == 'Cancelled' %} bg-red-100 text-red-800
                                {% else %} bg-yellow-100 text-yellow-800 {% endif %}">
                                {{ order.orderStatus.value }}
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            {% if order.rewardPoints > 0 %}
                                <span class="text-[#6B7C57] font-semibold">+{{ order.rewardPoints }} pts</span>
                            {% else %}
                                <span class="text-gray-400">-</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-center">
                            <a href="{{ path('app_order_show', {'id': order.id}) }}" class="text-[#6B7C57] hover:text-[#556345] font-medium hover:underline">
                                View Details
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                            </svg>
                            <p class="text-lg">No orders found</p>
                            <p class="text-sm mb-4">Start shopping to see your orders here.</p>
                            <a href="{{ path('app_shop') }}" class="text-[#6B7C57] font-semibold hover:underline">Go to Shop</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
