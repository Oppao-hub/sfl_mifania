{% extends 'base.html.twig' %}

{% block title %}Shopping Cart{% endblock %}

{% block main_content %}
<section class="bg-gray-50 py-16 px-6 md:px-12 min-h-[70vh]">
        <div class="max-w-[1440px] mx-auto">
            <h1 class="text-3xl font-bold text-brand mb-8">Shopping Cart <span class="text-sm font-normal text-gray-500 ml-2">(2 Items)</span></h1>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                <!-- Cart Items List -->
                {% if cart is empty %}
                    <div class="text-center p-10 bg-white shadow rounded-lg">
                        <p class="text-gray-600 text-lg">Your cart is currently empty.</p>
                        <a href="{{ path('app_home') }}" class="mt-4 inline-block text-white bg-mocha px-6 py-2 rounded hover:bg-mocha-dark transition">
                            Continue Shopping
                        </a>
                    </div>
                {% else %}
                    <div class="lg:col-span-2 space-y-6">
                        <!-- Item 1 -->
                        <div class="bg-white p-6 rounded-lg shadow-sm flex flex-col sm:flex-row gap-6 items-center sm:items-start">
                            <div class="w-32 h-40 bg-gray-100 flex-shrink-0 overflow-hidden rounded-md">
                                <img src="https://images.unsplash.com/photo-1595777457583-95e059d581b8?q=80&w=400&auto=format&fit=crop" alt="Dress" class="w-full h-full object-cover">
                            </div>
                            <div class="flex-1 w-full">
                                <div class="flex justify-between items-start mb-2">
                                    <div>
                                        <p class="text-xs font-bold text-gray-400 uppercase mb-1">Dresses</p>
                                        <h3 class="text-lg font-bold text-gray-800">Organic Cotton Day Dress</h3>
                                        <p class="text-xs text-gray-500 mt-1">Size: M | Color: Rust</p>
                                    </div>
                                    <button class="text-gray-400 hover:text-red-500 transition-colors">
                                        {{ ux_icon('lucide:trash-2', { class: 'h-5 w-5' }) }}
                                    </button>
                                </div>
                                <div class="flex justify-between items-end mt-6">
                                    <div class="flex items-center border border-gray-300 rounded-md">
                                        <button class="px-3 py-1 text-gray-500 hover:bg-gray-100">-</button>
                                        <input type="text" value="1" class="w-10 text-center text-sm border-x border-gray-300 py-1 focus:outline-none">
                                        <button class="px-3 py-1 text-gray-500 hover:bg-gray-100">+</button>
                                    </div>
                                    <p class="text-lg font-bold text-brand">PHP 1,500</p>
                                </div>
                            </div>
                        </div>

                        <!-- Item 2 -->
                        <div class="bg-white p-6 rounded-lg shadow-sm flex flex-col sm:flex-row gap-6 items-center sm:items-start">
                            <div class="w-32 h-40 bg-gray-100 flex-shrink-0 overflow-hidden rounded-md">
                                <img src="https://images.unsplash.com/photo-1590874103328-304371a57b90?q=80&w=400&auto=format&fit=crop" alt="Bag" class="w-full h-full object-cover">
                            </div>
                            <div class="flex-1 w-full">
                                <div class="flex justify-between items-start mb-2">
                                    <div>
                                        <p class="text-xs font-bold text-gray-400 uppercase mb-1">Accessories</p>
                                        <h3 class="text-lg font-bold text-gray-800">Reusable Bamboo Tote Bag</h3>
                                        <p class="text-xs text-gray-500 mt-1">One Size | Color: Natural</p>
                                    </div>
                                    <button class="text-gray-400 hover:text-red-500 transition-colors">
                                        {{ ux_icon('lucide:trash-2', { class: 'h-5 w-5' }) }}
                                    </button>
                                </div>
                                <div class="flex justify-between items-end mt-6">
                                    <div class="flex items-center border border-gray-300 rounded-md">
                                        <button class="px-3 py-1 text-gray-500 hover:bg-gray-100">-</button>
                                        <input type="text" value="1" class="w-10 text-center text-sm border-x border-gray-300 py-1 focus:outline-none">
                                        <button class="px-3 py-1 text-gray-500 hover:bg-gray-100">+</button>
                                    </div>
                                    <p class="text-lg font-bold text-brand">PHP 800</p>
                                </div>
                            </div>
                        </div>

                        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-brand hover:underline mt-4">
                            {{ ux_icon('lucide:arrow-left', { class: 'h-4 w-4' }) }} Continue Shopping
                        </a>
                    </div>
                {% endif %}

                <!-- Order Summary -->
                <div class="lg:col-span-1">
                    <div class="bg-white p-8 rounded-lg shadow-sm sticky top-28">
                        <h2 class="text-xl font-bold text-gray-800 mb-6">Order Summary</h2>

                        <div class="space-y-4 text-sm text-gray-600 mb-6 border-b border-gray-100 pb-6">
                            <div class="flex justify-between">
                                <span>Subtotal</span>
                                <span class="font-medium">PHP 2,300</span>
                            </div>
                            <div class="flex justify-between">
                                <span>Shipping Estimate</span>
                                <span class="font-medium text-green-600">FREE</span>
                            </div>
                            <div class="flex justify-between">
                                <span>Tax</span>
                                <span class="font-medium">PHP 0</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-center mb-8">
                            <span class="text-lg font-bold text-gray-800">Total</span>
                            <span class="text-xl font-bold text-brand">PHP 2,300</span>
                        </div>

                        <button class="w-full bg-brand text-white py-4 rounded-md font-bold hover:bg-brand-dark transition-all shadow-lg hover:shadow-xl mb-4">
                            Proceed to Checkout
                        </button>

                        <div class="flex items-center justify-center gap-2 text-xs text-gray-400 mt-4">
                             {{ ux_icon('lucide:shield-check', { class: 'h-4 w-4' }) }}
                             Secure Checkout
                        </div>

                        <!-- Coupon Code -->
                        <div class="mt-8 pt-6 border-t border-gray-100">
                             <p class="text-xs font-bold text-gray-400 uppercase mb-3">Promo Code</p>
                             <div class="flex gap-2">
                                 <input type="text" placeholder="Enter code" class="flex-1 border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-brand">
                                 <button class="text-xs font-bold text-brand hover:text-brand-dark uppercase">Apply</button>
                             </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
