{% extends "customer/category/index.html.twig" %}

{% block title %}{{ subCategory.name }}{% endblock %}

{% block product_grid %}
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
    {% if products is not empty %}
        {# Responsive Grid Layout: 2 columns default, 3 on small, 4 on large screens #}
            {% for product in products %}
            <div class="group relative flex flex-col">
                {# 1. Product Link corrected to use product.id for detail page #}
                <a href="{{ path('app_product_show', { 'slug': product.slug }) | default('#') }}">
                    <div class="w-full aspect-[2/3] bg-gray-100 overflow-hidden rounded-lg shadow-sm">
                        <img src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('public/images/default-product.png') }}"
                            alt="{{ product.name }}"
                            class="w-full h-full object-cover object-center group-hover:opacity-75 transition-opacity duration-300">
                    </div>
                </a>

                <div class="absolute top-2 left-2 right-2 flex justify-between items-start">
                    {# 2. Only show NEW badge if the product property exists and is true #}
                    {#{% if product.is_new is defined and product.is_new %}
                        <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded">NEW</span>
                    {% else %}#}
                        <span></span>

                    <button class="text-white hover:text-red-500 transition duration-200 p-2 z-10"
                            title="Add to Wishlist"
                            onclick="console.log('Added product {{ product.id }} to wishlist')">
                        {# Heart Icon SVG #}
                        <twig:icon d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" class="w-6 h-6" fill="currentColor"/>
                    </button>
                </div>

                <div class="mt-4 flex flex-col space-y-1">
                    <h3 class="text-sm text-mocha font-medium truncate">
                        {# 1. Product Link corrected to use product.id for detail page #}
                        <a href="{{ path('app_product_show', { 'slug': product.slug}) | default('#') }}" class="hover:underline">
                            {{ product.name }}
                        </a>
                    </h3>

                    <p class="text-xs text-mocha-200 font-normal">
                        {{ product.designer is defined ? product.designer : 'Designer' }}
                    </p>

                    <p class="text-sm font-semibold text-mocha">PHP {{ product.price|number_format(2, '.', ',') }}</p>
                </div>
            </div>
            {% endfor %}
    {% else %}
        <p class="text-lg text-mocha mt-8 col-span-4">No products were found in this listing.</p>
    {% endif %}
</div>
{% endblock %}
