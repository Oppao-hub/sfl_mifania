{% extends 'customer/category/index.html.twig' %}

{% block title %}{{ currentSubCategory.name }}{% endblock %}

{% block beradcrumbs %}
    <div class="text-sm text-mocha-200 mb-6">
        <a href="{{ path('app_home') }}" class="hover:underline">Home</a> /
        <a href="{{ path('app_category_show', {'slug': category.slug }) }}" class="hover:underline">{{ category.name }}</a> /
        <span x-text="currentSubCategoryName" class="text-mocha"></span>
    </div>
{% endblock %}

{% block product_grid %}
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    {% for product in products %}
        {# {% set discount_percentage = product.price < product.originalPrice ? ((product.originalPrice - product.price) / product.originalPrice * 100)|round : 0 %} #}

        <a href="{{ path('app_product_show', { 'slug': product.slug }) }}">
            <div class="product-card bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300">

                {# Image and Quick Actions #}
                <div class="relative group">
                    <img
                        src="{{ product.image ? asset('uploads/products/' ~ product.image) : asset('images/default-product.png') }}"
                        alt="Product {{ product.name }}"
                        class="w-full h-auto object-cover rounded-t-xl"
                        onerror="this.onerror=null;this.src='https://placehold.co/600x800/e5e7eb/525252?text=Error';"
                        style="aspect-ratio: 3/4;"
                    >

                    <div class="absolute inset-0 bg-mocha bg-opacity-10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                        <div class="flex space-x-3">
                            {# Wishlist Button: Assuming this is purely visual, but should ideally be in a form or AJAX call #}
                            <button type="button" title="Add to Wishlist" class="p-3 bg-white rounded-full text-gray-800 hover:text-red-600 transition">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" /></svg>
                            </button>

                            {# Add to Cart Button #}
                            <button type="button" title="Quick Add to Cart" class="p-3 bg-white rounded-full text-gray-800 hover:text-red-600 transition">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43a1 1 0 00.95.69h4.38a1 1 0 00.945-.682l1.09-5.464a1 1 0 00-.232-.716V3a1 1 0 10-2 0v.517l-.744 3.725L7.95 4H6.84a1 1 0 00-.77 1.693l1.883 1.883a.999.999 0 00-.071 1.414.999.999 0 001.414-.071l1.883-1.883a1 1 0 001.414 0l1.883 1.883a.999.999 0 001.414-.071.999.999 0 00-.071-1.414l-1.883-1.883A1 1 0 0013.92 4h-1.01l-1.358-5.43a1 1 0 00-.95-.69H4.22L3 1zM7 16a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z"/></svg>
                            </button>
                        </div>
                    </div>
                </div>

                {# Details #}
                <div class="p-4">
                    <p class="text-xs text-gray-500 mb-1">{{ product.category.name|default('Uncategorized') }}</p>
                    <h3 class="font-medium text-base mb-2 truncate">{{ product.name }}</h3>
                    <div class="flex justify-between items-center">
                        <p class="text-lg font-semibold text-mocha">
                            {# Use the custom filter for currency if available, otherwise 'number_format' #}
                            PHP {{ product.price|number_format(2) }}

                        </p>
                        <div class="flex items-center text-sm text-gray-600">
                            {# Placeholder for dynamic rating logic #}
                            <span class="text-yellow-500">★</span> 4.8
                        </div>
                    </div>
                </div>
            </div>
        </a>
    {% endfor %}

    {# Handle No Products Found #}
    {% if products is empty %}
        <div class="md:col-span-3 lg:col-span-4 p-8 text-center text-gray-500">
            No products found in this category.
        </div>
    {% endif %}
</div>

{# ---------------------------------------------------- #}
{# --- PAGINATION (Must be outside the grid loop) --- #}
{# ---------------------------------------------------- #}
<div class="mt-12 flex justify-center items-center">
    {% set totalPages = ((numberOfItems|default(0) + limit|default(1) - 1) / limit|default(1))|round(0, 'ceil') %}
    <nav class="flex items-center justify-center pt-8" aria-label="Pagination">
        <div class="flex space-x-2">

            {# --------------------------------------------------- #}
            {# 2. PREVIOUS Button #}
            {# Disabled if current page is 1 #}
            <a
                href="{{ path('app_sub_category_show', { 'slug': currentSubCategory.slug, 'page': page - 1 }) }}"
                class="px-4 py-2 text-sm font-medium border rounded-lg
                    {% if page <= 1 %}
                        text-gray-400 bg-gray-100 cursor-not-allowed
                    {% else %}
                        text-mocha-600 bg-white hover:bg-gray-50 border-gray-300
                    {% endif %}"
                aria-disabled="{{ page <= 1 ? 'true' : 'false' }}"
            >
                Previous
            </a>

            {# --------------------------------------------------- #}
            {# 3. PAGE NUMBERS LOOP #}
            {% for i in 1..totalPages %}
                <a
                    href="{{ path('app_sub_category_show', { 'slug': currentSubCategory.slug, 'page': i }) }}"
                    class="px-4 py-2 text-sm font-medium border rounded-lg
                        {% if i == page %}
                            text-white bg-mocha-700 border-mocha-700 pointer-events-none
                        {% else %}
                            text-mocha-600 bg-white hover:bg-gray-50 border-gray-300
                        {% endif %}"
                    aria-current="{{ i == page ? 'page' : 'false' }}"
                >
                    {{ i }}
                </a>
            {% endfor %}

            {# --------------------------------------------------- #}
            {# 4. NEXT Button #}
            {# Disabled if current page is the last page #}
            <a
                href="{{ path('app_sub_category_show', { 'slug': currentSubCategory.slug, 'page': page + 1 }) }}"
                class="px-4 py-2 text-sm font-medium border rounded-lg
                    {% if page >= totalPages %}
                        text-gray-400 bg-gray-100 cursor-not-allowed
                    {% else %}
                        text-mocha-600 bg-white hover:bg-gray-50 border-gray-300
                    {% endif %}"
                aria-disabled="{{ page >= totalPages ? 'true' : 'false' }}"
            >
                Next
            </a>
        </div>
    </nav>
</div>
{% endblock %}
