{% extends 'base.html.twig' %} {% block title %}Homepage{% endblock %} {% block
main_content %}
    <!-- HERO SECTION -->
    <section class="flex items-center w-full h-screen relative">
        <!-- Left image -->
        <div class="w-1/3 h-full l-5">
            <img
                src=" {{ asset('images/heroimg1.png') }}"
                alt="Left image"
                class="object-cover w-full h-full"
            />
        </div>

        <!-- Center text block -->
        <div
            class="w-1/3 h-full bg-white flex items-center justify-center flex-col"
        >
            <h1 class="text-4xl font-bold text-gray-800 mb-4">
                Sustainable Fashion
            </h1>
            <p class="text-gray-600 text-lg">
                Eco-friendly. Timeless. Made to last.
            </p>
            <button
                class="mt-6 bg-mocha text-cream px-6 py-3 rounded-lg hover:bg-green-800 transition"
            >
                Shop Now
            </button>
        </div>

        <!-- Right image -->
        <div class="w-1/3 h-full">
            <img
                src="{{ asset('images/heroimg2.png') }}"
                alt="Right image"
                class="object-cover w-full h-full"
            />
        </div>
    </section>

    <!-- FEATURED COLLECTIONS -->
    <section class="py-12 px-4">
        <h2 class="text-2xl font-bold text-center mb-8 text-mocha">
            Featured Collections
        </h2>
        <div
            class="max-w-[1360px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-6"
        >
            <div class="bg-white shadow-md overflow-hidden flex flex-col">
                <img
                    src="{{ asset('images/categories/category1.png') }}"
                    alt="Collection 1"
                    class="w-full h-[500px] object-cover"
                />
                <div class="p-4">
                    <a
                        href="#"
                        class="inline-block mt-4 bg-mocha text-cream rounded px-4 py-2 font-semibold transition-colors duration-300 hover:bg-green"
                    >
                        Shop Now
                    </a>
                </div>
            </div>

            <div class="bg-white shadow-md overflow-hidden flex flex-col">
                <img
                    src="{{ asset('images/categories/category1.png') }}"
                    alt="Collection 2"
                    class="w-full h-[500px] object-cover"
                />
                <div class="p-4">
                    <a
                        href="#"
                        class="inline-block mt-4 bg-mocha text-cream rounded px-4 py-2 font-semibold transition-colors duration-300 hover:bg-green"
                    >
                        Shop Now
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- NEW ARRIVALS -->
    <section class="py-12 px-4">
        <div class="max-w-[1360px] mx-auto">
            <h2 class="text-2xl font-bold text-center mb-8 text-mocha">
                New Arrivals
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                {% for i in 1..3 %}
                <div
                    class="bg-white shadow-md overflow-hidden transition-transform duration-300 hover:-translate-y-1"
                >
                    <img
                        src="{{ asset('images/categories/category1.png') }}"
                        alt="Product {{ i }}"
                        class="w-full h-[250px] object-cover"
                    />
                    <div class="p-4 text-center">
                        <h3 class="text-lg font-semibold mb-2">
                            Product {{ i }}
                        </h3>
                        <p class="text-mocha font-bold mb-4">$4{{ i }}.99</p>
                        <button
                            class="bg-mocha text-cream border-2 border-mocha rounded px-5 py-2 transition-all duration-300 hover:bg-green"
                        >
                            Shop Now
                        </button>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section
        class="flex flex-col md:flex-row items-center max-w-[1360px] mx-auto overflow-hidden bg-white shadow-lg"
    >
        <div class="flex flex-2 w-full md:w-2/3">
            <img
                src="{{ asset('images/about/img1.png') }}"
                alt="Image 1"
                class="w-1/3 h-[75vh] object-cover"
            />
            <img
                src="{{ asset('images/about/img2.png') }}"
                alt="Image 2"
                class="w-1/3 h-[75vh] object-cover"
            />
            <img
                src="{{ asset('images/about/img3.png') }}"
                alt="Image 3"
                class="w-1/3 h-[75vh] object-cover"
            />
        </div>

        <div
            class="text-center flex-1 p-8 text-mocha flex flex-col items-center justify-center"
        >
            <h2 class="text-2xl font-bold">MIFANIA</h2>
            <h3 class="text-xl font-semibold mt-2">Introducing MIFANIA.com</h3>
            <p class="mt-3">Designed for confidence, crafted for comfort.</p>
            <a
                href="#"
                class="mt-4 inline-block bg-mocha text-cream px-5 py-2 rounded transition duration-300 hover:bg-green"
            >
                Shop Now
            </a>
        </div>
    </section>

    <!-- OPTIONAL: Newsletter / Media Sections -->
    <section class="newsletter py-8"></section>
    <section class="media-integration py-8"></section>
{% endblock %}
