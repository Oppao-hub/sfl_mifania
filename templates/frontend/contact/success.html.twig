{% extends 'base.html.twig' %}

{% block title %}Thank You | Mifania{% endblock %}

{% block main_content %}
<div class="min-h-[70vh] flex items-center justify-center bg-[#FBFBFA] px-4 py-16 sm:px-6 lg:px-8 animate-fadeIn">
    <div class="max-w-md w-full text-center space-y-8 bg-white p-10 rounded-2xl shadow-sm border border-gray-100">

        {# Success Icon #}
        <div class="mx-auto flex items-center justify-center h-24 w-24 rounded-full bg-green-50 mb-6">
            {{ ux_icon('lucide:check-circle-2', {class: 'h-12 w-12 text-green-600'}) }}
        </div>

        {# Text Content #}
        <div class="space-y-3">
            <h1 class="text-3xl font-black text-brand-dark uppercase tracking-tighter">
                Message Sent!
            </h1>
            <p class="text-sm font-medium text-gray-500 tracking-widest leading-relaxed">
                Thank you for reaching out to the Mifania team. We have received your message and will get back to you within 24-48 hours.
            </p>
        </div>

        {# Action Buttons #}
        <div class="pt-6 space-y-4 flex flex-col items-center">
            <a href="{{ path('app_shop') }}"
               class="w-full inline-flex justify-center items-center px-6 py-4 border border-transparent text-xs font-black uppercase tracking-[0.2em] rounded-sm shadow-sm text-white bg-brand hover:bg-brand-dark hover:-translate-y-0.5 transition-all duration-200">
                Continue Shopping
            </a>

            <a href="{{ path('app_home') }}"
               class="text-[10px] font-bold text-gray-400 uppercase tracking-widest hover:text-brand transition-colors mt-4 inline-block">
                Return to Homepage
            </a>
        </div>
    </div>
</div>
{% endblock %}
