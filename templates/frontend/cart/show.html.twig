{% extends 'base.html.twig' %}

{% block title %}Shopping Cart | Mifania{% endblock %}

{% block main_content %}

<section class="py-16 bg-light-gray text-center border-b border-gray-200">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-brand">My Cart</h1>
    {% include 'components/frontend/breadcrumbs.html.twig' with {
        items: [
            { name: 'Home', url: path('app_home') },
            { name: 'Shopping Cart' }
        ]
    } %}
</section>

<section class="bg-gray-50 py-16 px-6 md:px-12 min-h-[70vh]">
    <div class="max-w-[1440px] mx-auto">

        <h1 class="text-3xl font-bold text-brand mb-8">
            Shopping Cart
            <span class="text-sm font-normal text-gray-500 ml-2">({{ cart.cartItems|length }} Items)</span>
        </h1>

        {% if cart.cartItems is empty %}

            {# --- REFINED EMPTY CART STATE --- #}
            <div class="max-w-md mx-auto text-center py-16 px-6 sm:py-20 bg-white rounded-xl shadow-sm border border-gray-100 mt-4 md:mt-8">

                {# Icon inside a soft circular background #}
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-brand/5 mb-6 text-brand">
                    {{ ux_icon('lucide:shopping-bag', { class: 'w-10 h-10' }) }}
                </div>

                <h2 class="text-2xl font-bold text-gray-900 mb-2 tracking-tight">Your cart is empty</h2>
                <p class="text-gray-500 mb-8 text-sm leading-relaxed px-4">
                    Looks like you haven't added any sustainable fashion to your cart yet. Let's change that!
                </p>

                <a href="{{ path('app_shop') }}" class="inline-block text-white bg-brand px-8 py-3.5 rounded-sm font-bold text-xs tracking-widest uppercase hover:bg-brand-dark transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5">
                    Start Shopping
                </a>

            </div>

        {% else %}

            {# --- FILLED CART STATE --- #}
            {# The grid only exists if there are actually items to show #}
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

                {# --- LEFT COLUMN: Cart Items --- #}
                <div class="lg:col-span-2 space-y-6">

                    {# The Dynamic Loop #}
                    {% for cartItem in cart.cartItems %}
                        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-50 flex flex-col sm:flex-row gap-6 items-center sm:items-start relative group">

                            {# Product Image #}
                            <div class="w-32 h-40 bg-gray-100 flex-shrink-0 overflow-hidden rounded-md border border-gray-100">
                                <img src="{{ cartItem.product.image ? asset('uploads/products/' ~ cartItem.product.image) : asset('images/default-product.png') }}"
                                     alt="{{ cartItem.product.name }}"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                            </div>

                            {# Product Details #}
                            <div class="flex-1 w-full flex flex-col justify-between h-full min-h-[10rem]">
                                <div>
                                    <div class="flex justify-between items-start mb-2">
                                        <div>
                                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">
                                                {{ cartItem.product.subCategory.category ? cartItem.product.subCategory.category.name : 'Mifania Original' }}
                                            </p>
                                            <a href="#" class="text-lg font-bold text-gray-800 hover:text-brand transition-colors">
                                                {{ cartItem.product.name }}
                                            </a>
                                            <p class="text-xs text-gray-500 mt-1 uppercase tracking-wider font-medium">
                                                Size: {{ cartItem.product.size ? cartItem.product.size.value : 'N/A' }}
                                                <span class="mx-1 text-gray-300">|</span>
                                                Color: {{ cartItem.product.color ? cartItem.product.color.value : 'N/A' }}
                                            </p>
                                        </div>

                                        {# Remove Button Form #}
                                        <form action="{{ path('app_cart_remove', { 'id': cartItem.id }) }}" method="POST">
                                            <input type="hidden" name="_token" value="{{ csrf_token('remove' ~ cartItem.id) }}">
                                            <button type="submit" class="text-gray-300 hover:text-red-500 transition-colors p-2 cursor-pointer focus:outline-none" title="Remove Item">
                                                {{ ux_icon('lucide:trash-2', { class: 'h-5 w-5' }) }}
                                            </button>
                                        </form>
                                    </div>
                                </div>

                                <div class="flex justify-between items-end mt-4 sm:mt-0">
                                    {# Quantity Controls #}
                                    <div class="flex items-center border border-gray-200 rounded-sm bg-gray-50">
                                        <button type="button" class="px-3 py-1 text-gray-500 hover:bg-gray-200 transition-colors focus:outline-none">-</button>
                                        <input type="text" value="{{ cartItem.quantity }}" class="w-10 text-center text-sm font-bold bg-transparent border-x border-gray-200 py-1 focus:outline-none pointer-events-none" readonly>
                                        <button type="button" class="px-3 py-1 text-gray-500 hover:bg-gray-200 transition-colors focus:outline-none">+</button>
                                    </div>

                                    <div class="text-right">
                                        <p class="text-[10px] text-gray-400 font-medium uppercase tracking-widest mb-0.5">Subtotal</p>
                                        <p class="text-lg font-bold text-brand">PHP {{ cartItem.subtotal|number_format(2) }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}

                    {# Clear Cart & Continue Shopping Links #}
                    <div class="flex justify-between items-center mt-6 pt-6 border-t border-gray-200">
                        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-xs uppercase tracking-widest font-bold text-gray-500 hover:text-brand transition-colors">
                            {{ ux_icon('lucide:arrow-left', { class: 'h-4 w-4' }) }} Continue Shopping
                        </a>

                        <form action="{{ path('app_cart_clear') }}" method="POST">
                            <input type="hidden" name="_token" value="{{ csrf_token('clear_cart') }}">
                            <button type="submit" class="text-xs uppercase tracking-widest font-bold text-gray-400 hover:text-red-500 transition-colors cursor-pointer">
                                Empty Cart
                            </button>
                        </form>
                    </div>
                </div>

                {# --- RIGHT COLUMN: Order Summary --- #}
                <div class="lg:col-span-1">
                    <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100 sticky top-28">
                        <h2 class="text-xl font-bold text-gray-800 mb-6 uppercase tracking-tighter">Order Summary</h2>

                        <div class="space-y-4 text-sm text-gray-600 mb-6 border-b border-gray-100 pb-6">
                            <div class="flex justify-between items-center">
                                <span>Subtotal</span>
                                <span class="font-bold text-gray-800">PHP {{ cart.totalPrice|number_format(2) }}</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span>Shipping</span>
                                <span class="font-bold text-green-600 uppercase tracking-wider text-xs bg-green-50 px-2 py-1 rounded-sm">Free</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span>Tax</span>
                                <span class="font-bold text-gray-800">PHP 0.00</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-end mb-8">
                            <span class="text-sm font-bold text-gray-800 uppercase tracking-widest">Total</span>
                            <span class="text-2xl font-bold text-brand">PHP {{ cart.totalPrice|number_format(2) }}</span>
                        </div>

                        <a href="{{ path('app_checkout') }}" class="block text-center w-full bg-brand text-white py-4 rounded-sm font-bold uppercase tracking-widest hover:bg-brand-dark transition-all shadow-md hover:shadow-lg mb-4">
                            Proceed to Checkout
                        </a>

                        <div class="flex items-center justify-center gap-2 text-xs text-gray-400 mt-4 uppercase tracking-widest font-medium">
                             {{ ux_icon('lucide:shield-check', { class: 'h-4 w-4' }) }}
                             Secure SSL Checkout
                        </div>

                        {# <div class="mt-8 pt-6 border-t border-gray-100">
                             <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Promo Code</p>
                             <div class="flex gap-2">
                                 <input type="text" placeholder="Enter code..." class="flex-1 border border-gray-200 bg-gray-50 rounded-sm px-4 py-3 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all">
                                 <button class="text-xs font-bold text-white bg-gray-900 hover:bg-black px-4 rounded-sm uppercase tracking-widest transition-colors">Apply</button>
                             </div>
                        </div> #}
                    </div>
                </div>

            </div>
        {% endif %}

    </div>
</section>
{% endblock %}
