{% extends 'base.html.twig' %}

{% block title %}Shopping Cart | Mifania{% endblock %}

{% block main_content %}
{# --- PAGE HEADER --- #}
<section class="pt-32 pb-16 bg-light-gray text-center border-b border-gray-200 reveal">
    <h1 class="text-4xl md:text-5xl font-black tracking-tighter text-brand uppercase">My Cart</h1>
    <div class="mt-4 flex justify-center">
        {% include 'components/frontend/breadcrumbs.html.twig' with {
            items: [
                { name: 'Home', url: path('app_home') },
                { name: 'Shopping Cart' }
            ]
        } %}
    </div>
</section>

<section class="bg-white py-16 px-6 md:px-12 min-h-[70vh]">
    <div class="max-w-[1440px] mx-auto">

        {# --- CHECKOUT PROGRESS --- #}
        <div class="flex items-center justify-center mb-16 gap-4 md:gap-8">
            <div class="flex items-center gap-3">
                <span class="w-8 h-8 rounded-full bg-brand text-white flex items-center justify-center text-xs font-black">01</span>
                <span class="text-[10px] font-black uppercase tracking-widest text-brand">Shopping Cart</span>
            </div>
            <div class="w-12 h-px bg-gray-200"></div>
            <div class="flex items-center gap-3 opacity-30">
                <span class="w-8 h-8 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center text-xs font-black">02</span>
                <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Checkout</span>
            </div>
            <div class="w-12 h-px bg-gray-200"></div>
            <div class="flex items-center gap-3 opacity-30">
                <span class="w-8 h-8 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center text-xs font-black">03</span>
                <span class="text-[10px] font-black uppercase tracking-widest text-gray-400">Confirmation</span>
            </div>
        </div>

        {% if cart.cartItems is empty %}
            {# --- REFINED EMPTY CART STATE --- #}
            <div class="max-w-md mx-auto text-center py-20 bg-app-bg rounded-sm border border-gray-100 reveal">
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white mb-6 text-brand shadow-sm">
                    {{ ux_icon('lucide:shopping-bag', { class: 'w-8 h-8' }) }}
                </div>
                <h2 class="text-2xl font-black text-brand-dark mb-2 uppercase tracking-tight">Your bag is empty</h2>
                <p class="text-gray-500 mb-10 text-xs font-medium uppercase tracking-widest px-8">
                    Curate your collection with our sustainable pieces.
                </p>
                <a href="{{ path('app_shop') }}" class="inline-block text-white bg-brand px-10 py-4 rounded-sm font-black text-[10px] tracking-[0.2em] uppercase hover:bg-brand-dark transition-all shadow-md active:scale-95">
                    Start Shopping
                </a>
            </div>
        {% else %}
            {# --- FILLED CART STATE --- #}
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">

                {# --- LEFT COLUMN: Cart Items  --- #}
                <div class="lg:col-span-2 space-y-8">
                    <div class="flex items-center justify-between border-b border-gray-100 pb-4">
                        <h2 class="text-[10px] font-black uppercase tracking-[0.3em] text-gray-400">Cart Contents ({{ cart.cartItems|length }})</h2>
                        <button type="button"
                            onclick="window.dispatchEvent(new CustomEvent('open-confirm', {
                                detail: {
                                    title: 'Empty Bag?',
                                    message: 'Remove all items from your cart?',
                                    actionUrl: '{{ path('app_cart_clear') }}',
                                    confirmText: 'Empty Bag',
                                    csrfToken: '{{ csrf_token('clear_cart') }}',
                                    isDanger: true
                                }
                            }))"
                            class="text-[9px] font-black uppercase tracking-widest text-gray-300 hover:text-red-500 transition-colors cursor-pointer">
                            Clear All
                        </button>
                    </div>

                    {% for cartItem in cart.cartItems %}
                        <div data-controller="cart-item"
                             data-cart-item-update-url-value="{{ path('app_cart_update_ajax', {'id': cartItem.id}) }}"
                             class="flex flex-col sm:flex-row gap-8 items-start relative group pb-8 border-b border-gray-100 last:border-0">

                            <div class="w-32 h-44 bg-app-bg flex-shrink-0 overflow-hidden rounded-sm border border-gray-100">
                                <img src="{{ cartItem.product.image ? asset('uploads/products/' ~ cartItem.product.image) : asset('images/default-product.png') }}"
                                     alt="{{ cartItem.product.name }}"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                            </div>

                            <div class="flex-1 w-full flex flex-col justify-between self-stretch">
                                <div class="flex justify-between items-start">
                                    <div class="max-w-[80%]">
                                        <p class="text-[9px] font-black text-brand uppercase tracking-[0.2em] mb-1 opacity-60">
                                            {{ cartItem.product.subCategory.category ? cartItem.product.subCategory.category.name : 'Mifania Original' }}
                                        </p>
                                        <h3 class="text-xl font-black text-brand-dark uppercase tracking-tight leading-tight mb-2">
                                            {{ cartItem.product.name }}
                                        </h3>
                                        <div class="flex items-center gap-3 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                                            <span>Size: {{ cartItem.product.size ? cartItem.product.size.value : 'N/A' }}</span>
                                            <span class="w-1 h-1 rounded-full bg-gray-200"></span>
                                            <span>Color: {{ cartItem.product.color ? cartItem.product.color.value : 'N/A' }}</span>
                                        </div>
                                    </div>

                                    <button type="button"
                                        onclick="window.dispatchEvent(new CustomEvent('open-confirm', {
                                            detail: {
                                                title: 'Remove Product?',
                                                message: 'Remove {{ cartItem.product.name|e('js') }} from your bag?',
                                                actionUrl: '{{ path('app_cart_remove', { id: cartItem.id }) }}',
                                                confirmText: 'Remove',
                                                csrfToken: '{{ csrf_token('remove' ~ cartItem.id) }}',
                                                isDanger: true
                                            }
                                        }))"
                                        class="text-gray-300 hover:text-brand transition-colors p-2 cursor-pointer"
                                        title="Remove Item">
                                        {{ ux_icon('lucide:x', { class: 'h-4 w-4' }) }}
                                    </button>
                                </div>

                                <div class="flex justify-between items-end mt-6">
                                    <div class="flex items-center border border-gray-200 rounded-sm bg-white overflow-hidden shadow-sm">
                                        <button data-action="click->cart-item#update" data-type="decrement" class="px-4 py-2 text-gray-400 hover:text-brand hover:bg-gray-50 transition-colors cursor-pointer">-</button>
                                        <input data-cart-item-target="quantity" type="text" value="{{ cartItem.quantity }}" class="w-10 text-center text-xs font-black text-brand-dark focus:outline-none pointer-events-none" readonly>
                                        <button data-action="click->cart-item#update" data-type="increment" class="px-4 py-2 text-gray-400 hover:text-brand hover:bg-gray-50 transition-colors cursor-pointer">+</button>
                                    </div>

                                    <div class="text-right">
                                        <p class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-1 opacity-50">Subtotal</p>
                                        <p data-cart-item-target="subtotal" class="text-lg font-black text-brand-dark tracking-tighter">₱{{ cartItem.subtotal|number_format(2) }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# --- RIGHT COLUMN: Order Summary --- #}
                <div class="lg:col-span-1">
                    <div class="bg-app-bg p-10 rounded-sm border border-gray-100 sticky top-32">
                        <h2 class="text-2xl font-black text-brand-dark mb-8 uppercase tracking-tighter">Summary</h2>

                        <div class="space-y-5 text-[10px] font-bold text-gray-500 uppercase tracking-[0.2em] mb-8 border-b border-gray-200 pb-8">
                            <div class="flex justify-between items-center">
                                <span>Bag Subtotal</span>
                                <span id="global-cart-subtotal" class="text-brand-dark font-black">₱{{ cart.totalPrice|number_format(2) }}</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span>Carbon Neutral Shipping</span>
                                <span class="text-green-600 font-black">Free</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span>Environmental Tax</span>
                                <span class="text-brand-dark font-black">₱0.00</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-end mb-10">
                            <span class="text-xs font-black text-brand-dark uppercase tracking-[0.2em]">Manifest Total</span>
                            <div class="text-right">
                                <span id="global-cart-total" class="text-3xl font-black text-brand block tracking-tighter">₱{{ cart.totalPrice|number_format(2) }}</span>
                                {% if cart.estimatedPoints > 0 %}
                                    <span class="inline-flex items-center gap-1.5 text-[9px] font-black text-terracotta uppercase tracking-[0.2em] mt-2 bg-terracotta/5 px-2 py-1 rounded-sm border border-terracotta/10">
                                        {{ ux_icon('lucide:sparkles', {class: 'w-3 h-3'}) }}
                                        +{{ cart.estimatedPoints }} Points
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        <a href="{{ path('app_checkout') }}"
                           class="group relative block text-center w-full bg-brand text-white py-5 rounded-sm font-black text-[10px] tracking-[0.3em] uppercase hover:bg-brand-dark transition-all shadow-xl active:scale-95 overflow-hidden">
                            <span class="relative z-10">Proceed to Checkout</span>
                            <div class="absolute inset-0 bg-white/10 translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500"></div>
                        </a>

                        <div class="flex flex-col items-center gap-4 mt-8 pt-8 border-t border-gray-200">
                             <div class="flex items-center gap-3">
                                 {{ ux_icon('lucide:shield-check', { class: 'h-4 w-4 text-brand' }) }}
                                 <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest">Encrypted Checkout</span>
                             </div>
                             <div class="flex gap-4 opacity-30 grayscale contrast-125 scale-75">
                                 {{ ux_icon('logos:visa', { class: 'h-4 w-auto' }) }}
                                 {{ ux_icon('logos:mastercard', { class: 'h-4 w-auto' }) }}
                                 {{ ux_icon('logos:paypal', { class: 'h-4 w-auto' }) }}
                             </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
