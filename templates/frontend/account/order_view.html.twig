{% extends 'frontend/account/index.html.twig' %}

{% block title %}Order #{{ order.id }} | Mifania{% endblock %}

{% block page_breadcrumbs %}
    {% include 'components/breadcrumbs.html.twig' with {
        items: [
            { name: 'Home', url: path('app_home') },
            { name: 'My Account', url: path('app_account') },
            { name: 'My Orders', url: path('app_account_orders') },
            { name: 'Order #' ~ order.id }
        ]
    } %}
{% endblock %}

{% block account_content %}
<div class="bg-white rounded-sm shadow-md border border-gray-100 p-6 md:p-8">

    {# --- HEADER: Back Button & Order ID --- #}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4 border-b border-gray-100 pb-6">
        <div>
            <a href="{{ path('app_account_orders') }}" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-brand transition-colors mb-3">
                {{ ux_icon('lucide:arrow-left', { class: 'h-4 w-4' }) }} Back to Orders
            </a>
            <h2 class="text-2xl font-bold text-gray-900 uppercase tracking-tighter">
                Order <span class="text-brand">#{{ order.id }}</span>
            </h2>
            <p class="text-xs text-gray-500 mt-1 font-medium tracking-wider">
                Placed on {{ order.createdAt|date('F j, Y \\a\\t g:i A') }}
            </p>
        </div>

        {# Dynamic Status Badge #}
        <div class="flex items-center gap-2">
            <span class="px-4 py-2 rounded-sm text-xs font-bold uppercase tracking-widest
                {% if order.orderStatus.value == 'Pending' %} bg-yellow-50 text-yellow-600 border border-yellow-100
                {% elseif order.orderStatus.value == 'Completed' %} bg-green-50 text-green-600 border border-green-100
                {% elseif order.orderStatus.value == 'Cancelled' %} bg-red-50 text-red-600 border border-red-100
                {% else %} bg-blue-50 text-blue-600 border border-blue-100 {% endif %}">
                {{ order.orderStatus.value }}
            </span>
        </div>
    </div>

    {# --- ORDER ITEMS LIST --- #}
    <div class="mb-10">
        <h3 class="text-sm font-bold text-gray-800 uppercase tracking-widest mb-4">Items Ordered</h3>

        <div class="border border-gray-100 rounded-sm overflow-hidden">

            {# Desktop Table Header #}
            <div class="hidden md:grid grid-cols-12 gap-4 bg-gray-50 text-gray-500 text-[10px] font-bold uppercase tracking-widest py-3 px-6 border-b border-gray-100">
                <div class="col-span-6">Product Details</div>
                <div class="col-span-2 text-center">Price</div>
                <div class="col-span-2 text-center">Qty</div>
                <div class="col-span-2 text-right">Subtotal</div>
            </div>

            {# Loop through actual order items #}
            <div class="divide-y divide-gray-100">
                {% for item in order.orderItems %}
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center py-4 px-6 bg-white hover:bg-gray-50 transition-colors">

                        {# Image & Info #}
                        <div class="col-span-12 md:col-span-6 flex items-center gap-4">
                            <img src="{{ item.product.image ? asset('uploads/products/' ~ item.product.image) : asset('images/default-product.png') }}"
                                 class="w-16 h-20 object-cover rounded-sm border border-gray-100" alt="{{ item.product.name }}">
                            <div>
                                <a href="#" class="text-sm font-bold text-gray-800 hover:text-brand transition-colors line-clamp-1">
                                    {{ item.product.name }}
                                </a>
                                <p class="text-[10px] text-gray-400 mt-1 uppercase tracking-widest font-medium">
                                    Size: {{ item.product.size ? item.product.size.value : 'N/A' }}
                                    <span class="mx-1">|</span>
                                    Color: {{ item.product.color ? item.product.color.value : 'N/A' }}
                                </p>
                            </div>
                        </div>

                        {# Mobile labels / Desktop values #}
                        <div class="col-span-12 md:col-span-2 flex justify-between md:justify-center items-center">
                            <span class="md:hidden text-[10px] font-bold text-gray-400 uppercase tracking-widest">Price</span>
                            <span class="text-sm font-medium text-gray-600">PHP {{ item.price|number_format(2) }}</span>
                        </div>

                        <div class="col-span-12 md:col-span-2 flex justify-between md:justify-center items-center">
                            <span class="md:hidden text-[10px] font-bold text-gray-400 uppercase tracking-widest">Quantity</span>
                            <span class="text-sm font-bold text-gray-800 bg-gray-100 px-3 py-1 rounded-sm">{{ item.quantity }}</span>
                        </div>

                        <div class="col-span-12 md:col-span-2 flex justify-between md:justify-end items-center">
                            <span class="md:hidden text-[10px] font-bold text-gray-400 uppercase tracking-widest">Subtotal</span>
                            <span class="text-sm font-bold text-brand">PHP {{ item.subtotal|number_format(2) }}</span>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# --- ORDER SUMMARY & DETAILS GRID --- #}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        {# Left: Customer Details #}
        <div class="bg-gray-50 border border-gray-100 rounded-sm p-6">
            <h3 class="text-sm font-bold text-gray-800 uppercase tracking-widest mb-4 border-b border-gray-200 pb-2">Order Information</h3>

            <div class="space-y-4">
                <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Customer Name</p>
                    <p class="text-sm font-medium text-gray-800">{{ order.customer.firstName }} {{ order.customer.lastName }}</p>
                </div>

                <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Payment Method</p>
                    <p class="text-sm font-medium text-gray-800 flex items-center gap-2">
                        {{ ux_icon('lucide:credit-card', { class: 'w-4 h-4 text-brand' }) }}
                        {{ order.paymentMethod.value }}

                        {# Payment Status Mini-Badge #}
                        <span class="ml-2 px-2 py-0.5 text-[9px] rounded-sm font-bold uppercase tracking-widest
                            {{ order.paymentStatus.value == 'Paid' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' }}">
                            {{ order.paymentStatus.value }}
                        </span>
                    </p>
                </div>

                {% if order.rewardPoints > 0 %}
                <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Points Earned</p>
                    <p class="text-sm font-bold text-brand flex items-center gap-1">
                        {{ ux_icon('lucide:star', { class: 'w-4 h-4' }) }}
                        +{{ order.rewardPoints }} Points
                    </p>
                </div>
                {% endif %}
            </div>
        </div>

        {# Right: Totals Breakdown #}
        <div class="bg-white border border-gray-100 shadow-sm rounded-sm p-6">
            <h3 class="text-sm font-bold text-gray-800 uppercase tracking-widest mb-4 border-b border-gray-100 pb-2">Order Summary</h3>

            <div class="space-y-3 text-sm text-gray-600 mb-6">
                <div class="flex justify-between items-center">
                    <span>Subtotal</span>
                    <span class="font-medium">PHP {{ order.totalAmount|number_format(2) }}</span>
                </div>
                <div class="flex justify-between items-center">
                    <span>Shipping</span>
                    <span class="font-medium text-green-600 text-xs uppercase tracking-widest bg-green-50 px-2 py-1 rounded-sm">Free</span>
                </div>
                <div class="flex justify-between items-center">
                    <span>Tax</span>
                    <span class="font-medium">PHP 0.00</span>
                </div>
            </div>

            <div class="flex justify-between items-end pt-4 border-t border-gray-100">
                <span class="text-sm font-bold text-gray-800 uppercase tracking-widest">Total Paid</span>
                <span class="text-2xl font-bold text-brand">PHP {{ order.totalAmount|number_format(2) }}</span>
            </div>
        </div>

    </div>
</div>
{% endblock %}
