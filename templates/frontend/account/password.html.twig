{% extends 'frontend/account/index.html.twig' %}

{% block title %}Password Manager | Mifania{% endblock %}

{% block account_content %}
<div class="bg-white rounded-sm shadow-md border border-gray-100 p-6 md:p-10">

    {# Header Area #}
    <div class="flex items-center gap-3 mb-10 border-b border-gray-100 pb-4">
        <div class="p-2 bg-brand/10 rounded-full text-brand">
            {{ ux_icon('lucide:shield-check', { class: 'w-5 h-5' }) }}
        </div>
        <div>
            <h2 class="text-lg font-bold text-gray-800 uppercase tracking-tighter">Password Manager</h2>
            <p class="text-xs text-gray-500 mt-1">Ensure your account is using a long, random password to stay secure.</p>
        </div>
    </div>

    {# Create a grid to use the full width: Form on left (2/3), Tips on right (1/3) #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        {# --- LEFT SIDE: THE FORM --- #}
        <div class="lg:col-span-2">

            {# Your perfect Form Theme fix #}
            {% form_theme form 'form/error_theme.html.twig' %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                <input type="text" autocomplete="username" value="{{ app.user.email }}" class="hidden" aria-hidden="true">
                <div class="space-y-6">

                    {{ form_errors(form, {'attr': {'class': 'text-red-500 text-[10px] uppercase tracking-widest font-bold mb-4 bg-red-50 p-3 rounded-sm border border-red-100'}}) }}

                    {# 1. Current Password #}
                    <div x-data="{ show: false }">
                        {{ form_label(form.currentPassword, 'Current Password', {'label_attr': {'class': 'block text-[10px] font-bold tracking-widest uppercase text-gray-400 mb-2'}}) }}
                        <div class="relative">
                            {{ form_widget(form.currentPassword, {'attr': {
                                'class': 'w-full pl-4 pr-12 py-3 border border-gray-200 rounded-sm focus:border-brand focus:ring-1 focus:ring-brand transition-colors text-sm bg-gray-50 focus:bg-white',
                                'x-bind:type': "show ? 'text' : 'password'",
                                'placeholder': '••••••••'
                            }}) }}
                            <button type="button" @click="show = !show" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-brand transition-colors focus:outline-none">
                                <template x-if="!show">{{ ux_icon('lucide:eye', { class: 'w-4 h-4' }) }}</template>
                                <template x-if="show">{{ ux_icon('lucide:eye-off', { class: 'w-4 h-4' }) }}</template>
                            </button>
                        </div>
                        {{ form_errors(form.currentPassword, {'attr': {'class': 'text-red-500 text-[10px] uppercase tracking-widest font-bold mt-2'}}) }}
                    </div>

                    <hr class="border-gray-100 my-6">

                    {# 2. New Password #}
                    <div x-data="{ show: false }">
                        {{ form_label(form.plainPassword.first, 'New Password', {'label_attr': {'class': 'block text-[10px] font-bold tracking-widest uppercase text-gray-400 mb-2'}}) }}
                        <div class="relative">
                            {{ form_widget(form.plainPassword.first, {'attr': {
                                'class': 'w-full pl-4 pr-12 py-3 border border-gray-200 rounded-sm focus:border-brand focus:ring-1 focus:ring-brand transition-colors text-sm bg-gray-50 focus:bg-white',
                                'x-bind:type': "show ? 'text' : 'password'",
                                'placeholder': '••••••••'
                            }}) }}
                            <button type="button" @click="show = !show" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-brand transition-colors focus:outline-none">
                                <template x-if="!show">{{ ux_icon('lucide:eye', { class: 'w-4 h-4' }) }}</template>
                                <template x-if="show">{{ ux_icon('lucide:eye-off', { class: 'w-4 h-4' }) }}</template>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.first, {'attr': {'class': 'text-red-500 text-[10px] uppercase tracking-widest font-bold mt-2'}}) }}
                    </div>

                    {# 3. Confirm New Password #}
                    <div x-data="{ show: false }">
                        {{ form_label(form.plainPassword.second, 'Confirm New Password', {'label_attr': {'class': 'block text-[10px] font-bold tracking-widest uppercase text-gray-400 mb-2'}}) }}
                        <div class="relative">
                            {{ form_widget(form.plainPassword.second, {'attr': {
                                'class': 'w-full pl-4 pr-12 py-3 border border-gray-200 rounded-sm focus:border-brand focus:ring-1 focus:ring-brand transition-colors text-sm bg-gray-50 focus:bg-white',
                                'x-bind:type': "show ? 'text' : 'password'",
                                'placeholder': '••••••••'
                            }}) }}
                            <button type="button" @click="show = !show" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-brand transition-colors focus:outline-none">
                                <template x-if="!show">{{ ux_icon('lucide:eye', { class: 'w-4 h-4' }) }}</template>
                                <template x-if="show">{{ ux_icon('lucide:eye-off', { class: 'w-4 h-4' }) }}</template>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.second, {'attr': {'class': 'text-red-500 text-[10px] uppercase tracking-widest font-bold mt-2'}}) }}
                    </div>

                    {# Submit Action #}
                    <div class="pt-6 mt-8 border-t border-gray-100 flex justify-end">
                        <button type="submit" class="inline-flex justify-center items-center gap-2 py-3 px-8 border border-transparent shadow-sm text-xs font-bold uppercase tracking-widest rounded-sm text-white bg-brand hover:bg-brand-dark focus:outline-none transition-colors w-full sm:w-auto cursor-pointer">
                            {{ ux_icon('lucide:save', { class: 'w-4 h-4' }) }}
                            Update Password
                        </button>
                    </div>

                </div>
            {{ form_end(form) }}
        </div>

        {# --- RIGHT SIDE: SECURITY TIPS --- #}
        <div class="lg:col-span-1">
            <div class="bg-gray-50 border border-gray-100 rounded-sm p-6 sticky top-24">
                <div class="flex items-center gap-2 mb-4">
                    {{ ux_icon('lucide:lock-keyhole', { class: 'w-4 h-4 text-brand' }) }}
                    <h3 class="text-sm font-bold text-gray-800 uppercase tracking-widest">Password Tips</h3>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed mb-6">
                    A strong password helps prevent unauthorized access to your Mifania account and protects your personal information.
                </p>
                <ul class="space-y-3">
                    <li class="flex items-start gap-2">
                        {{ ux_icon('lucide:check-circle-2', { class: 'w-4 h-4 text-green-500 shrink-0 mt-0.5' }) }}
                        <span class="text-xs text-gray-600">At least 8 characters long</span>
                    </li>
                    <li class="flex items-start gap-2">
                        {{ ux_icon('lucide:check-circle-2', { class: 'w-4 h-4 text-green-500 shrink-0 mt-0.5' }) }}
                        <span class="text-xs text-gray-600">Contains uppercase and lowercase letters</span>
                    </li>
                    <li class="flex items-start gap-2">
                        {{ ux_icon('lucide:check-circle-2', { class: 'w-4 h-4 text-green-500 shrink-0 mt-0.5' }) }}
                        <span class="text-xs text-gray-600">Includes numbers and symbols (e.g. !@#$%)</span>
                    </li>
                    <li class="flex items-start gap-2">
                        {{ ux_icon('lucide:check-circle-2', { class: 'w-4 h-4 text-green-500 shrink-0 mt-0.5' }) }}
                        <span class="text-xs text-gray-600">Not used on any other website</span>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</div>
{% endblock %}
