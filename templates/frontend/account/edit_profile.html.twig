{% extends 'frontend/account/index.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block page_breadcrumbs %}
    {% include 'components/breadcrumbs.html.twig' with {
        items: [
            { name: 'Home', url: path('app_home') },
            { name: 'My Account', url: path('app_account') },
            { name: 'Edit Profile' }
        ]
    } %}
{% endblock %}

{% block account_content %}
<div class="container mx-auto max-w-4xl">
    <div class="bg-white p-8 rounded-xl shadow-md border border-gray-100 h-full">

        {# Header Section #}
        <div class="flex justify-between items-center mb-8 pb-4 border-b border-gray-100">
            <div>
                <h1 class="text-2xl font-bold text-brand">Edit Profile</h1>
                <p class="text-sm text-gray-500 mt-1">Update your personal information and shipping details.</p>
            </div>
        </div>

        {% form_theme form 'form/error_theme.html.twig' %}
        {{ form_start(form, {'attr': {'class': 'space-y-8', 'novalidate': 'novalidate'}}) }}

            {# --- SECTION 1: PERSONAL DETAILS --- #}
            <div>
                <h3 class="text-lg font-bold text-gray-700 mb-4 flex items-center">
                    <span class="bg-brand text-white p-1.5 rounded-md mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </span>
                    Personal Details
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        {{ form_label(form.firstName, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.firstName, {'attr': {'class': 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3 transition duration-150 ease-in-out'}}) }}
                        {{ form_errors(form.firstName, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.lastName, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.lastName, {'attr': {'class': 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3 transition duration-150 ease-in-out'}}) }}
                        {{ form_errors(form.lastName, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                    </div>
                </div>

                <div class="mt-6">
                    {{ form_label(form.contactNumber, 'Phone Number', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.contactNumber, {'attr': {'class': 'block w-full md:w-1/2 rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3 transition duration-150 ease-in-out'}}) }}
                    {{ form_errors(form.contactNumber, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                </div>
            </div>

            <hr class="border-gray-100">

            {# --- SECTION 2: ADDRESS --- #}
            <div>
                 <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                    <span class="bg-brand text-white p-1.5 rounded-md mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </span>
                    Shipping Address
                </h3>

                <div class="space-y-6">
                    <div>
                        {{ form_label(form.address, 'Street Address', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.address, {'attr': {'class': 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3'}}) }}
                        {{ form_errors(form.address, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            {{ form_label(form.city, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.city, {'attr': {'class': 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3'}}) }}
                            {{ form_errors(form.city, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                        </div>
                        <div>
                            {{ form_label(form.postalCode, 'Postal / Zip Code', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.postalCode, {'attr': {'class': 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3'}}) }}
                            {{ form_errors(form.postalCode, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                         <div>
                            {{ form_label(form.state, 'State / Province', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.state, {'attr': {'class': 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3'}}) }}
                            {{ form_errors(form.state, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                        </div>
                         <div>
                            {{ form_label(form.country, null, {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                            {{ form_widget(form.country, {'attr': {'class': 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-brand focus:ring-brand sm:text-sm py-2.5 px-3'}}) }}
                            {{ form_errors(form.country, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                        </div>
                    </div>
                </div>
            </div>

            <hr class="border-gray-100">

            {# --- SECTION 3: AVATAR --- #}
            <div>
                <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                    <span class="bg-brand/10 text-brand p-1.5 rounded-md mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </span>
                    Profile Photo
                </h3>
                <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 border-dashed">
                    {{ form_label(form.avatar, 'Upload New Image', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-2'}}) }}

                    {{ form_widget(form.avatar, {'attr': {
                        'class': 'block w-full text-sm text-gray-500
                                  file:mr-4 file:py-2.5 file:px-4
                                  file:rounded-full file:border-0
                                  file:text-sm file:font-semibold
                                  file:bg-brand file:text-white
                                  hover:file:bg-brand/90
                                  cursor-pointer'
                    }}) }}
                    <p class="mt-2 text-xs text-gray-500">Supported formats: JPG, PNG. Max size: 5MB.</p>
                    {{ form_errors(form.avatar, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
                </div>
            </div>

            {# --- ACTIONS --- #}
            <div class="pt-6 flex justify-end border-t border-gray-100 mt-6 gap-3">
                <a href="{{ path('app_account') }}" class="inline-flex justify-center items-center gap-2 py-3 px-8 bg-white border border-gray-200 shadow-sm text-xs font-bold uppercase tracking-widest rounded-sm text-gray-700 hover:bg-gray-50 hover:text-brand transition-all cursor-pointer">
                    Cancel
                </a>
                <button type="submit" class="inline-flex justify-center items-center gap-2 py-3 px-8 border border-transparent shadow-sm text-xs font-bold uppercase tracking-widest rounded-sm text-white bg-brand hover:bg-brand-dark hover:shadow-md focus:outline-none transition-all w-full sm:w-auto cursor-pointer">
                    {{ ux_icon('lucide:save', { class: 'w-4 h-4' }) }}
                    Save Changes
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
