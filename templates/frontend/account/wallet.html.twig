{% extends 'frontend/account/index.html.twig' %}

{% block title %}My Wallet | Mifania{% endblock %}

{% block account_content %}
<div class="container mx-auto max-w-4xl">

    {# --- 1. BALANCE CARD --- #}
    <div class="bg-white rounded-xl shadow-md overflow-hidden mb-8 border border-gray-100">
        <div class="p-8 md:p-10 bg-brand text-white relative">

            {# Decorative background circle #}
            <div class="absolute top-0 right-0 -mt-4 -mr-4 w-32 h-32 bg-white opacity-10 rounded-full blur-2xl"></div>

            <h2 class="text-sm font-bold uppercase tracking-widest opacity-80 mb-2">Total Balance</h2>

            <div class="flex items-baseline gap-2 mb-8">
                <span class="text-5xl font-bold tracking-tight">
                    {# Null coalescing to prevent errors if wallet doesn't exist #}
                    ₱ {{ wallet ? wallet.balance|number_format(2) : '0.00' }}
                </span>
                <span class="text-lg opacity-80 font-medium">PHP</span>
            </div>

            <div class="flex flex-wrap gap-4 relative z-10">
                {# Top Up Button (Visual for now) #}
                <button class="bg-white text-brand px-6 py-2.5 rounded-sm font-bold hover:bg-gray-100 transition shadow-sm flex items-center group">
                    <div class="mr-2 p-1 bg-brand/10 rounded-full group-hover:bg-brand/20 transition">
                        {{ ux_icon('lucide:plus', { class: 'w-4 h-4 text-brand' }) }}
                    </div>
                    Top Up Wallet
                </button>

                {# Transfer Button (Visual for now) #}
                <button class="bg-black/20 text-white border border-white/20 px-6 py-2.5 rounded-sm font-bold hover:bg-black/30 transition flex items-center backdrop-blur-sm">
                    {{ ux_icon('lucide:arrow-right-left', { class: 'w-4 h-4 mr-2 opacity-80' }) }}
                    Transfer Funds
                </button>
            </div>
        </div>
    </div>

    {# --- 2. TRANSACTION HISTORY --- #}
    <div class="bg-white rounded-xl shadow-md border border-gray-100 p-6">
        <div class="flex justify-between items-center mb-6 border-b border-gray-100 pb-4">
            <h3 class="text-lg font-bold text-gray-800 uppercase tracking-tighter">Transaction History</h3>

            {# Filter (Visual Only) #}
            <div class="relative">
                <select class="appearance-none bg-gray-50 border border-gray-200 text-gray-700 py-2 pl-4 pr-8 rounded-sm text-xs font-bold focus:outline-none focus:ring-1 focus:ring-brand focus:border-brand cursor-pointer uppercase tracking-widest">
                    <option>All Transactions</option>
                    <option>Deposits</option>
                    <option>Withdrawals</option>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-500">
                    {{ ux_icon('lucide:chevron-down', { class: 'h-4 w-4' }) }}
                </div>
            </div>
        </div>

        {# Check if transactions exist #}
        {% if wallet and wallet.transactions is defined and wallet.transactions|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-gray-400 border-b border-gray-100 text-[10px] uppercase tracking-widest">
                            <th class="pb-3 font-bold pl-2">Date</th>
                            <th class="pb-3 font-bold">Description</th>
                            <th class="pb-3 font-bold">Status</th>
                            <th class="pb-3 font-bold text-right pr-2">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm divide-y divide-gray-50">
                        {% for transaction in wallet.transactions|sort((a, b) => b.createdAt <=> a.createdAt) %}
                            <tr class="hover:bg-gray-50 transition duration-150">
                                <td class="py-4 pl-2 text-gray-500">
                                    <span class="font-bold text-gray-700">{{ transaction.createdAt|date('M d, Y') }}</span>
                                    <span class="block text-xs text-gray-400">{{ transaction.createdAt|date('h:i A') }}</span>
                                </td>
                                <td class="py-4">
                                    <p class="font-bold text-sm text-gray-800">{{ transaction.description }}</p>
                                    <p class="text-[10px] uppercase tracking-widest text-gray-400">ID: #{{ transaction.id }}</p>
                                </td>
                                <td class="py-4">
                                    <span class="inline-flex items-center px-2 py-1 rounded-sm text-[10px] uppercase tracking-widest font-bold bg-green-100 text-green-800">
                                        Completed
                                    </span>
                                </td>
                                <td class="py-4 pr-2 text-right">
                                    {% if transaction.type == 'credit' %}
                                        <span class="text-green-600 font-bold">+ ₱ {{ transaction.amount|number_format(2) }}</span>
                                    {% else %}
                                        <span class="text-red-500 font-bold">- ₱ {{ transaction.amount|number_format(2) }}</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            {# --- EMPTY STATE --- #}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-sm bg-gray-50">
                <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm border border-gray-100">
                    {{ ux_icon('lucide:wallet', { class: 'w-8 h-8 text-gray-300' }) }}
                </div>
                <h4 class="text-gray-900 font-bold text-sm uppercase tracking-widest mb-1">No transactions yet</h4>
                <p class="text-gray-500 text-xs max-w-xs mx-auto leading-relaxed">
                    You haven't made any transactions yet. Top up your wallet to get started!
                </p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
