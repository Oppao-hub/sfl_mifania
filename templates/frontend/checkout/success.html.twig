{% extends 'base.html.twig' %}

{% block title %}Order Successful | Mifania{% endblock %}

{% block main_content %}
<section class="bg-gray-50 py-16 px-6 md:px-12 min-h-[70vh] flex items-center justify-center">
    <div class="max-w-2xl mx-auto w-full">
        <div class="bg-white p-8 md:p-12 rounded-xl shadow-sm text-center border border-gray-100">

            {# Success Icon #}
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mb-6">
                {{ ux_icon('lucide:check-circle', { class: 'h-10 w-10 text-green-600' }) }}
            </div>

            <h1 class="text-3xl font-bold text-gray-900 mb-2">Thank you for your order!</h1>
            <p class="text-gray-500 mb-8">Your order has been placed successfully and is now being processed. We will send you an email confirmation shortly.</p>

            {# Order Details Box #}
            <div class="bg-gray-50 rounded-lg p-6 text-left mb-8 border border-gray-100">
                <h2 class="text-lg font-bold text-gray-800 mb-4 border-b border-gray-200 pb-2">Order Summary</h2>

                <div class="grid grid-cols-2 gap-y-4 text-sm">
                    <div class="text-gray-500">Order Number:</div>
                    <div class="font-medium text-gray-900 text-right">#{{ order.id }}</div>

                    <div class="text-gray-500">Date:</div>
                    <div class="font-medium text-gray-900 text-right">{{ order.createdAt|date('F j, Y') }}</div>

                    <div class="text-gray-500">Payment Method:</div>
                    <div class="font-medium text-gray-900 text-right">{{ order.paymentMethod.value }}</div>

                    <div class="text-gray-500 pt-3 border-t border-gray-200 mt-1">Total Amount:</div>
                    <div class="font-bold text-brand text-right text-base pt-3 border-t border-gray-200 mt-1">PHP {{ order.totalAmount|number_format(2) }}</div>
                </div>
            </div>

            {# Next Steps #}
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                {# Link back to the store #}
                <a href="{{ path('app_shop') }}" class="px-8 py-3 bg-brand text-white font-bold rounded-md hover:bg-brand-dark transition-all shadow-md hover:shadow-lg">
                    Continue Shopping
                </a>
            </div>

        </div>
    </div>
</section>
{% endblock %}
