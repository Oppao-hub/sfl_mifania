{% extends "auth.html.twig" %}
{% block title %}Registration{% endblock %}

{% block stylesheets %}
<style>
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-in-out;
    }
</style>
{% endblock %}

{% block user_form %}
<div
    class="flex justify-center items-center min-h-screen bg-[#F9F1E8] font-[Montserrat] text-[#422B1C]"
>
    <div
        class="bg-white p-8 rounded-xl w-full max-w-md shadow-lg animate-fadeIn"
    >
        <div class="text-center mb-6">
            <img
                src="{{ asset('images/symbol.svg') }}"
                alt="Logo"
                class="h-14 mx-auto mb-6"
            />
            <h2 class="text-2xl font-bold text-[#422B1C]">Create an Account</h2>
            <p class="text-sm text-gray-600 mt-1">
                Join us to continue your journey
            </p>
        </div>

        {{
            form_start(credentialsForm, {
                attr: { class: "space-y-5", novalidate: "novalidate" }
            })
        }}

        <!-- Email -->
        <div>
            {{
                form_label(credentialsForm.email, null, {
                    label_attr: {
                        class: "block mb-2 text-sm font-medium text-[#422B1C]"
                    }
                })
            }}
            {{
                form_widget(credentialsForm.email, {
                    attr: {
                        class: "w-full p-2.5 border border-gray-300 rounded-md focus:ring-[#645D1E] focus:border-[#645D1E] outline-none",
                        autocomplete: "email"
                    }
                })
            }}
            {% if form_errors(credentialsForm.email) is not empty %}
                <div class="bg-red-100 border border-red-400 text-red-700 rounded-md p-2 mt-2 text-sm animate-fadeIn">
                    {{ form_errors(credentialsForm.email) }}
                </div>
            {% endif %}
        </div>

        <!-- Password -->
        <div>
            {{
                form_label(credentialsForm.plainPassword.first, "Password", {
                    label_attr: {
                        class: "block mb-2 text-sm font-medium text-[#422B1C]"
                    }
                })
            }}
            {{
                form_widget(credentialsForm.plainPassword.first, {
                    attr: {
                        class: "w-full p-2.5 border border-gray-300 rounded-md focus:ring-[#645D1E] focus:border-[#645D1E] outline-none",
                        autocomplete: "new-password"
                    }
                })
            }}
            {% if credentialsForm.plainPassword.first.vars.errors|length > 0 %}
            <div
                class="bg-red-100 border border-red-400 text-red-700 rounded-md p-2 mt-2 text-sm animate-fadeIn"
            >
                {{ form_errors(credentialsForm.plainPassword.first) }}
            </div>
            {% endif %}
        </div>

        <!-- Confirm Password -->
        <div>
            {{
                form_label(
                    credentialsForm.plainPassword.second,
                    "Confirm Password",
                    {
                        label_attr: {
                            class: "block mb-2 text-sm font-medium text-[#422B1C]"
                        }
                    }
                )
            }}
            {{
                form_widget(credentialsForm.plainPassword.second, {
                    attr: {
                        class: "w-full p-2.5 border border-gray-300 rounded-md focus:ring-[#645D1E] focus:border-[#645D1E] outline-none",
                        autocomplete: "new-password"
                    }
                })
            }}
            {% if credentialsForm.plainPassword.second.vars.errors|length > 0 %}
            <div
                class="bg-red-100 border border-red-400 text-red-700 rounded-md p-2 mt-2 text-sm animate-fadeIn"
            >
                {{ form_errors(credentialsForm.plainPassword.second) }}
            </div>
            {% endif %}
        </div>

        <!-- Terms -->
        <div class="flex items-center gap-2">
            {{
                form_widget(credentialsForm.agreeTerms, {
                    attr: { class: "w-4 h-4 accent-[#422B1C]" }
                })
            }}
            {{
                form_label(credentialsForm.agreeTerms, null, {
                    label_attr: { class: "text-sm text-[#422B1C]" }
                })
            }}
        </div>

        <!-- Submit Button -->
        <button
            type="submit"
            class="w-full py-3 rounded-md bg-[#422B1C] text-white font-semibold text-lg hover:bg-[#645D1E] hover:text-[#F9F1E8] transition-colors"
        >
            Continue
        </button>

        {{ form_end(credentialsForm) }}

        <!-- Login Link -->
        <p class="text-center text-sm text-gray-600 mt-4">
            Already have an account?
            <a
                href="{{ path('app_login') }}"
                class="font-bold text-[#422B1C] hover:underline"
            >
                Login here
            </a>
        </p>
    </div>
</div>
{% endblock %}
