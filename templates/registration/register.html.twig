{% extends 'auth.html.twig' %}

{% block title %}Register | Mifania{% endblock %}

{% block main_content %}
<div class="min-h-screen w-full bg-cover bg-center bg-no-repeat flex items-center justify-center p-6"
    style="background-image: url('{{ asset('uploads/auth/background.png') }}')"
>
    <div class="flex items-center justify-center md:justify-end">
        <div class="bg-white/30 backdrop-blur-xl border border-white/40 p-8 rounded-[1rem] w-full max-w-md shadow-2xl animate-fadeIn">

            <div class="text-center mb-6">
                <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Logo" class="h-10 mx-auto mb-2" />
                <h2 class="inline-block text-[#6b703d] font-bold border-b-2 border-[#6b703d] pb-1 text-sm uppercase tracking-wider">Create an Account</h2>
            </div>

            {% form_theme registrationForm 'form/error_theme.html.twig' %}
            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, { attr: { class: "space-y-4", novalidate: "novalidate" } }) }}

                {# Name Fields #}
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        {{ form_widget(registrationForm.firstName, { attr: {
                            placeholder: "First Name",
                            class: "w-full p-3 rounded-xl border-2 border-transparent bg-white text-gray-700 placeholder-gray-400 focus:border-[#6b703d] outline-none transition-all shadow-sm"
                        } }) }}
                    </div>
                    <div>
                        {{ form_widget(registrationForm.lastName, { attr: {
                            placeholder: "Last Name",
                            class: "w-full p-3 rounded-xl border-2 border-transparent bg-white text-gray-700 placeholder-gray-400 focus:border-[#6b703d] outline-none transition-all shadow-sm"
                        } }) }}
                    </div>
                </div>

                {# Email #}
                <div>
                    {{ form_widget(registrationForm.email, { attr: {
                        placeholder: "Email Address",
                        class: "w-full p-3 rounded-xl border-2 border-transparent bg-white text-gray-700 placeholder-gray-400 focus:border-[#6b703d] outline-none transition-all shadow-sm"
                    } }) }}
                </div>

                {# Password #}
                <div>
                    {{ form_widget(registrationForm.plainPassword, { attr: {
                        placeholder: "Password",
                        class: "w-full p-3 rounded-xl border-2 border-transparent bg-white text-gray-700 placeholder-gray-400 focus:border-[#6b703d] outline-none transition-all shadow-sm"
                    } }) }}
                </div>

                {# Terms #}
                <div class="flex items-center space-x-2 px-2">
                    {{ form_widget(registrationForm.agreeTerms, { attr: { class: "w-4 h-4 rounded border-gray-300 text-[#6b703d] focus:ring-[#6b703d] cursor-pointer" } }) }}
                    <label class="text-xs text-white font-medium">
                        I agree to the <a href="#" class="underline">terms and conditions.</a>
                    </label>
                </div>

                {# Submit Button #}
                <button type="submit" class="w-full py-3.5 rounded-xl bg-[#6b703d] text-white font-bold text-lg tracking-widest hover:bg-[#5a5f33] transition-colors shadow-lg uppercase cursor-pointer">
                    Register
                </button>

            {{ form_end(registrationForm) }}

            {# Social Footer #}
            <div class="text-center text-white text-sm font-medium mt-4">
                Already have an account? <a href="{{ path('app_login') }}" class="font-bold hover:underline">Login</a>
            </div>

            <div class="flex justify-center space-x-6 pt-4 text-white">
                <a href="#" class="hover:scale-110 transition-transform">{{ ux_icon('lucide:facebook', { class: 'w-6 h-6' }) }}</a>
                <a href="#" class="hover:scale-110 transition-transform">{{ ux_icon('lucide:instagram', { class: 'w-6 h-6' }) }}</a>
                <a href="#" class="hover:scale-110 transition-transform">{{ ux_icon('lucide:apple', { class: 'w-6 h-6' }) }}</a>
                <a href="#" class="hover:scale-110 transition-transform">{{ ux_icon('lucide:twitter', { class: 'w-6 h-6' }) }}</a>
            </div>

            <p class="text-center text-white text-[10px] mt-6 font-medium opacity-80 uppercase tracking-widest">
                Join a movement for a better tomorrow.
            </p>
        </div>
    </div>
</div>
{% endblock %}
