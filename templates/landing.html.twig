<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Mifania | Conscious Craftsmanship{% endblock %}</title>

    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_script_tags('app') }}
</head>

<body class="bg-app-bg text-brand-dark antialiased flex flex-col min-h-screen animate-page-intro">

    {# 1. SLEEK, TRANSPARENT LANDING NAVIGATION #}
    <nav class="absolute top-0 w-full z-50 flex items-center justify-between px-6 md:px-12 py-6 bg-transparent">
        {# Logo #}
        <div class="flex flex-shrink-0 items-center relative opacity-85">
            <div>
                <a href="{{ path('app_home') }}">
                    <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Mifania Logo" class="w-auto h-8 md:h-10 transition-transform hover:scale-105" />
                </a>
            </div>
        </div>

        {# Primary Call to Action #}
        <div class="flex items-center opacity-85">
            <a href="{{ path('app_shop') }}" class="border-2 border-brand text-brand px-6 py-2 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-brand hover:text-white transition-all">
                Shop Collection
            </a>
        </div>
    </nav>

    {# 2. MAIN CONTENT AREA #}
    <main class="min-h-[70vh] flex flex-col text-left flex-grow">
        <div class="flex-grow animation-fadeIn">
            {% block main_content %}{% endblock %}
        </div>
    </main>

    {# 3. POLISHED FOOTER #}
    <footer class="bg-light-gray border-t border-border-color mt-auto pt-16 pb-8 px-6 md:px-12 text-left overflow-hidden">

        {# Main Footer Grid (Added the .reveal class for scroll animation) #}
        <div class="max-w-[1440px] mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 text-sm reveal">

            {# Column 1: Brand #}
            <div class="lg:col-span-1 space-y-6">
                <a href="{{ path('app_home') }}" class="inline-block">
                    {# Fixed the md:10 typo to md:h-10 #}
                    <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Mifania Logo" class="w-auto h-8 md:h-10 transition-transform hover:scale-105">
                </a>
                <p class="text-gray-500 text-xs leading-relaxed font-medium pr-4">
                    MIFANIA Sustainable Fashion Line. Fashion that respects the Earth isn't a trend; it's our future. We create timeless pieces using 100% organic materials and ethical labor practices.
                </p>
                <div class="flex gap-4 pt-2">
                    <a href="https://www.facebook.com/profile.php?id=61586255665900" target="_blank" class="w-9 h-9 bg-brand rounded-full flex items-center justify-center hover:bg-brand-dark hover:-translate-y-1 shadow-sm transition-all duration-300">
                        {{ ux_icon('lucide:facebook', { class: 'h-4 w-4 text-white' }) }}
                    </a>
                    <a href="#" class="w-9 h-9 bg-brand rounded-full flex items-center justify-center hover:bg-brand-dark hover:-translate-y-1 shadow-sm transition-all duration-300">
                        {{ ux_icon('lucide:instagram', { class: 'h-4 w-4 text-white' }) }}
                    </a>
                    <a href="https://www.tiktok.com/@mifania.sfl" target="_blank" class="w-9 h-9 bg-brand rounded-full flex items-center justify-center hover:bg-brand-dark hover:-translate-y-1 shadow-sm transition-all duration-300">
                        {{ ux_icon('ic:baseline-tiktok', { class: 'h-4 w-4 text-white' }) }}
                    </a>
                </div>
            </div>

            {# Column 2: Company #}
            <div>
                <h4 class="font-bold text-brand mb-6 uppercase tracking-widest text-xs">Company</h4>
                <ul class="text-gray-500 space-y-4 text-xs font-medium">
                    <li><a href="{{ path('app_home') }}#story" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">Our Story</a></li>
                    <li><a href="{{ path('app_contact') }}" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">Contact Us</a></li>
                </ul>
            </div>

            {# Column 3: Customer Service #}
            <div>
                <h4 class="font-bold text-brand mb-6 uppercase tracking-widest text-xs">Customer Service</h4>
                <ul class="text-gray-500 space-y-4 text-xs font-medium">
                    <li><a href="{{ path('app_account') }}" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">My Account</a></li>
                    <li><a href="{{ path('app_account_orders') }}" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">Track Your Order</a></li>
                    <li><a href="{{ path('app_home') }}#faq" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">FAQ</a></li>
                </ul>
            </div>

            {# Column 4: Contact Info #}
            <div>
                 <h4 class="font-bold text-brand mb-6 uppercase tracking-widest text-xs">Contact Info</h4>
                 <ul class="text-gray-500 space-y-4 text-xs font-medium">
                     <li class="flex items-start gap-3 group">
                         {{ ux_icon('lucide:phone', { class: 'h-4 w-4 shrink-0 text-brand mt-0.5 group-hover:scale-110 transition-transform' }) }}
                         <span>+63 09234 2342</span>
                     </li>
                     <li class="flex items-start gap-3 group">
                         {{ ux_icon('lucide:mail', { class: 'h-4 w-4 shrink-0 text-brand mt-0.5 group-hover:scale-110 transition-transform' }) }}
                         <a href="mailto:mifaniasfl@example.com" class="hover:text-brand transition-colors">mifaniasfl@example.com</a>
                     </li>
                     <li class="flex items-start gap-3 group">
                         {{ ux_icon('lucide:map-pin', { class: 'h-4 w-4 shrink-0 text-brand mt-0.5 group-hover:scale-110 transition-transform' }) }}
                         <span>National Highway, Zamboanguita,<br>Negros Oriental, Philippines</span>
                     </li>
                 </ul>
            </div>
        </div>

        {# Bottom Bar (Added slight transition delay so it animates in just after the top section) #}
        <div class="max-w-[1440px] mx-auto mt-16 pt-8 border-t border-border-color flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] font-bold uppercase tracking-widest text-gray-400 reveal" style="transition-delay: 200ms;">
            <p>Copyright © {{ "now"|date("Y") }} Mifania. All Rights Reserved.</p>
            <div class="flex gap-6">
                <a href="#" class="hover:text-brand transition-colors">Privacy Policy</a>
                <a href="#" class="hover:text-brand transition-colors">Terms of Service</a>
            </div>
        </div>
    </footer>

    {# Javascript Block #}
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.15
            });

            const hiddenElements = document.querySelectorAll('.reveal');
            hiddenElements.forEach((el) => observer.observe(el));
        });
    </script>

    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    {% include 'components/frontend/back_to_top.html.twig' ignore missing %}
    {% include 'components/frontend/flash/flash_messages.html.twig' ignore missing %}
</body>
</html>
