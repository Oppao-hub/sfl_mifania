<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mifania | Sustainable Fashion Line</title>
    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_script_tags('app') }}
    <!-- Alpine.js for FAQ Interactivity -->
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <!-- Montserrat Font -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

</head>
<body class="text-gray-800 bg-white">

    <!-- Navigation -->
    <nav class="flex items-center justify-between px-6 py-5 md:px-12 bg-white sticky top-0 z-50 shadow-sm">
        <!-- Logo -->
        <div class="flex flex-shrink-0 w-64 items-center gap-2">
            <a href="{{ path('app_home') }}">
                <img
                    src="{{ asset('uploads/logo/logo.svg') }}"
                    alt="Mifania Logo"
                    class="w-full h-auto max-h-10 md:max-h-12 lg:max-h-14 xl:max-h-16"
                />
            </a>
        </div>

        <!-- Menu Items -->
        <div class="hidden lg:flex items-center gap-8 text-sm font-semibold text-[#52622E]">
            <a href="{{ path('app_home') }}" class="hover:text-brand transition-colors">Home</a>
            <a href="{{ path('app_shop') }}" class="hover:text-brand transition-colors">Shop</a>
            <a href="#" class="hover:text-brand transition-colors">Women</a>
            <a href="#" class="hover:text-brand transition-colors">Men</a>
            <a href="#" class="hover:text-brand transition-colors">Accessories</a>
            <a href="#" class="hover:text-brand transition-colors">About</a>
            <a href="#" class="hover:text-brand transition-colors">Contact Us</a>
        </div>

        <div class="flex items-center gap-5 text-[#52622E]">
            <a hraf="#" class="hover:text-brand" title="Search">
                {{ ux_icon('lucide:search', { class: 'h-5 w-5' }) }}
            </a>
            <a href="{{ path('app_cart_show') }}" class="hover:text-brand" title="Cart">
                {{ ux_icon('lucide:shopping-cart', { class: 'h-5 w-5' }) }}
            </a>
             <a href="#" class="hover:text-brand" title="Wishlist">
                {{ ux_icon('lucide:heart', { class: 'h-5 w-5' }) }}
            </a>
            <a href="{{ path('app_account') }}" class="hover:text-brand" title="Profile">
                {{ ux_icon('lucide:user-circle', { class: 'h-5 w-5' }) }}
            </a>
        </div>
    </nav>

    {% block main_content %}{% endblock %}

    <section class="bg-light-gray px-6 md:px-12 pb-12">
         <div class="max-w-[1440px] mx-auto border-t border-gray-300 pt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 text-sm">
            <div class="lg:col-span-1">
                <div class="flex items-center gap-2 mb-6">
                    <svg viewBox="0 0 24 24" class="text-brand fill-current w-8 h-8">
                        <path d="M12 2L4 7v10l8 5 8-5V7l-8-5zm0 2.3l6 3.7v7.4l-6 3.7-6-3.7V8l6-3.7z"/>
                    </svg>
                    <span class="text-xl font-bold tracking-tight text-gray-700 uppercase">MIFANIA</span>
                </div>
                <p class="text-gray-500 text-xs leading-relaxed mb-6">
                    MIFANIA Sustainable Fashion Line. Fashion that respects the Earth isn't a trend; it's our future. We create timeless pieces using 100% organic materials and ethical labor practices.
                </p>
                <div class="flex gap-4 text-brand">
                    <!-- Social Icons placeholder -->
                    <div class="w-6 h-6 bg-brand rounded-full">
                        <a href="#" class="flex items-center justify-center w-full h-full">{{ ux_icon('lucide:facebook', { class: 'h-4 w-4 text-white' }) }}</a>
                    </div>
                    <div class="w-6 h-6 bg-brand rounded-full">
                        <a href="#" class="flex items-center justify-center w-full h-full">{{ ux_icon('lucide:instagram', { class: 'h-4 w-4 text-white' }) }}</a>
                    </div>
                    <div class="w-6 h-6 bg-brand rounded-full">
                        <a href="#" class="flex items-center justify-center w-full h-full">{{ ux_icon('lucide:twitter', { class: 'h-4 w-4 text-white' }) }}</a>
                    </div>
                    <div class="w-6 h-6 bg-brand rounded-full">
                        <a href="#" class="flex items-center justify-center w-full h-full">{{ ux_icon('lucide:linkedin', { class: 'h-4 w-4 text-white' }) }}</a>
                    </div>
                </div>
            </div>

            <div>
                <h4 class="font-bold text-brand mb-6">Company</h4>
                <ul class="text-gray-500 space-y-4 text-xs">
                    <li><a href="#" class="hover:text-brand">About Us</a></li>
                    <li><a href="#" class="hover:text-brand">Blog</a></li>
                    <li><a href="#" class="hover:text-brand">Contact Us</a></li>
                    <li><a href="#" class="hover:text-brand">Career</a></li>
                </ul>
            </div>

            <div>
                <h4 class="font-bold text-brand mb-6">Customer Service</h4>
                <ul class="text-gray-500 space-y-4 text-xs">
                    <li><a href="#" class="hover:text-brand">My Account</a></li>
                    <li><a href="#" class="hover:text-brand">Track Your Order</a></li>
                    <li><a href="#" class="hover:text-brand">Return</a></li>
                    <li><a href="#" class="hover:text-brand">FAQ</a></li>
                </ul>
            </div>

            <div>
                <h4 class="font-bold text-brand mb-6">Our Information</h4>
                <ul class="text-gray-500 space-y-4 text-xs">
                    <li><a href="#" class="hover:text-brand">Privacy</a></li>
                    <li><a href="#" class="hover:text-brand">User Terms & Conditions</a></li>
                    <li><a href="#" class="hover:text-brand">Return Policy</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-bold text-brand mb-6">Newsletter</h4>
                <p class="text-gray-500 text-xs mb-4">
                    Subscribe to our newsletter to get updates on new products and promotions.
                </p>
                <input type="email" placeholder="Your email address" class="w-full p-2 rounded-md border border-gray-300 focus:outline-none focus:ring-1 focus:ring-brand text-xs">
                <button class="mt-3 w-full bg-brand text-white py-2 rounded-md hover:bg-brand-dark transition-colors text-xs">Subscribe</button>
            </div>
             <div>
                <h4 class="font-bold text-brand mb-6">Contact Info</h4>
                <ul class="text-gray-500 space-y-4 text-xs">
                    <li>+63 09234 2342</li>
                    <li>mifaniasfl@example.com</li>
                    <li>1234 Street Dumaguete City, Negros Oriental, Philippines</li>
                </ul>
            </div>
        </div>
        <div class="max-w-[1440px] mx-auto mt-16 pt-8 border-t border-gray-300 text-left text-[10px] text-gray-500">
            Copyright © 2024 Mifania Sustainable Fashion Line. All Rights Reserved.
        </div>
    </section>
    {% include "components/back_to_top.html.twig" %}
</body>
</html>
