<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Mifania | Sustainable Fashion Line{% endblock %}</title>

    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_script_tags('app') }}
</head>

{# We keep your Alpine data for menus and search #}
<body x-data="{ mobileMenuOpen: false, searchOpen: false }" :class="mobileMenuOpen ? 'overflow-hidden' : ''" class="bg-app-bg text-brand-dark antialiased flex flex-col min-h-screen animate-page-intro">

    {# Define nav_links here so the Mobile Menu can still use them later! #}
    {% set nav_links = [
        { name: 'Shop', url: path('app_shop') },
        { name: 'About Us', url: path('app_about') },
        { name: 'Contact Us', url: path('app_contact') }
    ] %}

    {# THIS SINGLE LINE LOADS THE ENTIRE HEADER & MOBILE MENU #}
    {{ render(controller('App\\Controller\\Frontend\\NavbarController::renderNav')) }}

    {# MAIN CONTENT #}
    <main class="min-h-[70vh] flex flex-col text-left flex-grow">
        <div class="flex-grow animation-fadeIn">
            {% block main_content %}{% endblock %}
        </div>
        {% if app.request.attributes.get('_route') != 'app_home' %}
            {% include 'components/frontend/benefits.html.twig' ignore missing %}
        {% endif %}
    </main>

    {# YOUR EXISTING FOOTER #}
    <footer class="bg-light-gray px-6 md:px-12 pb-12 pt-16 mt-auto text-left">
         <div class="max-w-[1440px] mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 text-sm border-t border-gray-300 pt-16">
            <div class="lg:col-span-1">
                <div class="flex items-center gap-2 mb-6">
                    <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                        <img src="{{ asset('uploads/logo/logo.svg') }}" alt="Mifania Logo" class="w-auto h-8 md:10">
                        <span class="text-xl font-bold tracking-tight text-brand uppercase">MIFANIA</span>
                    </a>
                </div>
                <p class="text-gray-500 text-xs leading-relaxed mb-6">
                    MIFANIA Sustainable Fashion Line. Fashion that respects the Earth isn't a trend; it's our future. We create timeless pieces using 100% organic materials and ethical labor practices.
                </p>
                <div class="flex gap-4">
                    <a href="https://www.facebook.com/profile.php?id=61586255665900" target="_blank" class="w-9 h-9 bg-brand rounded-full flex items-center justify-center hover:bg-brand-dark hover:-translate-y-1 shadow-sm transition-all duration-300">
                        {{ ux_icon('lucide:facebook', { class: 'h-4 w-4 text-white' }) }}
                    </a>
                    <a href="#" class="w-9 h-9 bg-brand rounded-full flex items-center justify-center hover:bg-brand-dark hover:-translate-y-1 shadow-sm transition-all duration-300">
                        {{ ux_icon('lucide:instagram', { class: 'h-4 w-4 text-white' }) }}
                    </a>
                    <a href="https://www.tiktok.com/@mifania.sfl" target="_blank" class="w-9 h-9 bg-brand rounded-full flex items-center justify-center hover:bg-brand-dark hover:-translate-y-1 shadow-sm transition-all duration-300">
                        {{ ux_icon('ic:baseline-tiktok', { class: 'h-4 w-4 text-white' }) }}
                    </a>
                </div>
            </div>

            <div>
                <h4 class="font-bold text-brand mb-6 uppercase tracking-wider text-xs">Company</h4>
                <ul class="text-gray-500 space-y-4 text-xs">
                    <li><a href="{{ path('app_about') }}#story" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">About Us</a></li>
                    <li><a href="{{ path('app_contact') }}#contact" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">Contact Us</a></li>
                </ul>
            </div>

            <div>
                <h4 class="font-bold text-brand mb-6 uppercase tracking-wider text-xs">Customer Service</h4>
                <ul class="text-gray-500 space-y-4 text-xs">
                    <li><a href="{{ path('app_account') }}" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">My Account</a></li>
                    <li><a href="{{ path('app_account_orders') }}" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">Track Your Order</a></li>
                    <li><a href="{{ path('app_home') }}#faq" class="hover:text-brand hover:translate-x-1 inline-block transition-transform duration-300">FAQ</a></li>
                </ul>
            </div>

            <div>
                 <h4 class="font-bold text-brand mb-6 uppercase tracking-widest text-xs">Contact Info</h4>
                 <ul class="text-gray-500 space-y-4 text-xs font-medium">
                     <li class="flex items-start gap-3 group">
                         {{ ux_icon('lucide:phone', { class: 'h-4 w-4 shrink-0 text-brand mt-0.5 group-hover:scale-110 transition-transform' }) }}
                         <span>+63 09234 2342</span>
                     </li>
                     <li class="flex items-start gap-3 group">
                         {{ ux_icon('lucide:mail', { class: 'h-4 w-4 shrink-0 text-brand mt-0.5 group-hover:scale-110 transition-transform' }) }}
                         <a href="mailto:mifaniasfl@example.com" class="hover:text-brand transition-colors">mifaniasfl@example.com</a>
                     </li>
                     <li class="flex items-start gap-3 group">
                         {{ ux_icon('lucide:map-pin', { class: 'h-4 w-4 shrink-0 text-brand mt-0.5 group-hover:scale-110 transition-transform' }) }}
                         <span>National Highway, Zamboanguita,<br>Negros Oriental, Philippines</span>
                     </li>
                 </ul>
            </div>
        </div>

        <div class="max-w-[1440px] mx-auto mt-16 pt-8 border-t border-gray-300 flex flex-col sm:flex-row justify-between items-center gap-4 text-[10px] text-gray-500">
            <p>Copyright © {{ "now"|date("Y") }} Mifania Sustainable Fashion Line. All Rights Reserved.</p>
            <div class="flex gap-4">
                <a href="#" class="hover:text-brand">Privacy Policy</a>
                <a href="#" class="hover:text-brand">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Create the observer
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    // If the element is in the viewport...
                    if (entry.isIntersecting) {
                        // Add the 'active' class to trigger the CSS transition
                        entry.target.classList.add('active');
                        // Optional: Stop observing it so it doesn't fade out when scrolling up
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.15 // Triggers when 15% of the element is visible
            });

            // Find all elements with the 'reveal' class and observe them
            const hiddenElements = document.querySelectorAll('.reveal');
            hiddenElements.forEach((el) => observer.observe(el));
        });
    </script>

    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    {% include 'components/frontend/back_to_top.html.twig' ignore missing %}
    {% include 'components/frontend/flash/flash_messages.html.twig' ignore missing %}
    {% include 'components/frontend/modal/global_confirm.html.twig' ignore missing %}
</body>
</html>
